*/

	//---
	// 创建装饰物
	// 创建后无法删除
	//---
	// 参数:
	//* id: 装饰物ID
	//* style: 样式序号
	//* x: 坐标点x
	//* y: 坐标点y
	//* z: 坐标点z
	//* facing: 朝向 (角度)
	function MHDoodad_Create takes integer id, integer style, real x, real y, real z, real facing returns integer
	endfunction

	//---
	// 创建装饰物Ex
	// 创建后无法删除
	//---
	// 参数:
	//* id: 装饰物ID
	//* style: 样式序号
	//* x: 坐标点x
	//* y: 坐标点y
	//* z: 坐标点z
	//* facing: 朝向 (角度)
	//* x_scale: x轴缩放
	//* y_scale: y轴缩放
	//* z_scale: z轴缩放
	function MHDoodad_CreateEx takes integer id, integer style, real x, real y, real z, real facing, real x_scale, real y_scale, real z_scale returns integer
	endfunction




