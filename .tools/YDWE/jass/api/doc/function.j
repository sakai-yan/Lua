	endfunction




/*
* ---------------------------------------------------
* math.j
* ---------------------------------------------------
*/

	//---
	// 异步随机整数
	// 返回值完全异步, 不要用于同步的逻辑
	//---
	// 参数:
	//* lower_bound: 最小值
	//* upper_bound: 最大值
	function MHMath_GetLocalRandomInt takes integer lower_bound, integer upper_bound returns integer
	endfunction

	//---
	// 异步随机实数
	// 返回值完全异步, 不要用于同步的逻辑
	//---
	// 参数:
	//* lower_bound: 最小值
	//* upper_bound: 最大值
	function MHMath_GetLocalRandomReal takes integer lower_bound, integer upper_bound returns real
	endfunction

	//---
	// 包含Bit
	// 操作某些标志的时候用到
	// 例如0x6包含0x4和0x2. 百度搜索bitset
	//---
	// 参数:
	//* flag: flag
	//* bit: bit
	function MHMath_IsBitSet takes integer flag, integer bit returns boolean
	endfunction

	//---
	// 添加bit
	// 操作某些标志的时候用到. 例如为0x6添加0x3结果为0x7. 百度搜索bitset
	//---
	// 参数:
	//* flag: flag
	//* bit: bit
	function MHMath_AddBit takes integer flag, integer bit returns integer
	endfunction

	//---
	// 删除bit
	// 操作某些标志的时候用到. 例如为0x6删除0x3结果为0x4. 百度搜索bitset
	//---
	// 参数:
	//* flag: flag
	//* bit: bit
	function MHMath_RemoveBit takes integer flag, integer bit returns integer
	endfunction

	//---
	// 逻辑异或
	// 相同为假, 不同为真
	//---
	// 参数:
	//* op1: 操作数1
	//* op2: 操作数2
	function MHMath_Xor takes boolean op1, boolean op2 returns boolean
	endfunction

	//---
	// 按位取反
	// 位运算
	//---
	// 参数:
	//* op1: 操作数1
	function MHMath_BitwiseNot takes integer op1 returns integer
	endfunction

	//---
	// 按位与
	// 位运算
	//---
	// 参数:
	//* op1: 操作数1
	//* op2: 操作数2
	function MHMath_BitwiseAnd takes integer op1, integer op2 returns integer
	endfunction

	//---
	// 按位或
	// 位运算
	//---
	// 参数:
	//* op1: 操作数1
	//* op2: 操作数2
	function MHMath_BitwiseOr takes integer op1, integer op2 returns integer
	endfunction

	//---
	// 按位异或
	// 位运算
	//---
	// 参数:
	//* op1: 操作数1
	//* op2: 操作数2
	function MHMath_BitwiseXor takes integer op1, integer op2 returns integer
	endfunction

	//---
	// 左移位
	// 移位运算
	//---
	// 参数:
	//* op1: 操作数1
	//* op2: 操作数2
	function MHMath_LShift takes integer op1, integer op2 returns integer
	endfunction

	//---
	// 右移位
	// 移位运算
	//---
	// 参数:
	//* op1: 操作数1
	//* op2: 操作数2
	function MHMath_RShift takes integer op1, integer op2 returns integer
	endfunction

	//---
	// 对数 (底数2)
	// 整数对数运算
	//---
	// 参数:
	//* op1: 真数
	function MHMath_Log2 takes integer op1 returns integer
	endfunction

	//---
	// 取余
	//---
	// 参数:
	//* dividend: 被除数
	//* modulus: 除数
	function MHMath_ModI takes integer dividend, integer modulus returns integer
	endfunction

	//---
	// 取余
	//---
	// 参数:
	//* dividend: 被除数
	//* modulus: 除数
	function MHMath_ModF takes real dividend, real modulus returns real
	endfunction

	//---
	// 合成4Bytes
	// 例如0x11 + 0x45 + 0x14 + 0x19 --> 0x11451419
	//---
	// 参数:
	//* byte_1: 字节1
	//* byte_2: 字节2
	//* byte_3: 字节3
	//* byte_4: 字节4
	function MHMath_Get4Bytes takes integer byte_1, integer byte_2, integer byte_3, integer byte_4 returns integer
	endfunction

	//---
	// 转换整数为16进制字符串
	//---
	// 参数:
	//* dec: 10进制整数
	function MHMath_ToHex takes integer dec returns string
	endfunction

	//---
	// 转换16进制字符串为整数
	// 仅支持DWORD
	//---
	// 参数:
	//* hex: 16进制整数
	function MHMath_ToDec takes string hex returns integer
	endfunction

	//---
	// 二阶贝塞尔
	//---
	// 参数:
	//* start: 起始点坐标
	//* control: 控制点坐标
	//* finish: 结束点坐标
	//* progress: 进度 (起始点时进度为0, 终止点时进度为1)
	function MHMath_Bezier2 takes real start, real control, real finish, real progress returns real
	endfunction

	//---
	// 三阶贝塞尔
	// 起始点时进度为0, 终止点时进度为1
	//---
	// 参数:
	//* start: 起始点坐标
	//* control1: 控制点1坐标
	//* control2: 控制点2坐标
	//* finish: 结束点坐标
	//* progress: 进度 (起始点时进度为0, 终止点时进度为1)
	function MHMath_Bezier3 takes real start, real control1, real control2, real finish, real progress returns real
	endfunction

	//---
	// 获取两坐标间距离
	// 起始点到目标点的距离
	//---
	// 参数:
	//* x1: 起始点坐标x
	//* y1: 起始点坐标y
	//* x2: 目标点坐标x
	//* y2: 目标点坐标y
	function MHMath_Distance takes real x1, real y1, real x2, real y2 returns real
	endfunction

	//---
	// 获取两坐标间方向
	// 起始点到目标点的方向
	// @return: 方向角 (角度值)
	//---
	// 参数:
	//* x1: 起始点坐标x
	//* y1: 起始点坐标y
	//* x2: 目标点坐标x
	//* y2: 目标点坐标y
	function MHMath_Orientation takes real x1, real y1, real x2, real y2 returns real
	endfunction

	//---
	// 获取位移点的X坐标
	// 从起始点开始向指定方向位移指定距离的点X坐标
	//---
	// 参数:
	//* x: 起始点坐标x
	//* orientation: 方向角 (角度值)
	//* distance: 位移距离
	function MHMath_PointOffsetX takes real x, real orientation, real distance returns real
	endfunction

	//---
	// 获取位移点的Y坐标
	// 从起始点开始向指定方向位移指定距离的点Y坐标
	//---
	// 参数:
	//* y: 起始点坐标y
	//* orientation: 方向角 (角度值)
	//* distance: 位移距离
	function MHMath_PointOffsetY takes real y, real orientation, real distance returns real
	endfunction

	//---
	// 获取物体位移点的X坐标
	// 从单位所在位置开始向指定方向位移指定距离的点X坐标
	//---
	// 参数:
	//* obj: 物体
	//* orientation: 方向角 (角度值)
	//* distance: 位移距离
	function MHMath_WidgetOffsetX takes widget obj, real orientation, real distance returns real
	endfunction

	//---
	// 获取物体位移点的Y坐标
	// 从物体所在位置开始向指定方向位移指定距离的点Y坐标
	//---
	// 参数:
	//* obj: 物体
	//* orientation: 方向角 (角度值)
	//* distance: 位移距离
	function MHMath_WidgetOffsetY takes widget obj, real orientation, real distance returns real
	endfunction

	//---
	// 创建整数池
	function MHMath_CreateIntegerPool takes nothing returns integer
	endfunction

	//---
	// 删除整数池
	//---
	// 参数:
	//* pool: 整数池
	function MHMath_RemoveIntegerPool takes integer pool returns boolean
	endfunction

	//---
	// 清空整数池
	//---
	// 参数:
	//* pool: 整数池
	function MHMath_ClearIntegerPool takes integer pool returns boolean
	endfunction

	//---
	// 整数池插入整数
	//---
	// 参数:
	//* pool: 整数池
	//* value: 整数
	//* weight: 权重
	function MHMath_IntegerPoolInsert takes integer pool, integer value, real weight returns boolean
	endfunction

	//---
	// 整数池移除整数
	//---
	// 参数:
	//* pool: 整数池
	//* value: 整数
	function MHMath_IntegerPoolErase takes integer pool, integer value returns boolean
	endfunction

	//---
	// 整数池包含整数
	//---
	// 参数:
	//* pool: 整数池
	//* value: 整数
	function MHMath_IntegerPoolContains takes integer pool, integer value returns boolean
	endfunction

	//---
	// 整数池获取权重
	//---
	// 参数:
	//* pool: 整数池
	//* value: 整数
	function MHMath_IntegerPoolGetWeight takes integer pool, integer value returns real
	endfunction

	//---
	// 整数池数量
	//---
	// 参数:
	//* pool: 整数池
	function MHMath_IntegerPoolGetSize takes integer pool returns integer
	endfunction

	//---
	// 整数池采样
	// 结果是同步的, 只能在同步环境下使用
	//---
	// 参数:
	//* pool: 整数池
	function MHMath_IntegerPoolSample takes integer pool returns integer
	endfunction

	//---
	// 整数池采样Ex
	//---
	// 参数:
	//* pool: 整数池
	//* erase: 是否移除结果
	//* async: 是否异步
	function MHMath_IntegerPoolSampleEx takes integer pool, boolean erase, boolean async returns integer
	endfunction

	//---
	// 整数池采样 (异步)
	// 结果是异步的, 不要用于同步逻辑
	//---
	// 参数:
	//* pool: 整数池
	function MHMath_IntegerPoolAsyncSample takes integer pool returns integer
	endfunction

	//---
	// 选取整数池做动作
	//---
	// 参数:
	//* pool: 整数池
	//* callback: 选取回调
	function MHMath_IntegerPoolEnum takes integer pool, code callback returns boolean
	endfunction

	//---
	// 整数池获取选取的整数
	// 指代 选取整数池做动作 中被选取的整数
	function MHMath_IntegerPoolGetEnumValue takes nothing returns integer
	endfunction

	//---
	// 整数池获取选取的权重
	// 指代 选取整数池做动作 中被选取的权重
	function MHMath_IntegerPoolGetEnumWeight takes nothing returns real
	endfunction




/*
* ---------------------------------------------------
* message.j
* ---------------------------------------------------
*/

	//---
	// 获取窗口宽度
	// 返回值是异步的
	//---
	// 返回值:
	//* integer (像素)
	function MHMsg_GetWindowWidth takes nothing returns integer
	endfunction

	//---
	// 获取窗口高度
	// 返回值是异步的
	//---
	// 返回值:
	//* integer (像素)
	function MHMsg_GetWindowHeight takes nothing returns integer
	endfunction

	//---
	// 设置窗口大小
	//---
	// 参数:
	//* width: 宽度 (像素)
	//* height: 高度 (像素)
	function MHMsg_SetWindowSize takes integer width, integer height returns boolean
	endfunction

	//---
	// 设置窗口位置
	// 屏幕左上角为坐标原点
	// xy代表窗口左上角距离屏幕左边/顶部的距离, 建议搭配获取屏幕分辨率食用
	//---
	// 参数:
	//* x: x坐标 (像素)
	//* y: y坐标 (像素)
	function MHMsg_SetWindowPosition takes integer x, integer y returns boolean
	endfunction

	//---
	// 获取客户区宽度
	// 返回值是异步的
	// 指不含边框和滚动条等的窗口宽度
	//---
	// 返回值:
	//* integer (像素)
	function MHMsg_GetClientWidth takes nothing returns integer
	endfunction

	//---
	// 获取客户区高度
	// 返回值是异步的
	// 指不含边框和滚动条等的窗口高度
	//---
	// 返回值:
	//* integer (像素)
	function MHMsg_GetClientHeight takes nothing returns integer
	endfunction

	//---
	// 获取分辨率宽度
	// 返回值是异步的
	//---
	// 返回值:
	//* integer (像素)
	function MHMsg_GetResolutionWidth takes nothing returns integer
	endfunction

	//---
	// 获取分辨率高度
	// 返回值是异步的
	//---
	// 返回值:
	//* integer (像素)
	function MHMsg_GetResolutionHeight takes nothing returns integer
	endfunction

	//---
	// 获取鼠标的屏幕坐标X
	// 返回值是异步的
	//---
	// 返回值:
	//* real (屏幕坐标)
	function MHMsg_GetCursorX takes nothing returns real
	endfunction

	//---
	// 获取鼠标的屏幕坐标Y
	// 返回值是异步的
	//---
	// 返回值:
	//* real (屏幕坐标)
	function MHMsg_GetCursorY takes nothing returns real
	endfunction

	//---
	// 设置鼠标坐标
	//---
	// 参数:
	//* x: x坐标 (屏幕坐标)
	//* y: y坐标 (屏幕坐标)
	function MHMsg_SetCursorPosition takes real x, real y returns nothing
	endfunction

	//---
	// 获取鼠标的世界坐标X
	// 返回值是异步的
	//---
	// 返回值:
	//* real (世界坐标)
	function MHMsg_GetMouseX takes nothing returns real
	endfunction

	//---
	// 获取鼠标的世界坐标Y
	// 返回值是异步的
	//---
	// 返回值:
	//* real (世界坐标)
	function MHMsg_GetMouseY takes nothing returns real
	endfunction

	//---
	// 获取鼠标的世界坐标Z
	// 返回值是异步的
	//---
	// 返回值:
	//* real (世界坐标)
	function MHMsg_GetMouseZ takes nothing returns real
	endfunction

	//---
	// 强制按键
	//---
	// 参数:
	//* key: 按键 [参考 MemHack::MEMHACK_VK]
	function MHMsg_PressKey takes integer key returns integer
	endfunction

	//---
	// 按键状态判断
	// 异步函数
	//---
	// 参数:
	//* key: 按键 [参考 MemHack::MEMHACK_VK]
	function MHMsg_IsKeyDown takes integer key returns boolean
	endfunction

	//---
	// 世界坐标转屏幕坐标X
	// 返回值是异步的
	//---
	// 参数:
	//* x: 世界坐标x
	//* y: 世界坐标y
	//* z: 世界坐标z
	function MHMsg_WorldToScreenX takes real x, real y, real z returns real
	endfunction

	//---
	// 世界坐标转屏幕坐标Y
	// 返回值是异步的
	//---
	// 参数:
	//* x: 世界坐标x
	//* y: 世界坐标y
	//* z: 世界坐标z
	function MHMsg_WorldToScreenY takes real x, real y, real z returns real
	endfunction

	//---
	// 世界坐标转屏幕缩放值
	// 返回值是异步的
	//---
	// 参数:
	//* x: 世界坐标x
	//* y: 世界坐标y
	//* z: 世界坐标z
	function MHMsg_WorldToScreenScale takes real x, real y, real z returns real
	endfunction

	//---
	// 屏幕坐标转世界坐标X
	// 返回值是异步的
	//---
	// 参数:
	//* x: 屏幕坐标x
	//* y: 屏幕坐标y
	function MHMsg_ScreenToWorldX takes real x, real y returns real
	endfunction

	//---
	// 屏幕坐标转世界坐标Y
	// 返回值是异步的
	//---
	// 参数:
	//* x: 屏幕坐标x
	//* y: 屏幕坐标y
	function MHMsg_ScreenToWorldY takes real x, real y returns real
	endfunction

	//---
	// 世界坐标转小地图坐标X
	// 返回值是异步的
	// 获取的结果是相对于小地图UI左下锚点的偏移
	//---
	// 参数:
	//* x: 世界坐标x
	function MHMsg_WorldToMinimapX takes real x returns real
	endfunction

	//---
	// 世界坐标转小地图坐标Y
	// 返回值是异步的
	// 获取的结果是相对于小地图UI左下锚点的偏移
	//---
	// 参数:
	//* y: 世界坐标y
	function MHMsg_WorldToMinimapY takes real y returns real
	endfunction

	//---
	// 小地图坐标转世界坐标X
	// 返回值是异步的
	//---
	// 参数:
	//* x: 小地图坐标x (相对于小地图UI左下锚点的偏移)
	function MHMsg_MinimapToWorldX takes real x returns real
	endfunction

	//---
	// 小地图坐标转世界坐标Y
	// 返回值是异步的
	//---
	// 参数:
	//* x: 小地图坐标y (相对于小地图UI左下锚点的偏移)
	function MHMsg_MinimapToWorldY takes real x returns real
	endfunction

	//---
	// 在屏幕内
	// 返回值是异步的
	//---
	// 参数:
	//* x: 世界坐标x
	//* y: 世界坐标y
	function MHMsg_InScreen takes real x, real y returns boolean
	endfunction

	//---
	// 调起指示器
	// 强制调起指示器, 要求当前选择的单位/单位组有对应的技能或命令
	//---
	// 参数:
	//* aid: 技能id
	//* oid: 命令id
	//* flag: 释放类型 [参考 MemHack::ABILITY_CAST_TYPE]
	function MHMsg_CallTargetMode takes integer aid, integer oid, integer flag returns integer
	endfunction

	//---
	// 调起指示器Ex
	// 强制调起指示器, 不要求当前选择的单位/单位组有对应的技能或命令, 但可能按不下去 (会触发事件)
	//---
	// 参数:
	//* aid: 技能id
	//* oid: 命令id
	//* flag: 释放类型 [参考 MemHack::ABILITY_CAST_TYPE]
	function MHMsg_CallTargetModeEx takes integer aid, integer oid, integer flag returns integer
	endfunction

	//---
	// 调起建造指示器
	// 强制调起建造指示器, 要求当前选择的单位/单位组能建造对应建筑
	//---
	// 参数:
	//* oid: 命令id (即单位类型)
	//* flag: 释放类型 [参考 MemHack::ABILITY_CAST_TYPE]
	function MHMsg_CallBuildMode takes integer oid, integer flag returns integer
	endfunction

	//---
	// 取消指示器
	// 强制取消当前指示器
	function MHMsg_CancelIndicator takes nothing returns integer
	endfunction

	//---
	// 指示器被激活
	//---
	// 参数:
	//* indicator_type: 指示器类型 [参考 MemHack::INDICATOR_TYPE]
	function MHMsg_IsIndicatorOn takes integer indicator_type returns boolean
	endfunction

	//---
	// 获取鼠标指向的单位
	// 返回值是异步的
	function MHMsg_GetCursorUnit takes nothing returns unit
	endfunction

	//---
	// 获取鼠标指向的物品
	// 返回值是异步的
	function MHMsg_GetCursorItem takes nothing returns item
	endfunction

	//---
	function MHMsg_GetCursorDest takes nothing returns destructable
	endfunction

	//---
	// 发布本地无目标命令
	//---
	// 参数:
	//* oid: 命令ID
	//* flag: 命令标志 [参考 MemHack::LOCAL_ORDER_FLAG]
	function MHMsg_SendImmediateOrder takes integer oid, integer flag returns integer
	endfunction

	//---
	// 发布本地目标命令
	//---
	// 参数:
	//* target: 目标单位/物品/可破坏物
	//* x: 目标点x
	//* y: 目标点y
	//* oid: 命令ID
	//* source_item: 来源物品
	//* cast_type: 释放类型 [参考 MemHack::ABILITY_CAST_TYPE]
	//* flag: 本地命令标志 [参考 MemHack::LOCAL_ORDER_FLAG]
	function MHMsg_SendTargetOrder takes widget target, real x, real y, integer oid, item source_item, integer cast_type, integer flag returns boolean
	endfunction

	//---
	// 发布指示器命令
	// 目标参数省略的时候为点目标命令
	//---
	// 参数:
	//* target: 目标单位/物品/可破坏物
	//* x: 目标点x
	//* y: 目标点y
	//* oid: 命令ID
	//* flag: 命令标志 [参考 MemHack::LOCAL_ORDER_FLAG]
	function MHMsg_SendIndicatorOrder takes widget target, real x, real y, integer oid, integer flag returns integer
	endfunction

	//---
	// 发布选择器命令
	//---
	// 参数:
	//* x: 目标点x
	//* y: 目标点y
	//* oid: 命令ID
	//* flag: 命令标志 [参考 MemHack::LOCAL_ORDER_FLAG]
	function MHMsg_SendSelectorOrder takes real x, real y, integer oid, integer flag returns integer
	endfunction

	//---
	// 发布丢弃物品命令
	// 目标参数省略的时候为点目标命令
	//---
	// 参数:
	//* target: 目标单位
	//* x: 目标点x
	//* y: 目标点y
	//* it: 要丢弃的物品
	//* flag: 命令标志 [参考 MemHack::LOCAL_ORDER_FLAG]
	function MHMsg_SendDropItemOrder takes unit target, real x, real y, item it, integer flag returns integer
	endfunction

	//---
	// 发布右键物体命令
	// 目标参数省略的时候为点目标命令
	//---
	// 参数:
