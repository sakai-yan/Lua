	//---
	// 连接字符串lv15
	// 可减少连接字符串带来的字符串泄漏
	//---
	// 参数:
	//* str0: 字符串
	//* str1: 字符串
	//* str2: 字符串
	//* str3: 字符串
	//* str4: 字符串
	//* str5: 字符串
	//* str6: 字符串
	//* str7: 字符串
	//* str8: 字符串
	//* str9: 字符串
	//* strA: 字符串
	//* strB: 字符串
	//* strC: 字符串
	//* strD: 字符串
	//* strE: 字符串
	function MHString_Concat15 takes string str0, string str1, string str2, string str3, string str4, string str5, string str6, string str7, string str8, string str9, string strA, string strB, string strC, string strD, string strE returns string
	endfunction

	//---
	// 连接字符串lv16
	// 可减少连接字符串带来的字符串泄漏
	//---
	// 参数:
	//* str0: 字符串
	//* str1: 字符串
	//* str2: 字符串
	//* str3: 字符串
	//* str4: 字符串
	//* str5: 字符串
	//* str6: 字符串
	//* str7: 字符串
	//* str8: 字符串
	//* str9: 字符串
	//* strA: 字符串
	//* strB: 字符串
	//* strC: 字符串
	//* strD: 字符串
	//* strE: 字符串
	//* strF: 字符串
	function MHString_Concat16 takes string str0, string str1, string str2, string str3, string str4, string str5, string str6, string str7, string str8, string str9, string strA, string strB, string strC, string strD, string strE, string strF returns string
	endfunction

	//---
	// 连接字符串
	//---
	// 参数:
	//* v_name: 全局字符串数据变量名
	//* first: 起始索引
	//* last: 终止索引
	function MHString_ConcatFromVar takes string v_name, integer first, integer last returns string
	endfunction




/*
* ---------------------------------------------------
* sync.j
* ---------------------------------------------------
*/

	//---
	// 注册 数据同步 事件
	// 该事件不可注销
	//---
	// 参数:
	//* trig: 触发器
	//* key: 标签
	function MHSyncEvent_Register takes trigger trig, string key returns boolean
	endfunction

	//---
	// 注册 数据同步 事件 (code)
	//---
	// 参数:
	//* key: 标签
	//* callback: 事件回调
	function MHSyncEvent_RegisterByCode takes string key, code callback returns boolean
	endfunction

	//---
	// 发送同步数据
	// 标签key最长32字节, 数据data长度没有限制
	//---
	// 参数:
	//* key: 标签
	//* data: 数据
	function MHSyncEvent_Sync takes string key, string data returns boolean
	endfunction

	//---
	// 发送Json格式的同步数据
	// 标签key最长32字节, 数据data长度没有限制
	//---
	// 参数:
	//* key: 标签
	//* data: 数据
	function MHSyncEvent_JsonSync takes string key, integer data returns boolean
	endfunction

	//---
	// 获取被同步的标签
	// 响应 数据同步 事件
	function MHSyncEvent_GetKey takes nothing returns string
	endfunction

	//---
	// 获取被同步的数据
	// 响应 数据同步 事件
	function MHSyncEvent_GetData takes nothing returns string
	endfunction

	//---
	// 获取被同步的数据 (Json)
	// 响应 数据同步 事件
	// 会创建Json对象, 用完记得删除
	function MHSyncEvent_GetJsonData takes nothing returns integer
	endfunction




