	function MHUnit_SetColor takes unit u, integer color returns boolean
	endfunction

	//---
	// 重置颜色
	// 重置MHUnit_SetColor设置的颜色, 也可以重置原生冰冻/幻想/操纵死尸等颜色
	//---
	// 参数:
	//* u: 单位
	function MHUnit_ResetColor takes unit u returns integer
	endfunction

	//---
