	// 会同步设置肖像模型
	//---
	// 参数:
	//* u: 单位
	//* model_path: 模型路径
	//* flag: 参数 (作用未知)
	function MHUnit_SetModel takes unit u, string model_path, boolean flag returns integer
	endfunction

	//---
	// 设置队伍颜色
	// 填颜色就行
	//---
	// 参数:
	//* u: 单位
	//* color: 颜色 (ARGB16进制颜色代码)
	function MHUnit_SetTeamColor takes unit u, playercolor color returns integer
	endfunction

	//---
	// 设置队伍光晕
	// 填颜色就行
	//---
	// 参数:
	//* u: 单位
	//* glow: 队伍颜色 [参考 common::playercolor]
	function MHUnit_SetTeamGlow takes unit u, playercolor glow returns integer
	endfunction

