	endfunction

	//---
	// 注册 血条刷新 事件 (code)
	// 异步回调
	//---
	// 参数:
	//* callback: 事件回调
	function MHUIHPBarEvent_RegisterByCode takes code callback returns boolean
	endfunction

	//---
	// 获取血条的X偏移
	// 响应 血条刷新 事件
	//---
	// 返回值:
	//* real (绝对锚点y坐标)
	function MHUIHPBarEvent_GetX takes nothing returns real
	endfunction

	//---
	// 设置血条X偏移
	// 响应 血条刷新 事件
	//---
	// 参数:
	//* x: x轴偏移 (绝对锚点)
	function MHUIHPBarEvent_SetX takes real x returns boolean
	endfunction

	//---
	// 获取血条的Y偏移
	// 响应 血条刷新 事件
	//---
	// 返回值:
