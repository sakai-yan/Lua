/*
* ---------------------------------------------------
* buff.j
* ---------------------------------------------------
*/

	//---
	// 添加Buff
	//---
	// 参数:
	//* u: 单位
	//* bid: 魔法效果ID
	//* template_buff: 模板 [参考 MemHack::BUFF_TEMPLATE]
	//* dur: 持续时间
	//---
	// 返回值:
	//* buff
	function MHBuff_Create takes unit u, integer bid, integer template_buff, real dur returns buff
	endfunction

	//---
	// 添加BuffEx
	//---
	// 参数:
	//* u: 单位
	//* bid: 魔法效果ID
	//* template_buff: 模板 [参考 MemHack::BUFF_TEMPLATE]
	//* level: 魔法效果等级
	//* priority: 魔法偷取优先级
	//* dur: 持续时间
	//---
	// 返回值:
	//* buff
	function MHBuff_CreateEx takes unit u, integer bid, integer template_buff, integer level, integer priority, real dur returns buff
	endfunction

	//---
	// 获取等级
	//---
	// 参数:
	//* u: 单位
	//* bid: 魔法效果ID
	function MHBuff_GetLevel takes unit u, integer bid returns integer
	endfunction

	//---
	// 设置等级
	// 光环的魔法效果等级会被刷新
	//---
	// 参数:
	//* u: 单位
	//* bid: 魔法效果ID
	//* level: 魔法效果等级
	function MHBuff_SetLevel takes unit u, integer bid, integer level returns integer
	endfunction

	//---
	// 获取基础ID
	// 主要用于检查继承 (MHGame_CheckInherit)
	// 技能实例的基础ID与物编中的父级ID可能不同
	//---
	// 参数:
	//* u: 单位
	//* bid: 魔法效果ID
	function MHBuff_GetBaseID takes unit u, integer bid returns integer
	endfunction

	//---
	// 获取剩余持续时间
	//---
	// 参数:
	//* u: 单位
	//* bid: 魔法效果ID
	function MHBuff_GetRemain takes unit u, integer bid returns real
	endfunction

	//---
	// 设置剩余持续时间
	//---
	// 参数:
	//* u: 单位
	//* bid: 魔法效果ID
	//* value: 剩余持续时间
	function MHBuff_SetRemain takes unit u, integer bid, real value returns integer
	endfunction

	//---
	// 极性判定
	//---
	// 参数:
	//* u: 单位
	//* bid: 魔法效果ID
	//* polarity: 魔法效果极性 [参考 MemHack::BUFF_POLARITY]
	function MHBuff_IsPolarity takes unit u, integer bid, integer polarity returns boolean
	endfunction

	//---
	// 设置叠加
	// 解除同模板buff不叠加的限制
	// 暂不支持投射物技能buff的叠加
	//---
	// 参数:
	//* buff_template: 模板 [参考 MemHack::BUFF_TEMPLATE]
	//* is_enable: 允许叠加
	function MHBuff_SetOverlay takes integer buff_template, boolean is_enable returns boolean
	endfunction

	//---
	// 设置极性
	//---
	// 参数:
	//* u: 单位
	//* bid: 魔法效果ID
	//* polarity: 魔法效果极性 [参考 MemHack::BUFF_POLARITY]
	//* is_true: 是否为该极性
	function MHBuff_SetPolarity takes unit u, integer bid, integer polarity, boolean is_true returns boolean
	endfunction

	//---
	// 恢复极性
	//---
	// 参数:
	//* u: 单位
	//* bid: 魔法效果ID
	//* polarity: 魔法效果极性 [参考 MemHack::BUFF_POLARITY]
	function MHBuff_RestorePolarity takes unit u, integer bid, integer polarity returns boolean
	endfunction




/*
* ---------------------------------------------------
* constant.j
* ---------------------------------------------------
*/

	//---
	// 设置字节码限制
	// 有符号整数, 默认为30w, 在魔兽版本1.29或更高版本是300w
	//---
	// 参数:
	//* limit: 字节码限制
	//---
	// 返回值:
	//* integer (旧限制)
	function MHConst_SetOPLimit takes integer limit returns integer
	endfunction

	//---
	// 获取字节码限制
	// 默认为30w, 在魔兽版本1.29或更高版本是300w
	function MHConst_GetOPLimit takes nothing returns integer
	endfunction

	//---
	// 设置最大数组长度
	// 无符号整数. 默认限制为8192
	// 只能增加不能减少
	//---
	// 参数:
	//* limit: 最大数组长度
	//---
	// 返回值:
	//* integer (旧长度限制)
	function MHConst_SetMaxArraySize takes integer limit returns integer
	endfunction

	//---
	// 获取最大数组长度
	// 无符号整数. 默认限制为8192
	function MHConst_GetMaxArraySize takes nothing returns integer
	endfunction

	//---
	// 解除Blp大小限制
	// 解除后blp大小最大为32768x32768
	//---
	// 参数:
	//* is_unlock: 是否解除
	function MHConst_UnlockBlpSizeLimit takes boolean is_unlock returns integer
	endfunction

	//---
	// 设置最大移动速度
	// 可突破522的移速上限. 不推荐超过1000
	//---
	// 参数:
	//* limit: 最大移速上限
	//---
	// 返回值:
	//* real (旧的上限)
	function MHConst_SetMaxMoveSpeed takes real limit returns real
	endfunction

	//---
	// 设置最大攻击速度
	// 可突破每秒46次的上限. 默认为5 (即500%攻速加成)
	//---
	// 参数:
	//* limit: 最大攻速倍率上限
	//---
	// 返回值:
	//* real (旧的上限)
	function MHConst_SetMaxAttackSpeed takes real limit returns real
	endfunction

	//---
	// 设置最大持续时间
	// 可突破300s的最大持续时间和冷却时间的限制
	//---
	// 参数:
	//* limit: 最大持续时间
	//---
	// 返回值:
	//* real (旧的上限)
	function MHConst_SetMaxDuration takes real limit returns real
	endfunction

	//---
	// 设置最大视野
	// 可突破1800的最大视野限制
	// 不能设置太大的值否则会崩溃
	//---
	// 参数:
	//* limit: 最大视野
	//---
	// 返回值:
	//* real (旧的上限)
	function MHConst_SetMaxSight takes real limit returns real
	endfunction

	//---
	// 设置最大人口
	// 可突破300的最大人口限制
	//---
	// 参数:
	//* limit: 最大人口
	//---
	// 返回值:
	//* integer (旧的上限)
	function MHConst_SetMaxFood takes integer limit returns integer
	endfunction

	//---
	// 解除字体大小限制
	// 默认限制为19.2/当前窗口高度
	// 解除后仍然有一定限制, 超出某个数值后不会渲染
	//---
	// 参数:
	//* is_unlock: 是否解除
	function MHConst_UnlockFontHeight takes boolean is_unlock returns integer
	endfunction




/*
* ---------------------------------------------------
* damage.j
* ---------------------------------------------------
*/

	//---
	// 伤害目标
	// 等同于 单位-伤害目标 函数, 只是开放了设置物理伤害和伤害标志的接口
	//---
	// 参数:
	//* u: 单位
	//* target: 目标单位/物品/可破坏物
	//* dmg: 伤害
	//* atk_type: 攻击类型 [参考 common::attacktype]
	//* dmg_type: 伤害类型 [参考 common::damagetype]
	//* is_physical: 是物理伤害
	//* flag: 伤害标志 [参考 MemHack::DAMAGE_FLAG]
	//---
	// 返回值:
	//* real (实际造成的伤害值)
	function MHDamage_DamageTarget takes unit u, widget target, real dmg, attacktype atk_type, damagetype dmg_type, boolean is_physical, integer flag returns real
	endfunction

	//---
	// 任意单位即将受伤
	// 该事件不可注销
	// 前伤害事件, 事件触发时伤害还未结算为最终伤害, 此时可以修改攻击/伤害类型和伤害来源/受伤单位
	//---
	// 参数:
	//* trig: 触发器
	function MHDamagingEvent_Register takes trigger trig returns boolean
	endfunction

	//---
	// 任意单位即将受伤 (code)
	// 前伤害事件, 事件触发时伤害还未结算为最终伤害, 此时可以修改攻击/伤害类型和伤害来源/受伤单位
	//---
	// 参数:
	//* callback: 事件回调
	function MHDamagingEvent_RegisterByCode takes code callback returns boolean
	endfunction

	//---
	// 是物理伤害 (前伤害事件)
	// 响应 任意单位即将受伤 事件. 用于判定普攻
	function MHDamagingEvent_IsPhysical takes nothing returns boolean
	endfunction

	//---
	// 获取伤害值 (前伤害事件)
	// 响应 任意单位即将受伤 事件. 此时伤害还未结算为最终伤害
	function MHDamagingEvent_GetDamage takes nothing returns real
	endfunction

	//---
	// 设置伤害值 (前伤害事件)
	// 响应 任意单位即将受伤 事件
	//---
	// 参数:
	//* value: 伤害值
	function MHDamagingEvent_SetDamage takes real value returns boolean
	endfunction

	//---
	// 获取伤害来源 (前伤害事件)
	// 响应 任意单位即将受伤 事件
	function MHDamagingEvent_GetSource takes nothing returns unit
	endfunction

	//---
	// 设置伤害来源 (前伤害事件)
	// 响应 任意单位即将受伤 事件
	//---
	// 参数:
	//* u: 伤害来源
	function MHDamagingEvent_SetSource takes unit u returns boolean
	endfunction

	//---
	// 获取攻击类型 (前伤害事件)
	// 响应 任意单位即将受伤 事件
	//---
	// 返回值:
	//* attacktype [参考 common::attacktype]
	function MHDamagingEvent_GetAtkType takes nothing returns attacktype
	endfunction

	//---
	// 获取攻击类型 (整数) (前伤害事件)
	// 响应 任意单位即将受伤 事件
	//---
	// 返回值:
	//* integer [参考 common::attacktype]
	function MHDamagingEvent_GetAtkTypeInt takes nothing returns integer
	endfunction

	//---
	// 设置攻击类型 (前伤害事件)
	// 响应 任意单位即将受伤 事件
	//---
	// 参数:
	//* atk_type: 攻击类型 [参考 common::attacktype]
	function MHDamagingEvent_SetAtkType takes attacktype atk_type returns boolean
	endfunction

	//---
	// 获取伤害类型 (前伤害事件)
	// 响应 任意单位即将受伤 事件
	//---
	// 返回值:
	//* damagetype [参考 common::damagetype]
	function MHDamagingEvent_GetDmgType takes nothing returns damagetype
	endfunction

	//---
	// 获取伤害类型 (整数) (前伤害事件)
	// 响应 任意单位即将受伤 事件
	function MHDamagingEvent_GetDmgTypeInt takes nothing returns integer
	endfunction

	//---
	// 设置伤害类型 (前伤害事件)
