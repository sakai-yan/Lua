	//* alpha: 透明度
	//* red: 红色值
	//* green: 绿色值
	//* blue: 蓝色值
	function MHEffect_SetColorEx takes effect eff, integer alpha, integer red, integer green, integer blue returns boolean
	endfunction

	//---
	// 播放动画
	//---
	// 参数:
	//* eff: 特效
	//* index: 动画
	//* rarity: 概率 (0: 普通概率, 1: 罕见概率)
	function MHEffect_SetAnimation takes effect eff, integer index, integer rarity returns boolean
	endfunction

	//---
	// 播放动画 (按名字)
	//---
	// 参数:
	//* eff: 特效
	//* name: 动画
	//* attachment: 附加链接动画名
	function MHEffect_SetAnimationByName takes effect eff, string name, string attachment returns boolean
	endfunction

	//---
	// 播放动画 (按类型)
	//---
	// 参数:
	//* eff: 特效
	//* anim_type: 动画类型 [参考 MemHack::ANIM_TYPE]
	//* looping: 是否循环
	function MHEffect_SetAnimationByType takes effect eff, integer anim_type, boolean looping returns boolean
	endfunction

	//---
	// 获取动画进度
	//---
	// 参数:
	//* eff: 特效
	//---
	// 返回值:
	//* real (0~1)
	function MHEffect_GetAnimationProgress takes effect eff returns real
	endfunction

	//---
	// 设置动画进度
	// 取值范围0~1
	//---
	// 参数:
	//* eff: 特效
	//* progress: 动画进度
	function MHEffect_SetAnimationProgress takes effect eff, real progress returns boolean
	endfunction

	//---
	// 设置动画速度
	// 取值范围0~1
	//---
	// 参数:
	//* eff: 特效
	//* scale: 动画速度
	function MHEffect_SetTimeScale takes effect eff, real scale returns boolean
	endfunction

	//---
	// 绑定到单位
	//---
	// 参数:
	//* eff: 特效
	//* target: 目标单位/物品/可破坏物
	//* attach_name: 附加点
	function MHEffect_BindToWidget takes effect eff, widget target, string attach_name returns boolean
	endfunction

	//---
	// 绑定到特效
	//---
	// 参数:
	//* eff: 特效
	//* target: 目标特效
	//* attach_name: 附加点
	function MHEffect_BindToEffect takes effect eff, effect target, string attach_name returns boolean
	endfunction

	//---
	// 绑定到Frame
	// 仅支持CSpriteFrame和CPortraitButton
	//---
	// 参数:
	//* eff: 特效
	//* frame: 目标Frame
	//* attach_name: 附加点
	function MHEffect_BindToFrame takes effect eff, integer frame, string attach_name returns boolean
	endfunction

	//---
	// 从物体上解绑
	//---
	// 参数:
	//* eff: 解绑
	function MHEffect_Unbind takes effect eff returns boolean
	endfunction

	//---
	// 选取特效做动作
	//---
	// 参数:
	//* x: 圆心x
	//* y: 圆心y
	//* range: 选取半径
	//* callback: 回调函数
	function MHEffect_EnumInRange takes real x, real y, real range, code callback returns boolean
	endfunction

	//---
	// 选取特效做动作
	//---
	// 参数:
	//* x: 圆心x
	//* y: 圆心y
	//* range: 选取半径
	//* callback: 回调函数名
	function MHEffect_EnumInRangeEx takes real x, real y, real range, string callback returns boolean
	endfunction

	//---
	// 获取选取的特效
	// 在选取特效做动作中, 指代被选取的特效
	function MHEffect_GetEnumEffect takes nothing returns effect
	endfunction

	//---
	// 强制渲染
	// 可以强制渲染大模型特效, 即使特效中心不在屏幕内也能渲染
	// 仅支持没有绑定到物体的特效
	//---
	// 参数:
	//* eff: 特效
	//* is_force: 是否强制渲染
	function MHEffect_ForceRender takes effect eff, boolean is_force returns boolean
	endfunction

	//---
	// 开关特效渲染
	// 填false即可停止渲染所有非绑定的特效
	//---
	// 参数:
	//* is_render: 是否渲染
	function MHEffect_SwitchRender takes boolean is_render returns boolean
	endfunction

	//---
	// 除外特效渲染
	// 指 开关特效渲染 关闭后仍然渲染的特效
	//---
	// 参数:
	//* eff: 继续渲染的特效
	//* is_exclude: 是否渲染
	function MHEffect_SwitchExclude takes effect eff, boolean is_exclude returns boolean
	endfunction




