	function MHUnit_FlagTypeOperator takes unit u, integer op, integer flag returns boolean
	endfunction

	//---
	// 单位被变形
	// 判定是否被妖术之类的技能变形
	//---
	// 参数:
	//* u: 单位
	function MHUnit_IsPolymorphed takes unit u returns boolean
	endfunction

	//---
	// 杀死单位
	// 等同于cj的杀死单位, 但是多了个设置凶手单位
	//---
	// 参数:
	//* victim: 受害单位
	//* killer: 凶手单位
	function MHUnit_Kill takes unit victim, unit killer returns boolean
	endfunction

	//---
	// 复活单位
	// 复活英雄时相当于cj的立即复活, 无特效
	//---
	// 参数:
	//* u: 单位
	//* x: 坐标X
	//* y: 坐标Y
	function MHUnit_Revive takes unit u, real x, real y returns boolean
	endfunction

	//---
	// 获取凶手单位
	// 没有事件的限制, 在任何时候都可以对死亡单位使用
	//---
	// 参数:
	//* victim: 受害单位
	function MHUnit_GetKiller takes unit victim returns unit
	endfunction

	//---
	// 眩晕单位
	// 本质是单位的眩晕计数 + 1. 如果是第一次眩晕, 则会添加眩晕flag, 然后对单位发布眩晕命令
	//---
	// 参数:
	//* u: 单位
	//* is_stun: 是否眩晕
	function MHUnit_Stun takes unit u, boolean is_stun returns boolean
	endfunction

	//---
	// 获取眩晕计数
	//---
	// 参数:
	//* u: 单位
	function MHUnit_GetStunCount takes unit u returns integer
	endfunction

	//---
	// 设置虚无状态
	// 计数器
	// 可以在启用虚无前先启用'Aatk'(攻击)技能, 则不会禁用攻击
	// 如果先启用了攻击, 则禁用虚无后也要禁用攻击技能来恢复计数.
	//---
	// 参数:
	//* u: 单位
	//* is_add: 是否添加
	function MHUnit_SetEthereal takes unit u, boolean is_add returns boolean
	endfunction

	//---
	// 获取虚无计数
	//---
	// 参数:
	//* u: 单位
	function MHUnit_GetEtherealCount takes unit u returns integer
	endfunction

	//---
	// 设置单位隐形
	// 计数器
	//---
	// 参数:
	//* u: 单位
	//* is_add: 是否隐形
	//* gradient_time: 渐变时间
	function MHUnit_SetInvisible takes unit u, boolean is_add, real gradient_time returns integer
	endfunction

	//---
	// 获取隐形计数
	//---
	// 参数:
	//* u: 单位
	function MHUnit_GetInvisionCount takes unit u returns integer
	endfunction

	//---
	// 禁用自动攻击
	// 计数器
	// 疾风步等隐形技能同款
	//---
	// 参数:
	//* u: 单位
	//* is_disable: 是否禁用
	function MHUnit_DisableAutoAttack takes unit u, boolean is_disable returns integer
	endfunction

	//---
	// 获取禁用自动攻击计数
	//---
	// 参数:
	//* u: 单位
	function MHUnit_GetDisableAutoAttackCount takes unit u returns integer
	endfunction

