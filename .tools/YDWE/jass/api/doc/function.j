	function MHUI_GetTimerDialogBackdrop takes timerdialog d returns integer
	endfunction

	//---
	// 注册 本地帧绘制 事件
	// 该事件不可注销
	// 异步事件仅支持逆天触发器
	//---
	// 参数:
	//* trig: 触发器
	function MHUITickEvent_Register takes trigger trig returns boolean
	endfunction

	//---
	// 注册 本地帧绘制 事件 (code)
	// 异步回调
	//---
	// 参数:
	//* callback: 事件回调
	function MHUITickEvent_RegisterByCode takes code callback returns boolean
	endfunction

	//---
	// 注册 血条刷新 事件
	// 该事件不可注销
	// 异步事件仅支持逆天触发器
	//---
	// 参数:
	//* trig: 触发器
