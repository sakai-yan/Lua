	// 隐藏
	//---
	// 参数:
	//* eff: 特效
	//* is_hide: 是否隐藏
	function MHEffect_Hide takes effect eff, boolean is_hide returns boolean
	endfunction

	//---
	// 被隐藏
	//---
	// 参数:
	//* eff: 特效
	function MHEffect_IsHidden takes effect eff returns boolean
	endfunction

	//---
	// 设置透明度
	// 取值范围0~255
	//---
	// 参数:
	//* eff: 特效
	//* alpha: 透明度
	function MHEffect_SetAlpha takes effect eff, integer alpha returns boolean
	endfunction

	//---
	// 设置颜色
	//---
	// 参数:
	//* eff: 特效
	//* color: 颜色 (ARGB16进制颜色代码)
	function MHEffect_SetColor takes effect eff, integer color returns boolean
	endfunction

	//---
	// 设置颜色 (ARGB)
	// 颜色值的取值范围与物编中相同
	//---
	// 参数:
