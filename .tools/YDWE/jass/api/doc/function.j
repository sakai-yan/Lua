	function MHEffect_SetScaleEx takes effect eff, real x, real y, real z returns boolean
	endfunction

	//---
	// 设置粒子缩放
	// 多次设置会乘算叠加
	//---
	// 参数:
	//* eff: 特效
	//* scale: 粒子缩放
	function MHEffect_SetParticleScale takes effect eff, real scale returns boolean
	endfunction

	//---
	// 重置变换
	// 方向和大小重置到初始状态
	//---
	// 参数:
	//* eff: 特效
	function MHEffect_ResetMatrix takes effect eff returns boolean
	endfunction

