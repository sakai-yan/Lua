	// 不会打断当前动作
	// 会触发 任意单位攻击出手 事件
	//---
	// 参数:
	//* source: 单位
	//* weapons_on: 攻击索引 (0~3)
	//* target: 目标单位/物品/可破坏物
	function MHUnit_LaunchAttack takes unit source, integer weapons_on, widget target returns integer
	endfunction

	//---
	// 设置朝向
	//---
	// 参数:
	//* u: 单位
	//* facing: 朝向 (角度)
	//* is_instant: 是否立即
	function MHUnit_SetFacing takes unit u, real facing, boolean is_instant returns integer
	endfunction

	//---
	// 沉默
	// 计数器
	//---
	// 参数:
	//* u: 单位
	//* is_silence: 是否沉默
	function MHUnit_Silence takes unit u, boolean is_silence returns integer
	endfunction

	//---
	// 获取沉默计数
	//---
	// 参数:
	//* u: 单位
	function MHUnit_GetSilenceCount takes unit u returns integer
	endfunction

	//---
	// 禁用所有技能
