	// 更新信息栏
	// 设置某些属性后需要运行一次该函数
	//---
	// 参数:
	//* u: 单位
	function MHUnit_UpdateInfoBar takes unit u returns integer
	endfunction

	//---
	// 获取训练列表中的ID
	// 仅对正在训练/研究的单位起效
	//---
	// 参数:
	//* u: 单位
	//* index: 序号 (1~7)
	function MHUnit_GetTrainId takes unit u, integer index returns integer
	endfunction

	//---
	// 取消训练/研究
	//---
	// 参数:
	//* u: 单位
	//* index: 序号 (1~7)
	function MHUnit_CancelTrain takes unit u, integer index returns integer
	endfunction

