/*
* ---------------------------------------------------
* debug.j
* ---------------------------------------------------
*/

	//---
	// 打开控制台
	//---
	// 参数:
	//* is_enable: 是否打开
	function MHDebug_EnableConsole takes boolean is_enable returns nothing
	endfunction

	//---
	// 获取句柄数量
	// 当前存在的句柄数量
	function MHDebug_GetHandleCount takes nothing returns integer
	endfunction

	//---
	// 获取最大句柄数量
	// 历史最大存在的句柄数量
	function MHDebug_GetHandleMaxCount takes nothing returns integer
	endfunction

	//---
	// 允许崩溃追踪
	// 崩溃后会自动生成日志, 填false可关闭
	//---
	// 参数:
	//* is_enable: 允许崩溃追踪
	function MHDebug_EnableCrashTracer takes boolean is_enable returns integer
	endfunction

	//---
	// 允许崩溃转储
	// 必须先开启崩溃追踪, 崩溃后追加生成内存转储, 用于调试
	// 游戏流程长的话转储文件会特别大, 非必要不开启
	//---
	// 参数:
	//* is_enable: 允许崩溃转储
	function MHDebug_EnableCrashTracerDump takes boolean is_enable returns integer
	endfunction

	//---
	// 允许异步检测
	// 启动后无法关闭
	// 会在玩家掉线时生成日志
	function MHDebug_EnableDesyncCheck takes nothing returns integer
	endfunction

	//---
	// 设置异步日志文件数量
	// 默认为2, 超过该数量后日志会轮换删除
	// 异步日志没有记录到异步点的时候可以尝试设置为一个较大的数或者-1
	// 过多的异步日志会导致游戏目录体积急剧增大
	//---
	// 参数:
	//* count: 保留文件数量
	function MHDebug_SetDesyncCheckFileCount takes integer count returns integer
	endfunction

	//---
	// 允许泄漏检测
	// 启动后无法关闭. 启动后才能生成泄露报告
	function MHDebug_EnableLeakMonitor takes nothing returns boolean
	endfunction

	//---
	// 显示泄漏信息
	// 显示当前存在的对象信息
	function MHDebug_ShowLeakMessage takes nothing returns boolean
	endfunction

	//---
	// 生成泄漏报告
	// 生成详细的泄漏检测报告
	function MHDebug_DumpLeakReport takes nothing returns boolean
	endfunction

	//---
	// 运行性能分析
	// 时间到后会生成一个性能分析报告
	//---
	// 参数:
	//* dur: 运行性能分析
	function MHDebug_StartProfiling takes real dur returns boolean
	endfunction




/*
* ---------------------------------------------------
* doodad.j
