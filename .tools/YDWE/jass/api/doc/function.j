	// 参数:
	//* u: 单位
	//* is_disable: 是否禁用
	//* is_hide: 是否隐藏
	//* disable_magic: 禁用魔法技能
	//* disable_physical: 禁用物理技能
	function MHUnit_DisableAbility takes unit u, boolean is_disable, boolean is_hide, boolean disable_magic, boolean disable_physical returns integer
	endfunction

