	// 设置的是物编中 战斗-作为目标类型
	//---
	// 参数:
	//* u: 单位
	//* as_target_type: 作为目标类型 [参考 MemHack::TARGET_ALLOW]
	function MHUnit_SetAsTargetType takes unit u, integer as_target_type returns boolean
	endfunction

	//---
