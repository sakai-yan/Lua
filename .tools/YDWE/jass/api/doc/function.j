	endfunction

	//---
	// 设置血条Y偏移
	// 响应 血条刷新 事件
	// 绝对锚点
	//---
	// 参数:
	//* y: y轴偏移 (绝对锚点)
	function MHUIHPBarEvent_SetY takes real y returns boolean
	endfunction

	//---
	// 注册 预渲染 事件
	// 可在该事件中绘制自定义血条, 不会抖动
	// 该事件不可注销
	// 异步事件仅支持逆天触发器
	//---
	// 参数:
	//* trig: 触发器
	function MHUIRenderEvent_Register takes trigger trig returns boolean
	endfunction

	//---
	// 注册 预渲染 事件 (code)
	// 可在该事件中绘制自定义血条, 不会抖动
	// 异步回调
	//---
	// 参数:
	//* callback: 事件回调
	function MHUIRenderEvent_RegisterByCode takes code callback returns boolean
	endfunction

	//---
	// 获取头顶X坐标
	// 响应 预渲染 事件
	//---
	// 参数:
	//* w: 单位/物品/可破坏物
	//---
	// 返回值:
	//* real (屏幕坐标x)
	function MHUIRenderEvent_GetOverheadX takes widget w returns real
	endfunction

	//---
	// 获取头顶Y坐标
	// 响应 预渲染 事件
	//---
	// 参数:
	//* w: 单位/物品/可破坏物
	//---
	// 返回值:
	//* real (屏幕坐标y)
	function MHUIRenderEvent_GetOverheadY takes widget w returns real
	endfunction

	//---
	// 获取头顶缩放
	// 响应 预渲染 事件
	//---
	// 参数:
	//* w: 单位/物品/可破坏物
	function MHUIRenderEvent_GetOverheadScale takes widget w returns real
	endfunction

	//---
	// 绘制攻速
	// 启用后会在控制台攻击图标的提示工具中显示实际攻速
	//---
	// 参数:
	//* is_draw: 是否绘制
	function MHUI_DrawAttackSpeed takes boolean is_draw returns boolean
	endfunction

	//---
	// 绘制移速
	// 启用后会在控制台防御图标的提示工具中显示实际移速
	//---
	// 参数:
	//* is_draw: 是否绘制
	function MHUI_DrawMoveSpeed takes boolean is_draw returns boolean
	endfunction

	//---
	// 绘制蓝条
	// 启用后会按照重置版的蓝条样式在单位头顶绘制蓝条
	//---
	// 参数:
	//* is_enable: 是否开启
	function MHUI_EnableDrawMPBar takes boolean is_enable returns nothing
	endfunction

	//---
	// 仅绘制盟友蓝条
	//---
	// 参数:
	//* is_only: 是否仅绘制盟友蓝条
	function MHUI_OnlyDrawAllyMPBar takes boolean is_only returns nothing
	endfunction

	//---
	// 绘制英雄等级
	//---
	// 参数:
	//* is_draw: 是否在蓝条旁绘制英雄等级
	function MHUI_MPBarDrawHeroLevel takes boolean is_draw returns nothing
	endfunction

	//---
	// 技能冷却显示
	// 启用后会按照重置版的冷却显示样式在技能按钮上绘制冷却时间
	//---
	// 参数:
	//* is_enable: 是否开启
	function MHUI_EnableDrawAbilsCooldown takes boolean is_enable returns nothing
	endfunction

	//---
	// 物品冷却显示
	// 启用后会按照重置版的冷却显示样式在物品按钮上绘制冷却时间
	//---
	// 参数:
	//* is_enable: 是否开启
	function MHUI_EnableDrawItemsCooldown takes boolean is_enable returns nothing
	endfunction

	//---
	// 技能热键显示
	// 启用后会按照重置版的热键显示样式在技能按钮上绘制热键
	//---
	// 参数:
	//* is_enable: 是否开启
	function MHUI_EnableDrawAbilsHotkey takes boolean is_enable returns nothing
	endfunction

	//---
	// 物品热键显示
	// 启用后会按照重置版的热键显示样式在物品按钮上绘制热键
	//---
	// 参数:
	//* is_enable: 是否开启
