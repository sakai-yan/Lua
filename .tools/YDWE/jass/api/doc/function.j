	// 响应 哈希项发生变动 事件
	//---
	// 参数:
	//* value: 新值
	function MHHashtableChangeEvent_SetNewValueBool takes boolean value returns boolean
	endfunction

	//---
	// 设置变动的字符串哈希项新值
	// 响应 哈希项发生变动 事件
	//---
	// 参数:
	//* value: 新值
	function MHHashtableChangeEvent_SetNewValueStr takes string value returns boolean
	endfunction

	//---
	// 获取变动的哈希项类型
	// 响应 哈希表项变动 事件
	//---
	// 返回值:
	//* integer [参考 MemHack::HASHTABLE_CHANGE]
	function MHHashtableChangeEvent_GetType takes nothing returns integer
	endfunction




/*
* ---------------------------------------------------
* hero.j
* ---------------------------------------------------
*/

	//---
	// 获取最大经验值
	// 单位从0级到指定等级所需经验值
	//---
	// 参数:
	//* u: 英雄
	//* level: 等级
	function MHHero_GetMaxExp takes unit u, integer level returns integer
	endfunction

	//---
	// 获取需求经验值
	// 单位从当前等级到指定等级所需经验值
	//---
	// 参数:
	//* u: 英雄
	//* level: 等级
	function MHHero_GetNeededExp takes unit u, integer level returns integer
	endfunction

	//---
	// 获取属性成长
	//---
	// 参数:
	//* u: 英雄
	//* attr: 英雄属性 [参考 MemHack::HERO_ATTR]
	function MHHero_GetAttrPlus takes unit u, integer attr returns real
	endfunction

	//---
	// 设置属性成长
	// 游戏不会存储当前属性, 只会存储基础属性 (初始+绿字) 和 属性成长
	// 需要用到当前属性的时候就会计算: 基础属性 + 属性成长 * (英雄等级 - 1)
	//---
	// 参数:
	//* u: 英雄
	//* attr: 英雄属性 [参考 MemHack::HERO_ATTR]
	//* value: 成长值
	function MHHero_SetAttrPlus takes unit u, integer attr, real value returns integer
	endfunction

	//---
	// 获取主属性
	//---
	// 参数:
	//* u: 英雄
	//---
	// 返回值:
	//* integer [参考 MemHack::HERO_ATTR]
	function MHHero_GetPrimaryAttr takes unit u returns integer
	endfunction

	//---
	// 设置主属性
	//---
	// 参数:
	//* u: 英雄
	//* attr: 英雄属性 [参考 MemHack::HERO_ATTR]
	function MHHero_SetPrimaryAttr takes unit u, integer attr returns integer
	endfunction

	//---
	// 获取主属性数值
	//---
	// 参数:
	//* u: 英雄
	//* include_bonus: 包括加成
	function MHHero_GetPrimaryAttrValue takes unit u, boolean include_bonus returns integer
	endfunction

	//---
	// 设置主属性数值
	// "永久奖励貌似无效项, 不需要理会" by ydwe
	//---
	// 参数:
	//* u: 英雄
	//* value: 主属性数值
	//* allow_bonus: 允许永久奖励
	function MHHero_SetPrimaryAttrValue takes unit u, integer value, boolean allow_bonus returns integer
	endfunction

	//---
	// 替换学习技能
	// 只会影响未学习的技能
	//---
	// 参数:
	//* u: 英雄
	//* old_id: 旧的技能ID
	//* new_id: 新的技能ID
	function MHHero_ModifyAbility takes unit u, integer old_id, integer new_id returns boolean
	endfunction

	//---
	// 替换学习技能Ex
	// 只会影响未学习的技能
	//---
	// 参数:
	//* u: 英雄
	//* index: 序号 (1~5)
	//* new_id: 新的技能ID
	function MHHero_ModifyAbilityEx takes unit u, integer index, integer new_id returns boolean
	endfunction

	//---
	// 替换英雄技能
	// 最好替换同源技能
	// 会同时影响已学习和未学习的技能
	//---
	// 参数:
	//* u: 英雄
	//* old_id: 旧的技能ID
	//* new_id: 新的技能ID
	function MHHero_ChangeAbility takes unit u, integer old_id, integer new_id returns boolean
	endfunction

	//---
	// 替换英雄技能Ex
	// 无同源技能限制
	// 本质上是替换学习技能 + 删除旧技能 + 添加新技能 + 设置技能等级
	//---
	// 参数:
	//* u: 英雄
	//* old_id: 旧的技能ID
	//* new_id: 新的技能ID
	function MHHero_ChangeAbilityEx takes unit u, integer old_id, integer new_id returns boolean
	endfunction

	//---
	// 注册 任意单位获取经验值 事件
	// 该事件不可注销
	//---
	// 参数:
	//* trig: 触发器
	function MHHeroGetExpEvent_Register takes trigger trig returns boolean
	endfunction

	//---
	// 注册 任意单位获取经验值 事件 (code)
	//---
	// 参数:
	//* callback: 事件回调
	function MHHeroGetExpEvent_RegisterByCode takes code callback returns boolean
	endfunction

	//---
	// 获取获得的经验值
	// 响应 任意单位获取经验值 事件
	function MHHeroGetExpEvent_GetValue takes nothing returns integer
	endfunction

	//---
	// 设置获得的经验值
	// 响应 任意单位获取经验值 事件
	// 非负数
	//---
	// 参数:
	//* value: 新值
	function MHHeroGetExpEvent_SetValue takes integer value returns boolean
	endfunction




