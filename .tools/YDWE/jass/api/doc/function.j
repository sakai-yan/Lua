*/

	//---
	// 选取范围内的单位做动作
	//---
	// 参数:
	//* x: 中心X
	//* y: 中心Y
	//* range: 半径
	//* callback: 选取回调 (函数名)
	function MHUnit_EnumInRange takes real x, real y, real range, string callback returns boolean
	endfunction

	//---
	// 选取圆形范围内的单位做动作
	//---
	// 参数:
	//* x: 中心X
	//* y: 中心Y
	//* range: 半径
	//* callback: 选取回调
	function MHUnit_EnumInRangeEx takes real x, real y, real range, code callback returns boolean
	endfunction

	//---
	// 选取扇形范围内的单位做动作
	//---
	// 参数:
	//* x: 圆心x
	//* y: 圆心y
	//* range: 半径
	//* orientation: 方向角 (角度)
	//* angle: 圆心角 (角度)
	//* callback: 选取回调
	function MHUnit_EnumSector takes real x, real y, real range, real orientation, real angle, code callback returns boolean
	endfunction

	//---
	// 选取直线范围内的单位做动作
	//---
	// 参数:
	//* x: 原点x
	//* y: 原点y
	//* orientation: 方向角 (角度)
	//* range: 长度
	//* width: 宽度
	//* callback: 选取回调
	function MHUnit_EnumLine takes real x, real y, real orientation, real range, real width, code callback returns boolean
	endfunction

	//---
	// 选取屏幕内的单位做动作
	//---
	// 参数:
	//* callback: 选取回调 (函数名)
	function MHUnit_EnumInScreen takes string callback returns boolean
	endfunction

	//---
	// 选取屏幕内的单位做动作
	//---
	// 参数:
	//* callback: 选取回调
	function MHUnit_EnumInScreenEx takes code callback returns boolean
	endfunction

	//---
	// 选取当前选择的所有单位做动作
	// 每个人选择的单位是不一样的, 注意不要拿去做同步逻辑
	//---
	// 参数:
	//* callback: 选取回调
	function MHUnit_EnumSelections takes code callback returns boolean
	endfunction

	//---
	// 获取选取的单位
	// 在MH的选取单位做动作中, 指代被选取的单位
	function MHUnit_GetEnumUnit takes nothing returns unit
	endfunction

	//---
	// 获取当前选择的单位数量
	// 每个人选择的单位数量可能不同, 注意不要拿去做同步逻辑
	function MHUnit_GetSelectionsSize takes nothing returns integer
	endfunction

	//---
	// 创建建筑
	//---
	// 参数:
	//* p: 玩家
	//* uid: 建筑
	//* x: 坐标X
	//* y: 坐标Y
	//* auto_build: 是否自动建造
	//* can_assist: 是否多敲
	function MHUnit_CreateBuilding takes player p, integer uid, real x, real y, boolean auto_build, boolean can_assist returns unit
	endfunction

	//---
	// 添加技能
	// 原版的添加技能会检查相同技能
	//---
	// 参数:
	//* u: 单位
	//* aid: 技能ID
	//* check_duplicate: 是否检查相同技能
	function MHUnit_AddAbility takes unit u, integer aid, boolean check_duplicate returns ability
	endfunction

	//---
	// 删除技能
	// 原版的删除技能不会检查相同技能
	//---
	// 参数:
	//* u: 单位
	//* aid: 技能ID
	//* check_duplicate: 是否检查相同技能
	function MHUnit_RemoveAbility takes unit u, integer aid, boolean check_duplicate returns boolean
	endfunction

	//---
	// 获取技能
	//---
	// 参数:
	//* u: 单位
	//* aid: 技能ID
	//* search_base: 是否按基础ID搜索
	//---
	// 返回值:
	//* ability
	function MHUnit_GetAbility takes unit u, integer aid, boolean search_base returns ability
	endfunction

	//---
	// 获取技能数量
	// 包括魔法效果
	//---
	// 参数:
	//* u: 单位
	function MHUnit_GetAbilityCount takes unit u returns integer
	endfunction

	//---
	// 获取指定序号的技能
	// 包括魔法效果
	// 后添加的技能更靠前
	//---
	// 参数:
	//* u: 单位
	//* index: 序号
	function MHUnit_GetAbilityByIndex takes unit u, integer index returns integer
	endfunction

	//---
	// 获取指定序号的技能
	// 包括魔法效果
	// 后添加的技能更靠前
	//---
	// 参数:
	//* u: 单位
	//* index: 序号
	//---
	// 返回值:
	//* ability
	function MHUnit_GetAbilityHandleByIndex takes unit u, integer index returns ability
	endfunction

	//---
	// 选取技能做动作
	// 不要在回调中添加或删除技能
	//---
	// 参数:
	//* u: 单位
	//* callback: 选取回调
	function MHUnit_EnumAbility takes unit u, code callback returns boolean
	endfunction

	//---
	// 选取的技能
	// 指代在 选取技能做动作 中被选取的技能
	//---
	// 返回值:
	//* ability
	function MHUnit_GetEnumAbility takes nothing returns ability
	endfunction

	//---
	// 选取的技能
	// 指代在 选取技能做动作 中被选取的技能
	function MHUnit_GetEnumAbilityId takes nothing returns integer
	endfunction

