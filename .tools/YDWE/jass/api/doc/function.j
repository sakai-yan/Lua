	function MHUI_PlayNativeSound takes string label returns boolean
	endfunction

	//---
	// 播放错误音效
	// 相当于MHUI_PlayNativeSound("InterfaceError")
	function MHUI_PlayErrorSound takes nothing returns boolean
	endfunction

