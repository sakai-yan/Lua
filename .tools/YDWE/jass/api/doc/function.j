	// 注册 任意投射物命中 事件
	// 该事件不可注销
	// 不推荐使用
	//---
	// 参数:
	//* trig: 触发器
	function MHMissileHitEvent_Register takes trigger trig returns boolean
	endfunction

	//---
	// 注册 任意投射物命中 事件 (code)
	// 不推荐使用
	//---
	// 参数:
	//* callback: 事件回调
	function MHMissileHitEvent_RegisterByCode takes code callback returns boolean
	endfunction

	//---
	// 获取命中的单位
	// 响应 任意投射物命中 事件
	// 不推荐使用
	function MHMissileHitEvent_GetTargetUnit takes nothing returns unit
	endfunction

	//---
	// 获取命中的物品
	// 响应 任意投射物命中 事件
	// 不推荐使用
	function MHMissileHitEvent_GetTargetItem takes nothing returns item
	endfunction

	//---
	// 获取命中的可破坏物
	// 响应 任意投射物命中 事件
	// 不推荐使用
	function MHMissileHitEvent_GetTargetDest takes nothing returns unit
	endfunction

	//---
	// 设置命中的目标
	// 响应 任意投射物命中 事件
	// 不推荐使用
	//---
	// 参数:
	//* target: 目标单位/物品/可破坏物
	function MHMissileHitEvent_SetTarget takes widget target returns integer
	endfunction

	//---
	// 获取命中时的伤害
	// 不推荐使用
	// 响应 任意投射物命中 事件
	function MHMissileHitEvent_GetDamage takes nothing returns real
	endfunction

	//---
	// 设置命中时的伤害
	// 响应 任意投射物命中 事件
	// 不推荐使用
	//---
	// 参数:
	//* damage: 伤害
	function MHMissileHitEvent_SetDamage takes real damage returns integer
	endfunction

	//---
	// 重置投射物
	// 响应 任意投射物命中 事件
	// 重新运行投射物, 重置后本次命中不会结算
	// 不推荐使用
	//---
	// 参数:
	//* source: 新的来源
	//* target: 新的目标
	function MHMissileHitEvent_Reset takes unit source, widget target returns boolean
	endfunction




