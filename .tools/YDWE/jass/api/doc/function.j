	// 设置冷却显示小数显示分隔
	// 指冷却到什么时间以下时显示小数
	// 默认为1s
	//---
	// 参数:
	//* divide: 分隔时间
	function MHUI_SetCooldownDivide takes real divide returns nothing
	endfunction

	//---
	// 获取冷却显示文本
	// 指代 开启冷却显示 中对应的文本Frame
	//---
	// 参数:
	//* index: 序号 (1~12: 技能栏文本, 13~18: 物品栏文本)
	//---
	// 返回值:
	//* integer (CSimpleFontString)
	function MHUI_GetCooldownText takes integer index returns integer
	endfunction

	//---
	// 获取热键显示背景
	// 指代 开启热键显示 中对应的背景Frame
	//---
	// 参数:
	//* index: 序号 (1~12: 技能栏背景, 13~18: 物品栏背景)
	//---
	// 返回值:
	//* integer (CSimpleTexture)
	function MHUI_GetHotkeyOverlay takes integer index returns integer
	endfunction

	//---
	// 获取热键显示文本
	// 指代 开启热键显示 中对应的文本Frame
	//---
	// 参数:
	//* index: 序号 (1~12: 技能栏文本, 13~18: 物品栏文本)
	//---
	// 返回值:
	//* integer (CSimpleFontString)
	function MHUI_GetHotkeyText takes integer index returns integer
	endfunction

	//---
	// 开启叠字修复
	// 并非窗口缩放
	//---
	// 参数:
	//* is_enable: 开启叠字修复
	function MHUI_FixGarbled takes boolean is_enable returns nothing
	endfunction




