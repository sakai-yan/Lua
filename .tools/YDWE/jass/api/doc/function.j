	//---
	// 获取handle类型
	// 填入Handle
	// 例如单位返回'+w3u'
	//---
	// 参数:
	//* hd: handle
	function MHTool_GetHandleType takes handle hd returns integer
	endfunction

	//---
	// 获取Handle类型
	// 填入HandleId
	// 例如单位返回'+w3u'
	//---
	// 参数:
	//* hid: handleid
	function MHTool_GetHandleIdType takes integer hid returns integer
	endfunction

	//---
	// 获取系统时间
	// 返回值是异步的
	//---
	// 参数:
	//* flag: 系统时间 [参考 MemHack::SYSTEM_TIME]
	function MHTool_GetLocalTime takes integer flag returns integer
	endfunction

	//---
	// 获取计时
	// clock()
	// 可用于函数运行效率测试
	//---
	// 返回值:
	//* integer (毫秒 )
	function MHTool_Clock takes nothing returns integer
	endfunction

	//---
	// 判定Handle对象有效
	//---
	// 参数:
	//* hd: handle对象
	function MHTool_IsHandleValid takes handle hd returns boolean
	endfunction

	//---
	// 读取剪贴板
	function MHTool_ReadClipboard takes nothing returns string
	endfunction

	//---
	// 写入剪贴板
	//---
	// 参数:
	//* str: 内容
	function MHTool_WriteClipboard takes string str returns nothing
	endfunction




