	endfunction

	//---
	// 设置幻象接受伤害
	// 仅对真正的幻象起效
	//---
	// 参数:
	//* u: 单位
	//* value: 接受伤害倍率
	function MHUnit_SetIllusionDamageReceive takes unit u, real value returns boolean
	endfunction

