	//---
	// 获取第一个有效玩家
	// 第一个正在游玩的用户玩家
	function MHPlayer_FirstValid takes nothing returns player
	endfunction

	//---
	// 获取当前选择的单位
	// 返回值是异步的
	function MHPlayer_GetSelectUnit takes nothing returns unit
	endfunction

	//---
	// 获取当前选择的物品
	// 返回值是异步的
	function MHPlayer_GetSelectItem takes nothing returns item
	endfunction

	//---
	// 检查可用性
	//---
	// 参数:
	//* p: 玩家
	//* id: 科技/单位/物品/技能等id
	function MHPlayer_CheckAvailable takes player p, integer id returns boolean
	endfunction

	//---
	// 注册 任意玩家离开游戏 事件
	// 该事件不可注销
	// 包括正常离开和掉线
	//---
	// 参数:
	//* trig: 触发器
	function MHPlayerLeaveEvent_Register takes trigger trig returns boolean
	endfunction

	//---
	// 注册 任意玩家离开游戏 事件 (code)
	// 包括正常离开和掉线
	//---
	// 参数:
	//* callback: 事件回调
	function MHPlayerLeaveEvent_RegisterByCode takes code callback returns boolean
	endfunction

	//---
	// 获取离开原因
	// 响应 任意玩家离开游戏 事件
	//---
	// 返回值:
	//* integer [参考 MemHack::PLAYER_LEAVE_REASON]
	function MHPlayerLeaveEvent_GetReason takes nothing returns integer
	endfunction

	//---
	// 注册 任意玩家黄金变动 事件
	// 该事件不可注销
	//---
	// 参数:
	//* trig: 触发器
