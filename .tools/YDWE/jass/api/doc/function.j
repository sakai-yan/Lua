	// 参数:
	//* msg: 消息文本
	//* dur: 持续时间
	//* color: 颜色 (ARGB16进制颜色代码)
	function MHUI_SendUpKeepMessage takes string msg, real dur, integer color returns boolean
	endfunction

	//---
	// 播放原生音效
