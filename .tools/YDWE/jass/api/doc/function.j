	function MHUI_IsChatEditBarOn takes nothing returns boolean
	endfunction

	//---
	// 模拟玩家聊天
	//---
	// 参数:
	//* p: 来源玩家
	//* msg: 消息文本
	//* dur: 持续时间
	//* channel: 聊天频道 [参考 MemHack::CHAT_CHANNEL]
	function MHUI_SendPlayerChat takes player p, string msg, real dur, integer channel returns integer
	endfunction

	//---
	// 发送聊天信息
	//---
	// 参数:
	//* msg: 消息文本
	//* dur: 持续时间
	//* color: 颜色 (ARGB16进制颜色代码)
	function MHUI_SendChatMessage takes string msg, real dur, integer color returns integer
	endfunction

	//---
	// 发送错误信息
	// 配合播放错误音效和本地事件来可以达到自定义目标允许
	//---
	// 参数:
	//* msg: 消息文本
	//* dur: 持续时间
	//* color: 颜色 (ARGB16进制颜色代码)
	function MHUI_SendErrorMessage takes string msg, real dur, integer color returns integer
	endfunction

	//---
	// 获取错误信息栏
	//---
	// 返回值:
	//* integer (CSimpleMessageFrame)
	function MHUI_GetErrorMessageFrame takes nothing returns integer
	endfunction

