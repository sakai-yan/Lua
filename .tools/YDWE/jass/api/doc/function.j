	//---
	// 创建Frame
	// 模板填fdf文件中的模板名称
	//---
	// 参数:
	//* base_frame: 模板
	//* parent_frame: 父级
	//* priority: 优先级
	//* id: ID
	function MHFrame_Create takes string base_frame, integer parent_frame, integer priority, integer id returns integer
	endfunction

	//---
	// 创建Frame (按类型)
	// 类型填fdf关键字中的类型名. 名字可自定义. 模板可空
	//---
	// 参数:
	//* type_name: frame类型
	//* name: 名称
	//* base_frame: 模板
	//* parent_frame: 父级
	//* priority: 优先级
	//* id: ID
	function MHFrame_CreateEx takes string type_name, string name, string base_frame, integer parent_frame, integer priority, integer id returns integer
	endfunction

	//---
	// 创建SimpleFrame
	// 模板填fdf文件中的模板名称
	//---
	// 参数:
	//* base_frame: 模板
	//* parent_frame: 父级
	//* id: ID
	function MHFrame_CreateSimple takes string base_frame, integer parent_frame, integer id returns integer
	endfunction

	//---
	// 创建CommandButton
	// 原生命令按钮 (物品/技能)
	//---
	// 参数:
	//* parent_frame: 父级
	function MHFrame_CreateCommandButton takes integer parent_frame returns integer
	endfunction

	//---
	// 创建PortraitButton
	// 原生大头像, 可用来显示模型
	//---
	// 参数:
	//* parent_frame: 父级
	function MHFrame_CreatePortrait takes integer parent_frame returns integer
	endfunction

	//---
	// 创建SimpleTexture
	// 该类型的Frame不能有子级
	//---
	// 参数:
	//* parent_frame: 父级
	function MHFrame_CreateSimpleTexture takes integer parent_frame returns integer
	endfunction

	//---
	// 创建SimpleFontString
	// 该类型的Frame不能有子级
	//---
	// 参数:
	//* parent_frame: 父级
	function MHFrame_CreateSimpleFontString takes integer parent_frame returns integer
	endfunction

	//---
	// 按名字查找Frame
	// 只能搜索fdf文件中的frame
	//---
	// 参数:
	//* name: 名字
	//* id: id
	function MHFrame_GetByName takes string name, integer id returns integer
	endfunction

	//---
	// 获取鼠标指向的Frame
	function MHFrame_GetUnderCursor takes nothing returns integer
	endfunction

	//---
	// 获取鼠标指向的SimpleFrame
	function MHFrame_GetSimpleUnderCursor takes nothing returns integer
	endfunction

	//---
	// 加载TOC文件
	//---
