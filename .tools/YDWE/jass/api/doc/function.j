	//---
	// 获取物体整数数据
	// 通过读取slk表格获取物体编辑器中的数据, 同ydlua的slk库
	//---
	// 参数:
	//* table: slk表 [参考 MemHack::SLK_TABLE]
	//* id: 物体ID
	//* field: 属性
	function MHSlk_ReadInt takes integer table, integer id, string field returns integer
	endfunction

	//---
	// 获取物体实数数据
	// 通过读取slk表格获取物体编辑器中的数据, 同ydlua的slk库
	//---
	// 参数:
	//* table: slk表 [参考 MemHack::SLK_TABLE]
	//* id: 物体ID
	//* field: 属性
	function MHSlk_ReadReal takes integer table, integer id, string field returns real
	endfunction

	//---
	// 获取物体布尔值数据
	// 通过读取slk表格获取物体编辑器中的数据, 同ydlua的slk库
	//---
	// 参数:
	//* table: slk表 [参考 MemHack::SLK_TABLE]
	//* id: 物体ID
	//* field: 属性
	function MHSlk_ReadBool takes integer table, integer id, string field returns boolean
	endfunction

	//---
	// 获取物体字符串数据
	// 通过读取slk表格获取物体编辑器中的数据, 同ydlua的slk库
	//---
	// 参数:
	//* table: slk表 [参考 MemHack::SLK_TABLE]
	//* id: 物体ID
	//* field: 属性
	function MHSlk_ReadStr takes integer table, integer id, string field returns string
	endfunction




/*
* ---------------------------------------------------
* string.j
* ---------------------------------------------------
*/

	//---
	// 转换ID为字符串
	// 例如将'AHtb'这样的整数转为字符串"AHtb"
	//---
	// 参数:
	//* id: ID
	function MHString_FromId takes integer id returns string
	endfunction

	//---
	// 转换字符串为ID
	// 例如将字符串"AHtb"转为'AHtb'这样的整数
	//---
	// 参数:
	//* id: ID字符串
	function MHString_ToId takes string id returns integer
	endfunction

	//---
	// 查找字符串
	//---
	// 参数:
	//* str: 字符串
	//* target: 目标字符串
	//* start: 搜索起始位置
	//---
	// 返回值:
	//* integer (-1: 未搜索到)
	function MHString_Find takes string str, string target, integer start returns integer
	endfunction

	//---
	// 反转字符串
	// 不支持中文
	//---
	// 参数:
	//* str: 字符串
	function MHString_Reverse takes string str returns string
	endfunction

	//---
	// 裁剪字符串
	// 去掉两边的空格
	//---
	// 参数:
	//* str: 字符串
	function MHString_Trim takes string str returns string
	endfunction

	//---
	// 裁剪字符串的左侧
	// 去掉左侧的空格
	//---
	// 参数:
	//* str: 字符串
	function MHString_LTrim takes string str returns string
	endfunction

	//---
	// 裁剪字符串的右侧
	// 去掉右侧的空格
	//---
	// 参数:
	//* str: 字符串
	function MHString_RTrim takes string str returns string
	endfunction

	//---
	// 包含字符串
	//---
	// 参数:
	//* str: 字符串
	//* target: 目标字符串
	function MHString_Contain takes string str, string target returns boolean
	endfunction

	//---
	// 包含的字符串数量
	//---
	// 参数:
	//* str: 字符串
	//* target: 目标字符串
	function MHString_GetCount takes string str, string target returns integer
	endfunction

	//---
	// 截取字符串
	//---
	// 参数:
	//* str: 字符串
	//* start: 起始位置
	//* length: 长度 (-1: 截取起始位置到字符串结束位置的所有字符)
	function MHString_Sub takes string str, integer start, integer length returns string
	endfunction

	//---
	// 替换字符串
	//---
	// 参数:
	//* str: 字符串
	//* old_str: 旧字符串
	//* new_str: 新字符串
	function MHString_Replace takes string str, string old_str, string new_str returns string
	endfunction

	//---
	// 分割字符串
	//---
	// 参数:
	//* str: 字符串
	//* delimiter: 分隔符
	//* index: 序号 (从1开始)
	function MHString_Split takes string str, string delimiter, integer index returns string
	endfunction

	//---
	// 正则匹配
	//---
	// 参数:
	//* str: 字符串
	//* regex: 正则表达式
	function MHString_RegexMatch takes string str, string regex returns boolean
	endfunction

	//---
	// 正则搜索
	//---
	// 参数:
	//* str: 字符串
	//* regex: 正则表达式
	//* index: 序号 (从1开始)
	//* capture: 捕获组 (为0时返回整个匹配字符串)
	function MHString_RegexSearch takes string str, string regex, integer index, integer capture returns string
	endfunction

	//---
	// 正则替换
	//---
	// 参数:
	//* str: 字符串
	//* regex: 正则表达式
	//* new_val: 新字符串 (可以用$捕获组序号来引用原字符串中的捕获组)
	function MHString_RegexReplace takes string str, string regex, string new_val returns string
	endfunction

	//---
	// 转换字符串为目标允许
	// 参考物编中目标允许的编写格式
	//---
	// 参数:
	//* str: 目标允许字符串
	//---
	// 返回值:
	//* integer [参考 MemHack::TARGET_ALLOW]
	function MHString_Str2TargetAllow takes string str returns integer
	endfunction

	//---
	// 转换目标允许为字符串
	//---
	// 参数:
	//* allow: 目标允许 [参考 MemHack::TARGET_ALLOW]
	function MHString_TargetAllow2Str takes integer allow returns string
	endfunction

	//---
	// 选取字符串中的UTF8字符做动作
	// 魔兽默认使用utf8字符串
	//---
	// 参数:
	//* str: 字符串
	//* callback: 选取回调
	function MHString_EnumU8Char takes string str, code callback returns string
	endfunction

	//---
	// 获取选取的UTF8字符
	// 指代 MHString_EnumU8Char 中被选取的字符
	function MHString_GetEnumU8Char takes nothing returns string
	endfunction

	//---
	// 获取随机UTF8字符
	// 使用了魔兽的随机数, 不要在异步的逻辑中使用
	//---
	// 参数:
	//* enable_garbled: 允许乱码字符
	function MHString_GetRandomU8Char takes boolean enable_garbled returns string
	endfunction

	//---
	// 异步获取随机UTF8字符
	// 返回值是纯异步的, 不要用于同步的逻辑
	//---
	// 参数:
	//* enable_garbled: 允许乱码字符
	function MHString_GetLocalRandomU8Char takes boolean enable_garbled returns string
	endfunction

	//---
	// 获取字符串的UTF8长度
	// 例如"你好我是丁真"返回6而不是18
	//---
	// 参数:
	//* str: 字符串
	function MHString_GetU8Size takes string str returns integer
	endfunction

