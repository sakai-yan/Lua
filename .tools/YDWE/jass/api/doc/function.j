	//---
	// 获取X坐标
	//---
	// 参数:
	//* eff: 特效
	function MHEffect_GetX takes effect eff returns real
	endfunction

	//---
	// 获取Y坐标
	//---
	// 参数:
	//* eff: 特效
	function MHEffect_GetY takes effect eff returns real
	endfunction

	//---
	// 获取Z坐标
	//---
	// 参数:
	//* eff: 特效
	function MHEffect_GetZ takes effect eff returns real
	endfunction

	//---
	// 设置X坐标
	//---
	// 参数:
	//* eff: 特效
	//* value: X坐标
	function MHEffect_SetX takes effect eff, real value returns boolean
	endfunction

	//---
	// 设置Y坐标
	//---
	// 参数:
	//* eff: 特效
	//* value: Y坐标
	function MHEffect_SetY takes effect eff, real value returns boolean
	endfunction

	//---
	// 设置Z坐标
	//---
	// 参数:
	//* eff: 特效
	//* value: Z坐标
	function MHEffect_SetZ takes effect eff, real value returns boolean
	endfunction

	//---
	// 设置三轴坐标
	//---
	// 参数:
	//* eff: 特效
	//* x: 三轴坐标
	//* y: y
	//* z: z
	function MHEffect_SetPosition takes effect eff, real x, real y, real z returns boolean
	endfunction

	//---
	// 设置绕X轴转角
	// 多次调用会累加
	//---
	// 参数:
	//* eff: 特效
	//* deg: 绕X轴转角
	function MHEffect_SetRoll takes effect eff, real deg returns boolean
	endfunction

	//---
	// 设置绕Y轴转角
	// 多次调用会累加
	//---
	// 参数:
	//* eff: 特效
	//* deg: 绕Y轴转角
	function MHEffect_SetPitch takes effect eff, real deg returns boolean
	endfunction

	//---
	// 设置绕Z轴转角
	// 多次调用会累加
	//---
	// 参数:
	//* eff: 特效
	//* deg: 绕Z轴转角
	function MHEffect_SetYaw takes effect eff, real deg returns boolean
	endfunction

	//---
	// 设置自转角
	// 多次调用会累加. 右手螺旋定则
	//---
	// 参数:
	//* eff: 特效
	//* deg: 自转角
	function MHEffect_Rotate takes effect eff, real deg returns boolean
	endfunction

	//---
	// 获取自转角
	//---
	// 参数:
	//* eff: 特效
	function MHEffect_Rotation takes effect eff returns real
	endfunction

	//---
	// 设置方向向量
	// 向量形式
	// (1, 0, 0)表示初始朝向 (正东)
	// 不需要归一化
	//---
	// 参数:
	//* eff: 特效
	//* xv: 方向向量
	//* yv: yv
	//* zv: zv
	function MHEffect_SetVector takes effect eff, real xv, real yv, real zv returns boolean
	endfunction

	//---
	// 获取方向向量X坐标
	// 向量形式. (1, 0, 0) 表示初始方向 (正东)
	// 已归一化
	//---
	// 参数:
	//* eff: 特效
	function MHEffect_GetVectorX takes effect eff returns real
	endfunction

	//---
	// 获取方向向量Y坐标
	// 向量形式. (1, 0, 0) 表示初始方向 (正东)
	// 已归一化
	//---
	// 参数:
	//* eff: 特效
	function MHEffect_GetVectorY takes effect eff returns real
	endfunction

	//---
	// 获取方向向量Z坐标
	// 向量形式. (1, 0, 0) 表示初始方向 (正东)
	// 已归一化
	//---
	// 参数:
	//* eff: 特效
	function MHEffect_GetVectorZ takes effect eff returns real
	endfunction

	//---
	// 设置朝向
	// 直接让特效指向目标点
	//---
	// 参数:
	//* eff: 特效
	//* target_x: 目标点X坐标
	//* target_y: 目标点Y坐标
	//* target_z: 目标点Z坐标
	function MHEffect_Towards takes effect eff, real target_x, real target_y, real target_z returns boolean
	endfunction

	//---
	// 镜像操作
	//---
	// 参数:
	//* eff: 特效
	//* axis: 镜像轴 [参考 MemHack::MIRROR_AXIS]
	function MHEffect_SetMirror takes effect eff, integer axis returns boolean
	endfunction

	//---
	// 设置缩放
	//---
	// 参数:
