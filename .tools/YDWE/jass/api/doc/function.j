	//---
	// 设置漂浮文字字体
	//---
	// 参数:
	//* path: 字体文件
	//* flag: 文字类型 [参考 MemHack::TEXT_TYPE]
	function MHTextTag_SetFont takes string path, integer flag returns boolean
	endfunction

	//---
	// 设置漂浮文字数量限制
	// 游戏默认限制为100, 只能增加不能减少
	//---
	// 参数:
	//* limit: 数量限制
	function MHTextTag_SetLimit takes integer limit returns boolean
	endfunction

	//---
	// 获取漂浮文字文本
	//---
	// 参数:
	//* tag: 漂浮文字
	function MHTextTag_GetText takes texttag tag returns string
	endfunction

	//---
	// 设置透明度
	//---
	// 参数:
	//* tag: 漂浮文字
	//* alpha: 透明度 (0~255)
	function MHTextTag_SetAlpha takes texttag tag, integer alpha returns boolean
	endfunction

	//---
	// 设置阴影颜色
	//---
	// 参数:
	//* tag: 漂浮文字
	//* color: 颜色 (ARGB16进制颜色代码)
	function MHTextTag_SetShadowColor takes texttag tag, integer color returns boolean
	endfunction




