	// 获取移动类型
	//---
	// 参数:
	//* u: 单位
	function MHUnit_GetMoveType takes unit u returns integer
	endfunction

	//---
	// 设置移动类型
	//---
	// 参数:
	//* u: 单位
	//* value: 移动类型 [参考 MemHack::UNIT_MOVE_TYPE]
	function MHUnit_SetMoveType takes unit u, integer value returns boolean
	endfunction

