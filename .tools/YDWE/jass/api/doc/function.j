	// 设置队伍颜色
	//---
	// 参数:
	//* eff: 特效
	//* color: 队伍颜色 [参考 commom::playercolor]
	function MHEffect_SetTeamColor takes effect eff, playercolor color returns boolean
	endfunction

	//---
	// 设置队伍光晕
	//---
	// 参数:
	//* eff: 特效
	//* glow: 队伍光晕 [参考 commom::playercolor]
	function MHEffect_SetTeamGlow takes effect eff, playercolor glow returns boolean
	endfunction

