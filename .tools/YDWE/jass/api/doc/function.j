	// 返回值:
	//* real (0~1)
	function MHUnit_GetAnimationProgress takes unit u returns real
	endfunction

	//---
	// 设置当前动画进度
	//---
	// 参数:
	//* u: 单位
	//* progress: 进度 (0~1)
	function MHUnit_SetAnimationProgress takes unit u, real progress returns integer
	endfunction

	//---
	// 变身
	//---
	// 参数:
	//* u: 单位
	//* uid: 目标单位类型
	function MHUnit_Morph takes unit u, integer uid returns integer
	endfunction

