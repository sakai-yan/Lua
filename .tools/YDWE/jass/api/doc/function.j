	//---
	// 设置数值
	// 进度条之类的数值, 取值范围0~1
	// 仅支持CSlider, CSimpleStatusBar和CStatBar
	//---
	// 参数:
	//* frame: frame
	//* value: 数值
	function MHFrame_SetValue takes integer frame, real value returns boolean
	endfunction

	//---
	// 获取数值
	// 进度条之类的数值, 取值范围0~1
	// 仅支持CSlider, CSimpleStatusBar和CStatBar
	//---
	// 参数:
	//* frame: frame
	function MHFrame_GetValue takes integer frame returns real
	endfunction

	//---
	// 设置数值限制
	// 进度条之类的数值
	// 仅支持CSlider, CSimpleStatusBar和CStatBar
	//---
	// 参数:
	//* frame: frame
	//* max_limit: 最大数值
	//* min_limit: 最小数值
	function MHFrame_SetLimit takes integer frame, real max_limit, real min_limit returns boolean
	endfunction

	//---
	// 添加边框
	// 仅支持CSimpleFrame和CBackdropFrame
	//---
	// 参数:
	//* frame: frame
	//* border_file: 边框贴图
	//* background_file: 背景贴图
	//* border_flag: 边框标志 [参考 MemHack::BORDER_FLAG]
	//* border_size: 边框尺寸
	//* padding: 填充尺寸
	//* is_tile: 是否平铺
	function MHFrame_AddBorder takes integer frame, string border_file, string background_file, integer border_flag, real border_size, real padding, boolean is_tile returns boolean
	endfunction

	//---
	// 限制鼠标
	//---
	// 参数:
	//* frame: frame
	//* is_lock: 是否限制
	function MHFrame_CageMouse takes integer frame, boolean is_lock returns boolean
	endfunction

	//---
	// 点击Frame
	//---
	// 参数:
	//* frame: frame
	function MHFrame_Click takes integer frame returns boolean
	endfunction

	//---
	// 删除Frame
	//---
	// 参数:
	//* frame: frame
	function MHFrame_Destroy takes integer frame returns boolean
	endfunction

	//---
	// 获取贴图 (CSimpleButton)
	// 返回一个CSimpleTexture
	//---
	// 参数:
	//* button_frame: 贴图
	//* state: 状态 [参考 MemHack::SIMPLE_BUTTON_STATE]
	function MHFrame_GetSimpleButtonTexture takes integer button_frame, integer state returns integer
	endfunction

	//---
	// 获取附加显示物 (CSimpleButton)
	// 指鼠标指向按钮时附加显示的frame, 例如鼠标指向顶部按钮时会显示其高光贴图
	//---
	// 参数:
	//* button_frame: frame
	function MHFrame_GetSimpleButtonAdditiveFrame takes integer button_frame returns integer
	endfunction

	//---
	// 设置状态 (CSimpleButton)
	// 仅支持CSimpleButton
	//---
	// 参数:
	//* button_frame: frame
	//* state: 状态 [参考 MemHack::SIMPLE_BUTTON_STATE]
	function MHFrame_SetSimpleButtonState takes integer button_frame, integer state returns boolean
	endfunction

	//---
	// 获取混合模式 (CSimpleTexture)
	//---
	// 参数:
	//* texture_frame: 混合模式
	//---
	// 返回值:
	//* blendmode [参考 common::blendmode]
	function MHFrame_GetSimpleTextureBlendMode takes integer texture_frame returns blendmode
	endfunction

	//---
	// 获取混合模式 (整数) (CSimpleTexture)
	//---
	// 参数:
	//* texture_frame: 混合模式
	//---
	// 返回值:
	//* integer [参考 common::blendmode]
	function MHFrame_GetSimpleTextureBlendModeInt takes integer texture_frame returns integer
	endfunction

	//---
	// 设置混合模式 (CSimpleTexture)
	// 仅支持CSimpleButton
	//---
	// 参数:
	//* texture_frame: 设置
	//* blend_mode: 混合模式 [参考 common::blendmode]
	function MHFrame_SetSimpleTextureBlendMode takes integer texture_frame, blendmode blend_mode returns boolean
	endfunction

	//---
	// 添加文本 (CTextArea)
	// 仅支持CTextArea
	//---
	// 参数:
	//* text_area: frame
	//* text: 文本
	function MHFrame_AddTextAreaText takes integer text_area, string text returns integer
	endfunction

	//---
	// 获取模型X坐标
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	function MHFrame_GetSpriteX takes integer frame returns real
	endfunction

	//---
	// 获取模型Y坐标
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	function MHFrame_GetSpriteY takes integer frame returns real
	endfunction

	//---
	// 获取模型Z坐标
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	function MHFrame_GetSpriteZ takes integer frame returns real
	endfunction

	//---
	// 设置模型X坐标
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* x: x坐标
	function MHFrame_SetSpriteX takes integer frame, real x returns boolean
	endfunction

	//---
	// 设置模型Y坐标
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* y: y坐标
	function MHFrame_SetSpriteY takes integer frame, real y returns boolean
	endfunction

	//---
	// 设置模型Z坐标
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* z: z坐标
	function MHFrame_SetSpriteZ takes integer frame, real z returns boolean
	endfunction

	//---
	// 设置模型三轴坐标
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* x: x坐标
	//* y: y坐标
	//* z: z坐标
	function MHFrame_SetSpritePosition takes integer frame, real x, real y, real z returns boolean
	endfunction

	//---
	// 设置模型横滚角
	// 绕X轴转角
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* roll: 横滚角 (角度)
	function MHFrame_SetSpriteRoll takes integer frame, real roll returns boolean
	endfunction

	//---
	// 设置模型俯仰角
	// 绕Y轴转角
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* pitch: 俯仰角 (角度)
	function MHFrame_SetSpritePitch takes integer frame, real pitch returns boolean
	endfunction

	//---
	// 设置模型偏航角
	// 绕Z轴转角
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* yaw: 偏航角
	function MHFrame_SetSpriteYaw takes integer frame, real yaw returns boolean
	endfunction

	//---
	// 设置模型缩放
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* sprite_frame: frame
	//* scale: 缩放大小
	function MHFrame_SetSpriteScale takes integer sprite_frame, real scale returns boolean
	endfunction

	//---
	// 设置模型三轴缩放
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* sprite_frame: frame
	//* x_scale: x轴缩放
	//* y_scale: y轴缩放
	//* z_scale: z轴缩放
	function MHFrame_SetSpriteScaleEx takes integer sprite_frame, real x_scale, real y_scale, real z_scale returns boolean
	endfunction

	//---
	// 设置模型颜色
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* color: 颜色 (ARGB16进制颜色代码)
	function MHFrame_SetSpriteColor takes integer frame, real color returns boolean
	endfunction

	//---
	// 设置模型动画
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* anim: 动画
	//* attach: 附加动画名
	function MHFrame_SetSpriteAnimation takes integer frame, string anim, string attach returns boolean
	endfunction

	//---
	// 设置模型动画进度
	// 取值范围0~1
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* progress: 进度
	function MHFrame_SetSpriteAnimationProgress takes integer frame, real progress returns boolean
	endfunction

	//---
	// 获取模型动画进度
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//---
	// 返回值:
	//* real (0~1)
	function MHFrame_GetSpriteAnimationProgress takes integer frame returns real
	endfunction

	//---
	// 设置模型贴图
	// 仅对CSpriteFrame和CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* texture: 贴图路径
	//* id: 可替换贴图ID
	function MHFrame_SetSpriteTexture takes integer frame, string texture, integer id returns boolean
	endfunction

	//---
	// 设置肖像模型
	// 仅对CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* model: 模型路径
	//* color: 队伍颜色 [参考 commom::playercolor]
	function MHFrame_SetPortraitModel takes integer frame, string model, playercolor color returns boolean
	endfunction

	//---
	// 设置肖像镜头位置
	// 仅对CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* x: 镜头x坐标
	//* y: 镜头y坐标
	//* z: 镜头z坐标
	function MHFrame_SetPortraitCameraPosition takes integer frame, real x, real y, real z returns boolean
	endfunction

	//---
	// 设置肖像镜头焦点
	// 仅对CPortraitButton有效
	//---
	// 参数:
	//* frame: frame
	//* x: 焦点x坐标
	//* y: 焦点y坐标
	//* z: 焦点z坐标
	function MHFrame_SetPortraitCameraFocus takes integer frame, real x, real y, real z returns boolean
	endfunction

	//---
	// 注册 本地Frame 事件
	// 同一个frame的同一事件只能注册一次
	// 该事件不可注销, 异步事件仅支持逆天触发器!
	//---
	// 参数:
	//* trig: 触发器
	//* frame: frame
	//* event_id: 事件ID [参考 MemHack::EVENT_ID]
	function MHFrameEvent_Register takes trigger trig, integer frame, integer event_id returns integer
	endfunction

	//---
	// 注册 本地Frame 事件 (code)
	// 同一个frame的同一事件只能注册一次
	//---
	// 参数:
	//* frame: frame
	//* event_id: 事件ID [参考 MemHack::EVENT_ID]
	//* callback: 事件回调
	function MHFrameEvent_RegisterByCode takes integer frame, integer event_id, code callback returns integer
	endfunction

	//---
	// 获取滚动值
	// 响应 鼠标滚动Frame 事件
	function MHFrameScrollEvent_GetValue takes nothing returns integer
	endfunction

	//---
	// 设置滚动值
	// 响应 鼠标滚动Frame 事件
	//---
	// 参数:
	//* value: 滚动值
	function MHFrameScrollEvent_SetValue takes integer value returns boolean
	endfunction

	//---
	// 设置Frame屏幕限制
	//---
	// 参数:
	//* is_limit: 是否限制在屏幕内
	function MHFrame_SetScreenLimit takes boolean is_limit returns boolean
	endfunction

	//---
	// 绑定到单位头顶
	//---
	// 参数:
	//* frame: frame
	//* u: 目标单位
	function MHFrame_BindToUnit takes integer frame, unit u returns boolean
	endfunction

	//---
	// 取消绑定
	//---
	// 参数:
	//* frame: 已绑定的frame
	function MHFrame_UnbindFrame takes integer frame returns boolean
	endfunction

	//---
	// 取消绑定
	//---
	// 参数:
	//* u: 被绑定的单位
	function MHFrame_UnbindUnit takes unit u returns boolean
	endfunction




/*
* ---------------------------------------------------
* game.j
* ---------------------------------------------------
*/

	//---
	// 获取当前内存使用量
	//---
	// 返回值:
	//* integer (bytes)
	function MHGame_GetMemoryUsage takes nothing returns integer
	endfunction

	//---
	// 获取最大内存使用量
	//---
	// 返回值:
	//* integer (bytes)
	function MHGame_GetMemoryMaxUsage takes nothing returns integer
	endfunction

	//---
	// 获取游戏版本
	function MHGame_GetGameVersion takes nothing returns string
	endfunction

	//---
	// 获取插件版本
	function MHGame_GetPluginVersion takes nothing returns string
	endfunction

	//---
	// 获取地图名字
	function MHGame_GetMapName takes nothing returns string
	endfunction

	//---
	// 获取地图描述
	function MHGame_GetMapDescription takes nothing returns string
	endfunction

	//---
	// 获取游戏设置
	// 返回值是异步的
	//---
	// 参数:
	//* option: 游戏设置 [参考 MemHack::GAME_OPTION]
	function MHGame_GetOption takes integer option returns integer
	endfunction

	//---
	// 获取作弊标志
	//---
	// 返回值:
	//* integer (Bitset) [参考 MemHack::CHEAT_FLAG]
	function MHGame_GetCheatFlag takes nothing returns integer
	endfunction

	//---
	// 设置作弊标志
	// 局域网下依然有效
	//---
	// 参数:
	//* flag: 作弊标志 (Bitset) [参考 MemHack::CHEAT_FLAG]
	function MHGame_SetCheatFlag takes integer flag returns integer
	endfunction

	//---
	// 判定作弊标志
	//---
	// 参数:
	//* flag: 作弊标志 (Bitset) [参考 MemHack::CHEAT_FLAG]
	function MHGame_IsCheatFlag takes integer flag returns boolean
	endfunction

	//---
	// 获取地图路径
	//---
	// 返回值:
	//* string (相对路径)
	function MHGame_GetMapPath takes nothing returns string
	endfunction

	//---
	// 检查继承关系
	// 例如 '+w3u'(单位) 继承自 '+w3w'(Widget)
	// 所有的被动技能都继承自 'APas'
	//---
	// 参数:
	//* child_id: 子ID
	//* parent_id: 父ID
	function MHGame_CheckInherit takes integer child_id, integer parent_id returns boolean
	endfunction

	//---
	// 获取code
	//---
	// 参数:
	//* func_name: 函数名
	function MHGame_GetCode takes string func_name returns code
	endfunction

	//---
	// 执行函数
	// 执行一个jass函数, 可异步
	//---
	// 参数:
	//* c: 函数 (不可有参数)
	function MHGame_ExecuteCode takes code c returns integer
	endfunction

	//---
	// 执行函数
	// 执行一个jass函数, 可异步
	//---
	// 参数:
	//* c: 函数 (不可有参数, C2I后的整数)
	function MHGame_ExecuteCodeEx takes integer c returns integer
	endfunction

	//---
	// 执行函数
	// 执行一个jass函数, 可异步
	//---
	// 参数:
	//* func_name: 函数名 (不可有参数)
	function MHGame_ExecuteFunc takes string func_name returns integer
	endfunction

	//---
	// 删除模型缓存
	//---
	// 参数:
	//* model_path: 模型路径
	function MHGame_RemoveModelCache takes string model_path returns boolean
	endfunction

	//---
	// 获取Z轴坐标
	// 注意可通行可破坏物会因为当前播放的动画改变所在点Z轴高度, 不同客户端之间可破坏物动画不同步
	//---
	// 参数:
	//* x: 坐标x
	//* y: 坐标y
	function MHGame_GetAxisZ takes real x, real y returns real
	endfunction

	//---
	// 是局域网游戏
	function MHGame_IsLan takes nothing returns boolean
	endfunction

	//---
	// 是录像模式
	// 不能判定网易的录像
	function MHGame_IsReplay takes nothing returns boolean
	endfunction

	//---
	// 游戏时间戳
	// 游戏开始到现在经过的时间, 最小刻度为5ms
	// 同步的
	//---
	// 返回值:
	//* integer (毫秒)
	function MHGame_GetGameStamp takes nothing returns integer
	endfunction

	//---
	// 本地时间戳
	// 返回值是纯异步的不要用于同步逻辑
	// 由于jass使用的有符号整数, 会有Y2K38问题 (即该时间戳在2038年1月19日 03:14:07 UTC后失效)
	//---
	// 返回值:
	//* integer (秒)
	function MHGame_GetLocalStamp takes nothing returns integer
	endfunction

	//---
	// 注册 游戏开始 事件
	// 该事件不可注销
	// 指所有玩家加载完毕进入地图的一瞬间
	//---
	// 参数:
	//* trig: 触发器
	function MHGameStartEvent_Register takes trigger trig returns boolean
	endfunction

	//---
	// 注册 游戏开始 事件 (code)
	// 指所有玩家加载完毕进入地图的一瞬间
	//---
	// 参数:
	//* callback: 事件回调
	function MHGameStartEvent_RegisterByCode takes code callback returns boolean
	endfunction

	//---
	// 注册 游戏Tick 事件
	// 该事件不可注销
	// 魔兽的同步帧
	//---
	// 参数:
	//* trig: 触发器
	function MHGameTickEvent_Register takes trigger trig returns boolean
	endfunction

	//---
	// 注册 游戏Tick 事件 (code)
	// 魔兽的同步帧
	//---
	// 参数:
	//* callback: 事件回调
	function MHGameTickEvent_RegisterByCode takes code callback returns boolean
	endfunction

	//---
	// 获取同步帧经过的时间戳
	// 响应 游戏Tick 事件
	function MHGameTickEvent_GetStamp takes nothing returns integer
	endfunction

	//---
	// 注册 游戏停止 事件
	// 该事件不可注销
	// 异步事件仅支持逆天触发器
	//---
	// 参数:
	//* trig: 触发器
	function MHGameStopEvent_Register takes trigger trig returns boolean
	endfunction

	//---
	// 注册 游戏停止 事件 (code)
	// 异步回调
	//---
	// 参数:
	//* callback: 事件回调
	function MHGameStopEvent_RegisterByCode takes code callback returns boolean
	endfunction

	//---
	// 注册 游戏退出 事件
	// 该事件不可注销
	// 异步事件仅支持逆天触发器
	//---
	// 参数:
	//* trig: 触发器
	function MHGameExitEvent_Register takes trigger trig returns boolean
	endfunction

	//---
	// 注册 游戏退出 事件 (code)
	// 异步回调
	//---
	// 参数:
	//* callback: 事件回调
	function MHGameExitEvent_RegisterByCode takes code callback returns boolean
	endfunction

	//---
	// 禁止游戏暂停
	//---
	// 参数:
	//* is_disable: 是否禁止
	function MHGame_DisablePause takes boolean is_disable returns nothing
	endfunction




