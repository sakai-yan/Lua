<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ── Deep Navy Background ── -->
  <Color x:Key="BgDeepVal">#0B0F1A</Color>
  <Color x:Key="BgSurfaceVal">#111827</Color>
  <Color x:Key="BgCardVal">#1A2235</Color>
  <Color x:Key="BgElevatedVal">#1E293B</Color>

  <!-- ── Accent: Electric Blue ── -->
  <Color x:Key="AccentColorVal">#3B82F6</Color>
  <Color x:Key="AccentBrightVal">#60A5FA</Color>
  <Color x:Key="AccentGlowVal">#1D4ED8</Color>
  <Color x:Key="AccentSoftVal">#1E3A5F</Color>

  <!-- ── CTA: Cyan ── -->
  <Color x:Key="CtaColorVal">#06B6D4</Color>
  <Color x:Key="CtaSoftVal">#164E63</Color>

  <!-- ── Semantic ── -->
  <Color x:Key="SuccessColorVal">#10B981</Color>
  <Color x:Key="SuccessSoftVal">#064E3B</Color>
  <Color x:Key="WarningColorVal">#F59E0B</Color>
  <Color x:Key="WarningSoftVal">#451A03</Color>
  <Color x:Key="DangerColorVal">#F87171</Color>
  <Color x:Key="DangerSoftVal">#450A0A</Color>
  <Color x:Key="PurpleColorVal">#A78BFA</Color>
  <Color x:Key="PurpleSoftVal">#2E1065</Color>
  <Color x:Key="OrangeColorVal">#FB923C</Color>
  <Color x:Key="OrangeSoftVal">#431407</Color>

  <!-- ── Text ── -->
  <Color x:Key="TextPrimaryVal">#F1F5F9</Color>
  <Color x:Key="TextSecondaryVal">#94A3B8</Color>
  <Color x:Key="TextMutedVal">#475569</Color>

  <!-- ── Border / Glass ── -->
  <Color x:Key="BorderSubtleVal">#1E3A5F</Color>
  <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleVal}"/>
  <Color x:Key="GlassFillVal">#CC1A2235</Color>
  <Color x:Key="GlassBorderVal">#403B82F6</Color>
  <Color x:Key="GlowBlueVal">#203B82F6</Color>

  <!-- ── Brushes ── -->
  <SolidColorBrush x:Key="BgDeepBrush"     Color="{StaticResource BgDeepVal}"/>
  <SolidColorBrush x:Key="BgSurfaceBrush"  Color="{StaticResource BgSurfaceVal}"/>
  <SolidColorBrush x:Key="BgCardBrush"     Color="{StaticResource BgCardVal}"/>
  <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevatedVal}"/>

  <SolidColorBrush x:Key="AccentBrush"     Color="{StaticResource AccentColorVal}"/>
  <SolidColorBrush x:Key="AccentBrightBrush" Color="{StaticResource AccentBrightVal}"/>
  <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftVal}"/>
  <SolidColorBrush x:Key="CtaBrush"        Color="{StaticResource CtaColorVal}"/>
  <SolidColorBrush x:Key="CtaSoftBrush"    Color="{StaticResource CtaSoftVal}"/>

  <SolidColorBrush x:Key="SuccessBrush"    Color="{StaticResource SuccessColorVal}"/>
  <SolidColorBrush x:Key="SuccessSoftBrush" Color="{StaticResource SuccessSoftVal}"/>
  <SolidColorBrush x:Key="WarningBrush"    Color="{StaticResource WarningColorVal}"/>
  <SolidColorBrush x:Key="WarningSoftBrush" Color="{StaticResource WarningSoftVal}"/>
  <SolidColorBrush x:Key="DangerBrush"     Color="{StaticResource DangerColorVal}"/>
  <SolidColorBrush x:Key="DangerSoftBrush" Color="{StaticResource DangerSoftVal}"/>
  <SolidColorBrush x:Key="PurpleBrush"     Color="{StaticResource PurpleColorVal}"/>
  <SolidColorBrush x:Key="PurpleSoftBrush" Color="{StaticResource PurpleSoftVal}"/>
  <SolidColorBrush x:Key="OrangeBrush"     Color="{StaticResource OrangeColorVal}"/>
  <SolidColorBrush x:Key="OrangeSoftBrush" Color="{StaticResource OrangeSoftVal}"/>

  <SolidColorBrush x:Key="TitleBrush"      Color="{StaticResource TextPrimaryVal}"/>
  <SolidColorBrush x:Key="BodyBrush"       Color="{StaticResource TextSecondaryVal}"/>
  <SolidColorBrush x:Key="MutedBrush"      Color="{StaticResource TextMutedVal}"/>

  <!-- Card / Glass -->
  <SolidColorBrush x:Key="CardFillBrush"   Color="{StaticResource GlassFillVal}"/>
  <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource GlassBorderVal}"/>
  <Color x:Key="CardShadowColor">#803B82F6</Color>

  <!-- Gradients -->
  <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#1D4ED8" Offset="0"/>
    <GradientStop Color="#06B6D4" Offset="1"/>
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="BgGradientBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="#0B0F1A" Offset="0"/>
    <GradientStop Color="#0F172A" Offset="0.5"/>
    <GradientStop Color="#0B1120" Offset="1"/>
  </LinearGradientBrush>

  <!-- Log -->
  <SolidColorBrush x:Key="LogPrefixBrush" Color="{StaticResource AccentBrightVal}"/>
  <SolidColorBrush x:Key="BakPrefixBrush" Color="{StaticResource SuccessColorVal}"/>
  <SolidColorBrush x:Key="ErrPrefixBrush" Color="{StaticResource DangerColorVal}"/>

  <!-- Compat aliases -->
  <SolidColorBrush x:Key="FormBackBrush"          Color="{StaticResource BgDeepVal}"/>
  <SolidColorBrush x:Key="PrimaryActionBrush"     Color="{StaticResource CtaColorVal}"/>
  <SolidColorBrush x:Key="PrimaryActionSoftBrush" Color="{StaticResource CtaSoftVal}"/>
  <SolidColorBrush x:Key="AccentSoftLightBrush"   Color="#1E3A5F"/>

</ResourceDictionary>
