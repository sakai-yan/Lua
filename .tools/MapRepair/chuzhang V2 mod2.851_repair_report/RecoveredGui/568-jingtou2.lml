conditions:
  -
actions:
  - CustomScriptCode (const:call RemoveUnit(udg_CCC[GetConvertedPlayerId(GetTriggerPlayer())]))
  - CustomScriptCode (const:set udg_CCC[GetConvertedPlayerId(GetTriggerPlayer())]=udg_HERO[GetConvertedPlayerId(GetTriggerPlayer())])
  - CustomScriptCode (const:if(Trig_jingtou2_Func003C())then)
  - CustomScriptCode (const:call SetCameraTargetControllerNoZForPlayer(GetTriggerPlayer(),udg_CCC[GetConvertedPlayerId(GetTriggerPlayer())],0,0,false))
  - CustomScriptCode (const:set udg_camera_T[GetConvertedPlayerId(GetTriggerPlayer())]=true)
  - CustomScriptCode (const:else)
  - ResetToGameCameraForPlayer (call:GetTriggerPlayer, const:0)
  - CustomScriptCode (const:set udg_camera_T[GetConvertedPlayerId(GetTriggerPlayer())]=false)
  - CustomScriptCode (const:endif)
