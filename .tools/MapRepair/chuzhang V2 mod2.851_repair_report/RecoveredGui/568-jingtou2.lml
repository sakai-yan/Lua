name: jingtou2
type: gui
category: 0
enabled: true
runOnMapInit: false
events:
  - TriggerRegisterPlayerChatEvent (preset:Player00, const:英雄模式, preset:ChatMatchTypeExact)
  - TriggerRegisterPlayerChatEvent (preset:Player01, const:英雄模式, preset:ChatMatchTypeExact)
  - TriggerRegisterPlayerChatEvent (preset:Player02, const:英雄模式, preset:ChatMatchTypeExact)
