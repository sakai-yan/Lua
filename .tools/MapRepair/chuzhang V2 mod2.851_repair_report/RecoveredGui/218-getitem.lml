name: getitem
type: gui
category: 0
enabled: true
runOnMapInit: false
events:
  - TriggerRegisterAnyUnitEventBJ (preset:PlayerUnitEventIssued_Unit_Order)
conditions:
  -
actions:
  - CustomScriptCode (const:if not Trig_getitem_Conditions() then)
  - CustomScriptCode (const:return)
  - CustomScriptCode (const:endif)
  - CustomScriptCode (const:call Trig_getitem_Actions())
