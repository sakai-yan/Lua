  - TriggerRegisterPlayerChatEvent (preset:Player05, const:YM, preset:ChatMatchTypeSubstring)
  - TriggerRegisterPlayerChatEvent (preset:Player06, const:YM, preset:ChatMatchTypeSubstring)
  - TriggerRegisterPlayerChatEvent (preset:Player07, const:YM, preset:ChatMatchTypeSubstring)
  - TriggerRegisterPlayerChatEvent (preset:Player08, const:YM, preset:ChatMatchTypeSubstring)
  - TriggerRegisterPlayerChatEvent (preset:Player09, const:YM, preset:ChatMatchTypeSubstring)
  - TriggerRegisterPlayerChatEvent (preset:Player10, const:YM, preset:ChatMatchTypeSubstring)
