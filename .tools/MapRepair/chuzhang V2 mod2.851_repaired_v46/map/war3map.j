    function Light___FilterFunc takes nothing returns boolean
        local unit u= GetFilterUnit()
        local boolean ok= GetWidgetLife(u) > .405 and IsUnitEnemy(u , GetOwningPlayer(GetTriggerUnit()))
        set u = null
        return ok
    endfunction

     function Light___Light_Conditions takes nothing returns boolean
          return GetSpellAbilityId() == Light___SPELL_ID
     endfunction

     function Light___Light_Actions takes nothing returns nothing
          local unit C= GetSpellAbilityUnit()
          local location CL= GetUnitLoc(C)
          local real CR= GetUnitX(C)
          local real RC= GetUnitY(C)
          local rect R= RectFromCenterSizeBJ(CL , Light___Real6 , Light___Real6)
          local player Y= GetOwningPlayer(C)
          local integer Level= GetUnitAbilityLevel(C , Light___SPELL_ID)
          local integer Index
          local real X1= CR + Light___Real5 * Cos(Light___Real1 * bj_DEGTORAD)
          local real X2= CR + Light___Real5 * Cos(Light___Real2 * bj_DEGTORAD)
          local real X3= CR + Light___Real5 * Cos(Light___Real3 * bj_DEGTORAD)
          local real X4= CR + Light___Real5 * Cos(Light___Real4 * bj_DEGTORAD)
          local real Y1= RC + Light___Real5 * Sin(Light___Real1 * bj_DEGTORAD)
          local real Y2= RC + Light___Real5 * Sin(Light___Real2 * bj_DEGTORAD)
          local real Y3= RC + Light___Real5 * Sin(Light___Real3 * bj_DEGTORAD)
          local real Y4= RC + Light___Real5 * Sin(Light___Real4 * bj_DEGTORAD)
          local real Z1= GetUnitFlyHeight(C) + Light___Real7
          local real Z2= GetUnitFlyHeight(C) + Light___Real8
          local lightning array L
          local real M1
          local real M2
          local real X5
          local real Y5
          local integer P=1
          local real Damage= I2R(GetHeroInt(C,true))*10 + I2R(GetHeroAgi(C,true))*10 + I2R(GetHeroStr(C,true))*50 + GetHeroLevel(C)*100 + GetUnitStateSwap(UNIT_STATE_MAX_LIFE,C)*20 + GetUnitStateSwap(UNIT_STATE_MAX_MANA,C)*20
              /////  //jss3   Light

          local location M
          local integer PE=30 * Level
          local unit U
          local group G= CreateGroup()
          set L[0]=AddLightning(Light___Lightning , true , X1 , Y1 , X2 , Y2)
          set L[1]=AddLightning(Light___Lightning , true , X2 , Y2 , X3 , Y3)
          set L[2]=AddLightning(Light___Lightning , true , X3 , Y3 , X4 , Y4)
          set L[3]=AddLightning(Light___Lightning , true , X4 , Y4 , X1 , Y1)
          set L[4]=AddLightningEx(Light___Lightning , true , X1 , Y1 , 0 , X1 , Y1 , Z1)
          set L[5]=AddLightningEx(Light___Lightning , true , X2 , Y2 , 0 , X2 , Y2 , Z1)
          set L[6]=AddLightningEx(Light___Lightning , true , X3 , Y3 , 0 , X3 , Y3 , Z1)
          set L[7]=AddLightningEx(Light___Lightning , true , X4 , Y4 , 0 , X4 , Y4 , Z1)
          set L[8]=AddLightningEx(Light___Lightning , true , X1 , Y1 , Z1 , X2 , Y2 , Z1)
          set L[9]=AddLightningEx(Light___Lightning , true , X2 , Y2 , Z1 , X3 , Y3 , Z1)
          set L[10]=AddLightningEx(Light___Lightning , true , X3 , Y3 , Z1 , X4 , Y4 , Z1)
          set L[11]=AddLightningEx(Light___Lightning , true , X4 , Y4 , Z1 , X1 , Y1 , Z1)
          set L[12]=AddLightningEx(Light___Lightning , true , X1 , Y1 , Z1 , CR , RC , Z2)
          set L[13]=AddLightningEx(Light___Lightning , true , X2 , Y2 , Z1 , CR , RC , Z2)
          set L[14]=AddLightningEx(Light___Lightning , true , X3 , Y3 , Z1 , CR , RC , Z2)
          set L[15]=AddLightningEx(Light___Lightning , true , X4 , Y4 , Z1 , CR , RC , Z2)
          set L[16]=AddLightningEx(Light___Lightning , true , X1 , Y1 , 0 , CR , RC , Z2)
          set L[17]=AddLightningEx(Light___Lightning , true , X2 , Y2 , 0 , CR , RC , Z2)
          set L[18]=AddLightningEx(Light___Lightning , true , X3 , Y3 , 0 , CR , RC , Z2)
          set L[19]=AddLightningEx(Light___Lightning , true , X4 , Y4 , 0 , CR , RC , Z2)
          call GroupEnumUnitsInRange(G , CR , RC , Light___Real6 , Light___BOOL)
          loop
               exitwhen P > PE
               set M = GetRandomLocInRect(R)
               call DestroyEffect(AddSpecialEffectLoc(Light___Effect1 , M))
               set M = GetRandomLocInRect(R)
               call DestroyEffect(AddSpecialEffectLoc(Light___Effect1 , M))
               set M = GetRandomLocInRect(R)
               call DestroyEffect(AddSpecialEffectLoc(Light___Effect1 , M))
               set M = GetRandomLocInRect(R)
               call DestroyEffect(AddSpecialEffectLoc(Light___Effect1 , M))
               call RemoveLocation(M)
               call TriggerSleepAction(.3)
               set P = P + 1
          endloop
          loop
               set U = FirstOfGroup(G)
               exitwhen U == null
               call GroupRemoveUnit(G , U)
               call UnitDamageTarget(C,U,Damage,true,false,ATTACK_TYPE_MAGIC,DAMAGE_TYPE_NORMAL,WEAPON_TYPE_WHOKNOWS)
               endloop
          call RemoveRect(R)
          set P = 0
          loop
               exitwhen P == 20
               call DestroyLightning(L[P])
               set P = P + 1
          endloop
          call DestroyGroup(G)
          set C = null
     endfunction

