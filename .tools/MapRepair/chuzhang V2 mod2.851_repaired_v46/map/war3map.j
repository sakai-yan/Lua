 //  call TriggerRegisterPlayerChatEvent( gg_trg_INT, Player(9), "-resety", true )
 //  call TriggerRegisterPlayerChatEvent( gg_trg_INT, Player(10), "-resety", true )
 //  call TriggerRegisterPlayerChatEvent( gg_trg_INT, Player(11), "-resety", true )
call TriggerAddCondition(gg_trg_INT,Condition(function Trig_tmdINT_Conditions))
call TriggerAddAction(gg_trg_INT,function Trig_tmdINT_Actions)
endfunction

function Trig_tmdCON_Conditions takes nothing returns boolean
if(not(udg_HERO[GetConvertedPlayerId(GetTriggerPlayer())]!=null))then
return false
endif
return true
endfunction
function Trig_tmdCON_Func001001C takes nothing returns boolean
if(not(udg_GOLD[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]>=10000))then
return false
endif
return true
endfunction
function Trig_tmdCON_Func001C takes nothing returns boolean
if(not(IsUnitAliveBJ(udg_HERO[GetConvertedPlayerId(GetTriggerPlayer())])==true))then
return false
endif
if(not Trig_tmdCON_Func001001C())then
return false
endif
if(not(udg_TIli_point[GetConvertedPlayerId(GetTriggerPlayer())]>=10))then
return false
endif
return true
endfunction
function Trig_tmdCON_Actions takes nothing returns nothing
if(Trig_tmdCON_Func001C())then
  set udg_GOLD[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=(udg_GOLD[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]-100000)
  call SetPlayerStateBJ(GetOwningPlayer(GetTriggerUnit()),PLAYER_STATE_RESOURCE_GOLD,udg_GOLD[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
set udg_hero_point[GetConvertedPlayerId(GetTriggerPlayer())]=(udg_hero_point[GetConvertedPlayerId(GetTriggerPlayer())]+10)
set udg_TIli_point[GetConvertedPlayerId(GetTriggerPlayer())]=(udg_TIli_point[GetConvertedPlayerId(GetTriggerPlayer())]-10)
call SetUnitLifeBJ(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],GetUnitStateSwap(UNIT_STATE_LIFE,udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])-100)
call SetUnitLifeBJ(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],GetUnitStateSwap(UNIT_STATE_MAX_LIFE,udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])-100)
call DisplayTextToPlayer(GetTriggerPlayer(),0,0,("你目前的体魄减少1点为"+I2S(udg_TIli_point[GetConvertedPlayerId(GetTriggerPlayer())])))
call UnitAddItemByIdSwapped('mp11',udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])

   else
call DisplayTextToPlayer(GetTriggerPlayer(),0,0,"大侠洗点最低需要100000，看看有没有")
endif
endfunction
