function Trig_J_WSDBZ_Actions takes nothing returns nothing
set udg_SP=GetUnitLoc(GetTriggerUnit())
set udg_SP2=PolarProjectionBJ(udg_SP,256,GetUnitFacing(GetTriggerUnit()))
set udg_SP3=PolarProjectionBJ(udg_SP,350.00,GetUnitFacing(GetTriggerUnit()))
set udg_SP4=PolarProjectionBJ(udg_SP,500.00,GetUnitFacing(GetTriggerUnit()))
call CreateNUnitsAtLoc(1,'esen',GetOwningPlayer(GetTriggerUnit()),udg_SP2,bj_UNIT_FACING)
call IssueImmediateOrder(GetLastCreatedUnit(),"creepthunderclap")
call UnitApplyTimedLifeBJ(1.00,'BTLF',GetLastCreatedUnit())
call CreateNUnitsAtLoc(1,'esen',GetOwningPlayer(GetTriggerUnit()),udg_SP3,bj_UNIT_FACING)
call IssueImmediateOrder(GetLastCreatedUnit(),"creepthunderclap")
call SetUnitScalePercent(GetLastCreatedUnit(),110.00,110.00,110.00)
call UnitApplyTimedLifeBJ(1.00,'BTLF',GetLastCreatedUnit())
call CreateNUnitsAtLoc(1,'esen',GetOwningPlayer(GetTriggerUnit()),udg_SP4,bj_UNIT_FACING)
call IssueImmediateOrder(GetLastCreatedUnit(),"creepthunderclap")
call SetUnitScalePercent(GetLastCreatedUnit(),150.00,150.00,150.00)
call UnitApplyTimedLifeBJ(1.00,'BTLF',GetLastCreatedUnit())
set udg_GROUP=GetUnitsInRangeOfLocMatching(256.00,udg_SP2,Condition(function Trig_J_WSDBZ_Func016002003))
call ForGroupBJ(udg_GROUP,function Trig_J_WSDBZ_Func017A)
set udg_GROUP2=GetUnitsInRangeOfLocMatching(400.00,udg_SP3,Condition(function Trig_J_WSDBZ_Func018002003))
call ForGroupBJ(udg_GROUP2,function Trig_J_WSDBZ_Func019A)
call DestroyGroup(udg_GROUP)
call DestroyGroup(udg_GROUP2)
call RemoveLocation(udg_SP)
call RemoveLocation(udg_SP2)
call RemoveLocation(udg_SP3)
call RemoveLocation(udg_SP4)
call GroupClear(udg_GROUP_KF[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
endfunction
function InitTrig_J_WSDBZ takes nothing returns nothing
