 function Trig_bagualiushisizhang_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'bg64' ) ) then
        return false
    endif
    return true
endfunction

function Trig_bagualiushisizhang_Func002Func013Func001C takes nothing returns boolean
    if ( not ( IsUnitAliveBJ(udg_Kbg64) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_bagualiushisizhang_Func002C takes nothing returns boolean
    if ( not ( GetUnitLifePercent(GetTriggerUnit()) <= 100.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_bagualiushisizhang_Actions takes nothing returns nothing
    call TriggerSleepAction( 0.50 )
    if ( Trig_bagualiushisizhang_Func002C() ) then
        set udg_Jbg6411111 = GetTriggerUnit()
        set udg_Kbg64 = GetSpellTargetUnit()
        call TriggerSleepAction( 0.35 )
        call SetUnitInvulnerable( udg_Jbg6411111, true )
        call SetUnitInvulnerable( udg_Kbg64, true )
        call PauseUnitBJ( true, udg_Jbg6411111 )
        call SetUnitPathing( udg_Jbg6411111, false )
        call SetUnitPathing( udg_Kbg64, false )
        call SetUnitTimeScalePercent( udg_Jbg6411111, 300.00 )
        call SetUnitLookAt( udg_Jbg6411111, "bone_head", udg_Kbg64, 0, 0, 90 )
        set bj_forLoopAIndex = 1
        set bj_forLoopAIndexEnd = 64
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            if ( Trig_bagualiushisizhang_Func002Func013Func001C() ) then
                call SetUnitAnimationWithRarity( udg_Jbg6411111, "attack", RARITY_RARE )
                call SetUnitInvulnerable( udg_Kbg64, false )
                call TriggerSleepAction( 0.05 )
                call AddSpecialEffectLocBJ( GetUnitLoc(udg_Kbg64), "Abilities\\Spells\\Items\\AIlb\\AIlbSpecialArt.mdl" )
                set udg_baguazhang1[GetForLoopIndexA()] = GetLastCreatedEffectBJ()
                call AddSpecialEffectLocBJ( GetUnitLoc(udg_Kbg64), "Abilities\\Spells\\Human\\Thunderclap\\ThunderClapCaster.mdl" )
                set udg_baguazhang2[GetForLoopIndexA()] = GetLastCreatedEffectBJ()
                call SetUnitPositionLoc( udg_Jbg6411111, PolarProjectionBJ(GetUnitLoc(udg_Jbg6411111), 10.00, GetUnitFacing(udg_Jbg6411111)) )
                call SetUnitPositionLoc( udg_Kbg64, PolarProjectionBJ(GetUnitLoc(udg_Kbg64), 10.00, GetUnitFacing(udg_Jbg6411111)) )
                call UnitDamageTargetBJ( udg_Jbg6411111, udg_Kbg64, ( I2R(GetHeroStatBJ(bj_HEROSTAT_INT, udg_Jbg6411111, true)) * 2.00 ), ATTACK_TYPE_CHAOS, DAMAGE_TYPE_UNIVERSAL )
                call SetUnitInvulnerable( udg_Kbg64, true )
                set udg_R2bg64222 = ( ( udg_R2bg64222 + 0 ) + 1 )
                call CreateTextTagLocBJ( ( I2S(udg_R2bg64222) + "Hit" ), GetUnitLoc(udg_Kbg64), 50.00, 10, 100, 0.00, 0.00, 0 )
                call SetTextTagPermanent( GetLastCreatedTextTag(), false )
                call SetTextTagVelocityBJ( GetLastCreatedTextTag(), 64, 90 )
                call SetTextTagLifespan( GetLastCreatedTextTag(), 1.00 )
            else
                call TriggerSleepAction( 0.10 )
                set bj_forLoopBIndex = 1
                set bj_forLoopBIndexEnd = 65
                loop
                    exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
                    call DestroyEffect( udg_baguazhang1[GetForLoopIndexB()] )
                    call DestroyEffect( udg_baguazhang2[GetForLoopIndexB()] )
                    set bj_forLoopBIndex = bj_forLoopBIndex + 1
                endloop
                set udg_R2bg64222 = 0
                call PauseUnitBJ( false, udg_Jbg6411111 )
                call SetUnitInvulnerable( udg_Jbg6411111, false )
                call SetUnitInvulnerable( udg_Kbg64, false )
                call SetUnitTimeScalePercent( udg_Jbg6411111, 100.00 )
                call SetUnitAnimation( udg_Jbg6411111, "stand" )
                call SetUnitPathing( udg_Jbg6411111, true )
                call ResetUnitLookAt( udg_Jbg6411111 )
                return
            endif
            set bj_forLoopAIndex = bj_forLoopAIndex + 1
        endloop
        call TriggerSleepAction( 0.10 )
        set bj_forLoopBIndex = 1
        set bj_forLoopBIndexEnd = 65
        loop
            exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
            call DestroyEffect( udg_baguazhang1[GetForLoopIndexB()] )
            call DestroyEffect( udg_baguazhang2[GetForLoopIndexB()] )
            set bj_forLoopBIndex = bj_forLoopBIndex + 1
        endloop
        set udg_R2bg64222 = 0
        ////////////////////////////////
  call UnitDamageTargetBJ( udg_Jbg6411111,  udg_Kbg64,((I2R(GetHeroStatBJ(bj_HEROSTAT_INT,udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],false))+udg_JX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])*((1*1)*(0.70+(0.02*I2R(udg_JX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))))), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL )

       ////////////////////////////////////
        call PauseUnitBJ( false, udg_Jbg6411111 )
        call SetUnitInvulnerable( udg_Jbg6411111, false )
        call SetUnitInvulnerable( udg_Kbg64, false )
        call SetUnitTimeScalePercent( udg_Jbg6411111, 300.00 )
        call SetUnitAnimation( udg_Jbg6411111, "stand" )
        call SetUnitPathing( udg_Jbg6411111, true )
        call SetUnitPathing( udg_Kbg64, true )
        call ResetUnitLookAt( udg_Jbg6411111 )
    else
        call DoNothing(  )
    endif
endfunction

function Trig_pingzhang_Conditions takes nothing returns boolean
