function Trig_tmd_11oop_Func001Func001Func024C takes nothing returns boolean
    if ( not ( udg_BtmdE_MAX[udg_BtmdE_array2] >= R2I(udg_BtmdE_distance[udg_BtmdE_array2]) ) ) then
        return false
    endif
    return true
endfunction

function Trig_tmd_11oop_Func001Func001Func033Func005C takes nothing returns boolean
    if ( not ( udg_tmd_11_first_integer == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_tmd_11oop_Func001Func001Func033C takes nothing returns boolean
    if ( not ( udg_tmd_11_bounces[udg_BtmdE_array2] <= 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_tmd_11oop_Func001Func001C takes nothing returns boolean
    if ( not ( udg_tmd_11_bounces[udg_BtmdE_array2] > 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_tmd_11oop_Actions takes nothing returns nothing
    set udg_BtmdE_array2 = 1
    loop
        exitwhen udg_BtmdE_array2 > udg_BtmdE_integer
        if ( Trig_tmd_11oop_Func001Func001C() ) then
            // ==============================================================================
            // ==============================================================================
            // these variables are the functions for the spell to move the unit and to set a variable -1 so when it reaches 0 it turns off the spell
            set udg_tmd_11_bounces[udg_BtmdE_array2] = ( udg_tmd_11_bounces[udg_BtmdE_array2] - 1 )
            // i also reset the point so the unit doesnt go back and fourth BtmdEwteen 2 spots.
            set udg_BtmdE_point1[udg_BtmdE_array2] = GetUnitLoc(udg_BtmdE_dummy[udg_BtmdE_array2])
            set udg_BtmdE_move[udg_BtmdE_array2] = PolarProjectionBJ(udg_BtmdE_point1[udg_BtmdE_array2], I2R(udg_BtmdE_speed[udg_BtmdE_array2]), udg_BtmdE_angle[udg_BtmdE_array2])
            call SetUnitPositionLoc( udg_BtmdE_dummy[udg_BtmdE_array2], udg_BtmdE_move[udg_BtmdE_array2] )
            set udg_BtmdE_group[udg_BtmdE_array2] = GetUnitsInRangeOfLocMatching(300.00, udg_BtmdE_move[udg_BtmdE_array2], Condition(function Trig_tmd_11oop_Func001Func001Func009002003))
            call ForGroupBJ( udg_BtmdE_group[udg_BtmdE_array2], function Trig_tmd_11oop_Func001Func001Func010A )
            call DestroyGroup(udg_BtmdE_group[udg_BtmdE_array2])
            // ==============================================================================
            // ==============================================================================
            // special effect of the gods ^^
            call AddSpecialEffectLocBJ( udg_BtmdE_move[udg_BtmdE_array2], "Abilities\\Spells\\Undead\\ReplenishMana\\ReplenishManaCasterOverhead.mdl" )
            call DestroyEffectBJ( GetLastCreatedEffectBJ() )
            // ==============================================================================
            // ==============================================================================
            // this will stop the spell where the target point of ability BtmdEing cast is.
            set udg_BtmdE_MAX[udg_BtmdE_array2] = ( udg_BtmdE_MAX[udg_BtmdE_array2] + udg_BtmdE_speed[udg_BtmdE_array2] )
            // ==============================================================================
            // ==============================================================================
            // the rest of the functions here happen at the end of the spell and creates a big explosion via a dummy unit.
            if ( Trig_tmd_11oop_Func001Func001Func024C() ) then
                // this is the final explosion damage.
                set udg_BtmdE_group[udg_BtmdE_array2] = GetUnitsInRangeOfLocMatching(400.00, udg_BtmdE_move[udg_BtmdE_array2], Condition(function Trig_tmd_11oop_Func001Func001Func024Func002002003))
                call ForGroupBJ( udg_BtmdE_group[udg_BtmdE_array2], function Trig_tmd_11oop_Func001Func001Func024Func003A )
                call DestroyGroup(udg_BtmdE_group[udg_BtmdE_array2])
                // i set bounces so i can run the end of the trigger (known as the cleanup trigger)
                set udg_tmd_11_bounces[udg_BtmdE_array2] = 0
                call RemoveUnit( udg_BtmdE_dummy[udg_BtmdE_array2] )
                call CreateNUnitsAtLoc( 1, 'icb0', GetOwningPlayer(udg_BtmdE_caster[udg_BtmdE_array2]), udg_BtmdE_move[udg_BtmdE_array2], bj_UNIT_FACING )
                call UnitApplyTimedLifeBJ( 2.00, 'BTLF', GetLastCreatedUnit() )
            else
            endif
            // ==============================================================================
            // ==============================================================================
            // ==============================================================================
            // ==============================================================================
            call RemoveLocation(udg_BtmdE_point1[udg_BtmdE_array2])
            call RemoveLocation(udg_BtmdE_move[udg_BtmdE_array2])
            // ==============================================================================
            // this is the trigger that runs when bounces (variable) is 0 ( i dunno why i named it bounces)
            if ( Trig_tmd_11oop_Func001Func001Func033C() ) then
                // i set these to 0 so they can BtmdE reused next cast
                set udg_BtmdE_MAX[udg_BtmdE_array2] = 0
                // i set this variable -1 so i can run the next part while it BtmdEing MUI
                set udg_tmd_11_first_integer = ( udg_tmd_11_first_integer - 1 )
                if ( Trig_tmd_11oop_Func001Func001Func033Func005C() ) then
                    // ==============================================================================
                    // rest of the cleanup including the turn off trigger function.
                    set udg_BtmdE_integer = 0
                    set udg_tmd_11_first_integer = 0
                    call DisableTrigger( GetTriggeringTrigger() )
                    // ==============================================================================
                    // ==============================================================================
                else
                endif
            else
            endif
        else
        endif
        set udg_BtmdE_array2 = udg_BtmdE_array2 + 1
    endloop
endfunction

