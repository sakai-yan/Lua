          local trigger I= CreateTrigger()
          call TriggerRegisterAnyUnitEventBJ(I , EVENT_PLAYER_UNIT_SPELL_CAST)
          call TriggerAddCondition(I , Condition(function Light___Light_Conditions))
          call TriggerAddAction(I , function Light___Light_Actions)
          set I = null
          call Preload(Light___Effect1)
          set Light___BOOL = Filter(function Light___FilterFunc)
     endfunction
