function Trig_eqweq1_Conditions takes nothing returns boolean
if(not(GetItemType(GetManipulatedItem())==ITEM_TYPE_CAMPAIGN))then
return false
endif
if(not(IsUnitType(GetTriggerUnit(),UNIT_TYPE_HERO)==true))then
return false
endif
if(not(IsUnitType(GetTriggerUnit(),UNIT_TYPE_TAUREN)==false))then
return false
endif
return true
endfunction
function Trig_eqweq1_Func003Func001C takes nothing returns boolean
if(not(GetItemType(UnitItemInSlotBJ(GetTriggerUnit(),GetForLoopIndexA()))==ITEM_TYPE_CAMPAIGN))then
return false
endif
if(not(UnitItemInSlotBJ(GetTriggerUnit(),GetForLoopIndexA())!=udg_T1))then
return false
endif
return true
endfunction
function Trig_eqweq1_Actions takes nothing returns nothing
call DisableTrigger(GetTriggeringTrigger())
set udg_T1=GetManipulatedItem()
set bj_forLoopAIndex=1
set bj_forLoopAIndexEnd=6
loop
exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
if(Trig_eqweq1_Func003Func001C())then
call UnitRemoveItemSwapped(udg_T1,GetTriggerUnit())
call EnableTrigger(GetTriggeringTrigger())
else
call DoNothing()
endif
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
call EnableTrigger(GetTriggeringTrigger())
