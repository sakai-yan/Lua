function Trig_Chain_Splash_Loop_Actions takes nothing returns nothing
    set udg_Loop_SP = 1
    loop
        exitwhen udg_Loop_SP > udg_Times5
        if ( Trig_Chain_Splash_Loop_Func001Func001C() ) then
            if ( Trig_Chain_Splash_Loop_Func001Func001Func001C() ) then
                set udg_SPtmdria_Point[1] = GetUnitLoc(udg_SPtmdria_Chain[udg_Loop_SP])
                set udg_SPtmdria_Point[3] = GetUnitLoc(udg_SPtmdria_Target[udg_Loop_SP])
                set udg_SPtmdria_Point[2] = PolarProjectionBJ(udg_SPtmdria_Point[1], 15.00, AngleBetweenPoints(udg_SPtmdria_Point[1], udg_SPtmdria_Point[3]))
                call SetUnitPositionLoc( udg_SPtmdria_Chain[udg_Loop_SP], udg_SPtmdria_Point[2] )
                if ( Trig_Chain_Splash_Loop_Func001Func001Func001Func007C() ) then
                    set udg_SPtmdria_Jumps[udg_Loop_SP] = ( udg_SPtmdria_Jumps[udg_Loop_SP] - 1 )
                    call UnitDamageTargetBJ( udg_SPtmdria_Caster[udg_Loop_SP], udg_SPtmdria_Target[udg_Loop_SP], 8000.00, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL )
                    set udg_LVsLV=(I2R(GetHeroLevel(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))/I2R(GetUnitLevel(udg_SPtmdria_Target[udg_Loop_SP])))
                    call UnitDamageTargetBJ(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],udg_SPtmdria_Target[udg_Loop_SP],(((I2R(GetHeroInt(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],true))+udg_FX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])-udg_FK[GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))])*((1.00*udg_LVsLV)*(1.25+(0.09*I2R(udg_FX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])))))*1.3,ATTACK_TYPE_NORMAL,DAMAGE_TYPE_FIRE)

                                                      //////bf67     1.8

                    call CreateNUnitsAtLoc( 1, 'b6f2', GetOwningPlayer(udg_SPtmdria_Caster[udg_Loop_SP]), udg_SPtmdria_Point[3], bj_UNIT_FACING )
                    call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
                    call ShowUnitHide( GetLastCreatedUnit() )
                    call IssueTargetOrderBJ( GetLastCreatedUnit(), "firebolt", udg_SPtmdria_Target[udg_Loop_SP] )
                    call AddSpecialEffectTargetUnitBJ( "origin", udg_SPtmdria_Target[udg_Loop_SP], "Objects\\Spawnmodels\\Naga\\NagaDeath\\NagaDeath.mdl" )
                    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                    set udg_SPtmdria_Group[udg_Loop_SP] = GetUnitsInRangeOfLocMatching(400.00, udg_SPtmdria_Point[3], Condition(function Trig_Chain_Splash_Loop_Func001Func001Func001Func007Func009002003))
                    set udg_SPtmdria_Target[udg_Loop_SP] = null
                    set udg_SPtmdria_Target[udg_Loop_SP] = GroupPickRandomUnit(udg_SPtmdria_Group[udg_Loop_SP])
                    call DestroyGroup(udg_SPtmdria_Group[udg_Loop_SP])
                    if ( Trig_Chain_Splash_Loop_Func001Func001Func001Func007Func013C() ) then
                        call GroupRemoveUnitSimple( udg_SPtmdria_Chain[udg_Loop_SP], udg_SPtmdria )
                        call UnitApplyTimedLifeBJ( 0.10, 'BTLF', udg_SPtmdria_Chain[udg_Loop_SP] )
                        set udg_SPtmdria_Jumps[udg_Loop_SP] = 0
                        set udg_SPtmdria_Chain[udg_Loop_SP] = null
                        set udg_SPtmdria_Caster[udg_Loop_SP] = null
                        set udg_SPtmdria_Target[udg_Loop_SP] = null
                        if ( Trig_Chain_Splash_Loop_Func001Func001Func001Func007Func013Func007C() ) then
                            set udg_Times5 = 0
                            call DisableTrigger( gg_trg_Chain_Splash_Loop )
                        else
                        endif
                    else
                    endif
                else
                endif
                call RemoveLocation(udg_SPtmdria_Point[1])
                call RemoveLocation(udg_SPtmdria_Point[3])
                call RemoveLocation(udg_SPtmdria_Point[2])
            else
                if ( Trig_Chain_Splash_Loop_Func001Func001Func001Func001C() ) then
                    // Doing The last Chek
                    set udg_SPtmdria_Jumps[udg_Loop_SP] = ( udg_SPtmdria_Jumps[udg_Loop_SP] - 1 )
                    call AddSpecialEffectTargetUnitBJ( "origin", udg_SPtmdria_Target[udg_Loop_SP], "Objects\\Spawnmodels\\Naga\\NagaDeath\\NagaDeath.mdl" )
                    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                    set udg_SPtmdria_Point[3] = GetUnitLoc(udg_SPtmdria_Target[udg_Loop_SP])
                    set udg_SPtmdria_Group[udg_Loop_SP] = GetUnitsInRangeOfLocMatching(400.00, udg_SPtmdria_Point[3], Condition(function Trig_Chain_Splash_Loop_Func001Func001Func001Func001Func007002003))
                    set udg_SPtmdria_Target[udg_Loop_SP] = null
                    set udg_SPtmdria_Target[udg_Loop_SP] = GroupPickRandomUnit(udg_SPtmdria_Group[udg_Loop_SP])
                    call DestroyGroup(udg_SPtmdria_Group[udg_Loop_SP])
                    call RemoveLocation(udg_SPtmdria_Point[3])
                    if ( Trig_Chain_Splash_Loop_Func001Func001Func001Func001Func012C() ) then
                        call GroupRemoveUnitSimple( udg_SPtmdria_Chain[udg_Loop_SP], udg_SPtmdria )
                        call UnitApplyTimedLifeBJ( 0.10, 'BTLF', udg_SPtmdria_Chain[udg_Loop_SP] )
                        set udg_SPtmdria_Jumps[udg_Loop_SP] = 0
                        set udg_SPtmdria_Chain[udg_Loop_SP] = null
                        set udg_SPtmdria_Caster[udg_Loop_SP] = null
                        set udg_SPtmdria_Target[udg_Loop_SP] = null
                        if ( Trig_Chain_Splash_Loop_Func001Func001Func001Func001Func012Func007C() ) then
                            set udg_Times5 = 0
                            call DisableTrigger( gg_trg_Chain_Splash_Loop )
                        else
                        endif
                    else
                    endif
                else
                endif
            endif
        else
        endif
        set udg_Loop_SP = udg_Loop_SP + 1
    endloop
endfunction

