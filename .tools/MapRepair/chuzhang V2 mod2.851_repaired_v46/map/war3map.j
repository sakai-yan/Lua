// Trigger: Axxfz11
//===========================================================================
function Trig_Axxfz11_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'xxfz' ) ) then       //
        return false
    endif
    return true
endfunction

function Trig_Axxfz11_Actions takes nothing returns nothing
    call TriggerSleepAction(0.40)
    set udg_Axf11=GetTriggerUnit()
    set udg_Bxf22=GetSpellTargetUnit()
    call CreateNUnitsAtLoc(1, 'xxz2', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(GetUnitLoc(udg_Bxf22), 312.00, 0.00), bj_UNIT_FACING)
    set udg_QQxf33[1]=GetLastCreatedUnit()
    call CreateNUnitsAtLoc(1, 'xxz2', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(GetUnitLoc(udg_Bxf22), 312.00, 40.00), bj_UNIT_FACING)
    set udg_QQxf33[2]=GetLastCreatedUnit()
    call CreateNUnitsAtLoc(1, 'xxz2', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(GetUnitLoc(udg_Bxf22), 312.00, 80.00), bj_UNIT_FACING)
    set udg_QQxf33[3]=GetLastCreatedUnit()
    call CreateNUnitsAtLoc(1, 'xxz2', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(GetUnitLoc(udg_Bxf22), 312.00, 120.00), bj_UNIT_FACING)
    set udg_QQxf33[4]=GetLastCreatedUnit()
    call CreateNUnitsAtLoc(1, 'xxz2', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(GetUnitLoc(udg_Bxf22), 312.00, 160.00), bj_UNIT_FACING)
    set udg_QQxf33[5]=GetLastCreatedUnit()
    call CreateNUnitsAtLoc(1, 'xxz2', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(GetUnitLoc(udg_Bxf22), 312.00, 200.00), bj_UNIT_FACING)
    set udg_QQxf33[6]=GetLastCreatedUnit()
    call CreateNUnitsAtLoc(1, 'xxz2', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(GetUnitLoc(udg_Bxf22), 312.00, 240.00), bj_UNIT_FACING)
    set udg_QQxf33[7]=GetLastCreatedUnit()
    call CreateNUnitsAtLoc(1, 'xxz2', GetOwningPlayer(GetTriggerUnit()), PolarProjectionBJ(GetUnitLoc(udg_Bxf22), 312.00, 280.00), bj_UNIT_FACING)
    set udg_QQxf33[8]=GetLastCreatedUnit()
    call TriggerSleepAction(0.10)
    call EnableTrigger(gg_trg_Bxxfz22)
    call TriggerSleepAction(6.00)
    call DisableTrigger(gg_trg_Bxxfz22)
    call RemoveUnit(udg_QQxf33[1])
    call RemoveUnit(udg_QQxf33[2])
    call RemoveUnit(udg_QQxf33[3])
    call RemoveUnit(udg_QQxf33[4])
    call RemoveUnit(udg_QQxf33[5])
    call RemoveUnit(udg_QQxf33[6])
    call RemoveUnit(udg_QQxf33[7])
    call RemoveUnit(udg_QQxf33[8])
    call TriggerSleepAction(0.10)
    call AddSpecialEffectTargetUnitBJ("chest", udg_Bxf22, "Abilities\\Spells\\Other\\Volcano\\VolcanoDeath.mdl")
    call DestroyEffect(GetLastCreatedEffectBJ())

      //////////////////     �ٻ�
        call UnitDamageTargetBJ( udg_Axf11,  udg_Bxf22,((I2R(GetHeroStatBJ(bj_HEROSTAT_INT,udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],false))+udg_JX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])*((1*1)*(0.70+(0.02*I2R(udg_JX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))))), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL )
                 ///////////
    call CreateNUnitsAtLoc(1, 'h000', GetOwningPlayer(udg_Axf11), PolarProjectionBJ(GetUnitLoc(udg_Bxf22), 20.00, GetUnitFacing(udg_Bxf22)), GetUnitFacing(udg_Bxf22))
    set udg_QQxf33[9]=GetLastCreatedUnit()
 call IssueTargetOrder(udg_QQxf33[9], "Awrs", udg_Bxf22)
      //////////////////////

    call TriggerSleepAction(0.20)
    call ConditionalTriggerExecute(gg_trg_Cxxfz33)
endfunction

