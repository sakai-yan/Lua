function Trig_item_Func001Func002C takes nothing returns boolean
if(not(GetItemType(GetEnumItem())!=ITEM_TYPE_PURCHASABLE))then
return false
endif
return true
endfunction
function Trig_item_Func001A takes nothing returns nothing
local integer i
if(Trig_item_Func001Func002C())then
set i=GetStoredInteger(udg_Cache,I2S(H2I(GetEnumItem())),"掉落物品")
if i>3 then
call StoreInteger(udg_Cache,I2S(H2I(GetEnumItem())),"掉落物品",i-3)
else
if i==3 then
call FlushStoredMissionBJ(I2S(H2I(GetEnumItem())),udg_Cache)
call FlushStoredMission(udg_Cache,"Index"+H2S(GetEnumItem()))
call RemoveItem(GetEnumItem())
else
call StoreInteger(udg_Cache,I2S(H2I(GetEnumItem())),"掉落物品",300)
endif
endif
else
endif
endfunction
