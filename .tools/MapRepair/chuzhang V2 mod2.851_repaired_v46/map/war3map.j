function Trig_jinzhiXSLV_Func001Func001C takes nothing returns boolean
local integer XS=0
if(not(GetHeroLevel(udg_HERO[udg_EX])<udg_JX_lv[udg_EX]-1))then
set XS=XS+1
endif
if(not(GetHeroLevel(udg_HERO[udg_EX])<udg_DX_lv[udg_EX]-1))then
set XS=XS+1
endif
if(not(GetHeroLevel(udg_HERO[udg_EX])<udg_FX_lv[udg_EX]-1))then
set XS=XS+1
endif
if(not(GetHeroLevel(udg_HERO[udg_EX])<udg_QX_lv[udg_EX]-1))then
set XS=XS+1
endif
if(not(GetHeroLevel(udg_HERO[udg_EX])<udg_GX_lv[udg_EX]-1))then
set XS=XS+1
endif
if((GetUnitState(udg_HERO[udg_EX], UNIT_STATE_MAX_LIFE)>=25000.00))then
set XS=XS+1
endif
if((GetUnitState(udg_HERO[udg_EX], UNIT_STATE_MAX_MANA)>=20000.00 ))then
set XS=XS+1
endif
if((GetHeroStatBJ(bj_HEROSTAT_STR,udg_HERO[udg_EX],false)>=3000.00))then
set XS=XS+1
endif
if((GetHeroStatBJ(bj_HEROSTAT_AGI,udg_HERO[udg_EX],false)>=3000.00))then
set XS=XS+1
endif
if((GetHeroStatBJ(bj_HEROSTAT_INT,udg_HERO[udg_EX],false)>=5000.00))then
set XS=XS+1
endif
if(not(XS!=5))then
return false
endif
if(not(udg_HERO[udg_EX]!=null))then
return false
endif
if(not(udg_Save[udg_EX]==true))then
return false
endif
if(not(GetPlayerSlotState(ConvertedPlayer(udg_EX))==PLAYER_SLOT_STATE_PLAYING))then
return false
endif
return true
endfunction
