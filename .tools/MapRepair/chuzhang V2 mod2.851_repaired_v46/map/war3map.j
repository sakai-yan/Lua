    set gg_trg_Poisenwave_1_Remake = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Poisenwave_1_Remake, EVENT_PLAYER_UNIT_SPELL_EFFECT )
    call TriggerAddCondition( gg_trg_Poisenwave_1_Remake, Condition( function Trig_Poisenwave_1_Remake_Conditions ) )
    call TriggerAddAction( gg_trg_Poisenwave_1_Remake, function Trig_Poisenwave_1_Remake_Actions )
endfunction

