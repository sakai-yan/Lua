//===========================================================================
// Trigger: Freezing Blast On
//
// Modified By Kingz AND Created and Trigered by RMX :)
//===========================================================================
function Trig_Freezing_Blast_On_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'bf60' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Freezing_Blast_On_Func001C takes nothing returns boolean
    if ( not ( CountUnitsInGroup(udg_ARROWS) == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Freezing_Blast_On_Actions takes nothing returns nothing
    if ( Trig_Freezing_Blast_On_Func001C() ) then
        call EnableTrigger( gg_trg_Freezing_Blast_Loop )
    else
    endif
    set udg_Times[1] = ( udg_Times[1] + 1 )
    set udg_Caster[udg_Times[1]] = GetSpellAbilityUnit()
    set udg_Pointtmdria[1] = GetUnitLoc(udg_Caster[udg_Times[1]])
    set udg_Targeted[udg_Times[1]] = GetSpellTargetUnit()
    set udg_Pointtmdria[2] = GetUnitLoc(udg_Targeted[udg_Times[1]])
    set udg_Angel[udg_Times[1]] = AngleBetweenPoints(udg_Pointtmdria[1], udg_Pointtmdria[2])
    set udg_Knock[udg_Times[1]] = 0
    // ---SETTINGS---
    set udg_SPtmdriaeed[udg_Times[1]] = 7.00
    // ---MISSILE INITIAL SPEED---
    // ---
    set udg_Distance[udg_Times[1]] = ( 100.00 + ( I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetSpellAbilityUnit())) * 100.00 ) )
    // ---KNOCKBACK DISTANCE---
    // ---
    // ---MODIFICATIONS BELOW---
    // ---
    set udg_SPtmdriaecial_effect1[udg_Times[1]] = "Abilities\\Weapons\\GryphonRiderMissile\\GryphonRiderMissileTarget.mdl"
    // ---TRAIL EFFECT 1---
    // ---
    set udg_SPtmdriaecial_effect2[udg_Times[1]] = "Abilities\\Spells\\Other\\CrushingWave\\CrushingWaveDamage.mdl"
    // ---TRAIL EFFECT 2---
    // ---
    set udg_SPtmdriaecial_effect3[udg_Times[1]] = "Objects\\Spawnmodels\\Naga\\NagaDeath\\NagaDeath.mdl"
    // ---KNOCKBACK TRAIL EFFECT---
    // ---
    // ---DAMAGE SETTINGS---
    set udg_Damage_per_fragment[udg_Times[1]] = ( I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), udg_Caster[udg_Times[1]])) * 1 )
    // ---HEALTH % MODIFICATOR---
    // ---
    set udg_Distance_fragment[udg_Times[1]] = ( 250.00 - ( I2R(GetUnitAbilityLevelSwapped(GetSpellAbilityId(), udg_Caster[udg_Times[1]])) * 50.00 ) )
    // ---DISTANCE MODIFIER---
    // ---
    // ---END OF SETTINGS---
    // ---
    set udg_Create_point[udg_Times[1]] = GetUnitLoc(udg_Caster[udg_Times[1]])
    // ---END OF MODIFICATION---
    // ---
    set udg_Formula[udg_Times[1]] = ( udg_Distance[udg_Times[1]] / udg_SPtmdriaeed[udg_Times[1]] )
    call CreateNUnitsAtLoc( 1, 'b6f0', GetOwningPlayer(udg_Caster[udg_Times[1]]), udg_Pointtmdria[1], udg_Angel[udg_Times[1]] )
    set udg_Arrow[udg_Times[1]] = GetLastCreatedUnit()
    call GroupAddUnitSimple( udg_Arrow[udg_Times[1]], udg_ARROWS )
    call RemoveLocation(udg_Pointtmdria[1])
    call RemoveLocation(udg_Pointtmdria[2])
endfunction

