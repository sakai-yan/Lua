    set udg_SPtmdria_Chain[udg_Times5] = GetLastCreatedUnit()
    call GroupAddUnitSimple( udg_SPtmdria_Chain[udg_Times5], udg_SPtmdria )
    call RemoveLocation(udg_SPtmdria_Point[1])
    call RemoveLocation(udg_SPtmdria_Point[2])
endfunction

