//===========================================================================
// Trigger: Massive Blast On
//
// Created and Trigered by RMX .
//===========================================================================
function Trig_Massive_Blast_On_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'bf61' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Massive_Blast_On_Func001C takes nothing returns boolean
    if ( not ( CountUnitsInGroup(udg_OnorOff) == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Massive_Blast_On_Func005Func022002003001 takes nothing returns boolean
    return ( GetOwningPlayer(GetFilterUnit()) != GetOwningPlayer(udg_MB_Caster[udg_Times2]) )
endfunction

function Trig_Massive_Blast_On_Func005Func022002003002 takes nothing returns boolean
    return ( IsUnitAliveBJ(GetFilterUnit()) == true )
endfunction

function Trig_Massive_Blast_On_Func005Func022002003 takes nothing returns boolean
    return GetBooleanAnd( Trig_Massive_Blast_On_Func005Func022002003001(), Trig_Massive_Blast_On_Func005Func022002003002() )
endfunction

function Trig_Massive_Blast_On_Func005Func023A takes nothing returns nothing
    call SetUnitPathing( GetEnumUnit(), false )
endfunction

function Trig_Massive_Blast_On_Func005C takes nothing returns boolean
    if ( not ( IsUnitInGroup(udg_MB_Caster[udg_Times2], udg_OnorOff) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_Massive_Blast_On_Actions takes nothing returns nothing
    if ( Trig_Massive_Blast_On_Func001C() ) then
        call EnableTrigger( gg_trg_Massive_Blast_Loop )
    else
    endif
    set udg_Times2 = ( udg_Times2 + 1 )
    set udg_MB_Caster[udg_Times2] = GetSpellAbilityUnit()
    // For not spamming the abilitie coz it create huge lag if spammed like 800 times still MUI
    if ( Trig_Massive_Blast_On_Func005C() ) then
        call GroupAddUnitSimple( udg_MB_Caster[udg_Times2], udg_OnorOff )
        set udg_MB_Center[udg_Times2] = GetUnitLoc(udg_MB_Caster[udg_Times2])
        set udg_MBLevel[udg_Times2] = GetUnitAbilityLevelSwapped('bf61', udg_MB_Caster[udg_Times2])
        // Settings that can be modified
        set udg_MB_Speed[udg_Times2] = 16.00
        set udg_MB_Distance[udg_Times2] = ( ( I2R(udg_MBLevel[udg_Times2]) * 100.00 ) + 100.00 )
        set udg_MB_Formula[udg_Times2] = ( udg_MB_Distance[udg_Times2] / udg_MB_Speed[udg_Times2] )
        set udg_MB_Damage[udg_Times2] = ( I2R(udg_MBLevel[udg_Times2]) * 100.00 )
        set udg_MB_Eyecandy1[udg_Times2] = 90.00
        // This MB_Countbuff is for the effects Set it to 3 if u don't want the game to lag !
        set udg_MB_Coutbuff[udg_Times2] = 1
        // 477 range is coz if 450 the unit will have the slow effect but not get sucked into the Blast :)
        // It ensures unit getting in that Whirlpool :p
        set udg_MB_Group[udg_Times2] = GetUnitsInRangeOfLocMatching(477.00, udg_MB_Center[udg_Times2], Condition(function Trig_Massive_Blast_On_Func005Func022002003))
        call ForGroupBJ( udg_MB_Group[udg_Times2], function Trig_Massive_Blast_On_Func005Func023A )
        set udg_MB_HOW[udg_Times2] = ( ( udg_MBLevel[udg_Times2] + 1 ) * 34 )
        // ------------------------------------------------------------------
        set udg_MB_Switch[udg_Times2] = 0
    else
        call CreateTextTagUnitBJ( "TRIGSTR_116", udg_MB_Caster[udg_Times2], 0, 10, 0.00, 0.00, 100, 0 )
        call SetTextTagPermanentBJ( GetLastCreatedTextTag(), false )
        call SetTextTagVelocityBJ( GetLastCreatedTextTag(), 64, 90 )
        call SetTextTagFadepointBJ( GetLastCreatedTextTag(), 2.00 )
        call SetTextTagLifespanBJ( GetLastCreatedTextTag(), 3.00 )
        set udg_MB_Caster[udg_Times2] = null
        set udg_Times2 = ( udg_Times2 - 1 )
    endif
endfunction

//===========================================================================
function InitTrig_Massive_Blast_On takes nothing returns nothing
    set gg_trg_Massive_Blast_On = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Massive_Blast_On, EVENT_PLAYER_UNIT_SPELL_EFFECT )
    call TriggerAddCondition( gg_trg_Massive_Blast_On, Condition( function Trig_Massive_Blast_On_Conditions ) )
    call TriggerAddAction( gg_trg_Massive_Blast_On, function Trig_Massive_Blast_On_Actions )
endfunction

