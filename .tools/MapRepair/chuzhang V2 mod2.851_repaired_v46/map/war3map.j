//===========================================================================
// Trigger: Poisenwave 1 Remake
//
// Basiclly you cast the spell, settings are set and then you launch trigger 2 where all the actions happens!
// Move to Poisenwave 2 Remake trigger
//===========================================================================
function Trig_Poisenwave_1_Remake_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'pwp0' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Poisenwave_1_Remake_Func001C takes nothing returns boolean
    if ( not ( udg_PW_tmd_22_Index[1] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Poisenwave_1_Remake_Actions takes nothing returns nothing
    if ( Trig_Poisenwave_1_Remake_Func001C() ) then
        call EnableTrigger( gg_trg_Poisenwave_2_Remake )
    else
    endif
    set udg_PW_tmd_22_Index[1] = ( udg_PW_tmd_22_Index[1] + 1 )
    set udg_PW_tmd_22_Index[2] = ( udg_PW_tmd_22_Index[2] + 1 )
    // SETTINGS
    // The Integer choose how long the wave will be, countin x*100
    set udg_PW_tmd_22_WaveInteger[udg_PW_tmd_22_Index[2]] = 1
    // The 100 range is changeable by changing the temp point variable so you can count with other numbers too
    set udg_PW_tmd_22_Integer[udg_PW_tmd_22_Index[2]] = ( 4 + GetUnitAbilityLevelSwapped('pwp0', GetTriggerUnit()) )
    // Set the damage, change 155 and if you dont want it increase remove the *  and after
    set udg_PW_tmd_22_Damage[udg_PW_tmd_22_Index[2]] = ( 12155.00 * I2R(GetUnitAbilityLevelSwapped('pwp0', GetTriggerUnit())) )
    // SETTINGS 2, shouldn't be changed
    // The point you target when you want to cast the spell
    set udg_PW_tmd_22_TargetPoint[udg_PW_tmd_22_Index[2]] = GetSpellTargetLoc()
    // Usally you set the other point at the caster
    set udg_PW_tmd_22_CasterPoint[udg_PW_tmd_22_Index[2]] = GetUnitLoc(GetTriggerUnit())
    // And the angle it will be created in
    set udg_PW_tmd_22_Real[udg_PW_tmd_22_Index[2]] = AngleBetweenPoints(udg_PW_tmd_22_CasterPoint[udg_PW_tmd_22_Index[2]], udg_PW_tmd_22_TargetPoint[udg_PW_tmd_22_Index[2]])
    // Sets the caster unit into a variable, used for trigger 2
    set udg_PW_tmd_22_Unit[udg_PW_tmd_22_Index[2]] = GetTriggerUnit()
endfunction

//===========================================================================
