    return true
endfunction

function Trig_Dummy_Splash_Func004C takes nothing returns boolean
    if ( not ( IsUnitInGroup(udg_DS_TAR[udg_Times6], udg_DS) == false ) ) then
        return false
    endif
    return true
endfunction

function Trig_Dummy_Splash_Actions takes nothing returns nothing
    if ( Trig_Dummy_Splash_Func001C() ) then
        call EnableTrigger( gg_trg_Dummy_Splash_Loop )
    else
    endif
    set udg_Times6 = ( udg_Times6 + 1 )
    set udg_DS_TAR[udg_Times6] = GetSpellTargetUnit()
    if ( Trig_Dummy_Splash_Func004C() ) then
        call PauseUnitBJ( true, udg_DS_TAR[udg_Times6] )
        set udg_DS_P[1] = GetUnitLoc(udg_DS_TAR[udg_DSs])
        call AddSpecialEffectLocBJ( udg_DS_P[1], "Objects\\Spawnmodels\\Naga\\NagaDeath\\NagaDeath.mdl" )
        call DestroyEffectBJ( GetLastCreatedEffectBJ() )
        call RemoveLocation(udg_DS_P[1])
        set udg_DS_High[udg_Times6] = 1.00
        set udg_DS_YA[udg_Times6] = false
        call UnitAddAbilityBJ( 'Arav', udg_DS_TAR[udg_Times6] )
        call UnitRemoveAbilityBJ( 'Arav', udg_DS_TAR[udg_Times6] )
        call GroupAddUnitSimple( udg_DS_TAR[udg_Times6], udg_DS )
    else
        set udg_DS_TAR[udg_Times6] = null
        set udg_Times6 = ( udg_Times6 - 1 )
    endif
endfunction

