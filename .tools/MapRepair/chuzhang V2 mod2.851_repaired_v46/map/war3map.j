function MOD takes integer i returns integer
return (i-(i/10)*10)
endfunction
function BrushMonster takes real x,real y returns nothing
local unit u=null
local integer i=GetUnitTypeId(GetTriggerUnit())
local effect e=null
if IsUnitHidden(GetTriggerUnit())==true then
set u=CreateUnitAtLocSaveLast(Player(PLAYER_NEUTRAL_AGGRESSIVE),i,udg_p[GetUnitUserData(GetTriggerUnit())],270)
call SetUnitUserData(u,GetUnitUserData(GetTriggerUnit()))
set e=AddSpecialEffectLoc("Abilities\\Spells\\Items\\AIil\\AIilTarget.mdl",udg_point[GetUnitUserData(GetTriggerUnit())])
call DestroyEffect(e)
else
set u=CreateUnitAtLocSaveLast(Player(PLAYER_NEUTRAL_AGGRESSIVE),i,udg_p[GetUnitUserData(GetTriggerUnit())],270)
call SetUnitUserData(u,GetUnitUserData(GetTriggerUnit()))
call UnitApplyTimedLifeBJ(GetRandomReal(x,y),'BUan',u)
call ShowUnitHide(u)
call SetUnitInvulnerable(u,true)
endif
set e=null
endfunction
function BrushMonster2 takes real x,real y,integer k returns nothing
if GetUnitTypeId(GetTriggerUnit())==k then
call BrushMonster(x,y)
return
endif
endfunction
function DemonTurn takes integer i,integer j,integer k,integer m returns nothing
local integer p=GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))
local integer n=100
if i !='nspi' then
set n=k+udg_XIA[p]/5
endif
if GetRandomInt(1,100)<=n then
call RemoveItem(GetSpellTargetItem())
call RemoveItem(GetItemOfTypeFromUnitBJ(GetTriggerUnit(),i))
call UnitAddItemByIdSwapped(j,GetTriggerUnit())
if udg_AA[m]==false and m !=0 then
set udg_AA[m]=true
set udg_MATCH_NUM=(udg_MATCH_NUM+1)
call PlaySoundBJ(gg_snd_egem)
endif
call PlaySoundOnUnitBJ(gg_snd_egem,100,GetTriggerUnit())
else
call RemoveItem(GetItemOfTypeFromUnitBJ(GetTriggerUnit(),i))
call PlaySoundOnUnitBJ(gg_snd_CreepAggroWhat1,100,GetTriggerUnit())
endif
endfunction
function DemonTurn2 takes integer i,integer j,integer k,integer n,integer m returns nothing
if GetItemTypeId(GetSpellTargetItem())==n then
call DemonTurn(i,j,k,m)
return
endif
endfunction
function TimerBuff takes nothing returns nothing
local integer i=GetStoredInteger(udg_Cache,"RemoveBuff"+H2S(GetExpiredTimer()),"Unit")
local integer id=GetStoredInteger(udg_Cache,"RemoveBuff"+H2S(GetExpiredTimer()),"Buff")
call UnitRemoveAbility(I2U(i),id)
call FlushStoredMission(udg_Cache,I2S(id)+"BuffHero"+I2S(i))
call FlushStoredMission(udg_Cache,"RemoveBuff"+H2S(GetExpiredTimer()))
call PauseTimer(GetExpiredTimer())
call DestroyTimer(GetExpiredTimer())
endfunction
function RemoveUnitBuff takes unit u,integer buffid,real r returns nothing
local integer i=GetStoredInteger(udg_Cache,I2S(buffid)+"BuffHero"+H2S(u),"Buff")
local timer t=null
if i>0 then
set t=I2T(i)
else
set t=CreateTimer()
endif
call StoreInteger(udg_Cache,"BuffHero"+H2S(u),"Timer",H2I(t))
call StoreInteger(udg_Cache,"RemoveBuff"+H2S(t),"Unit",H2I(u))
call StoreInteger(udg_Cache,"RemoveBuff"+H2S(t),"Buff",buffid)
call TimerStart(t,r,true,function TimerBuff)
set t=null
endfunction
function IsPlayerOnGame takes player p returns boolean
if GetPlayerController(p)==MAP_CONTROL_USER then
if GetPlayerSlotState(p)==PLAYER_SLOT_STATE_PLAYING then
return true
endif
endif
return false
endfunction
function Key takes nothing returns nothing
local string array v
local integer i=0
local integer j=0
local integer end
set v[0]="#k~*(!`lTth"
set v[0]=v[0]+")-Q_+[]{}@'"
set v[0]=v[0]+"=:,.W<>?^&;"
set v[0]=v[0]+"zxcvbnmasdg"
set end=StringLength(v[0])
loop
exitwhen i>end-1
set v[1]=SubString(v[0],i,i+1)
set j=i-(i/11)*11
if j<0 then
set j=j+11
endif
call StoreInteger(udg_Cache,"CacheKey",v[1],j)
set i=i+1
endloop
set v[0]=null
set v[1]=null
endfunction
function EncryptString takes string date returns string
local string array v
local integer i=0
local integer end=StringLength(date)
local integer j=0                            //a   浵
local string s
local string g=""
set v[1]="#k~*(!`lTth"
set v[2]=")-Q_+[]{}@'"
set v[3]="=:,.W<>?^&;"
set v[4]="zxcvbnmasdg"
loop
exitwhen i>end-1
set s=SubString(date,i,i+1)
call SetRandomSeed(GetRandomInt(1,100000))
set j=GetRandomInt(1,4)
if s !="|" then
set g=g+SubString(v[j],S2I(s),S2I(s)+1)
else
set g=g+SubString(v[j],StringLength(v[j])-1,StringLength(v[j]))
endif
set i=i+1
endloop
return g
endfunction
function DecryptString takes string date returns string
local string array v
local integer i=0
local integer end=StringLength(date)
local integer j
local integer k
local string s
local string b
local string g=""
set v[0]="0123456789|"                                      //a
loop
exitwhen i>end-1
set s=SubString(date,i,i+1)
set j=GetStoredInteger(udg_Cache,"CacheKey",s)
set b=SubString(v[0],j,j+1)
set g=g+b
set i=i+1
endloop
return g
endfunction
function RemoveW3v takes nothing returns nothing
local string path=GetWar3Path(GetPlayerId(GetLocalPlayer()),GetPlayerId(GetLocalPlayer()))
call DeleteFile(path+"//save//Profile1//Campaigns.w3v",GetPlayerId(GetLocalPlayer()),GetPlayerId(GetLocalPlayer()))
call DeleteFile(path+"//save//Profile2//Campaigns.w3v",GetPlayerId(GetLocalPlayer()),GetPlayerId(GetLocalPlayer()))
call DeleteFile(path+"//save//Profile3//Campaigns.w3v",GetPlayerId(GetLocalPlayer()),GetPlayerId(GetLocalPlayer()))
call DeleteFile(path+"//save//Profile4//Campaigns.w3v",GetPlayerId(GetLocalPlayer()),GetPlayerId(GetLocalPlayer()))
call DeleteFile(path+"//save//Profile5//Campaigns.w3v",GetPlayerId(GetLocalPlayer()),GetPlayerId(GetLocalPlayer()))
set path=null
endfunction
function Removeitem2 takes item t returns nothing
call FlushStoredMission(udg_Cache,H2S(t))
call RemoveItem(t)
endfunction
