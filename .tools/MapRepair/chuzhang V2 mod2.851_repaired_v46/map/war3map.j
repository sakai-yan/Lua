function InitTrig_Cage_Cast takes nothing returns nothing
    set gg_trg_Cage_Cast = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Cage_Cast, EVENT_PLAYER_UNIT_SPELL_EFFECT )
