call ForGroupBJ(udg_jituidanweizu,function Trig_quntijitui_Func005A)
call EnableTrigger(gg_trg_shijian)
call PolledWait(1.5)
call DisableTrigger(gg_trg_shijian)
call DestroyGroup(udg_jituidanweizu)
call RemoveLocation(udg_jituipoint)
endfunction
function InitTrig_quntijitui takes nothing returns nothing
set gg_trg_quntijitui=CreateTrigger()
call TriggerRegisterAnyUnitEventBJ(gg_trg_quntijitui,EVENT_PLAYER_UNIT_SPELL_EFFECT)
call TriggerAddCondition(gg_trg_quntijitui,Condition(function Trig_quntijitui_Conditions))
call TriggerAddAction(gg_trg_quntijitui,function Trig_quntijitui_Actions)
endfunction
function Trig_shijian_Actions takes nothing returns nothing
set bj_forLoopAIndex=0
set bj_forLoopAIndexEnd=udg_jiduishuzi
loop
exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
set udg_movepoint[GetForLoopIndexA()]=GetUnitLoc(udg_jituidanwei[GetForLoopIndexA()])
set udg_targetpoint[GetForLoopIndexA()]=PolarProjectionBJ(udg_movepoint[GetForLoopIndexA()],udg_jituijiaodu2,udg_jituidiaodu3[GetForLoopIndexA()])
set udg_jituidiaodu3[GetForLoopIndexA()]=AngleBetweenPoints(udg_jituipoint,udg_movepoint[GetForLoopIndexA()])
set udg_jituijiaodu1[GetForLoopIndexA()]=GetUnitFacing(udg_jituidanwei[GetForLoopIndexA()])
call SetUnitPositionLocFacingBJ(udg_jituidanwei[GetForLoopIndexA()],udg_targetpoint[GetForLoopIndexA()],udg_jituijiaodu1[GetForLoopIndexA()])
call AddSpecialEffectTargetUnitBJ("chest",udg_jituidanwei[GetForLoopIndexA()],"Abilities\\Weapons\\SteamTank\\SteamTankImpact.mdl")
set udg_jituixiaoguo=GetLastCreatedEffectBJ()
call UnitDamageTargetBJ(GetTriggerUnit(),udg_jituidanwei[GetForLoopIndexA()],((I2R(GetUnitAbilityLevelSwapped('A00G',GetTriggerUnit()))*10.)*(I2R(GetHeroStatBJ(bj_HEROSTAT_STR,GetTriggerUnit(),false))*(I2R(GetUnitAbilityLevelSwapped('A00G',GetTriggerUnit()))/10.))),ATTACK_TYPE_NORMAL,DAMAGE_TYPE_NORMAL)
call DestroyEffect(udg_jituixiaoguo)
call RemoveLocation(udg_targetpoint[GetForLoopIndexA()])
call RemoveLocation(udg_movepoint[GetForLoopIndexA()])
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
////////////////////////////////
call UnitDamageTargetBJ( udg_Axf11,  udg_Bxf22,((I2R(GetHeroStatBJ(bj_HEROSTAT_INT,udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],false))+udg_JX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])*((1*1)*(0.70+(0.02*I2R(udg_JX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))))), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL )
                 ///////////
call CreateNUnitsAtLoc(1, 'h000', GetOwningPlayer(udg_Axf11), PolarProjectionBJ(GetUnitLoc(udg_Bxf22), 20.00, GetUnitFacing(udg_Bxf22)), GetUnitFacing(udg_Bxf22))
    set udg_QQxf33[9]=GetLastCreatedUnit()
call IssueTargetOrder(udg_QQxf33[9], "Awrs", udg_Bxf22)

///////////////////////////
endfunction
function InitTrig_shijian takes nothing returns nothing
set gg_trg_shijian=CreateTrigger()
call DisableTrigger(gg_trg_shijian)
call TriggerRegisterTimerEventPeriodic(gg_trg_shijian,.1)
call TriggerAddAction(gg_trg_shijian,function Trig_shijian_Actions)
endfunction

