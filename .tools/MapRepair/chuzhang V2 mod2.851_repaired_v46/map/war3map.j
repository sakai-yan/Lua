if(not(GetItemCharges(GetSoldItem())!=0))then
return false
endif
return true
endfunction
function Trig_sellitem_Actions takes nothing returns nothing
if(Trig_sellitem_Func001C())then
set udg_GOLD[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=(udg_GOLD[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]+R2I(((GetItemLifeBJ(GetSoldItem())*I2R(GetItemCharges(GetSoldItem())))*0.20)))
set udg_WOOD[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=(udg_WOOD[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]+R2I((I2R(GetItemLevel(GetSoldItem()))*(0.20*I2R(GetItemCharges(GetSoldItem()))))))
call SetPlayerStateBJ(GetOwningPlayer(GetBuyingUnit()),PLAYER_STATE_RESOURCE_GOLD,udg_GOLD[GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))])
call SetPlayerStateBJ(GetOwningPlayer(GetBuyingUnit()),PLAYER_STATE_RESOURCE_LUMBER,udg_WOOD[GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))])
else
set udg_GOLD[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=(udg_GOLD[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]+R2I(((GetItemLifeBJ(GetSoldItem())*1.00)*0.20)))
call SetPlayerStateBJ(GetOwningPlayer(GetBuyingUnit()),PLAYER_STATE_RESOURCE_GOLD,udg_GOLD[GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))])
endif
endfunction
