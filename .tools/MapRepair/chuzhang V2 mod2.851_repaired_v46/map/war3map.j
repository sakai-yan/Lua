        call EnableTrigger( gg_trg_Chain_Splash_Loop )
    else
    endif
    set udg_Times5 = ( udg_Times5 + 1 )
    set udg_SPtmdria_Caster[udg_Times5] = GetSpellAbilityUnit()
    set udg_SPtmdria_Target[udg_Times5] = GetSpellTargetUnit()
