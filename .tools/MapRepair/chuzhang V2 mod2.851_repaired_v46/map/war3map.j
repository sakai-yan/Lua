function Trig_tmd_11oop_Func001Func001Func010A takes nothing returns nothing
   // call UnitDamageTargetBJ( udg_BtmdE_caster[udg_BtmdE_array2], GetEnumUnit(), I2R(udg_tmd_11_damage[udg_BtmdE_array2]), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL )

set udg_LVsLV=(I2R(GetHeroLevel(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))/I2R(GetUnitLevel(GetEnumUnit())))
