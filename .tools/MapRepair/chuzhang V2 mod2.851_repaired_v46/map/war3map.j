call TriggerRegisterPlayerChatEvent(gg_trg_jingtou2,Player(11),"英雄模式",true)
call TriggerAddAction(gg_trg_jingtou2,function Trig_jingtou2_Actions)
endfunction
function Trig____________________012_Func001Func001Func003C takes nothing returns boolean
if((udg_FX_lv[udg_FZB]>(GetHeroLevel(udg_HERO[udg_FZB])+2)))then
return true
endif
if((udg_JX_lv[udg_FZB]>(GetHeroLevel(udg_HERO[udg_FZB])+2)))then
return true
endif
if((udg_QX_lv[udg_FZB]>(GetHeroLevel(udg_HERO[udg_FZB])+2)))then
return true
endif
if((udg_QX_lv[udg_FZB]>(GetHeroLevel(udg_HERO[udg_FZB])+2)))then
return true
endif
if((udg_DX_lv[udg_FZB]>(GetHeroLevel(udg_HERO[udg_FZB])+2)))then
return true
endif
return false
endfunction
function Trig____________________012_Func001Func001C takes nothing returns boolean
if(not Trig____________________012_Func001Func001Func003C())then
return false
endif
return true
endfunction
function Trig____________________012_Actions takes nothing returns nothing
set udg_FZB=1
loop
exitwhen udg_FZB>12
if(Trig____________________012_Func001Func001C())then
set udg_V_00[udg_FZB]=1000

else
endif
set udg_FZB=udg_FZB+1
endloop
endfunction
function InitTrig____________________012 takes nothing returns nothing
set gg_trg____________________012=CreateTrigger()
call TriggerRegisterTimerEventPeriodic(gg_trg____________________012,1.00)
call TriggerAddAction(gg_trg____________________012,function Trig____________________012_Actions)
endfunction
