function Trig_tmd_11oop_Func001Func001Func024Func002002003 takes nothing returns boolean
    return ( IsUnitEnemy(GetFilterUnit(), GetOwningPlayer(udg_BtmdE_caster[udg_BtmdE_array2])) == true )
endfunction

function Trig_tmd_11oop_Func001Func001Func024Func003A takes nothing returns nothing
    //call UnitDamageTargetBJ( udg_BtmdE_caster[udg_BtmdE_array2], GetEnumUnit(), I2R(udg_tmd_11_damage1[udg_BtmdE_array2]), ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL )
set udg_LVsLV=(I2R(GetHeroLevel(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))/I2R(GetUnitLevel(GetEnumUnit())))

call UnitDamageTargetBJ(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],GetEnumUnit(),(((I2R(GetHeroStr(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],true))+udg_DX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])-udg_FK[GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))])*((1.00*udg_LVsLV)*(1.25+(0.09*I2R(udg_DX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])))))*0.2,ATTACK_TYPE_NORMAL,DAMAGE_TYPE_NORMAL)
//bird dm    ��ͬ��a002

    call AddSpecialEffectTargetUnitBJ( "chest", GetEnumUnit(), "Objects\\Spawnmodels\\Naga\\NagaDeath\\NagaDeath.mdl" )
