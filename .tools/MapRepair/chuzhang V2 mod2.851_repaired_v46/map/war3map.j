function Trig_Poisenwave_2_Remake_Func004Func001C takes nothing returns boolean
    if ( not ( udg_PW_tmd_22_WaveInteger[udg_PW_tmd_22_Index[3]] < udg_PW_tmd_22_Integer[udg_PW_tmd_22_Index[3]] ) ) then
        return false
    endif
    return true
endfunction

function Trig_Poisenwave_2_Remake_Actions takes nothing returns nothing
    // If/then/else
    // to make sure that the wave integer dont equal to the normal integer
    // so we can have our stun in the end without creating another trigger
    set udg_PW_tmd_22_Index[3] = 1
    loop
        exitwhen udg_PW_tmd_22_Index[3] > udg_PW_tmd_22_Index[2]
        if ( Trig_Poisenwave_2_Remake_Func004Func001C() ) then
            // sets the temp point
            set udg_PW_tmd_22_TempPoint[udg_PW_tmd_22_Index[3]] = PolarProjectionBJ(udg_PW_tmd_22_CasterPoint[udg_PW_tmd_22_Index[3]], ( 100.00 * I2R(udg_PW_tmd_22_WaveInteger[udg_PW_tmd_22_Index[3]]) ), udg_PW_tmd_22_Real[udg_PW_tmd_22_Index[3]])
            // now when we used the temp point we set the wave integer +1
            // so when next boom is comming up it wont be at the same spot as the other one
            set udg_PW_tmd_22_WaveInteger[udg_PW_tmd_22_Index[3]] = ( udg_PW_tmd_22_WaveInteger[udg_PW_tmd_22_Index[3]] + 1 )
            // picking group around the temp point
            set udg_PW_tmd_22_TempGroup[udg_PW_tmd_22_Index[3]] = GetUnitsInRangeOfLocMatching(100.00, udg_PW_tmd_22_TempPoint[udg_PW_tmd_22_Index[3]], Condition(function Trig_Poisenwave_2_Remake_Func004Func001Func016002003))
            // special effect, havent found anything that is better then this one yet
            // destroy it ofc
            call AddSpecialEffectLocBJ( udg_PW_tmd_22_TempPoint[udg_PW_tmd_22_Index[3]], "war3mapImported\\Radioactivecloud.mdx" )
            call DestroyEffectBJ( GetLastCreatedEffectBJ() )
            // a dummy for "owner of PW_tmd_22 unit" because there are no triggering unit here
            call CreateNUnitsAtLoc( 1, 'pwpw', GetOwningPlayer(udg_PW_tmd_22_Unit[udg_PW_tmd_22_Index[3]]), udg_PW_tmd_22_TempPoint[udg_PW_tmd_22_Index[3]], bj_UNIT_FACING )
            // add the ability to the dummy
            call UnitAddAbilityBJ( 'pwp2', GetLastCreatedUnit() )
            // sets the level of the dummy ability
            call SetUnitAbilityLevelSwapped( 'pwp2', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped('pwp0', udg_PW_tmd_22_Unit[udg_PW_tmd_22_Index[3]]) )
            // and ofc a timer of the unit so it will be removed
            call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
            // remove the point becaue we need to set it once more in the trigger
            call RemoveLocation(udg_PW_tmd_22_TempPoint[udg_PW_tmd_22_Index[3]])
            // unit group pick
            // and an if/then/else to check the number of units in the group so we dont hit thin air
            call ForGroupBJ( udg_PW_tmd_22_TempGroup[udg_PW_tmd_22_Index[3]], function Trig_Poisenwave_2_Remake_Func004Func001Func033A )
            call DestroyGroup(udg_PW_tmd_22_TempGroup[udg_PW_tmd_22_Index[3]])
        else
            set udg_PW_tmd_22_Index[1] = ( udg_PW_tmd_22_Index[1] - 1 )
            // set the temp point when the wave integer reached the end of the line
            set udg_PW_tmd_22_TempPoint[udg_PW_tmd_22_Index[3]] = PolarProjectionBJ(udg_PW_tmd_22_CasterPoint[udg_PW_tmd_22_Index[3]], ( 100.00 * I2R(udg_PW_tmd_22_WaveInteger[udg_PW_tmd_22_Index[3]]) ), udg_PW_tmd_22_Real[udg_PW_tmd_22_Index[3]])
            // the final with the stun, temp group
            set udg_PW_tmd_22_TempGroup[udg_PW_tmd_22_Index[3]] = GetUnitsInRangeOfLocMatching(300.00, udg_PW_tmd_22_TempPoint[udg_PW_tmd_22_Index[3]], Condition(function Trig_Poisenwave_2_Remake_Func004Func001Func006002003))
            // if/then/else
            // checking the number of units in the group just as before
            if ( Trig_Poisenwave_2_Remake_Func004Func001Func009C() ) then
                // create dummy
                call CreateNUnitsAtLoc( 1, 'pwpw', GetOwningPlayer(udg_PW_tmd_22_Unit[udg_PW_tmd_22_Index[3]]), udg_PW_tmd_22_TempPoint[udg_PW_tmd_22_Index[3]], bj_UNIT_FACING )
                // add stun dummy
                call UnitAddAbilityBJ( 'pwp5', GetLastCreatedUnit() )
                // set the level of the dummy spell
                call SetUnitAbilityLevelSwapped( 'pwp5', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped('pwp0', udg_PW_tmd_22_Unit[udg_PW_tmd_22_Index[3]]) )
                // timer
                call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
                // pick group
                call ForGroupBJ( udg_PW_tmd_22_TempGroup[udg_PW_tmd_22_Index[3]], function Trig_Poisenwave_2_Remake_Func004Func001Func009Func033A )
                call DestroyGroup(udg_PW_tmd_22_TempGroup[udg_PW_tmd_22_Index[3]])
            else
                // there will be a end of the line sp even if there arent any there
                // and destroyed
                call AddSpecialEffectLocBJ( udg_PW_tmd_22_TempPoint[udg_PW_tmd_22_Index[3]], "Objects\\Spawnmodels\\Undead\\UCancelDeath\\UCancelDeath.mdl" )
                call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                call AddSpecialEffectLocBJ( udg_PW_tmd_22_TempPoint[udg_PW_tmd_22_Index[3]], "war3mapImported\\Radioactivecloud.mdx" )
                call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                // and there will also be a poison missiles
                // so we create dummy
                call CreateNUnitsAtLoc( 1, 'pwpw', GetOwningPlayer(udg_PW_tmd_22_Unit[udg_PW_tmd_22_Index[3]]), udg_PW_tmd_22_TempPoint[udg_PW_tmd_22_Index[3]], bj_UNIT_FACING )
                // adds the dummy ability
                call UnitAddAbilityBJ( 'pwp5', GetLastCreatedUnit() )
                // sets level
                call SetUnitAbilityLevelSwapped( 'pwp5', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped('pwp0', udg_PW_tmd_22_Unit[udg_PW_tmd_22_Index[3]]) )
                // timer ofc
                call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
                // order unit to cast the spell
                call IssuePointOrderLocBJ( GetLastCreatedUnit(), "clusterrockets", udg_PW_tmd_22_TempPoint[udg_PW_tmd_22_Index[3]] )
                // destroy group and remove points
                call DestroyGroup(udg_PW_tmd_22_TempGroup[udg_PW_tmd_22_Index[3]])
                call RemoveLocation(udg_PW_tmd_22_TempPoint[udg_PW_tmd_22_Index[3]])
                call RemoveLocation(udg_PW_tmd_22_CasterPoint[udg_PW_tmd_22_Index[3]])
                call RemoveLocation(udg_PW_tmd_22_TargetPoint[udg_PW_tmd_22_Index[3]])
                // turn off the trigger
            endif
            if ( Trig_Poisenwave_2_Remake_Func004Func001Func010C() ) then
                set udg_PW_tmd_22_Index[2] = 0
                call DisableTrigger( GetTriggeringTrigger() )
            else
            endif
        endif
        set udg_PW_tmd_22_Index[3] = udg_PW_tmd_22_Index[3] + 1
    endloop
endfunction

//===========================================================================
function InitTrig_Poisenwave_2_Remake takes nothing returns nothing
    set gg_trg_Poisenwave_2_Remake = CreateTrigger(  )
    call DisableTrigger( gg_trg_Poisenwave_2_Remake )
    call TriggerRegisterTimerEventPeriodic( gg_trg_Poisenwave_2_Remake, 0.10 )
    call TriggerAddAction( gg_trg_Poisenwave_2_Remake, function Trig_Poisenwave_2_Remake_Actions )
endfunction


//===========================================================================
// Trigger: HL Cast
//                                   nzlo
// Well documented spell, not so hard to understand cause it's a very simple spell. Just read this for a start if you don't know alot of triggering.
// - Current Learning level: Easy
//===========================================================================
function Trig_HL_Cast_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'nzl0' ) ) then
        return false
    endif
    return true
endfunction

function Trig_HL_Cast_Func047002003001 takes nothing returns boolean
    return ( IsUnitType(GetFilterUnit(), UNIT_TYPE_STRUCTURE) == false )
endfunction

function Trig_HL_Cast_Func047002003002 takes nothing returns boolean
    return ( IsUnitAliveBJ(GetFilterUnit()) == true )
endfunction

function Trig_HL_Cast_Func047002003 takes nothing returns boolean
    return GetBooleanAnd( Trig_HL_Cast_Func047002003001(), Trig_HL_Cast_Func047002003002() )
endfunction

function Trig_HL_Cast_Func054Func007Func027001 takes nothing returns boolean
    return ( IsUnitType(GetEnumUnit(), UNIT_TYPE_MAGIC_IMMUNE) == false )
endfunction

function Trig_HL_Cast_Func054Func007Func027002 takes nothing returns boolean
    return ( IsUnitEnemy(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true )
endfunction

function Trig_HL_Cast_Func054Func007C takes nothing returns boolean
    if ( not GetBooleanAnd( Trig_HL_Cast_Func054Func007Func027001(), Trig_HL_Cast_Func054Func007Func027002() ) ) then
        return false
    endif
    return true
endfunction

function Trig_HL_Cast_Func054Func010C takes nothing returns boolean
    if ( not ( IsUnitAlly(GetEnumUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_HL_Cast_Func054A takes nothing returns nothing
    // When we pick the group we want two different things right?
    // Heal our allies and damage our enemies.
    // So we make an if/then/else
    // As in the first, we check if the picked unit is magic immune and is an enemy.
    // Cause we dont want it to hit magic immune units cause that will be OP
    // --------------------------------------
    if ( Trig_HL_Cast_Func054Func007C() ) then
        // --------------------------------------
        // If they match the conditon
        // We damage them with the damage we set in the damage variable.
        call UnitDamageTargetBJ( GetTriggerUnit(), GetEnumUnit(), udg_HL_Damage, udg_HL_AttackType, udg_HL_DamageType )

set udg_LVsLV=(I2R(GetHeroLevel(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))/I2R(GetUnitLevel(GetEnumUnit())))

call UnitDamageTargetBJ(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],GetEnumUnit(),(((I2R(GetHeroInt(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],true))+udg_YX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])-udg_FK[GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))])*((1.00*udg_LVsLV)*(1.25+(0.09*I2R(udg_FX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])))))*0.8,ATTACK_TYPE_NORMAL,DAMAGE_TYPE_COLD)
// nzl0      a002

        // --------------------------------------
        // Here we set a temp point
        // with that I mean that it's temporary
        // and I will only use it very quickly
        set udg_HL_TempPoint = GetUnitLoc(GetEnumUnit())
        // cause we use it to create a dummy unit
        // which will have the slow ability which we'll add later
        call CreateNUnitsAtLoc( 1, 'nzl0', GetOwningPlayer(GetTriggerUnit()), udg_HL_TempPoint, bj_UNIT_FACING )
        // but first a timer which will make the units get lost cause we wont use them anymore
        call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
        // add the slow ability
        call UnitAddAbilityBJ( 'nzl1', GetLastCreatedUnit() )
        // set the level of the slow ability to the level of the real ability
        call SetUnitAbilityLevelSwapped( 'nzl1', GetLastCreatedUnit(), udg_HL_Level )
        // and then we cast the ability
        // on the picked units
        call IssueTargetOrderBJ( GetLastCreatedUnit(), "slow", GetEnumUnit() )
        // --------------------------------------
        // Leak removing
        call RemoveLocation(udg_HL_TempPoint)
        // --------------------------------------
    else
        // --------------------------------------
    endif
    // --------------------------------------
    // If they are our allies we do like this
    if ( Trig_HL_Cast_Func054Func010C() ) then
        // Just set their current life + our healing amount that we put in the variable
        call SetUnitLifeBJ( GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_LIFE, GetEnumUnit()) + udg_HL_Heal ) )

        call SetUnitLifeBJ( GetEnumUnit(), ( GetUnitStateSwap(UNIT_STATE_LIFE, GetEnumUnit()) + GetUnitStateSwap(UNIT_STATE_MAX_LIFE, GetEnumUnit())*0.2   ) )

         //  ��     ��    ��   ��   ��


        // --------------------------------------
    else
        // --------------------------------------
    endif
endfunction

function Trig_HL_Cast_Func056Func005A takes nothing returns nothing
    call KillDestructable( GetEnumDestructable() )
endfunction

function Trig_HL_Cast_Func056C takes nothing returns boolean
    if ( not ( udg_HL_DestroyTrees == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_HL_Cast_Actions takes nothing returns nothing
    // --------------------------------------
    // The targeted point aka in the middle of the circle you target with.
    set udg_HL_TargetPoint = GetSpellTargetLoc()
    // --------------------------------------
    // The level of the ability of being cast, used for other variables below.
    set udg_HL_Level = GetUnitAbilityLevelSwapped(GetSpellAbilityId(), GetTriggerUnit())
    // --------------------------------------
    // Well this can you adjust to anything but I set it like this
    // an integer only used for the loop cause sometimes integer A fucks up blaah :)
    set udg_HL_Loop = ( udg_HL_Loop + 1 )
    // --------------------------------------
    // SETTINGS
    // --------------------------------------
    // Here is the AoE of the spell
    // I've made it with a formula so it will be as the aoe of the spell in object editor
    set udg_HL_Range = ( 175.00 + ( 25.00 * I2R(udg_HL_Level) ) )
    // --------------------------------------
    // Here we set the heal to our value
    // I've made it as a formula cause it's multi-leveled right? ^^
    set udg_HL_Heal = ( 100.00 + ( 50.00 * I2R(udg_HL_Level) ) )
    // --------------------------------------
    // The damage we will do to our enemies
    // As we dont wanna count the heal again we just use the heal variable
    // and do it x0.75 so it will be 75% of the total heal.
    set udg_HL_Damage = ( udg_HL_Heal * 0.75 )
    // --------------------------------------
    // Here we set the current attack type we're going to use
    // As this is a spell, and sometimes we need to count in spell reduction
    // So I've set it to spells
    set udg_HL_AttackType = ATTACK_TYPE_NORMAL
    // --------------------------------------
    // Here we set the current damage type.
    // Have actually no idea what they mean
    // But as this is a holy spell I thought divine fits it perfectly
    set udg_HL_DamageType = DAMAGE_TYPE_DIVINE
    // --------------------------------------
    // Here is a variable that isnt used by the spell but I thought it might come up useful to somebody
    // So basiclly
    // If you set it to true. All trees in the AoE will be destroyed.
    set udg_HL_DestroyTrees = false
    // --------------------------------------
    // END SETTINGS
    // --------------------------------------
    // Here I set a temp group with the AoE in as range and target point variable as the point
    // The matching conditions will be up in the unit group loop but I made it like this
    // As a start
    set udg_HL_TempGroup = GetUnitsInRangeOfLocMatching(udg_HL_Range, udg_HL_TargetPoint, Condition(function Trig_HL_Cast_Func047002003))
    // --------------------------------------
    // We pick units with in the AoE range of the target point so it will have the current aoe of the total spell.
    // Also here we got some conditions
    // So it wont damage structures
    // And wont hit dead units
    // --------------------------------------
    call ForGroupBJ( udg_HL_TempGroup, function Trig_HL_Cast_Func054A )
    // And if our boolean to destroy trees equal to true we destroy all the trees in a small aoe
    if ( Trig_HL_Cast_Func056C() ) then
        // Basic we pick all the trees in our "AoE"
        // And we kill them
        // Also remember that this also kills any desructible
        call EnumDestructablesInCircleBJ( udg_HL_Range, udg_HL_TargetPoint, function Trig_HL_Cast_Func056Func005A )
    else
    endif
    // Here we create the special effects
    // By creating 32 units
    // that moves in different directions cause of the loop
    // remember if you want to change this
    // change number
    // and angle if there will be less units or more units cause else it will look weird ;)
    set udg_HL_Loop = 1
    loop
        exitwhen udg_HL_Loop > 32
        // we set the temporary point once again
        // as this is a loop
        // it will create 32 locations aka points
        // in a circle
        // around the targeted point
        set udg_HL_TempPoint = PolarProjectionBJ(udg_HL_TargetPoint, udg_HL_Range, ( 11.25 * I2R(udg_HL_Loop) ))
        // we create a new dummy
        // this will have the ability aka the special effect
        call CreateNUnitsAtLoc( 1, 'nzl1', GetOwningPlayer(GetTriggerUnit()), udg_HL_TargetPoint, ( 11.25 * I2R(udg_HL_Loop) ) )
        // turn the collision off for smooth moving
        call SetUnitPathing( GetLastCreatedUnit(), false )
        // as the dummy size is 0.10 scaling value from the start, we increase it to the normal size and then we make it a little bigger
        call SetUnitScalePercent( GetLastCreatedUnit(), 200.00, 200.00, 200.00 )
        // a timer so the unit will be removed
        call UnitApplyTimedLifeBJ( ( 0.35 + ( 0.25 * I2R(udg_HL_Level) ) ), 'BTLF', GetLastCreatedUnit() )
        // here we add the dummy ability
        // as have the special effect attached with the ability
        // to change this
        // go to the object editor and change art - target field in the HL SP dummy ability
        call UnitAddAbilityBJ( 'nzl2', GetLastCreatedUnit() )
        // and then we order the dummies to move
        // to our points
        call IssuePointOrderLocBJ( GetLastCreatedUnit(), "move", udg_HL_TempPoint )
        // as we created 32 points we need to remove them too before they set the next ones
        // leak removing ....
        call RemoveLocation(udg_HL_TempPoint)
        set udg_HL_Loop = udg_HL_Loop + 1
    endloop
    // And last we remove the target point
    call RemoveLocation(udg_HL_TargetPoint)
    // as I changed the spell I will make it like thsi instead
    // and remove the temporary unit group
    call DestroyGroup(udg_HL_TempGroup)
    // --------------------------------------
    // Now we're clear
    // what we've done are
    // created 32 units that will move to the outer lines of the aoe
    // they have the special effect
    // and when they die they create a new special effect
    // look at the next trigger to see more about that
    // also we damage and heal our own units
    // slowing enemies down
    // Hope you learned something new
    // Have fun triggering ;)
    // regards
    // baassee
endfunction

//===========================================================================
function InitTrig_HL_Cast takes nothing returns nothing
    set gg_trg_HL_Cast = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_HL_Cast, EVENT_PLAYER_UNIT_SPELL_EFFECT )
    call TriggerAddCondition( gg_trg_HL_Cast, Condition( function Trig_HL_Cast_Conditions ) )
    call TriggerAddAction( gg_trg_HL_Cast, function Trig_HL_Cast_Actions )
endfunction

//===========================================================================
// Trigger: HL SP Dies
//
// Simple Trigger
// when the dummies die, we set a point and then we create a special effect on that point, then we destroy the sp and removes the location
//===========================================================================
function Trig_HL_SP_Dies_Conditions takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetDyingUnit()) == 'nzl1' ) ) then
        return false
    endif
    return true
endfunction

function Trig_HL_SP_Dies_Actions takes nothing returns nothing
    set udg_HL_TempPoint = GetUnitLoc(GetDyingUnit())
    call AddSpecialEffectLocBJ( udg_HL_TempPoint, "Abilities\\Spells\\Human\\HolyBolt\\HolyBoltSpecialArt.mdl" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    call RemoveLocation(udg_HL_TempPoint)
endfunction

//===========================================================================
function InitTrig_HL_SP_Dies takes nothing returns nothing
    set gg_trg_HL_SP_Dies = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_HL_SP_Dies, EVENT_PLAYER_UNIT_DEATH )
    call TriggerAddCondition( gg_trg_HL_SP_Dies, Condition( function Trig_HL_SP_Dies_Conditions ) )
    call TriggerAddAction( gg_trg_HL_SP_Dies, function Trig_HL_SP_Dies_Actions )
endfunction

//===========================================================================
// Trigger: Flashlight
//
// Documentation:
// To properly import this spell, do:
// *Copy the dummies 'dummy1', 'dummy2' & 'dummy3'
// *Copy the abilities 'Flashlight', 'Cl (dummy)', CL and 'thunder'
// *Copy all variables besides 'do_not_copy_me'
// *Copy this trigger
// --
// The spell works like this:
// A dummy is created, casting thunderbolt to the target - then, another dummy is created to cast the dummy-chainlightning ('CL (dummy)').
// Now, 10 more dummies are created the the target's position, moving circular outwards.
// Simultaneously, 10 more dummies are created at the position where the lightningdummies are moving to, casting chainlightning with a delay of 1.01 seconds.
// The damage is dealt by adding all chainlightnings together, making after all 100 / 120 / 150 damage, means divided by 10 (which equals the amount of dummies who cast chainlightning), each chainlightning deals 10 / 12 / 15 damage.
// Feel free to change the values concerning damage or amount of dummies but remember that if you decrease the amount of dummies, you have to align the formula (-> 360 degrees to make a circle] / x [amount of dummies])
//===========================================================================
function Trig_Flashlight_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'lt00' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Flashlight_Actions takes nothing returns nothing
    set udg_dummy_pttmd = GetUnitLoc(GetTriggerUnit())
    set udg_tar_utmd = GetSpellTargetUnit()
    set udg_tar_pttmd = GetUnitLoc(udg_tar_utmd)
    set udg_disttmd = 522.00
    set udg_exp_rtmd = 0.20
    set udg_lvltmd = GetUnitAbilityLevelSwapped('lt00' , GetTriggerUnit())
    call CreateNUnitsAtLocFacingLocBJ(1 , 'hlt0' , GetOwningPlayer(GetTriggerUnit()) , udg_dummy_pttmd , udg_tar_pttmd)
    set udg_dum_utmd = GetLastCreatedUnit()
    call IssueTargetOrderBJ(udg_dum_utmd , "chainlightning" , udg_tar_utmd)
    call UnitApplyTimedLifeBJ(udg_exp_rtmd , 'BTLF' , udg_dum_utmd)
    call CreateNUnitsAtLocFacingLocBJ(1 , 'hlt0' , GetOwningPlayer(GetTriggerUnit()) , udg_tar_pttmd , udg_tar_pttmd)
    call UnitApplyTimedLifeBJ(udg_exp_rtmd , 'BTLF' , udg_dum_utmd)
    set udg_dum_utmd = GetLastCreatedUnit()
    call IssueTargetOrderBJ(udg_dum_utmd , "thunderbolt" , udg_tar_utmd)
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = 10
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_tar_pttmd2 = PolarProjectionBJ(udg_tar_pttmd , udg_disttmd , udg_angtmd)
        call CreateNUnitsAtLocFacingLocBJ(1 , 'hlt1' , GetOwningPlayer(GetTriggerUnit()) , udg_tar_pttmd , udg_tar_pttmd2)
        set udg_dum_utmd = GetLastCreatedUnit()
        call UnitApplyTimedLifeBJ(( udg_exp_rtmd + 1.30 ) , 'BTLF' , udg_dum_utmd)
        call IssuePointOrderLocBJ(udg_dum_utmd , "move" , udg_tar_pttmd2)
        call CreateNUnitsAtLocFacingLocBJ(1 , 'hlt2' , GetOwningPlayer(GetTriggerUnit()) , udg_tar_pttmd2 , udg_tar_pttmd)
        set udg_dum_utmd = GetLastCreatedUnit()
        call SetUnitAbilityLevelSwapped('lt02' , udg_dum_utmd , udg_lvltmd)
        call UnitApplyTimedLifeBJ(( udg_exp_rtmd + 1.30 ) , 'BTLF' , udg_dum_utmd)
        call IssueTargetOrderBJ(udg_dum_utmd , "chainlightning" , udg_tar_utmd)
        set udg_angtmd = ( udg_angtmd + 36.00 )
        call RemoveLocation(udg_tar_pttmd2)
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
    set udg_angtmd = 0.00
    call RemoveLocation(udg_dummy_pttmd)
    call RemoveLocation(udg_tar_pttmd)
endfunction

//===========================================================================
function InitTrig_Flashlight takes nothing returns nothing
    set gg_trg_Flashlighttmd = CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_Flashlighttmd , EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_Flashlighttmd , Condition(function Trig_Flashlight_Conditions))
    call TriggerAddAction(gg_trg_Flashlighttmd , function Trig_Flashlight_Actions)
endfunction
 ///////////////////////////////////////

//===========================================================================
// Trigger: spelltrig1
//                           k3b1
// So, this trgger cares about the spawning of the dummies and the direction theymove to.
// Firstly, variables are set, sfx added and then (Level of Iceburst x 3) dummies made, moving circularly.
// Let's move to 'spelltrig2'
//===========================================================================
function Trig_spelltrigtmd2221_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'k3b1' ) ) then
        return false
    endif
    return true
endfunction

function Trig_spelltrigtmd2221_Actions takes nothing returns nothing
    // First, I declare the angle to be added each time the loop runs
    set udg_IB_ang_add = ( I2R(GetUnitAbilityLevelSwapped('k3b1', GetTriggerUnit())) * 3.00 )
    set udg_IB_tmppoint = GetUnitLoc(GetTriggerUnit())
    call AddSpecialEffectLocBJ( udg_IB_tmppoint, "Abilities\\Spells\\Items\\TomeOfRetraining\\TomeOfRetrainingCaster.mdl" )
    set udg_IB_tmpeff = GetLastCreatedEffectBJ()
    call DestroyEffect(udg_IB_tmpeff)
    set udg_IB_ang = -30.00
    // Here's the loop - it creates Lv*3 units around the caster using the formula 360.00 / Lv*3
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = ( GetUnitAbilityLevelSwapped('k3b1', GetTriggerUnit()) * 3 )
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_IB_tmppoint2 = PolarProjectionBJ(udg_IB_tmppoint, 100.00, ( udg_IB_ang + ( 360.00 / udg_IB_ang_add ) ))
        set udg_IB_tmppoint3 = PolarProjectionBJ(udg_IB_tmppoint2, 2500.00, ( udg_IB_ang + ( 360.00 / udg_IB_ang_add ) ))
        call CreateNUnitsAtLocFacingLocBJ( 1, 'k300', GetOwningPlayer(GetTriggerUnit()), udg_IB_tmppoint2, udg_IB_tmppoint3 )
        call IssuePointOrderLocBJ( GetLastCreatedUnit(), "move", udg_IB_tmppoint3 )
        call SetUnitAbilityLevelSwapped( 'k3b2', GetTriggerUnit(), GetUnitAbilityLevelSwapped('k3b1', GetTriggerUnit()) )
        set udg_IB_ang = ( udg_IB_ang + ( 360.00 / udg_IB_ang_add ) )
        call UnitApplyTimedLifeBJ( 1.20, 'BTLF', GetLastCreatedUnit() )
        call RemoveLocation(udg_IB_tmppoint2)
        call RemoveLocation(udg_IB_tmppoint3)
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
    set udg_IB_ang = 0.00
    call RemoveLocation(udg_IB_tmppoint)
endfunction

//===========================================================================
function InitTrig_spelltrigtmd2221 takes nothing returns nothing
    set gg_trg_spelltrigtmd2221 = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_spelltrigtmd2221, EVENT_PLAYER_UNIT_SPELL_EFFECT )
    call TriggerAddCondition( gg_trg_spelltrigtmd2221, Condition( function Trig_spelltrigtmd2221_Conditions ) )
    call TriggerAddAction( gg_trg_spelltrigtmd2221, function Trig_spelltrigtmd2221_Actions )
endfunction

//===========================================================================
// Trigger: spelltrig2
//
// Now here we're having the main part of the spell.
// It deals with the creation of the dummies upon the missiledummie's deaths.
// If the dying unit is a big dummy, further ones are created - if the fying unit is a small dummy, an effect is added.
// Now last, 'spelltrig3'
//===========================================================================
function Trig_spelltrigtmd2222_Func002Func002C takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetTriggerUnit()) == 'k301' ) ) then
        return false
    endif
    return true
endfunction

function Trig_spelltrigtmd2222_Func002C takes nothing returns boolean
    if ( not ( GetUnitTypeId(GetTriggerUnit()) == 'k300' ) ) then
        return false
    endif
    return true
endfunction

function Trig_spelltrigtmd2222_Actions takes nothing returns nothing
    // Here I check for the unit-type of the dying unit
    if ( Trig_spelltrigtmd2222_Func002C() ) then
        set udg_IB_tmppoint = GetUnitLoc(GetTriggerUnit())
        // Now, the dummy having the frost nova effect as model is made
        call CreateNUnitsAtLocFacingLocBJ( 1, 'k303', GetOwningPlayer(GetTriggerUnit()), udg_IB_tmppoint, udg_IB_tmppoint3 )
        call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
        call AddSpecialEffectLocBJ( udg_IB_tmppoint, "Abilities\\Spells\\Undead\\FrostNova\\FrostNovaTarget.mdl" )
        set udg_IB_tmpeff = GetLastCreatedEffectBJ()
        call DestroyEffect(udg_IB_tmpeff)
        // Here, the loop starts creating the nine dummies which shall move circularly
        set bj_forLoopAIndex = 1
        set bj_forLoopAIndexEnd = 9
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            set udg_IB_tmppoint2 = PolarProjectionBJ(udg_IB_tmppoint, 0.00, ( udg_IB_ang + 45.00 ))
            set udg_IB_tmppoint3 = PolarProjectionBJ(udg_IB_tmppoint2, 2500.00, ( udg_IB_ang + 45.00 ))
            call CreateNUnitsAtLocFacingLocBJ( 1, 'k301', GetOwningPlayer(GetTriggerUnit()), udg_IB_tmppoint2, udg_IB_tmppoint3 )
            call IssuePointOrderLocBJ( GetLastCreatedUnit(), "move", udg_IB_tmppoint3 )
            call SetUnitAbilityLevelSwapped( 'k3b2', GetTriggerUnit(), GetUnitAbilityLevelSwapped('k3b1', GetTriggerUnit()) )
            call UnitApplyTimedLifeBJ( 2.00, 'BTLF', GetLastCreatedUnit() )
            call RemoveLocation(udg_IB_tmppoint2)
            call RemoveLocation(udg_IB_tmppoint3)
            set udg_IB_ang = ( udg_IB_ang + 45.00 )
            set bj_forLoopAIndex = bj_forLoopAIndex + 1
        endloop
        call RemoveLocation(udg_IB_tmppoint)
        set udg_IB_ang = 0.00
    else
        // If the dying unit is not equal to the big dummy, I create an effect instead of the small dummies
        if ( Trig_spelltrigtmd2222_Func002Func002C() ) then
            set udg_IB_tmppoint = GetUnitLoc(GetTriggerUnit())
            call AddSpecialEffectLocBJ( udg_IB_tmppoint, "Abilities\\Weapons\\GryphonRiderMissile\\GryphonRiderMissileTarget.mdl" )
            set udg_IB_tmpeff = GetLastCreatedEffectBJ()
            call DestroyEffect(udg_IB_tmpeff)
            call RemoveLocation(udg_IB_tmppoint)
        else
        endif
    endif
endfunction

//===========================================================================
function InitTrig_spelltrigtmd2222 takes nothing returns nothing
    set gg_trg_spelltrigtmd2222 = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_spelltrigtmd2222, EVENT_PLAYER_UNIT_DEATH )
    call TriggerAddAction( gg_trg_spelltrigtmd2222, function Trig_spelltrigtmd2222_Actions )
endfunction

//===========================================================================
// Trigger: spelltrig3
//
// We're almost done - this very simple trigger just has the purpose to create a dummy casting faerie fire in order to apply the armor loss.
// Feel free to edit any model/ability if you want i.e. another buff.
//===========================================================================
function Trig_spelltrigtmd2223_Func003001002 takes nothing returns boolean
    return ( UnitHasBuffBJ(GetFilterUnit(), 'B000') == true )
endfunction

function Trig_spelltrigtmd2223_Func003A takes nothing returns nothing
    set udg_IB_tmppoint = GetUnitLoc(GetEnumUnit())
    // Now I create a dummy at the units positions
    call CreateNUnitsAtLocFacingLocBJ( 1, 'k302', GetOwningPlayer(GetEnumUnit()), udg_IB_tmppoint, udg_IB_tmppoint )
    // And last, I order it to cast faerie fire to the picked unit
    call IssueTargetOrderBJ( GetLastCreatedUnit(), "faeriefire", GetEnumUnit() )
    call UnitApplyTimedLifeBJ( 0.66, 'BTLF', GetLastCreatedUnit() )
    call RemoveLocation(udg_IB_tmppoint)
endfunction

function Trig_spelltrigtmd2223_Actions takes nothing returns nothing
    set bj_wantDestroyGroup = true
    // I set the type of units to be picked
    call ForGroupBJ( GetUnitsInRectMatching(GetPlayableMapRect(), Condition(function Trig_spelltrigtmd2223_Func003001002)), function Trig_spelltrigtmd2223_Func003A )
endfunction

//===========================================================================
function InitTrig_spelltrigtmd2223 takes nothing returns nothing
    set gg_trg_spelltrigtmd2223 = CreateTrigger(  )
    call TriggerRegisterTimerEventPeriodic( gg_trg_spelltrigtmd2223, 0.50 )
    call TriggerAddAction( gg_trg_spelltrigtmd2223, function Trig_spelltrigtmd2223_Actions )
endfunction
   ///////////////////////////////////////////


//===========================================================================
// Trigger: Shade Sheild On       elhd
//
// A Complete fully leakless GUI MUI ......... Sheild :P.
//===========================================================================
function Trig_Shade_Sheild_On_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'elhd' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Shade_Sheild_On_Func001C takes nothing returns boolean
    if ( not ( udg_SS_Skip == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Shade_Sheild_On_Actions takes nothing returns nothing
    if ( Trig_Shade_Sheild_On_Func001C() ) then
        call EnableTrigger( gg_trg_Shade_Sheild_Loop )
    else
    endif
    set udg_SS_LEVEL = GetUnitAbilityLevelSwapped('elhd', GetSpellAbilityUnit())
    set udg_Sheild_How_Many = 8

                         //  shuliang???



    set udg_SS_Number[1] = ( 360.00 / I2R(udg_Sheild_How_Many) )
    set udg_SS_Number[2] = udg_SS_Number[1]
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = udg_Sheild_How_Many
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_SS_Times = ( udg_SS_Times + 1 )
        set udg_SS_Skip = ( udg_SS_Skip + 1 )
        set udg_SS_Rotate_Off[udg_SS_Times] = true
        set udg_SS_Knockback_Off[udg_SS_Times] = false
        // -----------------------------------------------------------------------------------------------------------
        set udg_SS_Hero[udg_SS_Times] = GetSpellAbilityUnit()
        set udg_SS_Point[1] = GetUnitLoc(udg_SS_Hero[udg_SS_Times])
        set udg_SS_Point[2] = PolarProjectionBJ(udg_SS_Point[1], 165.00, udg_SS_Number[2])
        // -----------------------------------------------------------------------------------------------------------
        call CreateNUnitsAtLoc( 1, 'eld0', GetOwningPlayer(udg_SS_Hero[udg_SS_Times]), udg_SS_Point[2], ( AngleBetweenPoints(udg_SS_Point[1], udg_SS_Point[2]) + 90.00 ) )
        set udg_SS_Dummy[udg_SS_Times] = GetLastCreatedUnit()
        call AddSpecialEffectTargetUnitBJ( "chest", udg_SS_Dummy[udg_SS_Times], "Abilities\\Spells\\Other\\BlackArrow\\BlackArrowMissile.mdl" )
        set udg_SS_Special[udg_SS_Times] = GetLastCreatedEffectBJ()
        // -----------------------------------------------------------------------------------------------------------
        set udg_SS_Angle[udg_SS_Times] = udg_SS_Number[2]
        set udg_SS_Angle_Speed_Rotation[udg_SS_Times] = 6.00
        set udg_SS_Countdown[udg_SS_Times] = 267
        // -----------------------------------------------------------------------------------------------------------
        set udg_SS_Damage[udg_SS_Times] = ( 100.00 * I2R(udg_SS_LEVEL) )
        set udg_SS_Distance[udg_SS_Times] = ( udg_SS_Damage[udg_SS_Times] + 100.00 )
        set udg_SS_Speed[udg_SS_Times] = 15.00
        set udg_SS_Formula[udg_SS_Times] = ( udg_SS_Distance[udg_SS_Times] / udg_SS_Speed[udg_SS_Times] )
        // -----------------------------------------------------------------------------------------------------------
        set udg_SS_Number[2] = ( udg_SS_Number[2] + udg_SS_Number[1] )
        call RemoveLocation(udg_SS_Point[1])
        call RemoveLocation(udg_SS_Point[2])
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
    set udg_SS_LEVEL = 0
    set udg_Sheild_How_Many = 0
    set udg_SS_Number[1] = 0.00
    set udg_SS_Number[2] = 0.00
endfunction

//===========================================================================
function InitTrig_Shade_Sheild_On takes nothing returns nothing
    set gg_trg_Shade_Sheild_On = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Shade_Sheild_On, EVENT_PLAYER_UNIT_SPELL_EFFECT )
    call TriggerAddCondition( gg_trg_Shade_Sheild_On, Condition( function Trig_Shade_Sheild_On_Conditions ) )
    call TriggerAddAction( gg_trg_Shade_Sheild_On, function Trig_Shade_Sheild_On_Actions )
endfunction

//===========================================================================
// Trigger: Shade Sheild Loop
//===========================================================================
function Trig_Shade_Sheild_Loop_Func001Func001Func001Func001Func012C takes nothing returns boolean
    if ( not ( udg_SS_Skip == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001Func001Func001Func020Func001C takes nothing returns boolean
    if ( not ( udg_SS_Countdown[udg_SS] == 6 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001Func001Func001Func020C takes nothing returns boolean
    if ( not ( udg_SS_Countdown[udg_SS] == 4 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001Func001Func001Func021003 takes nothing returns nothing
    call KillDestructable( GetEnumDestructable() )
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001Func001Func001Func026C takes nothing returns boolean
    if ( ( udg_SS_Distance[udg_SS] <= 0.00 ) ) then
        return true
    endif
    if ( ( IsUnitDeadBJ(udg_SS_Unit[udg_SS]) == true ) ) then
        return true
    endif
    return false
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001Func001Func001C takes nothing returns boolean
    if ( not Trig_Shade_Sheild_Loop_Func001Func001Func001Func001Func026C() ) then
        return false
    endif
    return true
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001Func001C takes nothing returns boolean
    if ( not ( udg_SS_Knockback_Off[udg_SS] == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001Func002Func016C takes nothing returns boolean
    if ( not ( udg_SS_Skip == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001Func002Func024002003001 takes nothing returns boolean
    return ( GetOwningPlayer(GetFilterUnit()) != GetOwningPlayer(udg_SS_Hero[udg_SS]) )
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001Func002Func024002003002 takes nothing returns boolean
    return ( IsUnitAliveBJ(GetFilterUnit()) == true )
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001Func002Func024002003 takes nothing returns boolean
    return GetBooleanAnd( Trig_Shade_Sheild_Loop_Func001Func001Func002Func024002003001(), Trig_Shade_Sheild_Loop_Func001Func001Func002Func024002003002() )
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001Func002Func025Func002A takes nothing returns nothing
    set udg_SS_Rotate_Off[udg_SS] = false
    set udg_SS_Knockback_Off[udg_SS] = true
    // -----------------------------------------------------------------------------------------------------------
    call DestroyEffectBJ( udg_SS_Special[udg_SS] )
    call UnitApplyTimedLifeBJ( 0.03, 'BTLF', udg_SS_Dummy[udg_SS] )
    set udg_SS_Dummy[udg_SS] = null
    call AddSpecialEffectLocBJ( udg_SS_Point[4], "Objects\\Spawnmodels\\Undead\\ImpaleTargetDust\\ImpaleTargetDust.mdl" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    // -----------------------------------------------------------------------------------------------------------
    set udg_SS_Unit[udg_SS] = GetEnumUnit()
    call UnitDamageTargetBJ( udg_SS_Hero[udg_SS], udg_SS_Unit[udg_SS], udg_SS_Damage[udg_SS], ATTACK_TYPE_NORMAL, DAMAGE_TYPE_SHADOW_STRIKE )
    call AddSpecialEffectTargetUnitBJ( "chest", udg_SS_Unit[udg_SS], "Abilities\\Weapons\\IllidanMissile\\IllidanMissile.mdl" )
    set udg_SS_Special[udg_SS] = GetLastCreatedEffectBJ()
    set udg_SS_Angle[udg_SS] = ( udg_SS_Angle[udg_SS] + 90.00 )
    set udg_SS_Countdown[udg_SS] = 0
    // -----------------------------------------------------------------------------------------------------------
    set udg_SS_Angle_Speed_Rotation[udg_SS] = 0.00
    set udg_SS_Damage[udg_SS] = 0.00
    set udg_SS_Hero[udg_SS] = null
    // -----------------------------------------------------------------------------------------------------------
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001Func002Func025C takes nothing returns boolean
    if ( not ( CountUnitsInGroup(udg_SS_Group[udg_SS]) >= 1 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001Func002C takes nothing returns boolean
    if ( not ( udg_SS_Countdown[udg_SS] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Shade_Sheild_Loop_Func001Func001C takes nothing returns boolean
    if ( not ( udg_SS_Rotate_Off[udg_SS] == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Shade_Sheild_Loop_Actions takes nothing returns nothing
    set udg_SS = 1
    loop
        exitwhen udg_SS > udg_SS_Times
        if ( Trig_Shade_Sheild_Loop_Func001Func001C() ) then
            if ( Trig_Shade_Sheild_Loop_Func001Func001Func002C() ) then
                set udg_SS_Rotate_Off[udg_SS] = false
                set udg_SS_Skip = ( udg_SS_Skip - 1 )
                // -----------------------------------------------------------------------------------------------------------
                call DestroyEffectBJ( udg_SS_Special[udg_SS] )
                call UnitApplyTimedLifeBJ( 0.03, 'BTLF', udg_SS_Dummy[udg_SS] )
                set udg_SS_Dummy[udg_SS] = null
                // -----------------------------------------------------------------------------------------------------------
                set udg_SS_Angle[udg_SS] = 0.00
                set udg_SS_Countdown[udg_SS] = 0
                set udg_SS_Angle_Speed_Rotation[udg_SS] = 0.00
                set udg_SS_Damage[udg_SS] = 0.00
                set udg_SS_Distance[udg_SS] = 0.00
                set udg_SS_Speed[udg_SS] = 0.00
                set udg_SS_Formula[udg_SS] = 0.00
                set udg_SS_Hero[udg_SS] = null
                if ( Trig_Shade_Sheild_Loop_Func001Func001Func002Func016C() ) then
                    set udg_SS_Times = 0
                    call DisableTrigger( gg_trg_Shade_Sheild_Loop )
                else
                endif
            else
                set udg_SS_Countdown[udg_SS] = ( udg_SS_Countdown[udg_SS] - 1 )
                // -----------------------------------------------------------------------------------------------------------
                set udg_SS_Point[3] = GetUnitLoc(udg_SS_Hero[udg_SS])
                set udg_SS_Point[4] = PolarProjectionBJ(udg_SS_Point[3], 165.00, udg_SS_Angle[udg_SS])
                call SetUnitPositionLocFacingBJ( udg_SS_Dummy[udg_SS], udg_SS_Point[4], ( AngleBetweenPoints(udg_SS_Point[3], udg_SS_Point[4]) + 90.00 ) )
                set udg_SS_Angle[udg_SS] = ( udg_SS_Angle[udg_SS] + udg_SS_Angle_Speed_Rotation[udg_SS] )
                // -----------------------------------------------------------------------------------------------------------
                set udg_SS_Group[udg_SS] = GetUnitsInRangeOfLocMatching(65.00, udg_SS_Point[4], Condition(function Trig_Shade_Sheild_Loop_Func001Func001Func002Func024002003))
                if ( Trig_Shade_Sheild_Loop_Func001Func001Func002Func025C() ) then
                    call ForGroupBJ( udg_SS_Group[udg_SS], function Trig_Shade_Sheild_Loop_Func001Func001Func002Func025Func002A )
                else
                endif
                call DestroyGroup(udg_SS_Group[udg_SS])
                // -----------------------------------------------------------------------------------------------------------
                call RemoveLocation(udg_SS_Point[3])
                call RemoveLocation(udg_SS_Point[4])
            endif
        else
            if ( Trig_Shade_Sheild_Loop_Func001Func001Func001C() ) then
                if ( Trig_Shade_Sheild_Loop_Func001Func001Func001Func001C() ) then
                    set udg_SS_Knockback_Off[udg_SS] = false
                    set udg_SS_Skip = ( udg_SS_Skip - 1 )
                    // -----------------------------------------------------------------------------------------------------------
                    call DestroyEffectBJ( udg_SS_Special[udg_SS] )
                    set udg_SS_Unit[udg_SS] = null
                    // -----------------------------------------------------------------------------------------------------------
                    set udg_SS_Angle[udg_SS] = 0.00
                    set udg_SS_Countdown[udg_SS] = 0
                    set udg_SS_Distance[udg_SS] = 0.00
                    set udg_SS_Speed[udg_SS] = 0.00
                    set udg_SS_Formula[udg_SS] = 0.00
                    if ( Trig_Shade_Sheild_Loop_Func001Func001Func001Func001Func012C() ) then
                        set udg_SS_Times = 0
                        call DisableTrigger( gg_trg_Shade_Sheild_Loop )
                    else
                    endif
                else
                    // -----------------------------------------------------------------------------------------------------------
                    set udg_SS_Point[5] = GetUnitLoc(udg_SS_Unit[udg_SS])
                    set udg_SS_Speed[udg_SS] = ( udg_SS_Distance[udg_SS] / udg_SS_Formula[udg_SS] )
                    set udg_SS_Speed[udg_SS] = ( udg_SS_Speed[udg_SS] + 1.00 )
                    set udg_SS_Point[6] = PolarProjectionBJ(udg_SS_Point[5], udg_SS_Speed[udg_SS], udg_SS_Angle[udg_SS])
                    call SetUnitPositionLoc( udg_SS_Unit[udg_SS], udg_SS_Point[6] )
                    set udg_SS_Countdown[udg_SS] = ( udg_SS_Countdown[udg_SS] + 1 )
                    if ( Trig_Shade_Sheild_Loop_Func001Func001Func001Func001Func020C() ) then
                        call AddSpecialEffectLocBJ( udg_SS_Point[5], "Abilities\\Spells\\Human\\FlakCannons\\FlakTarget.mdl" )
                        call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                    else
                        if ( Trig_Shade_Sheild_Loop_Func001Func001Func001Func001Func020Func001C() ) then
                            set udg_SS_Countdown[udg_SS] = 0
                            call AddSpecialEffectLocBJ( udg_SS_Point[5], "Abilities\\Spells\\Undead\\OrbOfDeath\\AnnihilationMissile.mdl" )
                            call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                        else
                        endif
                    endif
                    call EnumDestructablesInCircleBJ( 150.00, udg_SS_Point[6], function Trig_Shade_Sheild_Loop_Func001Func001Func001Func001Func021003 )
                    call RemoveLocation(udg_SS_Point[5])
                    call RemoveLocation(udg_SS_Point[6])
                    // -----------------------------------------------------------------------------------------------------------
                    set udg_SS_Distance[udg_SS] = ( udg_SS_Distance[udg_SS] - udg_SS_Speed[udg_SS] )
                endif
            else
            endif
        endif
        set udg_SS = udg_SS + 1
    endloop
endfunction

//===========================================================================
function InitTrig_Shade_Sheild_Loop takes nothing returns nothing
    set gg_trg_Shade_Sheild_Loop = CreateTrigger(  )
    call DisableTrigger( gg_trg_Shade_Sheild_Loop )
    call TriggerRegisterTimerEventPeriodic( gg_trg_Shade_Sheild_Loop, 0.03 )
    call TriggerAddAction( gg_trg_Shade_Sheild_Loop, function Trig_Shade_Sheild_Loop_Actions )
endfunction


//===========================================================================
// Trigger: init            bird
//===========================================================================
function Trig_tmd_11init_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'bird' ) ) then
        return false
    endif
    return true
endfunction
function Trig_tmd_11init_Func001C takes nothing returns boolean
    if ( not ( udg_tmd_11_first_integer == 0 ) ) then
        return false
    endif
    return true
endfunction
function Trig_tmd_11init_Actions takes nothing returns nothing
    if ( Trig_tmd_11init_Func001C() ) then
        call EnableTrigger( gg_trg_tmd_11oop )
    else
    endif
    // ==============================================================================
    // CREDITS TO Rmx FOR HELPING ME FIX A BUG IN THE SPELL, thanks again ^^
    // ==============================================================================
    // set integer for Mui
    set udg_tmd_11_first_integer = ( udg_tmd_11_first_integer + 1 )
    set udg_BtmdE_integer = ( udg_BtmdE_integer + 1 )
    set udg_BtmdE_array = udg_BtmdE_integer
    // ==============================================================================
    // set these variables for the position of caster and target
    set udg_BtmdE_caster[udg_BtmdE_array] = GetSpellAbilityUnit()
    set udg_BtmdE_point1[0] = GetUnitLoc(udg_BtmdE_caster[udg_BtmdE_array])
    set udg_BtmdE_target[0] = GetSpellTargetLoc()
    // ==============================================================================
    // these variables will tell me how fast the trigger will run and for how long (and damage too)
    set udg_tmd_11_bounces[udg_BtmdE_array] = 80
    set udg_BtmdE_speed[udg_BtmdE_array] = 20
    set udg_tmd_11_damage[udg_BtmdE_array] = ( GetUnitAbilityLevelSwapped('bird', udg_BtmdE_caster[udg_BtmdE_array]) * 30 )
    set udg_tmd_11_damage1[udg_BtmdE_array] = ( GetUnitAbilityLevelSwapped('bird', udg_BtmdE_caster[udg_BtmdE_array]) * 200 )
    // ==============================================================================
    // ==============================================================================
    // this will create an angle for my dummy unit to travel in and creates the dummy unit.
    set udg_BtmdE_angle[udg_BtmdE_array] = AngleBetweenPoints(udg_BtmdE_point1[0], udg_BtmdE_target[0])
    call CreateNUnitsAtLoc( 1, 'icb1', GetOwningPlayer(udg_BtmdE_caster[udg_BtmdE_array]), udg_BtmdE_point1[0], udg_BtmdE_angle[udg_BtmdE_array] )
    set udg_BtmdE_dummy[udg_BtmdE_array] = GetLastCreatedUnit()
    // ==============================================================================
    // this sets distance and the loop condition to BtmdE used later in next trigger.
    set udg_BtmdE_distance[udg_BtmdE_array] = DistanceBetweenPoints(udg_BtmdE_point1[0], udg_BtmdE_target[0])
    call RemoveLocation(udg_BtmdE_point1[0])
    call RemoveLocation(udg_BtmdE_target[0])
endfunction
//===========================================================================
// Trigger: Cage Pre Cast
//
// This is just precast visual effect.
//===========================================================================
function Trig_Cage_Pre_Cast_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'Agu8' ) ) then
        return false                //
    endif
    return true
endfunction
function Trig_Cage_Pre_Cast_Actions takes nothing returns nothing
    set udg_guiTempPoint1 = GetSpellTargetLoc()
    call AddSpecialEffectLocBJ( udg_guiTempPoint1, "Abilities\\Spells\\Demon\\DarkPortal\\DarkPortalTarget.mdl" )
    call DestroyEffect( GetLastCreatedEffectBJ() )
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = 24
    loop
 //call UnitDamagePoint   ( udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))], 0, 500,udg_guiTempPoint1, (((I2R(GetHeroStatBJ(bj_HEROSTAT_AGI,udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],false))+udg_QX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])*(1.40+(0.16*I2R(udg_QX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))))*2),, true, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS )
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_guiTempPoint2 = PolarProjectionBJ(udg_guiTempPoint1, 280.00, ( 15.00 * I2R(GetForLoopIndexA()) ))
        call CreateNUnitsAtLoc( 1, 'hgui', GetOwningPlayer(GetTriggerUnit()), udg_guiTempPoint2, ( ( 15.00 * I2R(GetForLoopIndexA()) ) - 180.00 ) )
        call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
        call UnitAddAbilityBJ( 'AguH', GetLastCreatedUnit() )
        call IssuePointOrderLoc( GetLastCreatedUnit(), "flamestrike", udg_guiTempPoint2 )
        call RemoveLocation (udg_guiTempPoint2)
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
    call RemoveLocation (udg_guiTempPoint1)
endfunction
//===========================================================================
function InitTrig_Cage_Pre_Cast takes nothing returns nothing
    set gg_trg_Cage_Pre_Cast = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Cage_Pre_Cast, EVENT_PLAYER_UNIT_SPELL_CHANNEL )
    call TriggerAddCondition( gg_trg_Cage_Pre_Cast, Condition( function Trig_Cage_Pre_Cast_Conditions ) )
    call TriggerAddAction( gg_trg_Cage_Pre_Cast, function Trig_Cage_Pre_Cast_Actions )
endfunction
//===========================================================================
// Trigger: Cage Cast
//
// This trigger creates the tentacle cage and turns the the cage toture cycle.
// Part 2:
// This simply damages the victim inside the cage up to 8 times.
// Even if wait is unrealiable, 8 times 1 sec shouldn't go above 9.9 real seconds delay, after 20 tests of 20.
//===========================================================================
function Trig_Cage_Cast_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'Agu8' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Cage_Cast_Func002C takes nothing returns boolean
    if ( not ( UnitHasBuffBJ(udg_guiHero[GetForLoopIndexA()], 'gui1') == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Cage_Cast_Actions takes nothing returns nothing
    set udg_guiCageAnimLock[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] = true
    if ( Trig_Cage_Cast_Func002C() ) then
        call AddSpecialEffectTargetUnitBJ( "origin", GetTriggerUnit(), "Abilities\\Spells\\Other\\Doom\\DoomTarget.mdl" )
        call DestroyEffect( GetLastCreatedEffectBJ() )
        call UnitRemoveBuffBJ( 'gui1', GetTriggerUnit() )
        set udg_guiTempPoint1 = GetUnitLoc(GetTriggerUnit())
    else
        set udg_guiTempPoint1 = GetSpellTargetLoc()
    endif
    call AddSpecialEffectLocBJ( udg_guiTempPoint1, "Abilities\\Spells\\Human\\FlameStrike\\FlameStrikeTarget.mdl" )
    call DestroyEffect( GetLastCreatedEffectBJ() )
    call CreateNUnitsAtLoc( 1, 'hgui', GetOwningPlayer(GetTriggerUnit()), udg_guiTempPoint1, bj_UNIT_FACING )
    call UnitApplyTimedLifeBJ( 9.90, 'BTLF', GetLastCreatedUnit() )
    set udg_guiDarkOrigin[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] = GetLastCreatedUnit()
    call RemoveLocation (udg_guiTempPoint1)
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = 24
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        set udg_guiTempPoint1 = GetUnitLoc(udg_guiDarkOrigin[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
        set udg_guiTempPoint2 = PolarProjectionBJ(udg_guiTempPoint1, 280.00, ( 15.00 * I2R(GetForLoopIndexA()) ))
        call CreateNUnitsAtLoc( 1, 'hgu3', GetOwningPlayer(GetTriggerUnit()), udg_guiTempPoint2, ( ( 15.00 * I2R(GetForLoopIndexA()) ) - 180.00 ) )
        call UnitApplyTimedLifeBJ( 9.90, 'BTLF', GetLastCreatedUnit() )
        call SetUnitPathing( GetLastCreatedUnit(), false )
        call SetUnitPositionLoc( GetLastCreatedUnit(), udg_guiTempPoint2 )
        call GroupAddUnitSimple( GetLastCreatedUnit(), udg_guiDarkDummyGroup[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] )
        call RemoveLocation (udg_guiTempPoint1)
        call RemoveLocation (udg_guiTempPoint2)
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
    call StartTimerBJ( udg_guiCageAnimHoldTimer[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))], false, 0.40 )
    call TriggerSleepAction( 0.41 )
    set udg_guiCageAnimLock[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] = false
    // Part 2
    set bj_forLoopBIndex = 1
    set bj_forLoopBIndexEnd = 8
    loop
        exitwhen bj_forLoopBIndex > bj_forLoopBIndexEnd
        set udg_guiPickedNail[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] = GroupPickRandomUnit(udg_guiDarkDummyGroup[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
        call UnitAddAbilityBJ( 'Agu9', udg_guiPickedNail[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] )
        set udg_guiTempPoint1 = GetUnitLoc(udg_guiPickedNail[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
        set udg_guiTempPoint2 = PolarProjectionBJ(udg_guiTempPoint1, 256.00, GetUnitFacing(udg_guiPickedNail[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))
        call AddSpecialEffectLocBJ( udg_guiTempPoint2, "Abilities\\Spells\\Human\\FlameStrike\\FlameStrikeTarget.mdl" )
        call DestroyEffect( GetLastCreatedEffectBJ() )
        call IssuePointOrderLoc( udg_guiPickedNail[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))], "impale", udg_guiTempPoint1 )
        call RemoveLocation (udg_guiTempPoint1)
        call RemoveLocation (udg_guiTempPoint2)
        call TriggerSleepAction( 1.00 )
        call UnitRemoveAbilityBJ( 'Agu9', udg_guiPickedNail[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))] )
        set bj_forLoopBIndex = bj_forLoopBIndex + 1
    endloop
endfunction

