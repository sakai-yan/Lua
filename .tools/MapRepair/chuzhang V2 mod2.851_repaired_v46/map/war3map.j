function Trig_Poisenwave_2_Remake_Func004Func001Func033A takes nothing returns nothing
    if ( Trig_Poisenwave_2_Remake_Func004Func001Func033Func001C() ) then
    else
        // if there are units, then we damage them*
        call UnitDamageTargetBJ( udg_PW_tmd_22_Unit[udg_PW_tmd_22_Index[3]], GetEnumUnit(), udg_PW_tmd_22_Damage[udg_PW_tmd_22_Index[3]], ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL )

        set udg_LVsLV=(I2R(GetHeroLevel(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))/I2R(GetUnitLevel(GetEnumUnit())))
    //  call UnitDamageTargetBJ(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],GetEnumUnit(),(((I2R(GetHeroInt(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],true))+udg_YX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])-udg_FK[GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))])*((1.00*udg_LVsLV)*(1.25+(0.09*I2R(udg_FX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])))))*1.5,ATTACK_TYPE_NORMAL,DAMAGE_TYPE_FIRE)
        call UnitDamageTargetBJ(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],GetEnumUnit(),(((I2R(GetHeroInt(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],true))+udg_YX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])-udg_FK[GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))])*((1.00*udg_LVsLV)*(1.70+(0.13*I2R(udg_FX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])))))*1.5,ATTACK_TYPE_NORMAL,DAMAGE_TYPE_POISON)

    ///// pwp0    A05I  ˪����


        // and ofc casts the dummy spell on them
