function InitTrig_tmd_11oop takes nothing returns nothing
    set gg_trg_tmd_11oop = CreateTrigger(  )
    call DisableTrigger( gg_trg_tmd_11oop )
    call TriggerRegisterTimerEventPeriodic( gg_trg_tmd_11oop, 0.03 )
    call TriggerAddAction( gg_trg_tmd_11oop, function Trig_tmd_11oop_Actions )
endfunction

