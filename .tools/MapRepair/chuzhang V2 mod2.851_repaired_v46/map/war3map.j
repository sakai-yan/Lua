call RemoveLocation(udg_SP2)
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
set udg_GROUP=GetUnitsInRangeOfLocMatching(300.00,udg_SP,Condition(function Trig_J_LLS_Func004002003))
