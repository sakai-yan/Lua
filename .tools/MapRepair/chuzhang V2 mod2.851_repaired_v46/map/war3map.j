function Trig_item_bb_Conditions takes nothing returns boolean
if(not(IsUnitType(GetTriggerUnit(),UNIT_TYPE_HERO)==true))then
return false
endif
if(not(IsUnitType(GetTriggerUnit(),UNIT_TYPE_TAUREN)==false))then
return false
endif
if(not(udg_HERO_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]!=null))then
return false
endif
return true
endfunction

