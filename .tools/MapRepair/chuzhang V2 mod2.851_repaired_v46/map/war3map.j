endif
return true
endfunction
function Trig_zhaohuanBB_Actions takes nothing returns nothing
set udg_BB_TYPE[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=S2I(SubStringBJ(I2S(udg_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]),1,2))
if(Trig_zhaohuanBB_Func002C())then
call DisplayTextToPlayer(GetOwningPlayer(GetTriggerUnit()),0,0,"|cFFFF0000你没有绑定的幻灵！|r")
return
else
if(Trig_zhaohuanBB_Func002Func001C())then
set udg_BB_TURE[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=false
call ShowUnitHide(udg_HERO_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
call UnitRemoveItemSwapped(udg_ITEM_fb[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
call RemoveItem(udg_ITEM_fb[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
call CreateItemLoc(udg_ITEM_FB[udg_BB_TYPE[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]],GetUnitLoc(GetTriggerUnit()))
set udg_ITEM_fb[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=GetLastCreatedItem()
call SetItemInvulnerable(GetLastCreatedItem(),true)
call UnitAddItemSwapped(GetLastCreatedItem(),udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
else
call UnitRemoveItemSwapped(udg_ITEM_fb[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
call RemoveItem(udg_ITEM_fb[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
call CreateItemLoc(udg_ITEM_FB[udg_BB_TYPE[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]],GetUnitLoc(GetTriggerUnit()))                                  //修复卡血
set udg_ITEM_fb[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=GetLastCreatedItem()
call UnitRemoveItemSwapped(udg_ITEM_fb[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
call RemoveItem(udg_ITEM_fb[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])
set udg_SP=GetUnitLoc(GetTriggerUnit())
if(Trig_zhaohuanBB_Func002Func001Func004C())then
call CreateNUnitsAtLoc(1,udg_BB_type[udg_BB_TYPE[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]],GetOwningPlayer(GetTriggerUnit()),udg_SP,bj_UNIT_FACING)
set udg_HERO_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=GetLastCreatedUnit()
set udg_BB_LV[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=S2I(SubStringBJ(I2S(udg_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]),3,4))
call SetHeroLevelBJ(udg_HERO_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],udg_BB_LV[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],false)
call SetHeroXP(udg_HERO_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],udg_EXP_HERO_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],false)
set udg_BB_STR[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=S2I(SubStringBJ(I2S(udg_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]),5,5))
call ModifyHeroStat(bj_HEROSTAT_STR,udg_HERO_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],bj_MODIFYMETHOD_SET,(udg_BB_STR[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]*udg_BB_LV[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))
set udg_BB_AGI[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=S2I(SubStringBJ(I2S(udg_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]),6,6))
call ModifyHeroStat(bj_HEROSTAT_AGI,udg_HERO_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],bj_MODIFYMETHOD_SET,(udg_BB_AGI[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]*udg_BB_LV[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))
set udg_BB_INT[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=S2I(SubStringBJ(I2S(udg_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]),7,7))
call ModifyHeroStat(bj_HEROSTAT_INT,udg_HERO_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],bj_MODIFYMETHOD_SET,(udg_BB_INT[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]*udg_BB_LV[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))
set udg_BB_HP[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=S2I(SubStringBJ(I2S(udg_BB[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]),8,8))
set udg_lv_num[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]=1
loop
