//===========================================================================
function Trig_Extended_Lightning_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'slt1' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Extended_Lightning_Func019002003001 takes nothing returns boolean
    return ( IsUnitAliveBJ(GetFilterUnit()) == true )
endfunction

function Trig_Extended_Lightning_Func019002003002 takes nothing returns boolean
    return ( IsPlayerEnemy(GetOwningPlayer(GetFilterUnit()), udg_EL_Owner) == true )
endfunction

function Trig_Extended_Lightning_Func019002003 takes nothing returns boolean
    return GetBooleanAnd( Trig_Extended_Lightning_Func019002003001(), Trig_Extended_Lightning_Func019002003002() )
endfunction

function Trig_Extended_Lightning_Func040A takes nothing returns nothing
       //call UnitDamageTargetBJ( udg_EL_Caster, GetEnumUnit(), udg_EL_Total_Damage, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_UNKNOWN )
set udg_LVsLV=(I2R(GetHeroLevel(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))/I2R(GetUnitLevel(GetEnumUnit())))
//call UnitDamageTargetBJ(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],GetEnumUnit(),(((I2R(GetHeroInt(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],true))+udg_FX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])-udg_FK[GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))])*((1.00*udg_LVsLV)*(1.25+(0.09*I2R(udg_FX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])))))*1.1,ATTACK_TYPE_NORMAL,DAMAGE_TYPE_FIRE)

call UnitDamageTargetBJ(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],GetEnumUnit(),(((I2R(GetHeroInt(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],true))+udg_JX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])-udg_FK[GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))])*((1.00*udg_LVsLV)*(1.20+(0.07*I2R(udg_JX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])))))*1.5,ATTACK_TYPE_NORMAL,DAMAGE_TYPE_LIGHTNING)
 // call UnitDamageTargetBJ(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],GetEnumUnit(),(((I2R(GetHeroAgi(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],true))*5+100*udg_JX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])-udg_FK[GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))])*((1.00*udg_LVsLV)*(1.20+(0.07*I2R(udg_JX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])))))*1.5,ATTACK_TYPE_NORMAL,DAMAGE_TYPE_LIGHTNING)
//   slt1   ANmo
    call AddSpecialEffectTargetUnitBJ( "origin", GetEnumUnit(), "Abilities\\Weapons\\Bolt\\BoltImpact.mdl" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
endfunction

function Trig_Extended_Lightning_Func045Func013002003001 takes nothing returns boolean
    return ( IsUnitAliveBJ(GetFilterUnit()) == true )
endfunction

function Trig_Extended_Lightning_Func045Func013002003002 takes nothing returns boolean
    return ( IsPlayerEnemy(GetOwningPlayer(GetFilterUnit()), udg_EL_Owner) == true )
endfunction

function Trig_Extended_Lightning_Func045Func013002003 takes nothing returns boolean
    return GetBooleanAnd( Trig_Extended_Lightning_Func045Func013002003001(), Trig_Extended_Lightning_Func045Func013002003002() )
endfunction

function Trig_Extended_Lightning_Actions takes nothing returns nothing
    // --------------------------------------------------------------------------------------------
    // Getting the spell constants
    // --------------------------------------------------------------------------------------------
    set udg_EL_Caster = GetTriggerUnit()
    set udg_EL_Owner = GetOwningPlayer(udg_EL_Caster)
    set udg_EL_Targeted_Location = GetSpellTargetLoc()
    set udg_EL_Ability_Level = GetUnitAbilityLevelSwapped(GetSpellAbilityId(), udg_EL_Caster)
    // --------------------------------------------------------------------------------------------
    // Setting the spell values
    // --------------------------------------------------------------------------------------------
    set udg_EL_Dummy_Ability_Ligtning = 'slt2'
    set udg_EL_Dummy_Ability_Clap = 'slt3'
    set udg_EL_Base_Number_of_Ligtnings = 2
    set udg_EL_Total_Number_of_Ligtnings = ( udg_EL_Base_Number_of_Ligtnings * udg_EL_Ability_Level )
    set udg_EL_Seek_Area_of_Effect = 500.00
    set udg_EL_Damage_Area_of_Effect = 275.00
    set udg_EL_Base_Damage = 90.00
    set udg_EL_Total_Damage = ( udg_EL_Base_Damage * I2R(udg_EL_Ability_Level) )
    set udg_EL_Damage_Group = GetUnitsInRangeOfLocMatching(udg_EL_Damage_Area_of_Effect, udg_EL_Targeted_Location, Condition(function Trig_Extended_Lightning_Func019002003))
    // --------------------------------------------------------------------------------------------
    // Creating, setting and oredring dummy to cast a spell
    // --------------------------------------------------------------------------------------------
    call CreateNUnitsAtLoc( 1, 'h000', udg_EL_Owner, udg_EL_Targeted_Location, bj_UNIT_FACING )
    call UnitApplyTimedLifeBJ( 1.50, 'BTLF', GetLastCreatedUnit() )
    call UnitAddAbilityBJ( udg_EL_Dummy_Ability_Clap, GetLastCreatedUnit() )
    call SetUnitAbilityLevelSwapped( udg_EL_Dummy_Ability_Clap, GetLastCreatedUnit(), udg_EL_Ability_Level )
    call IssueImmediateOrderBJ( GetLastCreatedUnit(), "thunderclap" )
    // --------------------------------------------------------------------------------------------
    // Creating nice special effects
    // --------------------------------------------------------------------------------------------
    call AddSpecialEffectLocBJ( udg_EL_Targeted_Location, "Abilities\\Spells\\Human\\Thunderclap\\ThunderClapCaster.mdl" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    call AddSpecialEffectLocBJ( udg_EL_Targeted_Location, "Abilities\\Spells\\Other\\Charm\\CharmTarget.mdl" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    call AddSpecialEffectLocBJ( udg_EL_Targeted_Location, "Abilities\\Spells\\NightElf\\Taunt\\TauntCaster.mdl" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    // --------------------------------------------------------------------------------------------
    // Damaging the units from unit group and creating nice special effects
    // --------------------------------------------------------------------------------------------
    call ForGroupBJ( udg_EL_Damage_Group, function Trig_Extended_Lightning_Func040A )
    // --------------------------------------------------------------------------------------------
    // Clearing leaks
    // --------------------------------------------------------------------------------------------
    call DestroyGroup(udg_EL_Damage_Group)
    set bj_forLoopAIndex = 1
    set bj_forLoopAIndexEnd = udg_EL_Total_Number_of_Ligtnings
    loop
        exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
        // --------------------------------------------------------------------------------------------
        // Setting the locations inside the loop
        // --------------------------------------------------------------------------------------------
        set udg_EL_Loop_Location = PolarProjectionBJ(udg_EL_Targeted_Location, 5.00, ( 360.00 / I2R(GetForLoopIndexA()) ))
        // --------------------------------------------------------------------------------------------
        // Creating nice special effects
        // --------------------------------------------------------------------------------------------
        call AddSpecialEffectLocBJ( udg_EL_Loop_Location, "Abilities\\Spells\\Other\\Monsoon\\MonsoonBoltTarget.mdl" )
        call DestroyEffectBJ( GetLastCreatedEffectBJ() )
        // --------------------------------------------------------------------------------------------
        // Setting the unit group and the wanted unit
        // --------------------------------------------------------------------------------------------
        set udg_EL_Seek_Group = GetUnitsInRangeOfLocMatching(udg_EL_Seek_Area_of_Effect, udg_EL_Targeted_Location, Condition(function Trig_Extended_Lightning_Func045Func013002003))
        set udg_EL_Seek_Unit = GroupPickRandomUnit(udg_EL_Seek_Group)
        // --------------------------------------------------------------------------------------------
        // Creating, setting and oredring dummy to cast a spell
        // --------------------------------------------------------------------------------------------
        call CreateNUnitsAtLoc( 1, 'h000', udg_EL_Owner, udg_EL_Loop_Location, bj_UNIT_FACING )
        call UnitApplyTimedLifeBJ( 1.50, 'BTLF', GetLastCreatedUnit() )
        call UnitAddAbilityBJ( udg_EL_Dummy_Ability_Ligtning, GetLastCreatedUnit() )
        call SetUnitAbilityLevelSwapped( udg_EL_Dummy_Ability_Ligtning, GetLastCreatedUnit(), udg_EL_Ability_Level )
        call IssueTargetOrderBJ( GetLastCreatedUnit(), "chainlightning", udg_EL_Seek_Unit )
        // --------------------------------------------------------------------------------------------
        // Clearing leaks
        // --------------------------------------------------------------------------------------------
        call DestroyGroup(udg_EL_Seek_Group)
        call RemoveLocation(udg_EL_Loop_Location)
        set bj_forLoopAIndex = bj_forLoopAIndex + 1
    endloop
    // --------------------------------------------------------------------------------------------
    // Clearing leaks
    // --------------------------------------------------------------------------------------------
    call RemoveLocation(udg_EL_Targeted_Location)
endfunction

