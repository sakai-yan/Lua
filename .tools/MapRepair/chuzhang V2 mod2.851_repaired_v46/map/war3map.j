        constant real    Light___Real2     = 135
        constant real    Light___Real3     = 225
        constant real    Light___Real4     = 315
        constant real    Light___Real5     = 400 // Change this to increase or decrease how far away the lightning is
        constant real    Light___Real6     = 750 // This changes the size of the area were units are grouped and effects are created
        constant real    Light___Real7     = 500//Change this to set the height of the lightnings in the air.
        constant real    Light___Real8     = 250//Change this to set the height were the lightning meets above the caster.Set it heigher them Rea7 to make it over the cube.
        boolexpr Light___BOOL // Don't touch this
          constant integer Lightning__SPELL_ID  = 'jss0'
          constant string  Lightning__Effect1   = "Abilities\\Weapons\\Bolt\\BoltImpact.mdl"
          constant string  Lightning__Effect2   = "Abilities\\Spells\\Other\\Monsoon\\MonsoonBoltTarget.mdl"
          constant string  Lightning__Lightning = "CHIM"//RAWCODE!
          constant integer Lightning__DAMBASE   = 50100 // This is the base damage. It is multiplyed by the level later
          constant real    Lightning__Real1     = 45// Everything up to Real8 is the degree of were the lighgtning meets
          constant real    Lightning__Real2     = 90
          constant real    Lightning__Real3     = 135
          constant real    Lightning__Real4     = 180
          constant real    Lightning__Real5     = 225
          constant real    Lightning__Real6     = 270
          constant real    Lightning__Real7     = 315
          constant real    Lightning__Real8     = 360
          constant real    Lightning__Real9     = 400// How far away the effects are
          constant real    Lightning__Real10    = 750// The regions size for the effects
          constant real    Lightning__Real11    = 500// Change this to set the height were the ightning meets
          boolexpr Lightning__BOOL // Don't touch this
