function Trig_J_XQjjj_Conditions takes nothing returns boolean
if(not(GetUnitAbilityLevelSwapped('mt21',udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))])==1))then
return false
endif
if(not(GetEventDamage()>0.00))then
return false
endif
return true
endfunction
