function Trig_Winterstar_Conditions takes nothing returns boolean
    if ( not ( GetSpellAbilityId() == 'win1' ) ) then
        return false
    endif
    return true
endfunction

function Trig_Winterstar_Actions takes nothing returns nothing
    set udg_SD_tmd_34_Caster = GetSpellAbilityUnit()
    set udg_SD_tmd_34_Point = GetUnitLoc(udg_SD_tmd_34_Caster)
    set udg_SD_tmd_34_Effect = "Objects\\Spawnmodels\\Naga\\NagaDeath\\NagaDeath.mdl"
    //
    set udg_SD_tmd_34_Integer = 1
    loop
        exitwhen udg_SD_tmd_34_Integer > 30
        set udg_SD_tmd_34_Offset = PolarProjectionBJ(udg_SD_tmd_34_Point, 150.00, udg_SD_tmd_34_Real)
        call CreateNUnitsAtLoc( 1, 'wint', GetOwningPlayer(udg_SD_tmd_34_Caster), udg_SD_tmd_34_Point, bj_UNIT_FACING )
        call UnitAddAbilityBJ( 'win2', GetLastCreatedUnit() )
        call SetUnitAbilityLevelSwapped( 'win2', GetLastCreatedUnit(), GetUnitAbilityLevelSwapped('win1', udg_SD_tmd_34_Caster) )
        call IssuePointOrderLocBJ( GetLastCreatedUnit(), "impale", udg_SD_tmd_34_Offset )
        call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
        set udg_SD_tmd_34_Real = GetRandomReal(1.00, 360.00)
        call RemoveLocation(udg_SD_tmd_34_Offset)
        set udg_SD_tmd_34_Integer = udg_SD_tmd_34_Integer + 1
    endloop
    call AddSpecialEffectLocBJ( udg_SD_tmd_34_Point, udg_SD_tmd_34_Effect )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    call RemoveLocation(udg_SD_tmd_34_Point)
endfunction

