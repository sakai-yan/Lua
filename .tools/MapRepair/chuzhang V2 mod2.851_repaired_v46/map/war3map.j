    set gg_trg_Freezing_Blast_Loop = CreateTrigger(  )
    call DisableTrigger( gg_trg_Freezing_Blast_Loop )
    call TriggerRegisterTimerEventPeriodic( gg_trg_Freezing_Blast_Loop, 0.02 )
