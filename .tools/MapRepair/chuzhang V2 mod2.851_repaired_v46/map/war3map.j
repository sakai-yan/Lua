        call SetUnitInvulnerable( udg_GJ_Caster[udg_GJ], true )
        set udg_GJ_P[1] = GetUnitLoc(udg_GJ_Caster[udg_Times4])
        set udg_GJ_TARG[udg_Times4] = GetSpellTargetLoc()
        set udg_GJ_Distance[udg_Times4] = DistanceBetweenPoints(udg_GJ_P[1], udg_GJ_TARG[udg_Times4])
        set udg_GJ_Max[udg_Times4] = PolarProjectionBJ(udg_GJ_P[1], ( udg_GJ_Distance[udg_Times4] / 2.00 ), AngleBetweenPoints(udg_GJ_P[1], udg_GJ_TARG[udg_Times4]))
        set udg_GJ_Division[udg_Times4] = ( I2R(GetUnitAbilityLevelSwapped('bf65', udg_GJ_Caster[udg_Times4])) * 5.00 )
        set udg_GJ_D_Switch[udg_Times4] = 1.00
        set udg_GJ_YesorNO[udg_Times4] = false
        set udg_GJ_Switch[udg_Times4] = 0
        set udg_GJ_Timer[udg_Times4] = 0
        set udg_GJ_Speed[udg_Times4] = 20.00
        set bj_forLoopAIndex = 1
        set bj_forLoopAIndexEnd = 10
        loop
            exitwhen bj_forLoopAIndex > bj_forLoopAIndexEnd
            set udg_GJ_P[2] = PolarProjectionBJ(udg_GJ_P[1], 100.00, ( 36.00 * I2R(GetForLoopIndexA()) ))
            call AddSpecialEffectLocBJ( udg_GJ_P[1], "Abilities\\Spells\\Items\\AIma\\AImaTarget.mdl" )
            call DestroyEffectBJ( GetLastCreatedEffectBJ() )
            call RemoveLocation(udg_GJ_P[2])
            set bj_forLoopAIndex = bj_forLoopAIndex + 1
        endloop
        call RemoveLocation(udg_GJ_P[1])
        call GroupAddUnitSimple( udg_GJ_Caster[udg_Times4], udg_GEYSERS )
        call UnitAddAbilityBJ( 'Arav', udg_GJ_Caster[udg_Times4] )
        call UnitRemoveAbilityBJ( 'Arav', udg_GJ_Caster[udg_Times4] )
    else
        call CreateTextTagUnitBJ( "TRIGSTR_166", udg_GJ_Caster[udg_Times4], 0, 10, 0.00, 0.00, 100, 0 )
        call SetTextTagPermanentBJ( GetLastCreatedTextTag(), false )
        call SetTextTagVelocityBJ( GetLastCreatedTextTag(), 64, 90 )
        call SetTextTagFadepointBJ( GetLastCreatedTextTag(), 2.00 )
        call SetTextTagLifespanBJ( GetLastCreatedTextTag(), 3.00 )
        set udg_GJ_Caster[udg_Times4] = null
        set udg_Times4 = ( udg_Times4 - 1 )
    endif
endfunction

