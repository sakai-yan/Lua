                    set udg_DS_YA[udg_DSs] = false
                    if ( Trig_Dummy_Splash_Loop_Func001Func001Func001Func005Func007C() ) then
                        set udg_Times6 = 0
                        call DisableTrigger( gg_trg_Dummy_Splash_Loop )
                    else
                    endif
                else
                endif
            else
                if ( Trig_Dummy_Splash_Loop_Func001Func001Func001Func001C() ) then
                    call SetUnitFlyHeightBJ( udg_DS_TAR[udg_DSs], 0.00, 400.00 )
                    call PauseUnitBJ( false, udg_DS_TAR[udg_DSs] )
                    call GroupRemoveUnitSimple( udg_DS_TAR[udg_DSs], udg_DS )
                    set udg_DS_TAR[udg_DSs] = null
