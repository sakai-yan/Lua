function AnalyzeList takes string listfile,integer id returns boolean
local integer i=0
local integer j=0
local integer k=0
local integer end=StringLength(listfile)
local string list
local boolean b=true
if listfile==" " or listfile=="" or listfile==null then
return false
endif
loop
exitwhen i>end
if SubString(listfile,i,i+1)=="|" then
set list=SubString(listfile,j,i)
if b then
set k=k+1
call StoreString(udg_Cache,"CacheListFileName"+I2S(id),I2S(k),list)
call StoreInteger(udg_Cache,"CacheListFile"+I2S(id),"Nubmer",k)
else
call StoreInteger(udg_Cache,"CacheListFileData"+I2S(id),I2S(k),S2I(list))
if GetLocalPlayer()==Player(id)then
call SyncStoredInteger(udg_Cache,"CacheListFileData"+I2S(id),I2S(k))
endif
endif
set j=i+1
set b=(not b)
endif
set i=i+1
endloop
if GetLocalPlayer()==Player(id)then
call SyncStoredInteger(udg_Cache,"CacheListFile"+I2S(id),"Nubmer")
endif
call StoreBoolean(udg_Cache,"CacheListFile"+I2S(id),"List",true)
return true
endfunction
function GetCacheFilePath takes integer id returns string
local integer end
local integer i=1
local string s=""
set end=GetStoredInteger(udg_Cache,"CacheListFile"+I2S(id),"Nubmer")
loop
exitwhen i>end
if i==S2I(udg_File[id])then
set s=s+GetHeroProperName(udg_HERO[id+1])+"等级"+I2S(GetHeroLevel(udg_HERO[id+1]))+"|"
else
set s=s+GetStoredString(udg_Cache,"CacheListFileName"+I2S(id),I2S(i))+"|"
endif
set s=s+I2S(GetStoredInteger(udg_Cache,"CacheListFileData"+I2S(id),I2S(i)))+"|"
set i=i+1
endloop
return s
endfunction
function FuncName takes nothing returns nothing
local integer id=GetPlayerId(GetTriggerPlayer())
local string s
local integer i=1
local integer j=0
local boolean k=false
local string v=""
local integer n=0
set s=IniReadString(udg_War3Path[id]+udg_FileName,"FileName","ListFile"," ",id,GetPlayerId(GetLocalPlayer()))
call AnalyzeList(s,id)
call TriggerSleepAction(1.0)
call StoreBoolean(udg_Cache,"GetFileNameId",I2S(id),true)
endfunction
function InitTrig_Func takes nothing returns nothing
endfunction
function ReadSaveFile takes player p,integer j returns nothing
local integer id=GetPlayerId(p)
local dialog d=null
local button b=null
local trigger t=null
local integer i=GetStoredInteger(udg_Cache,"CacheListFile"+I2S(id),"Nubmer")
local integer n=1+j*8
local integer m=1
local integer k
local integer h=0
local integer v=768
local string array s1
local string array s2
local timer r
call FlushStoredMission(udg_Cache,"CacheLoadFile"+I2S(id))
if i>0 then
set d=DialogCreate()
set t=CreateTrigger()
call TriggerRegisterDialogEvent(t,d)
call DialogSetMessage(d,"读取")
loop
exitwhen n>i
set s1[n]=GetStoredString(udg_Cache,"CacheListFileName"+I2S(id),I2S(n))
set s2[n]=I2S(GetStoredInteger(udg_Cache,"CacheListFileData"+I2S(id),I2S(n)))
set n=n+1
endloop
if j>0 then
set b=DialogAddButton(d,"上一页(F1)",v)
call StoreBoolean(udg_Cache,"CacheLoadFile"+I2S(id),H2S(b),true)
call StoreInteger(udg_Cache,"CacheLoadFile"+I2S(id),H2S(b),j-1)
set v=v+1
endif
loop
exitwhen m>8
if s2[j*8+m]!=null and s2[j*8+m]!=" " and s2[j*8+m]!="" then
set b=DialogAddButton(d,s1[j*8+m]+"(F"+I2S(v-767)+")",v)
call StoreString(udg_Cache,"CacheLoadFile"+I2S(id),H2S(b),s2[j*8+m])
set v=v+1
endif
set m=m+1
endloop
if s2[j*8+m]!=null and s2[j*8+m]!="" then
set b=DialogAddButton(d,"下一页(F"+I2S(v-767)+")",v)
call StoreBoolean(udg_Cache,"CacheLoadFile"+I2S(id),H2S(b),true)
call StoreInteger(udg_Cache,"CacheLoadFile"+I2S(id),H2S(b),j+1)
set v=v+1
endif
set b=DialogAddButton(d,"取消(F"+I2S(v-767)+")",v)
call StoreInteger(udg_Cache,"CacheLoadFile"+I2S(id),"T",H2I(t))
call ExecuteFunc("AddDialogAction")
call DialogDisplay(p,d,true)
endif
set d=null
set b=null
set t=null
set r=null
endfunction
function DialogButtonClick takes nothing returns nothing
local integer id=GetPlayerId(GetTriggerPlayer())
local boolean y=GetStoredBoolean(udg_Cache,"CacheSaveFile"+I2S(id),H2S(GetClickedButton()))
local integer j=GetStoredInteger(udg_Cache,"CacheLoadFile"+I2S(id),H2S(GetClickedButton()))
local boolean x=GetStoredBoolean(udg_Cache,"CacheLoadFile"+I2S(id),H2S(GetClickedButton()))
local string s
if y or x then
call ReadSaveFile(GetTriggerPlayer(),j)
else
set s=GetStoredString(udg_Cache,"CacheLoadFile"+I2S(id),H2S(GetClickedButton()))
if s!=null and s!="" then
if GetLocalPlayer()==GetTriggerPlayer()then
call ClearTextMessages()
endif
call DisplayTimedTextToPlayer(GetTriggerPlayer(),0.52,-1.00,60.0,"|cffffcc00正在读取数据...请等待...这可能需要一定的时间!|r")
call DisableTrigger(GetTriggeringTrigger())
set udg_File[id]=s
call BJDebugMsg(s)
call ExecuteFunc("Trig_aa_Actions")
else
call ExecuteFunc("Trig_hero_chose1_Actions")
endif
endif
call DialogClear(GetClickedDialog())
call DialogDestroy(GetClickedDialog())
call TriggerRemoveAction(GetTriggeringTrigger(),I2TA(GetStoredInteger(udg_Cache,"CacheSaveFile"+I2S(id),H2S(GetTriggeringTrigger()))))
call FlushStoredMission(udg_Cache,"CacheSaveFile"+I2S(id))
call DestroyTrigger(GetTriggeringTrigger())
set s=null
endfunction
function LoadFile takes integer id returns nothing
local dialog d=DialogCreate()
local button b=null
local trigger t=CreateTrigger()
call TriggerRegisterDialogEvent(t,d)
call DialogSetMessage(d,"是否读取存档")
set b=DialogAddButton(d,"是(Y)",'Y')
call StoreBoolean(udg_Cache,"CacheSaveFile"+I2S(id),H2S(b),true)
set b=DialogAddButton(d,"否(N)",'N')
call StoreBoolean(udg_Cache,"CacheSaveFile"+I2S(id),H2S(b),false)
call StoreInteger(udg_Cache,"CacheSaveFile"+I2S(id),H2S(t),H2I(TriggerAddAction(t,function DialogButtonClick)))
if GetLocalPlayer()==Player(id)then
call ClearTextMessages()
endif
call DialogDisplay(Player(id),d,true)
set b=null
set t=null
endfunction
function PlayerLoadEscAct takes nothing returns nothing
local integer id=GetPlayerId(GetTriggerPlayer())
local integer i=GetStoredInteger(udg_Cache,"CachePlayerLoadEsc"+I2S(id),H2S(GetTriggeringTrigger()))
local string listfile
local string m=null
local string v
local string s
local integer k
call DisableTrigger(GetTriggeringTrigger())
call DisplayTimedTextToPlayer(Player(id),0.52,-1.00,60.0,"|cffffcc00正在分析数据...请等待...这可能需要一定的时间!|r")
call DisplayTimedTextToPlayer(Player(id),0.51,-1.00,60.0,"|cffffcc00再分析期间你可以选择英雄,假设你无存档你也可以选择英雄!|r")
call ExecuteFunc("FuncName")
loop
exitwhen HaveStoredBoolean(udg_Cache,"GetFileNameId",I2S(id))
call TriggerSleepAction(0.01)
endloop
set k=GetStoredInteger(udg_Cache,"CacheListFile"+I2S(id),"Nubmer")
if k>0 then
call LoadFile(id)
else
if GetLocalPlayer()==Player(id)then
call ClearTextMessages()
endif
call DisplayTimedTextToPlayer(Player(id),0.52,-1.00,3.0,"|cffffcc00无存档|r")
call TriggerExecute(gg_trg_hero_chose1)
endif
call TriggerRemoveAction(GetTriggeringTrigger(),I2TA(i))
call FlushStoredMission(udg_Cache,"CachePlayerLoadEsc"+I2S(id))
call DestroyTrigger(GetTriggeringTrigger())
endfunction
function PlayerLoadEsc takes nothing returns nothing
local integer i=0
local trigger t=null
set udg_War3Path[GetPlayerId(GetLocalPlayer())]=""
loop
exitwhen i>11
if IsPlayerOnGame(Player(i))then
call CreateFolder(udg_War3Path[i]+"\\save",i,GetPlayerId(GetLocalPlayer()))
set t=CreateTrigger()
call TriggerRegisterPlayerEvent(t,Player(i),EVENT_PLAYER_END_CINEMATIC)
call StoreInteger(udg_Cache,"CachePlayerLoadEsc"+I2S(i),H2S(t),H2I(TriggerAddAction(t,function PlayerLoadEscAct)))
if GetLocalPlayer()==Player(i)then
call ForceUICancel()
endif
endif
set i=i+1
endloop
set t=null
endfunction
function AddDialogAction takes nothing returns nothing
local integer id=GetPlayerId(GetTriggerPlayer())
local trigger t=I2T2(GetStoredInteger(udg_Cache,"CacheLoadFile"+I2S(id),"T"))
local integer i=H2I(TriggerAddAction(t,function DialogButtonClick))
call StoreInteger(udg_Cache,"CacheLoadFile"+I2S(id),H2S(t),i)
set t=null
endfunction
