//===========================================================================
// Trigger: Ini Trigger
//                                     pwpo
// A simple Preload trigger that is needed! :)
//===========================================================================
function Trig_Ini_tmd_pw_Trigger_Actions takes nothing returns nothing
    set udg_PW_tmd_22_TempPoint[0] = GetRectCenter(GetPlayableMapRect())
    call Preload( "war3mapImported\\Radioactivecloud.mdx" )
    call AddSpecialEffectLocBJ( udg_PW_tmd_22_TempPoint[0], "war3mapImported\\Radioactivecloud.mdx" )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
    call CreateNUnitsAtLoc( 1, 'hfoo', Player(0), udg_PW_tmd_22_TempPoint[0], bj_UNIT_FACING )
    call UnitAddAbilityBJ( 'pwp0', GetLastCreatedUnit() )
    call UnitAddAbilityBJ( 'pwp2', GetLastCreatedUnit() )
    call UnitAddAbilityBJ( 'pwp5', GetLastCreatedUnit() )
    call UnitApplyTimedLifeBJ( 0.01, 'BTLF', GetLastCreatedUnit() )
    call RemoveLocation (udg_PW_tmd_22_TempPoint[0])
    call DestroyTrigger(GetTriggeringTrigger())
endfunction

