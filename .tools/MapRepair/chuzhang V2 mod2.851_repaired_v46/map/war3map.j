  call UnitDamageTargetBJ(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],GetEnumUnit(),((I2R(GetHeroStatBJ(bj_HEROSTAT_STR,udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],false))+udg_DX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])*((1.00*(udg_LVsLV*1.00))*(2.00+(0.35*I2R(udg_DX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])))))*0.5,ATTACK_TYPE_CHAOS,DAMAGE_TYPE_NORMAL)

//bird  a04k
