function InitTrig_BBLVUP takes nothing returns nothing
set gg_trg_BBLVUP=CreateTrigger()
call TriggerRegisterAnyUnitEventBJ(gg_trg_BBLVUP,EVENT_PLAYER_HERO_LEVEL)
call TriggerAddCondition(gg_trg_BBLVUP,Condition(function Trig_BBLVUP_Conditions))
call TriggerAddAction(gg_trg_BBLVUP,function Trig_BBLVUP_Actions)
endfunction
function Trig_zidongheyao_Func001Func001C takes nothing returns boolean
if(not(GetSpellAbilityId()=='A081'))then
return false
endif
return true
endfunction
function Trig_zidongheyao_Func001C takes nothing returns boolean
if(not(GetSpellAbilityId()=='A080'))then
return false
endif
return true
endfunction
function Trig_zidongheyao_Actions takes nothing returns nothing
if(Trig_zidongheyao_Func001C())then
call IssueImmediateOrder(GetTriggerUnit(),"stop")
call UnitRemoveAbilityBJ('A080',GetTriggerUnit())
call UnitAddAbilityBJ('A081',GetTriggerUnit())
call DisplayTextToPlayer(GetOwningPlayer(GetTriggerUnit()),0,0,"你关闭了自动喝药")
else
if(Trig_zidongheyao_Func001Func001C())then
call IssueImmediateOrder(GetTriggerUnit(),"stop")
call UnitRemoveAbilityBJ('A081',GetTriggerUnit())
call UnitAddAbilityBJ('A080',GetTriggerUnit())
call DisplayTextToPlayer(GetOwningPlayer(GetTriggerUnit()),0,0,"你开启了自动喝药")
else
endif
endif
endfunction
function InitTrig_zidongheyao takes nothing returns nothing
set gg_trg_zidongheyao=CreateTrigger()
call TriggerRegisterAnyUnitEventBJ(gg_trg_zidongheyao,EVENT_PLAYER_UNIT_SPELL_EFFECT)
call TriggerAddAction(gg_trg_zidongheyao,function Trig_zidongheyao_Actions)
endfunction
function Trig_zidongheyao2_Func001Func001C takes nothing returns boolean
if(not(udg_BB_TURE[udg_BBtime2]==true))then
return false
endif
if(not(IsUnitAliveBJ(udg_HERO[udg_BBtime2])==true))then
return false
endif
if(not(GetUnitAbilityLevelSwapped('A080',udg_HERO_BB[udg_BBtime2])==1))then
return false
endif
if(not(GetUnitStateSwap(UNIT_STATE_LIFE,udg_HERO[udg_BBtime2])<(GetUnitStateSwap(UNIT_STATE_MAX_LIFE,udg_HERO[udg_BBtime2])*(udg_BB_X[udg_BBtime2]/100.00))))then
return false
endif
return true
endfunction
function Trig_zidongheyao2_Func001Func002C takes nothing returns boolean
if(not(udg_BB_TURE[udg_BBtime2]==true))then
return false
endif
if(not(IsUnitAliveBJ(udg_HERO[udg_BBtime2])==true))then
return false
endif
if(not(GetUnitAbilityLevelSwapped('A080',udg_HERO_BB[udg_BBtime2])==1))then
return false
endif
if(not(GetUnitStateSwap(UNIT_STATE_MANA,udg_HERO[udg_BBtime2])<(GetUnitStateSwap(UNIT_STATE_MAX_MANA,udg_HERO[udg_BBtime2])*(udg_BB_Y[udg_BBtime2]/100.00))))then
return false
endif
return true
endfunction
function Trig_zidongheyao2_Actions takes nothing returns nothing
set udg_BBtime2=1
loop
exitwhen udg_BBtime2>12
if(Trig_zidongheyao2_Func001Func001C())then
call UnitUseItem(udg_HERO_BB[udg_BBtime2],UnitItemInSlotBJ(udg_HERO_BB[udg_BBtime2],1))
else
endif
if(Trig_zidongheyao2_Func001Func002C())then
call UnitUseItem(udg_HERO_BB[udg_BBtime2],UnitItemInSlotBJ(udg_HERO_BB[udg_BBtime2],2))
else
endif
set udg_BBtime2=udg_BBtime2+1
endloop
endfunction
function InitTrig_zidongheyao2 takes nothing returns nothing
set gg_trg_zidongheyao2=CreateTrigger()
call TriggerRegisterTimerEventPeriodic(gg_trg_zidongheyao2,5.00)
call TriggerAddAction(gg_trg_zidongheyao2,function Trig_zidongheyao2_Actions)
endfunction
function Trig_bbx_Actions takes nothing returns nothing
set udg_BB_X[GetConvertedPlayerId(GetTriggerPlayer())]=S2R(SubStringBJ(GetEventPlayerChatString(),3,4))
call DisplayTextToPlayer(GetTriggerPlayer(),0,0,(("你设置了珍兽使用生命药丹的百分比为："+"|CFF00FF00")+(R2S(udg_BB_X[GetConvertedPlayerId(GetTriggerPlayer())])+"%")))
endfunction
function InitTrig_bbx takes nothing returns nothing
set gg_trg_bbx=CreateTrigger()
call TriggerRegisterPlayerChatEvent(gg_trg_bbx,Player(0),"XM",false)
call TriggerRegisterPlayerChatEvent(gg_trg_bbx,Player(1),"XM",false)
call TriggerRegisterPlayerChatEvent(gg_trg_bbx,Player(2),"XM",false)
call TriggerRegisterPlayerChatEvent(gg_trg_bbx,Player(3),"XM",false)
