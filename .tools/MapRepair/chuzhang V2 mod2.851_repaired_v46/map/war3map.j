    set gg_trg_Freezing_Blast_On = CreateTrigger(  )
    call TriggerRegisterAnyUnitEventBJ( gg_trg_Freezing_Blast_On, EVENT_PLAYER_UNIT_SPELL_EFFECT )
    call TriggerAddCondition( gg_trg_Freezing_Blast_On, Condition( function Trig_Freezing_Blast_On_Conditions ) )
    call TriggerAddAction( gg_trg_Freezing_Blast_On, function Trig_Freezing_Blast_On_Actions )
endfunction

