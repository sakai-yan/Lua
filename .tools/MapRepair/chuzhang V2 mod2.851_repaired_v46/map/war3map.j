function Trig_Geyser_Jump_Loop_Actions takes nothing returns nothing
    set udg_GJ = 1
    loop
        exitwhen udg_GJ > udg_Times4
        if ( Trig_Geyser_Jump_Loop_Func001Func001C() ) then
            if ( Trig_Geyser_Jump_Loop_Func001Func001Func001C() ) then
                set udg_GJ_P[1] = GetUnitLoc(udg_GJ_Caster[udg_GJ])
                set udg_GJ_P[2] = PolarProjectionBJ(udg_GJ_P[1], udg_GJ_Speed[udg_GJ], AngleBetweenPoints(udg_GJ_P[1], udg_GJ_TARG[udg_GJ]))
                call SetUnitPositionLoc( udg_GJ_Caster[udg_GJ], udg_GJ_P[2] )
                call AddSpecialEffectTargetUnitBJ( "origin", udg_GJ_Caster[udg_GJ], "Abilities\\Weapons\\FrostWyrmMissile\\FrostWyrmMissile.mdl" )
                call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                if ( Trig_Geyser_Jump_Loop_Func001Func001Func001Func007C() ) then
                    if ( Trig_Geyser_Jump_Loop_Func001Func001Func001Func007Func003C() ) then
                        set udg_GJ_D_Switch[udg_GJ] = ( udg_GJ_D_Switch[udg_GJ] + udg_GJ_Speed[udg_GJ] )
                        call SetUnitFlyHeightBJ( udg_GJ_Caster[udg_GJ], ( GetUnitFlyHeight(udg_GJ_Caster[udg_GJ]) + ( DistanceBetweenPoints(udg_GJ_P[1], udg_GJ_Max[udg_GJ]) / udg_GJ_Division[udg_GJ] ) ), 0.00 )
                    else
                        set udg_GJ_YesorNO[udg_GJ] = true
                    endif
                else
                    if ( Trig_Geyser_Jump_Loop_Func001Func001Func001Func007Func001C() ) then
                        set udg_GJ_D_Switch[udg_GJ] = ( udg_GJ_D_Switch[udg_GJ] - udg_GJ_Speed[udg_GJ] )
                        call SetUnitFlyHeightBJ( udg_GJ_Caster[udg_GJ], ( GetUnitFlyHeight(udg_GJ_Caster[udg_GJ]) - ( DistanceBetweenPoints(udg_GJ_P[1], udg_GJ_Max[udg_GJ]) / udg_GJ_Division[udg_GJ] ) ), 0.00 )
                    else
                    endif
                endif
                call RemoveLocation(udg_GJ_P[1])
                call RemoveLocation(udg_GJ_P[2])
                if ( Trig_Geyser_Jump_Loop_Func001Func001Func001Func010C() ) then
                    call RemoveLocation(udg_GJ_Max[udg_GJ])
                    set udg_GJ_Group[udg_GJ] = GetUnitsInRangeOfLocMatching(260.00, udg_GJ_TARG[udg_GJ], Condition(function Trig_Geyser_Jump_Loop_Func001Func001Func001Func010Func002002003))
                    if ( Trig_Geyser_Jump_Loop_Func001Func001Func001Func010Func003C() ) then
                        call ForGroupBJ( udg_GJ_Group[udg_GJ], function Trig_Geyser_Jump_Loop_Func001Func001Func001Func010Func003Func002A )
                    else
                    endif
                    call TerrainDeformationCraterBJ( 0.08, true, udg_GJ_TARG[udg_GJ], 260.00, 100.00 )
                    set udg_GJ_Distance[udg_GJ] = 0.00
                    set udg_GJ_D_Switch[udg_GJ] = 0.00
                    set udg_GJ_Division[udg_GJ] = 0.00
                    set udg_GJ_YesorNO[udg_GJ] = false
                    set udg_GJ_Speed[udg_GJ] = 0.00
                    call SetUnitPathing( udg_GJ_Caster[udg_GJ], true )
                    call SetUnitInvulnerable( udg_GJ_Caster[udg_GJ], false )
                    set udg_GJ_Switch[udg_GJ] = 1
                else
                endif
            else
                if ( Trig_Geyser_Jump_Loop_Func001Func001Func001Func001C() ) then
                    if ( Trig_Geyser_Jump_Loop_Func001Func001Func001Func001Func001C() ) then
                        call TerrainDeformationCraterBJ( 0.5, true, udg_GJ_TARG[udg_GJ], 260.00, -100.00 )
                        call DestroyGroup(udg_GJ_Group[udg_GJ])
                        call RemoveLocation(udg_GJ_TARG[udg_GJ])
                        set udg_GJ_Distance[udg_GJ] = 0.00
                        set udg_GJ_Switch[udg_GJ] = 0
                        set udg_GJ_Timer[udg_GJ] = 0
                        call GroupRemoveUnitSimple( udg_GJ_Caster[udg_GJ], udg_GEYSERS )
                        set udg_GJ_Caster[udg_GJ] = null
                        if ( Trig_Geyser_Jump_Loop_Func001Func001Func001Func001Func001Func020C() ) then
                            set udg_Times4 = 0
                            call DisableTrigger( gg_trg_Geyser_Jump_Loop )
                        else
                        endif
                    else
                        // ////Eye Candy OPTIONAL \\\\
                        set udg_GJ_Distance[udg_GJ] = ( udg_GJ_Distance[udg_GJ] + 8.00 )
                        set udg_GJ_P[5] = PolarProjectionBJ(udg_GJ_TARG[udg_GJ], 185.00, ( AngleBetweenPoints(udg_GJ_TARG[udg_GJ], udg_GJ_P[5]) + udg_GJ_Distance[udg_GJ] ))
                        call AddSpecialEffectLocBJ( udg_GJ_P[5], "Abilities\\Weapons\\LichMissile\\LichMissile.mdl" )
                        call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                        if ( Trig_Geyser_Jump_Loop_Func001Func001Func001Func001Func001Func006C() ) then
                            call CreateNUnitsAtLoc( 1, 'b6f0', GetOwningPlayer(udg_GJ_Caster[udg_GJ]), udg_GJ_P[5], bj_UNIT_FACING )
                            call SetUnitFlyHeightBJ( GetLastCreatedUnit(), 2000.00, 1000000000.00 )
                            call ShowUnitHide( GetLastCreatedUnit() )
                            call UnitApplyTimedLifeBJ( 1.00, 'BTLF', GetLastCreatedUnit() )
                            call IssueTargetOrderBJ( GetLastCreatedUnit(), "chainlightning", GroupPickRandomUnit(udg_GJ_Group[udg_GJ]) )
                            call AddSpecialEffectLocBJ( udg_GJ_TARG[udg_GJ], "Objects\\Spawnmodels\\Naga\\NagaDeath\\NagaDeath.mdl" )
                            call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                        else
                        endif
                        call RemoveLocation(udg_GJ_P[5])
                        // \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
                        call ForGroupBJ( udg_GJ_Group[udg_GJ], function Trig_Geyser_Jump_Loop_Func001Func001Func001Func001Func001Func009A )
                        set udg_GJ_Timer[udg_GJ] = ( udg_GJ_Timer[udg_GJ] + 1 )
                        if ( Trig_Geyser_Jump_Loop_Func001Func001Func001Func001Func001Func011C() ) then
                            call ForGroupBJ( udg_GJ_Group[udg_GJ], function Trig_Geyser_Jump_Loop_Func001Func001Func001Func001Func001Func011Func001A )
                            call TerrainDeformationCraterBJ( 0.5, true, udg_GJ_TARG[udg_GJ], 260.00, -100.00 )
                            call DestroyGroup(udg_GJ_Group[udg_GJ])
                            call RemoveLocation(udg_GJ_TARG[udg_GJ])
                            set udg_GJ_Distance[udg_GJ] = 0.00
                            set udg_GJ_Switch[udg_GJ] = 0
                            set udg_GJ_Timer[udg_GJ] = 0
                            call GroupRemoveUnitSimple( udg_GJ_Caster[udg_GJ], udg_GEYSERS )
                            set udg_GJ_Caster[udg_GJ] = null
                            if ( Trig_Geyser_Jump_Loop_Func001Func001Func001Func001Func001Func011Func010C() ) then
                                set udg_Times4 = 0
                                call DisableTrigger( gg_trg_Geyser_Jump_Loop )
                            else
                            endif
                        else
                        endif
                    endif
                else
                endif
            endif
        else
        endif
        set udg_GJ = udg_GJ + 1
    endloop
endfunction

