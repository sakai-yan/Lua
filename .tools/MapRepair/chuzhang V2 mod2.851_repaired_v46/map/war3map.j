    return GetBooleanAnd( Trig_Freezing_Blast_Loop_Func001Func001Func002Func008002003001(), Trig_Freezing_Blast_Loop_Func001Func001Func002Func008002003002() )
endfunction

function Trig_Freezing_Blast_Loop_Func001Func001Func002Func009A takes nothing returns nothing
    call AddSpecialEffectTargetUnitBJ( "chest", GetEnumUnit(), udg_SPtmdriaecial_effect1[udg_Loop] )
    call DestroyEffectBJ( GetLastCreatedEffectBJ() )
endfunction

function Trig_Freezing_Blast_Loop_Func001Func001Func002Func016Func001002003001 takes nothing returns boolean
    return ( GetOwningPlayer(GetFilterUnit()) != GetOwningPlayer(udg_Caster[udg_Loop]) )
endfunction

function Trig_Freezing_Blast_Loop_Func001Func001Func002Func016Func001002003002 takes nothing returns boolean
    return ( IsUnitAliveBJ(GetFilterUnit()) == true )
endfunction

function Trig_Freezing_Blast_Loop_Func001Func001Func002Func016Func001002003 takes nothing returns boolean
    return GetBooleanAnd( Trig_Freezing_Blast_Loop_Func001Func001Func002Func016Func001002003001(), Trig_Freezing_Blast_Loop_Func001Func001Func002Func016Func001002003002() )
endfunction

function Trig_Freezing_Blast_Loop_Func001Func001Func002Func016Func002A takes nothing returns nothing
    set udg_Targeted[udg_Loop] = null
    set udg_Targeted[udg_Loop] = GroupPickRandomUnit(udg_Collision[udg_Loop])
    set udg_Angel[udg_Loop] = GetUnitFacing(udg_Arrow[udg_Loop])
    call GroupRemoveUnitSimple( udg_Arrow[udg_Loop], udg_ARROWS )
    call UnitApplyTimedLifeBJ( 0.10, 'BTLF', udg_Arrow[udg_Loop] )
    set udg_SPtmdriaeed[udg_Loop] = 12.00
    set udg_Arrow[udg_Loop] = null
    set udg_Knock[udg_Loop] = 1
    call GroupAddUnitSimple( udg_Targeted[udg_Loop], udg_TARGETED )
    // ---MODIFICATED BY THIS---
    set udg_Pointtmdria[99] = GetUnitLoc(udg_Targeted[udg_Loop])
    // ---CALCULATING DAMAGE---
    set udg_Damage_formula[udg_Loop] = ( ( DistanceBetweenPoints(udg_Create_point[udg_Loop], udg_Pointtmdria[99]) / udg_Distance_fragment[udg_Loop] ) * ( ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, udg_Targeted[udg_Loop]) / 100.00 ) * udg_Damage_per_fragment[udg_Loop] ) )
    // ---
    call UnitDamageTargetBJ( udg_Caster[udg_Loop], udg_Targeted[udg_Loop], udg_Damage_formula[udg_Loop], ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL )
    set udg_LVsLV=(I2R(GetHeroLevel(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))/I2R(GetUnitLevel(GetEnumUnit())))
    call UnitDamageTargetBJ(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],GetEnumUnit(),(((I2R(GetHeroInt(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],true))*2+2*udg_JX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])-udg_FK[GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))])*((1.00*udg_LVsLV)*(1.25+(0.09*I2R(udg_JX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])))))*0.5,ATTACK_TYPE_NORMAL,DAMAGE_TYPE_COLD)
           /////////// bf60 11  0.5



    // ---
    // ---END OF MODIFICATION---
    call SetUnitFacingTimed( udg_Targeted[udg_Loop], udg_Angel[udg_Loop], 0.03 )
    call RemoveLocation(udg_Pointtmdria[99])
    call RemoveLocation(udg_Create_point[udg_Loop])
endfunction

function Trig_Freezing_Blast_Loop_Func001Func001Func002Func016C takes nothing returns boolean
    if ( not ( DistanceBetweenPoints(udg_Pointtmdria[2], udg_Pointtmdria[3]) <= 45.00 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Freezing_Blast_Loop_Func001Func001Func002C takes nothing returns boolean
    if ( not ( udg_Knock[udg_Loop] == 0 ) ) then
        return false
    endif
    return true
endfunction

function Trig_Freezing_Blast_Loop_Func001Func001C takes nothing returns boolean
    if ( not ( IsUnitInGroup(udg_Arrow[udg_Loop], udg_ARROWS) == true ) ) then
        return false
    endif
    return true
endfunction

function Trig_Freezing_Blast_Loop_Actions takes nothing returns nothing
    set udg_Loop = 1
    loop
        exitwhen udg_Loop > udg_Times[1]
        if ( Trig_Freezing_Blast_Loop_Func001Func001C() ) then
            if ( Trig_Freezing_Blast_Loop_Func001Func001Func002C() ) then
                set udg_Pointtmdria[1] = GetUnitLoc(udg_Arrow[udg_Loop])
                set udg_Pointtmdria[3] = GetUnitLoc(udg_Targeted[udg_Loop])
                set udg_Angel[udg_Loop] = AngleBetweenPoints(udg_Pointtmdria[1], udg_Pointtmdria[3])
                set udg_Pointtmdria[2] = PolarProjectionBJ(udg_Pointtmdria[1], udg_SPtmdriaeed[udg_Loop], udg_Angel[udg_Loop])
                call SetUnitPositionLoc( udg_Arrow[udg_Loop], udg_Pointtmdria[2] )
                // EYE CANDY OPTIONAL
                set udg_SPtmdriaeedBlast[udg_Loop] = GetUnitsInRangeOfLocMatching(145.00, udg_Pointtmdria[2], Condition(function Trig_Freezing_Blast_Loop_Func001Func001Func002Func008002003))
                call ForGroupBJ( udg_SPtmdriaeedBlast[udg_Loop], function Trig_Freezing_Blast_Loop_Func001Func001Func002Func009A )
                call DestroyGroup(udg_SPtmdriaeedBlast[udg_Loop])
                call AddSpecialEffectLocBJ( udg_Pointtmdria[1], udg_SPtmdriaecial_effect2[udg_Loop] )
                call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                set udg_Angel[udg_Loop] = 0.00
                // Do not Increase more than 2.5 or it will not hit the unit >>
                set udg_SPtmdriaeed[udg_Loop] = ( udg_SPtmdriaeed[udg_Loop] + 0.50 )
                if ( Trig_Freezing_Blast_Loop_Func001Func001Func002Func016C() ) then
                    set udg_Angel[udg_Loop] = GetUnitFacing(udg_Arrow[udg_Loop])
                    call GroupRemoveUnitSimple( udg_Arrow[udg_Loop], udg_ARROWS )
                    call UnitApplyTimedLifeBJ( 0.10, 'BTLF', udg_Arrow[udg_Loop] )
                    set udg_SPtmdriaeed[udg_Loop] = 12.00
                    set udg_Arrow[udg_Loop] = null
                    set udg_Knock[udg_Loop] = 1
                    call GroupAddUnitSimple( udg_Targeted[udg_Loop], udg_TARGETED )
                    // ---MODIFICATED BY THIS---
                    set udg_Pointtmdria[99] = GetUnitLoc(udg_Targeted[udg_Loop])
                    // ---CALCULATING DAMAGE---
                    set udg_Damage_formula[udg_Loop] = ( ( DistanceBetweenPoints(udg_Create_point[udg_Loop], udg_Pointtmdria[99]) / udg_Distance_fragment[udg_Loop] ) * ( ( GetUnitStateSwap(UNIT_STATE_MAX_LIFE, udg_Targeted[udg_Loop]) / 100.00 ) * udg_Damage_per_fragment[udg_Loop] ) )
                    // ---
                    call UnitDamageTargetBJ( udg_Caster[udg_Loop], udg_Targeted[udg_Loop], udg_Damage_formula[udg_Loop], ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL )

                    set udg_LVsLV=(I2R(GetHeroLevel(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]))/I2R(GetUnitLevel(GetEnumUnit())))
                    call UnitDamageTargetBJ(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],GetEnumUnit(),(((I2R(GetHeroInt(udg_HERO[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))],true))+udg_FX[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])-udg_FK[GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))])*((1.00*udg_LVsLV)*(1.25+(0.09*I2R(udg_FX_lv[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))])))))*0.3,ATTACK_TYPE_NORMAL,DAMAGE_TYPE_FIRE)
                           ////////////bf60 22 0.3



                    // ---
                    // ---END OF MODIFICATION---
                    call SetUnitFacingTimed( udg_Targeted[udg_Loop], udg_Angel[udg_Loop], 0.03 )
                    call RemoveLocation(udg_Pointtmdria[99])
                    call RemoveLocation(udg_Create_point[udg_Loop])
                else
                    set udg_Collision[udg_Loop] = GetUnitsInRangeOfLocMatching(65.00, udg_Pointtmdria[2], Condition(function Trig_Freezing_Blast_Loop_Func001Func001Func002Func016Func001002003))
                    call ForGroupBJ( udg_Collision[udg_Loop], function Trig_Freezing_Blast_Loop_Func001Func001Func002Func016Func002A )
                    call DestroyGroup(udg_Collision[udg_Loop])
                endif
                call RemoveLocation(udg_Pointtmdria[1])
                call RemoveLocation(udg_Pointtmdria[3])
                call RemoveLocation(udg_Pointtmdria[2])
            else
            endif
        else
            if ( Trig_Freezing_Blast_Loop_Func001Func001Func001C() ) then
                if ( Trig_Freezing_Blast_Loop_Func001Func001Func001Func002C() ) then
                    set udg_Pointtmdria[5] = GetUnitLoc(udg_Targeted[udg_Loop])
                    set udg_SPtmdriaeed[udg_Loop] = ( udg_Distance[udg_Loop] / udg_Formula[udg_Loop] )
                    set udg_SPtmdriaeed[udg_Loop] = ( udg_SPtmdriaeed[udg_Loop] + 0.50 )
                    set udg_Pointtmdria[6] = PolarProjectionBJ(udg_Pointtmdria[5], udg_SPtmdriaeed[udg_Loop], udg_Angel[udg_Loop])
                    call SetUnitPositionLoc( udg_Targeted[udg_Loop], udg_Pointtmdria[6] )
                    call EnumDestructablesInCircleBJ( 150.00, udg_Pointtmdria[6], function Trig_Freezing_Blast_Loop_Func001Func001Func001Func002Func006A )
                    if ( Trig_Freezing_Blast_Loop_Func001Func001Func001Func002Func007C() ) then
                        call AddSpecialEffectLocBJ( udg_Pointtmdria[5], udg_SPtmdriaecial_effect3[udg_Loop] )
                        call DestroyEffectBJ( GetLastCreatedEffectBJ() )
                    else
                    endif
                    call RemoveLocation(udg_Pointtmdria[5])
                    call RemoveLocation(udg_Pointtmdria[6])
                    set udg_Distance[udg_Loop] = ( udg_Distance[udg_Loop] - udg_SPtmdriaeed[udg_Loop] )
                    if ( Trig_Freezing_Blast_Loop_Func001Func001Func001Func002Func011C() ) then
                        call GroupRemoveUnitSimple( udg_Targeted[udg_Loop], udg_TARGETED )
                        set udg_Angel[udg_Loop] = 0.00
                        set udg_Knock[udg_Loop] = 0
                        set udg_Formula[udg_Loop] = 0.00
                        set udg_Targeted[udg_Loop] = null
                        set udg_SPtmdriaeed[udg_Loop] = 0.00
                        set udg_Distance[udg_Loop] = 0.00
                        set udg_Caster[udg_Loop] = null
                        if ( Trig_Freezing_Blast_Loop_Func001Func001Func001Func002Func011Func009C() ) then
                            set udg_Times[1] = 0
                            call DisableTrigger( gg_trg_Freezing_Blast_Loop )
                        else
                        endif
                    else
                    endif
                else
                endif
            else
            endif
        endif
        set udg_Loop = udg_Loop + 1
    endloop
endfunction

