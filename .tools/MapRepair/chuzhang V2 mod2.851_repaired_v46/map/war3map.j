call TriggerRegisterPlayerChatEvent(gg_trg_jingtou2,Player(6),"英雄模式",true)
call TriggerRegisterPlayerChatEvent(gg_trg_jingtou2,Player(7),"英雄模式",true)
call TriggerRegisterPlayerChatEvent(gg_trg_jingtou2,Player(8),"英雄模式",true)
call TriggerRegisterPlayerChatEvent(gg_trg_jingtou2,Player(9),"英雄模式",true)
