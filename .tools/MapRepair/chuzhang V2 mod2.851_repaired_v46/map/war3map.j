return false
endif
return true
endfunction
function Trig_pingzhang_Actions takes nothing returns nothing
set udg_pzWarper=GetTriggerUnit()
set udg_pzWarperCastPoint=GetUnitLoc(GetTriggerUnit())
set bj_forLoopAIndex=1
set bj_forLoopAIndexEnd=36
loop
exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
call CreateNUnitsAtLoc(1,'mfpz',GetOwningPlayer(udg_pzWarper),udg_pzWarperCastPoint,(I2R(GetForLoopIndexA())*10.00))
set udg_pzbarrier[GetForLoopIndexA()]=GetLastCreatedUnit()
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
call EnableTrigger(gg_trg_pingzhang2)
call TriggerSleepAction(10.00)
call DisableTrigger(gg_trg_pingzhang2)
set bj_forLoopAIndex=1
set bj_forLoopAIndexEnd=9
loop
exitwhen bj_forLoopAIndex>bj_forLoopAIndexEnd
call TriggerSleepAction((0.01/100.00))
call RemoveUnit(udg_pzbarrier[GetForLoopIndexA()])
call RemoveUnit(udg_pzbarrier[R2I((I2R(GetForLoopIndexA())+9.00))])
call RemoveUnit(udg_pzbarrier[R2I((I2R(GetForLoopIndexA())+18.00))])
call RemoveUnit(udg_pzbarrier[R2I((I2R(GetForLoopIndexA())+27.00))])
set bj_forLoopAIndex=bj_forLoopAIndex+1
endloop
endfunction
