        endif
        if ( ( HaveSavedBoolean(YDHT, GetHandleId(GetEnumItem()), 0x00F48EBF) == true ) ) then
            call FlushChildHashtable(YDHT, GetHandleId(GetEnumItem()))
            call RemoveItem(GetEnumItem())
        else
            call SaveBoolean(YDHT, GetHandleId(GetEnumItem()), 0x00F48EBF, true)
        endif
    else
    endif
endfunction
