            if ( ( LoadReal(YDHT, udg_WP[ydul_WP], 0xA65B3CF5) != 0.00 ) ) then
                call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09) ) + ( "|n法抗: + " ) + ( I2S(R2I(LoadReal(YDHT, udg_WP[ydul_WP], 0xA65B3CF5))) ) ))
            else
