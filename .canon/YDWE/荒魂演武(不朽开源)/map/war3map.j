    if ( ( YDWEUnitHasItemOfTypeBJNull(GetBuyingUnit() , 'I07B') == true ) and ( GetSellingUnit() == gg_unit_n03E_0223 ) ) then
        call RemoveItem(YDWEGetItemOfTypeFromUnitBJNull(GetBuyingUnit() , 'I07B'))
        call UnitAddItemByIdSwapped('I07A', GetBuyingUnit())
        call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cffffff00这是给您的奖励|r")
