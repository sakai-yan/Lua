    call SaveLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA, GetUnitLoc(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)))
    if ( ( DistanceBetweenPoints(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA), LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382)) <= 200.00 ) and ( GetUnitCurrentOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x8B1FFFFC)) == String2OrderIdBJ("move") ) ) then
