endfunction
//===========================================================================
// Trigger: 获得物品B
//===========================================================================
function Trig_____________BConditions takes nothing returns boolean
    return ( ( IsItemPowerup(GetManipulatedItem()) == false ) )
endfunction
function Trig_____________BActions takes nothing returns nothing
    local integer ydul_x
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x556E03EA, ( LoadInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x556E03EA) + LoadInteger(YDHT, GetItemTypeId(GetManipulatedItem()), 0xC1C7B969) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x59E18EE2, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x59E18EE2) + LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x59E18EE2) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xAAFAF365, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xAAFAF365) + LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xAAFAF365) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xA65B3CF5, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xA65B3CF5) + LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xA65B3CF5) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x1B5F3A6A, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x1B5F3A6A) + LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xBFA256FF) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x636DFFD3, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x636DFFD3) + LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x636DFFD3) ))
