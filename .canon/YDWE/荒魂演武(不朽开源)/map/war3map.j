function InitTrig_6C takes nothing returns nothing
    set gg_trg_6C=CreateTrigger()
    call DisableTrigger(gg_trg_6C)
    call TriggerRegisterAnyUnitEventBJ(gg_trg_6C, EVENT_PLAYER_UNIT_ISSUED_POINT_ORDER)
    call TriggerAddCondition(gg_trg_6C, Condition(function Trig_6CConditions))
    call TriggerAddAction(gg_trg_6C, function Trig_6CActions)
endfunction
