function Trig_020_2Actions takes nothing returns nothing
    local timer ydl_timer
    local integer ydul_x
    local group ydl_group
    local unit ydl_unit
    if ( ( GetClickedButtonBJ() != udg_WJdhkan[9] ) ) then
        set ydul_x=1
        loop
            exitwhen ydul_x > 3
            if ( ( GetClickedButtonBJ() == udg_WJdhkan[ydul_x] ) ) then
                set udg_WJ_LV=LoadInteger(YDHT, GetHandleId(udg_WJdhkan[ydul_x]), 0x67F63465)
                call DisplayTimedTextToForce(GetPlayersAll(), 30, ( ( "MVP玩家选择进入无尽模式！开始波数： " ) + ( I2S(udg_WJ_LV) ) + ( " 所有玩家有1分钟准备时间！" ) ))
                call ForGroupBJ(YDWEGetUnitsOfPlayerAllNull(Player(PLAYER_NEUTRAL_AGGRESSIVE)), function Trig_020_2Func001Func003Func001Func003A)
                call TriggerExecute(gg_trg_wj1_____________u)
                call DoNothing()
 exitwhen true //(  )
            else
            endif
            set ydul_x=ydul_x + 1
        endloop
    else
        call DisplayTimedTextToForce(GetPlayersAll(), 30, "MVP玩家未选择开启无尽模式！游戏结束！")
        set ydl_timer=CreateTimer()
        call TimerStart(ydl_timer, 5.00, false, function Trig_020_2Func001Func002T)
    endif
    call DestroyTrigger(GetTriggeringTrigger())
    set ydl_timer=null
    set ydl_group=null
    set ydl_unit=null
endfunction
