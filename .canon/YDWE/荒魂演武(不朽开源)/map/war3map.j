            call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x1B5F3A6A, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x1B5F3A6A) + 0.10 ))
            call AddPlayerTechResearched(GetOwningPlayer(GetTriggerUnit()), 'R001', 1)
            call DestroyTrigger(GetTriggeringTrigger())
        else
            call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xE2DD07B4, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xE2DD07B4) + 0.10 ))
            call SaveInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x556E03EA, ( LoadInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x556E03EA) + 5 ))
