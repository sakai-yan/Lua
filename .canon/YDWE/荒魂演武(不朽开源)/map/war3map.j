function Trig_15W2Conditions takes nothing returns boolean
    return ( ( GetRandomReal(0, 0.10) <= ( 0.03 + ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0xE98AD181) * 0.14 ) ) ) )
endfunction
function Trig_15W2Func001Func005Conditions takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    if ( ( YDWEIsEventAttackDamage() == true ) and ( GetEventDamageSource() == LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xBB85B401) ) ) then
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA99320FA, GetUnitX(GetTriggerUnit()))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xFDF65382, GetUnitY(GetTriggerUnit()))
        if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x3864ED47) == 1 ) ) then
            call SaveEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA4FCAD46, AddSpecialEffect("TX_xfz.mdx", GetUnitX(GetEventDamageSource()), GetUnitY(GetEventDamageSource())))
            call EXSetEffectSize(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA4FCAD46), ( ( 2.00 ) + ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xE98AD181) ) ))
            call EXEffectMatRotateZ(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA4FCAD46), YDWEAngleBetweenUnits(GetEventDamageSource() , GetTriggerUnit()))
            call EXSetEffectSpeed(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA4FCAD46), 4.00)
            call DestroyEffect(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA4FCAD46))
        else
            call SaveEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA4FCAD46, AddSpecialEffect("TX_xfz.mdx", GetUnitX(GetEventDamageSource()), GetUnitY(GetEventDamageSource())))
            call EXEffectMatScale(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA4FCAD46), 1.00, - 1.00, 1.00)
            call EXSetEffectSize(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA4FCAD46), ( ( 2.00 ) + ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xE98AD181) ) ))
            call EXEffectMatRotateZ(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA4FCAD46), YDWEAngleBetweenUnits(GetEventDamageSource() , GetTriggerUnit()))
            call EXSetEffectSpeed(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA4FCAD46), 4.00)
            call DestroyEffect(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA4FCAD46))
        endif
        call QueueUnitAnimation(GetEventDamageSource(), "stand ready")
        set ydl_group=CreateGroup()
        call GroupEnumUnitsInRange(ydl_group, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA99320FA), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xFDF65382), ( ( 250.00 ) + ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xE98AD181) ) * ( 140.00 ) ), null)
        loop
            set ydl_unit=FirstOfGroup(ydl_group)
            exitwhen ydl_unit == null
            call GroupRemoveUnit(ydl_group, ydl_unit)
            if ( ( IsUnitEnemy(ydl_unit, GetOwningPlayer(GetEventDamageSource())) == true ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) ) then
                call UnitDamageTarget(GetEventDamageSource(), ydl_unit, ( ( I2R(GetUnitAbilityLevel(GetEventDamageSource(), 'A064')) * 500.00 ) + ( GetUnitState(GetEventDamageSource(), ConvertUnitState(0x15)) * ( 3.00 + LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xE98AD181) ) ) ), false, false, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_METAL_HEAVY_SLICE)
            else
            endif
        endloop
        call DestroyGroup(ydl_group)
    else
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()))
    call DestroyTrigger(GetTriggeringTrigger())
    set ydl_group=null
    set ydl_unit=null
endfunction
function Trig_15W2Func001T takes nothing returns nothing
    local trigger ydl_trigger
    call SaveUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xBB85B401, LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x86A02DAE, RMinBJ(GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xBB85B401), ConvertUnitState(0x51)), 5.00))
    call SaveInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x3864ED47, GetRandomInt(1, 2))
