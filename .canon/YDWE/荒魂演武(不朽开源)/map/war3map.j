            // 最后
            if ( ( HaveSavedString(YDHT, udg_WP[ydul_WP], 0x7602A218) == true ) ) then
                call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09, ( ( LoadStr(YDHT, udg_WP[ydul_WP], 0xB1B52F49) ) + ( ( ( ( "  |CFFFED312" ) + ( LoadStr(YDHT, udg_WP[ydul_WP], 0x7602A218) ) + ( "|r" ) ) + LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09) ) ) + ( "|n" ) ))
            else
