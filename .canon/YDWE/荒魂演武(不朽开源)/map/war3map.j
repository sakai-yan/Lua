function Trig_______UI_______uFunc054Func002Func022FT takes nothing returns nothing
    call SaveInteger(YDLOC, 0x3E338A2A, 0xA99320FA, DzF2I(DzGetTriggerUIEventFrame()))
    call SaveInteger(YDLOC, 0x3E338A2A, 0x1ADEDE7B, LoadInteger(YDHT, LoadInteger(YDLOC, 0x3E338A2A, 0xA99320FA), 0x5F0E88EF))
    if ( ( LoadInteger(udg_HXB, GetConvertedPlayerId(DzGetTriggerUIEventPlayer()), LoadInteger(YDLOC, 0x3E338A2A, 0x1ADEDE7B)) == 1 ) ) then
        if ( ( HaveSavedString(YDHT, GetItemTypeId(LoadItemHandle(udg_HXB, GetConvertedPlayerId(DzGetTriggerUIEventPlayer()), LoadInteger(YDLOC, 0x3E338A2A, 0x1ADEDE7B))), 0x6945FB09) == true ) ) then
            call SaveStr(YDLOC, 0x3E338A2A, 0x90F4A78E, ( ( ( GetItemName(LoadItemHandle(udg_HXB, GetConvertedPlayerId(DzGetTriggerUIEventPlayer()), LoadInteger(YDLOC, 0x3E338A2A, 0x1ADEDE7B))) + "|n|n" ) ) + ( LoadStr(YDHT, GetItemTypeId(LoadItemHandle(udg_HXB, GetConvertedPlayerId(DzGetTriggerUIEventPlayer()), LoadInteger(YDLOC, 0x3E338A2A, 0x1ADEDE7B))), 0x6945FB09) ) + ( ( "|n" + LoadStr(YDHT, GetItemTypeId(LoadItemHandle(udg_HXB, GetConvertedPlayerId(DzGetTriggerUIEventPlayer()), LoadInteger(YDLOC, 0x3E338A2A, 0x1ADEDE7B))), 0xC3C655B7) ) ) ))
        else
            call SaveStr(YDLOC, 0x3E338A2A, 0x90F4A78E, ( GetItemName(LoadItemHandle(udg_HXB, GetConvertedPlayerId(DzGetTriggerUIEventPlayer()), LoadInteger(YDLOC, 0x3E338A2A, 0x1ADEDE7B))) + ( "|n|n" + YDWEGetItemDataString(GetItemTypeId(LoadItemHandle(udg_HXB, GetConvertedPlayerId(DzGetTriggerUIEventPlayer()), LoadInteger(YDLOC, 0x3E338A2A, 0x1ADEDE7B))) , 3) ) ))
        endif
        call DzFrameSetText(udg_UIWB, LoadStr(YDLOC, 0x3E338A2A, 0x90F4A78E))
        call SaveStr(YDLOC, 0x3E338A2A, 0x90F4A78E, "")
    else
        call DzFrameSetText(udg_UIWB, "")
    endif
    call SaveInteger(YDLOC, 0x3E338A2A, 0xA99320FA, 0)
    call SaveInteger(YDLOC, 0x3E338A2A, 0x1ADEDE7B, 0)
endfunction
