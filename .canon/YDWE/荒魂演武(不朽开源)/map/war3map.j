    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0xE978590C, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE978590C))
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x62DD4FAA, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x62DD4FAA))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x91D9239B, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x91D9239B))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x25947577, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x25947577))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x6BB2DE8A, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6BB2DE8A))
    call TimerStart(ydl_timer, 0.10, false, function Trig_10C1Func017T)
