//===========================================================================
function Trig_00003Conditions takes nothing returns boolean
    return ( ( GetSpellAbilityId() == 'A05L' ) )
endfunction
function Trig_00003Actions takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    local integer ydl_triggerstep
    local trigger ydl_trigger
    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Orc\\WarStomp\\WarStompCaster.mdl", GetTriggerUnit(), "origin"))
    set ydl_group=CreateGroup()
    call GroupEnumUnitsInRange(ydl_group, GetUnitX(GetTriggerUnit()), GetUnitY(GetTriggerUnit()), 350.00, null)
    loop
        set ydl_unit=FirstOfGroup(ydl_group)
        exitwhen ydl_unit == null
        call GroupRemoveUnit(ydl_group, ydl_unit)
        if ( ( IsUnitEnemy(ydl_unit, GetOwningPlayer(GetTriggerUnit())) == true ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) ) then
            call UnitDamageTarget(GetTriggerUnit(), ydl_unit, ( GetUnitState(GetTriggerUnit(), ConvertUnitState(0x15)) * 3.00 ), false, false, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
            set ydl_trigger=gg_trg_______1A
            set ydl_triggerstep=GetHandleId(ydl_trigger) * ( LoadInteger(YDLOC, GetHandleId(ydl_trigger), 0xCFDE6C76) + 3 )
            call SaveUnitHandle(YDLOC, ydl_triggerstep, 0x911D5DC2, ydl_unit)
            call SaveReal(YDLOC, ydl_triggerstep, 0x312C4181, 3.00)
            call TriggerExecute(ydl_trigger)
        else
        endif
    endloop
    call DestroyGroup(ydl_group)
    set ydl_group=null
    set ydl_unit=null
    set ydl_trigger=null
endfunction
