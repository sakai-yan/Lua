    else
        call CreateTextTagUnitBJ("|cff00ff00闪躲|r", LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x4C5B9A34), 0, 12.00, 100.00, 100.00, 100.00, 0)
        call SetTextTagPermanent(GetLastCreatedTextTag(), false)
        call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
        call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 85.00, ( GetRandomReal(0.00, 360.00) ))
