//===========================================================================
// Trigger: 0
//===========================================================================
function Trig_0Func002A takes nothing returns nothing
    if ( ( ( DzAPI_Map_IsAuthor(GetEnumPlayer()) == true ) or ( DzAPI_Map_HasMallItem(GetEnumPlayer(), "H1") == true ) ) ) then
        call AddPlayerTechResearched(GetEnumPlayer(), 'R003', 1)
    else
    endif
    if ( ( ( DzAPI_Map_HasMallItem(GetEnumPlayer(), "H2") == true ) or ( DzAPI_Map_IsAuthor(GetEnumPlayer()) == true ) ) ) then
        call AddPlayerTechResearched(GetEnumPlayer(), 'R005', 1)
    else
    endif
    if ( ( ( DzAPI_Map_HasMallItem(GetEnumPlayer(), "H4") == true ) or ( DzAPI_Map_IsAuthor(GetEnumPlayer()) == true ) ) ) then
        call AddPlayerTechResearched(GetEnumPlayer(), 'R007', 1)
    else
    endif
    if ( ( ( DzAPI_Map_HasMallItem(GetEnumPlayer(), "H3") == true ) or ( DzAPI_Map_IsAuthor(GetEnumPlayer()) == true ) ) ) then
        call AddPlayerTechResearched(GetEnumPlayer(), 'R006', 1)
    else
    endif
    if ( ( ( ( YDWEGetIntegerByInteger(4 , GetConvertedPlayerId(GetEnumPlayer())) ) / ( 100 ) ) >= 50 ) ) then
        call AddPlayerTechResearched(GetEnumPlayer(), 'R004', 1)
    else
    endif
    if ( ( ( ( YDWEGetIntegerByInteger(4 , GetConvertedPlayerId(GetEnumPlayer())) ) / ( 100 ) ) >= 120 ) ) then
        call AddPlayerTechResearched(GetEnumPlayer(), 'R008', 1)
    else
    endif
    if ( ( ( DzAPI_Map_HasMallItem(GetEnumPlayer(), "B1") == true ) or ( DzAPI_Map_IsAuthor(GetEnumPlayer()) == true ) ) ) then
        call AdjustPlayerStateBJ(1000, GetEnumPlayer(), PLAYER_STATE_RESOURCE_GOLD)
        call DisplayTimedTextToPlayer(GetEnumPlayer(), 0, 0, 10.00, "|cffff0000 【福利】|r|cffff9900：您已购买开局金币礼包，开局金币额外增加1000！|r")
    else
    endif
    if ( ( ( DzAPI_Map_HasMallItem(GetEnumPlayer(), "B2") == true ) or ( DzAPI_Map_IsAuthor(GetEnumPlayer()) == true ) ) ) then
        call DisplayTimedTextToPlayer(GetEnumPlayer(), 0, 0, 10.00, "|cffff0000 【福利】|r|cffff9900：您已购买开局战魂礼包，开局战魂额外增加50！|r")
        call AdjustPlayerStateBJ(50, GetEnumPlayer(), PLAYER_STATE_RESOURCE_LUMBER)
    else
    endif
    if ( ( ( DzAPI_Map_HasMallItem(GetEnumPlayer(), "B3") == true ) or ( DzAPI_Map_IsAuthor(GetEnumPlayer()) == true ) ) ) then
        call DisplayTimedTextToPlayer(GetEnumPlayer(), 0, 0, 10.00, "|cffff0000 【疾风祝福】|r|cffff9900：您拥有“疾风祝福”，英雄攻速+40%。移速+35|r")
    else
    endif
    if ( ( ( DzAPI_Map_HasMallItem(GetEnumPlayer(), "B4") == true ) or ( DzAPI_Map_IsAuthor(GetEnumPlayer()) == true ) ) ) then
        call DisplayTimedTextToPlayer(GetEnumPlayer(), 0, 0, 10.00, "|cffff0000 【统御之冠】|r|cffff9900：英雄物理/法术暴击率+5%、英雄物理/法术暴击上限+20%、英雄总攻击力+10%！、英雄总法术伤害+10%！|r")
    else
    endif
endfunction
