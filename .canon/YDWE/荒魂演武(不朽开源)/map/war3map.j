 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA, GetSpellTargetItem())
    set ydul_X=1
    loop
        exitwhen ydul_X > 40
        if ( ( LoadInteger(udg_HXB, GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit())), ydul_X) == 1 ) and ( GetItemTypeId(LoadItemHandle(udg_HXB, GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit())), ydul_X)) == GetItemTypeId(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA)) ) and ( GetItemType(LoadItemHandle(udg_HXB, GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit())), ydul_X)) == ITEM_TYPE_CHARGED ) ) then
            if ( ( GetOwningPlayer(GetTriggerUnit()) == GetLocalPlayer() ) ) then
                call DzFrameSetText(udg_ZBCS[ydul_X], I2S(( ( GetItemCharges(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA)) ) + ( GetItemCharges(LoadItemHandle(udg_HXB, GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit())), ydul_X)) ) )))
            else
            endif
            call SetItemCharges(LoadItemHandle(udg_HXB, GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit())), ydul_X), ( GetItemCharges(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA)) + GetItemCharges(LoadItemHandle(udg_HXB, GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit())), ydul_X)) ))
            call RemoveItem(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA))
            call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF5C06594, 1)
            call DoNothing()
 exitwhen true //(  )
        else
        endif
        set ydul_X=ydul_X + 1
    endloop
    if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF5C06594) != 1 ) ) then
        set ydul_X=1
        loop
            exitwhen ydul_X > 40
            if ( ( LoadInteger(udg_HXB, GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit())), ydul_X) == 0 ) ) then
                call SaveInteger(udg_HXB, GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit())), ydul_X, 1)
                if ( ( GetOwningPlayer(GetTriggerUnit()) == GetLocalPlayer() ) ) then
                    call DzFrameSetTexture(udg_ZBTB[ydul_X], YDWEGetItemDataString(GetItemTypeId(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA)) , 1), 0)
                    call DzFrameShow(udg_ZBTB[ydul_X], true)
                    if ( ( GetItemType(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA)) == ITEM_TYPE_CHARGED ) ) then
                        call DzFrameSetText(udg_ZBCS[ydul_X], I2S(GetItemCharges(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA))))
                        call DzFrameShow(udg_ZBCS[ydul_X], true)
                    else
                        call DzFrameShow(udg_ZBCS[ydul_X], false)
                    endif
                else
                endif
                call SaveItemHandle(udg_HXB, GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit())), ydul_X, LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA))
                call SetItemPosition(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), 3637.00, - 8158.00)
                call SetItemVisible(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), false)
                call DoNothing()
 exitwhen true //(  )
            else
            endif
            set ydul_X=ydul_X + 1
        endloop
    else
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
//===========================================================================
function InitTrig_____________2 takes nothing returns nothing
    set gg_trg_____________2=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_____________2, EVENT_PLAYER_UNIT_SPELL_CHANNEL)
    call TriggerAddCondition(gg_trg_____________2, Condition(function Trig_____________2Conditions))
    call TriggerAddAction(gg_trg_____________2, function Trig_____________2Actions)
endfunction
