    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetTriggerPlayer())]), 0x2F591435, ( ( 100.00 ) + ( I2R(GetHeroStr(udg_Hero[1], true)) ) * ( 25.00 ) ))
