function InitTrig_______2 takes nothing returns nothing
    set gg_trg_______2=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_______2, EVENT_PLAYER_UNIT_SELL_ITEM)
    call TriggerAddCondition(gg_trg_______2, Condition(function Trig_______2Conditions))
    call TriggerAddAction(gg_trg_______2, function Trig_______2Actions)
endfunction
//===========================================================================
// Trigger: 创建UI
//
// 2-7
// 3-8
// 1-9
//===========================================================================
function Trig_______UIActions takes nothing returns nothing
    // 创建法抗
    set udg_UI[7]=DzCreateFrameByTagName("TEXT", "name", DzGetGameUI(), "template", 0)
    call DzFrameSetSize(udg_UI[7], 0.03, 0.02)
    call DzFrameSetPoint(udg_UI[7], 4, DzGetGameUI(), 4, - 0.008, - 0.2615)
    call DzFrameSetText(udg_UI[7], "|cffffff00法抗:|r")
    call DzFrameSetFont(udg_UI[7], "Fonts\\fonts.ttf", 0.009, 0)
    call DzFrameShow(udg_UI[7], false)
    // 创建数值
    set udg_UI[8]=DzCreateFrameByTagName("TEXT", "name", udg_UI[7], "template", 0)
    call DzFrameSetSize(udg_UI[8], 0.03, 0.02)
    call DzFrameSetPoint(udg_UI[8], 4, udg_UI[7], 4, 0.005, - 0.012)
    call DzFrameSetText(udg_UI[8], "1")
    call DzFrameSetFont(udg_UI[8], "Fonts\\fonts.ttf", 0.009, 0)
    call DzFrameShow(udg_UI[8], false)
    // 创建法减伤
    set udg_UI[9]=DzCreateFrameByTagName("TEXT", "name", udg_UI[8], "template", 0)
    call DzFrameSetSize(udg_UI[9], 0.07, 0.02)
    call DzFrameSetPoint(udg_UI[9], 4, udg_UI[7], 4, 0.00, - 0.02)
    call DzFrameSetText(udg_UI[9], "法伤减少")
    call DzFrameSetFont(udg_UI[9], "Fonts\\fonts.ttf", 0.009, 0)
    call DzFrameShow(udg_UI[9], false)
    // 排泄
    call DestroyTrigger(GetTriggeringTrigger())
endfunction
//===========================================================================
function InitTrig_______UI takes nothing returns nothing
    set gg_trg_______UI=CreateTrigger()
    call TriggerRegisterTimerEventSingle(gg_trg_______UI, 0.00)
    call TriggerAddAction(gg_trg_______UI, function Trig_______UIActions)
endfunction
//===========================================================================
// Trigger: 选择UI 1
//
// 0.06*护甲/0.06*护甲+1
//===========================================================================
function Trig_______UI_1Actions takes nothing returns nothing
    set udg_xz[GetConvertedPlayerId(GetTriggerPlayer())]=GetTriggerUnit()
    if ( ( GetTriggerPlayer() == GetLocalPlayer() ) ) then
        if ( ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0xA65B3CF5) >= 0.00 ) ) then
            call DzFrameSetText(udg_UI[9], ( ( "法伤减少: " ) + ( R2SW(( ( ( 0.01 * LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0xA65B3CF5) ) ) / ( ( ( 0.01 ) * ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0xA65B3CF5) ) + ( 1.00 ) ) ) * ( 100.00 ) ), 1, 1) ) + ( " %" ) ))
            call DzFrameSetText(udg_UI[8], I2S(R2I(LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0xA65B3CF5))))
        else
            call DzFrameSetText(udg_UI[9], ( ( "|cffff0000法伤加深: " ) + ( R2SW(( ( 1.00 - Pow(0.99, RAbsBJ(LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0xA65B3CF5))) ) * 100.00 ), 1, 2) ) + ( " %|r" ) ))
            call DzFrameSetText(udg_UI[8], I2S(R2I(LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0xA65B3CF5))))
        endif
        call DzFrameShow(udg_UI[9], true)
        call DzFrameShow(udg_UI[7], true)
        call DzFrameShow(udg_UI[8], true)
    else
    endif
endfunction
