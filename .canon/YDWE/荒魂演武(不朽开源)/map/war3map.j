function Trig_6EFunc005Func001Func024T takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA, EXGetEffectX(LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x65BCB4D1)))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382, EXGetEffectY(LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x65BCB4D1)))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x41713DA3, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA) + ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x9A0A741D) * CosBJ(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x795160B8)) ) ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382) + ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x9A0A741D) * SinBJ(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x795160B8)) ) ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C) - 40.00 ))
    if ( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C) > 0.00 ) ) then
        call EXSetEffectXY(LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x65BCB4D1), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x41713DA3), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531))
        call SaveLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x1F451449, Location(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x41713DA3), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531)))
        call EXSetEffectZ(LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x65BCB4D1), ( 80.00 + GetLocationZ(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x1F451449)) ))
        call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x1F451449))
        // 伤害
        set ydl_group=CreateGroup()
        call GroupEnumUnitsInRange(ydl_group, EXGetEffectX(LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x65BCB4D1)), EXGetEffectY(LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x65BCB4D1)), 220.00, null)
        loop
            set ydl_unit=FirstOfGroup(ydl_group)
            exitwhen ydl_unit == null
            call GroupRemoveUnit(ydl_group, ydl_unit)
            if ( ( IsUnitEnemy(ydl_unit, GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x0C32B182))) == true ) and ( IsUnitInGroup(ydl_unit, LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x13D5DA5B)) == false ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) ) then
                // 将选取单位添加至单位组，避免重复对单位造成伤害
                call GroupAddUnit(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x13D5DA5B), ydl_unit)
                call UnitDamageTarget(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x0C32B182), ydl_unit, ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x0C32B182), ConvertUnitState(0x15)) * ( ( 1.00 ) + ( I2R(GetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x0C32B182), 'A04L')) ) * ( 0.50 ) ) ), false, false, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
            else
            endif
        endloop
        call DestroyGroup(ydl_group)
    else
        call DestroyEffect(LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x65BCB4D1))
        call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
        call DestroyTimer(GetExpiredTimer())
    endif
    set ydl_group=null
    set ydl_unit=null
endfunction
