function Trig_10C1Func017Func004T takes nothing returns nothing
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA, GetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382, GetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x41713DA3, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA) + ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x9A0A741D) * CosBJ(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xB9A583B8)) ) ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382) + ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x9A0A741D) * SinBJ(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xB9A583B8)) ) ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C) - 33.00 ))
    if ( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C) > 0.00 ) ) then
        call SetUnitPosition(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), YDWECoordinateX(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x41713DA3)), YDWECoordinateY(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531)))
        call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x25947577, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x25947577) + LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x3D4834E1) ))
        if ( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x25947577) < LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x91D9239B) ) ) then
            call SetUnitFlyHeight(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x25947577), 0.00)
            call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x6BB2DE8A, LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x25947577))
        else
            call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x6BB2DE8A, ( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x6BB2DE8A) ) - ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x3D4834E1) ) ))
            call SetUnitFlyHeight(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x6BB2DE8A), 0.00)
