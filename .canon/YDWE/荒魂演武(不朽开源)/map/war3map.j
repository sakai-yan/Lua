 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SavePlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946, GetTriggerPlayer())
    call DisplayTimedTextToForce(GetPlayersAll(), 10.00, ( ( "|cffff0000" ) + ( GetPlayerName(GetTriggerPlayer()) ) + ( "离开游戏！现将其物品放在泉水旁边。" ) ))
    set ydul_X=1
    loop
        exitwhen ydul_X > 40
        if ( ( LoadInteger(udg_HXB, GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), ydul_X) == 1 ) ) then
