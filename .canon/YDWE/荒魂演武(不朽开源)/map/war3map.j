    local timer ydl_timer
    if ( ( LoadInteger(YDHT, GetHandleId(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xE23F1111)), 0xE2805BCF) == 1 ) and ( LoadInteger(YDHT, GetHandleId(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xE23F1111)), 0xF45B60AB) == 1 ) and ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xE23F1111), UNIT_STATE_MANA) >= ( ( 50.00 ) + ( I2R(GetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xE23F1111), 'A056')) ) * ( 50.00 ) ) ) ) then
