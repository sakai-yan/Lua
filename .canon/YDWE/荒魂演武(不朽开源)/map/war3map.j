function Trig_012Actions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    if ( ( GetItemType(GetSoldItem()) == ITEM_TYPE_CHARGED ) ) then
        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8D62EFEB, ( GetItemCharges(GetSoldItem()) * ( S2I(EXExecuteScript("(require'jass.slk').item[" + I2S(GetItemTypeId(GetSoldItem())) + "].goldcost")) / 2 ) ))
        if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8D62EFEB) >= 10000 ) ) then
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x40C38A9B, S2R(EXExecuteScript("(require'jass.slk').unit[" + I2S(GetUnitTypeId(GetTriggerUnit())) + "].collision")))
            if ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x40C38A9B) == 32.00 ) ) then
                call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53, GetUnitLoc(GetTriggerUnit()))
                call CreateTextTagLocBJ(( "     0" ), GetUnitLoc(GetTriggerUnit()), - 3.00, 11.00, 100, 86.27, 0.00, 0)
                call SetTextTagPermanent(GetLastCreatedTextTag(), false)
                call SetTextTagFadepoint(GetLastCreatedTextTag(), 2.00)
                call SetTextTagLifespan(GetLastCreatedTextTag(), 3.00)
                call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 54.00, 90)
                call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53))
            else
                call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53, GetUnitLoc(GetTriggerUnit()))
                call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xBDF9789F, PolarProjectionBJ(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53), 16.00, 270.00))
                call CreateTextTagLocBJ(( "    0" ), LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xBDF9789F), - 3.00, 11.00, 100, 86.27, 0.00, 0)
                call SetTextTagPermanent(GetLastCreatedTextTag(), false)
                call SetTextTagFadepoint(GetLastCreatedTextTag(), 2.00)
                call SetTextTagLifespan(GetLastCreatedTextTag(), 3.00)
                call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 54.00, 90)
                call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53))
                call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xBDF9789F))
            endif
        else
        endif
    else
        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8D62EFEB, ( S2I(EXExecuteScript("(require'jass.slk').item[" + I2S(GetItemTypeId(GetSoldItem())) + "].goldcost")) / 2 ))
        if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8D62EFEB) >= 10000 ) ) then
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x40C38A9B, S2R(EXExecuteScript("(require'jass.slk').unit[" + I2S(GetUnitTypeId(GetTriggerUnit())) + "].collision")))
            if ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x40C38A9B) == 32.00 ) ) then
                call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53, GetUnitLoc(GetTriggerUnit()))
                call CreateTextTagLocBJ(( "     0" ), GetUnitLoc(GetTriggerUnit()), - 3.00, 11.00, 100, 86.27, 0.00, 0)
                call SetTextTagPermanent(GetLastCreatedTextTag(), false)
                call SetTextTagFadepoint(GetLastCreatedTextTag(), 2.00)
                call SetTextTagLifespan(GetLastCreatedTextTag(), 3.00)
                call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 54.00, 90)
                call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53))
            else
                call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53, GetUnitLoc(GetTriggerUnit()))
                call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xBDF9789F, PolarProjectionBJ(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53), 16.00, 270.00))
                call CreateTextTagLocBJ(( "    0" ), LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xBDF9789F), - 3.00, 11.00, 100, 86.27, 0.00, 0)
                call SetTextTagPermanent(GetLastCreatedTextTag(), false)
