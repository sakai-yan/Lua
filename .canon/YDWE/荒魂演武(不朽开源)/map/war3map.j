function Trig__________uActions takes nothing returns nothing
    call SaveStr(YDHT, 'I003', 0xB1B52F49, "|cffffff00英雄级|r")
    call SaveStr(YDHT, 'I003', 0xB1B52F49, "|cffff6800传奇|r")
    call SaveStr(YDHT, 'I003', 0xB1B52F49, "|cffff0000不朽|r")
    // ----
