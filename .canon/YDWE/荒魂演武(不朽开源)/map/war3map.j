        call DestroyEffect(AddSpecialEffectTarget("Objects\\Spawnmodels\\Human\\HumanBlood\\BloodElfSpellThiefBlood.mdl", LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x04FC4D6D), "head"))
        call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x9890BA1B, ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x04FC4D6D), UNIT_STATE_MAX_LIFE) * 0.03 ))
        call SetUnitLifeBJ(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x04FC4D6D), ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x04FC4D6D), UNIT_STATE_LIFE) + LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x9890BA1B) ))
        call UnitDamageTarget(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x04FC4D6D), LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x4C5B9A34), ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), ConvertUnitState(0x15)) * 3.00 ), false, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
        call CreateTextTagUnitBJ(R2S(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x9890BA1B)), LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x04FC4D6D), 0, 12.00, 0.00, 100.00, 0.00, 0)
        call SetTextTagPermanent(GetLastCreatedTextTag(), false)
        call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
        call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 85.00, ( GetRandomReal(0.00, 360.00) ))
    else
        call YDWEUnitRemoveStun(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x4C5B9A34))
        call QueueUnitAnimation(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x4C5B9A34), "stand")
