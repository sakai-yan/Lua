function Trig_7DActions takes nothing returns nothing
    local timer ydl_timer
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xEF12EDB1, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xEF12EDB1) + ( ( 300.00 ) + ( I2R(GetUnitAbilityLevel(GetTriggerUnit(), GetSpellAbilityId())) ) * ( 200.00 ) ) ))
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCED9FF9B, GetUnitAbilityLevel(GetTriggerUnit(), 'A04P'))
    // 分割
    call UnitAddAbility(GetTriggerUnit(), 'A04R')
    call SetUnitState(GetTriggerUnit(), ConvertUnitState(0x51), ( GetUnitState(GetTriggerUnit(), ConvertUnitState(0x51)) + ( I2R(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCED9FF9B)) * 1.00 ) ))
    call SaveInteger(YDHT, GetHandleId(GetTriggerUnit()), 0xE98AD181, 1)
    call AddUnitAnimationProperties(GetTriggerUnit(), "alternate", true)
    call SetUnitInvulnerable(GetTriggerUnit(), true)
    call PauseUnit(GetTriggerUnit(), true)
    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Other\\HowlOfTerror\\HowlCaster.mdl", GetTriggerUnit(), "origin"))
    call SetUnitAnimationByIndex(GetTriggerUnit(), 7)
    set ydl_timer=CreateTimer()
    call SetUnitAnimationByIndex(GetTriggerUnit(), 16)
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x1E4E9577, 60.00)
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x458B7DE9, GetTriggerUnit())
    call TimerStart(ydl_timer, 0.02, true, function Trig_7DFunc013T)
    set ydl_timer=CreateTimer()
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x458B7DE9, GetTriggerUnit())
    call SaveInteger(YDLOC, GetHandleId(ydl_timer), 0xCED9FF9B, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCED9FF9B))
    call TimerStart(ydl_timer, 1.00, false, function Trig_7DFunc014T)
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    set ydl_timer=null
endfunction
