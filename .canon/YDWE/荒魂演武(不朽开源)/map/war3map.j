function Trig_016SFunc003Func002Func009T takes nothing returns nothing
    if ( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B) < 4.00 ) ) then
        call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B, ( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B) ) + ( 1.00 ) ))
        call SetUnitAnimation(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x4C5B9A34), "Death")
