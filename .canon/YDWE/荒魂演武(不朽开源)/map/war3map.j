    call EXSetEffectZ(LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xDE5D1324), ( ( GetLocationZ(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x8F368FEC)) ) + ( 150.00 ) ))
