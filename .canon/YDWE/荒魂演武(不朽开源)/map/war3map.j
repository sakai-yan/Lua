function Trig_10DFunc021T takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    local integer ydl_triggerstep
    local trigger ydl_trigger
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA, GetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x65BCB4D1)))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382, GetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x65BCB4D1)))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x41713DA3, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA) + ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x9A0A741D) * CosBJ(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x795160B8)) ) ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382) + ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x9A0A741D) * SinBJ(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x795160B8)) ) ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C) - 40.00 ))
    if ( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C) > 0.00 ) ) then
        call SetUnitPosition(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x65BCB4D1), YDWECoordinateX(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x41713DA3)), YDWECoordinateY(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531)))
        // 伤害
        call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE42C4FCD, ( ( 1000.00 * I2R(GetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 'A053')) ) + ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), ConvertUnitState(0x15)) * 10.00 ) ))
        call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x25B4E1BE, ( 9.00 * ( ( 1.00 ) - ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C) ) / ( 5000.00 ) ) ))
        call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA56B5B8B, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE42C4FCD) + ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE42C4FCD) * LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x25B4E1BE) ) ))
        set ydl_group=CreateGroup()
        call GroupEnumUnitsInRange(ydl_group, GetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x65BCB4D1)), GetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x65BCB4D1)), 400.00, null)
        loop
            set ydl_unit=FirstOfGroup(ydl_group)
            exitwhen ydl_unit == null
            call GroupRemoveUnit(ydl_group, ydl_unit)
            if ( ( IsUnitEnemy(ydl_unit, GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9))) == true ) and ( IsUnitInGroup(ydl_unit, LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x13D5DA5B)) == false ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) ) then
                // 将选取单位添加至单位组，避免重复对单位造成伤害
                call GroupAddUnit(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x13D5DA5B), ydl_unit)
                call UnitDamageTarget(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), ydl_unit, LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA56B5B8B), true, true, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_METAL_HEAVY_SLICE)
