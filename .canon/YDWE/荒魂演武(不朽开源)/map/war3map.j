// Trigger: 9C
//===========================================================================
function Trig_9CConditions takes nothing returns boolean
    return ( ( GetLearnedSkill() == 'A044' ) )
endfunction
function Trig_9CActions takes nothing returns nothing
    call SetUnitAbilityLevel(GetTriggerUnit(), 'A04Y', GetUnitAbilityLevel(GetTriggerUnit(), 'A044'))
    call SetUnitAbilityLevel(GetTriggerUnit(), 'A04Z', GetUnitAbilityLevel(GetTriggerUnit(), 'A044'))
    if ( ( GetUnitAbilityLevel(GetTriggerUnit(), 'A044') == 4 ) ) then
        call DestroyTrigger(GetTriggeringTrigger())
    else
    endif
endfunction
//===========================================================================
function InitTrig_9C takes nothing returns nothing
    set gg_trg_9C=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_9C, EVENT_PLAYER_HERO_SKILL)
    call TriggerAddCondition(gg_trg_9C, Condition(function Trig_9CConditions))
    call TriggerAddAction(gg_trg_9C, function Trig_9CActions)
endfunction
//===========================================================================
// Trigger: 9C1
//===========================================================================
function Trig_9C1Conditions takes nothing returns boolean
    return ( ( GetSpellAbilityId() == 'A044' ) )
endfunction
function Trig_9C1Func004T takes nothing returns nothing
    if ( ( LoadInteger(YDHT, GetHandleId(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)), 0x99ED79DC) == 2 ) ) then
        call SetPlayerAbilityAvailable(GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)), 'A044', true)
        call SetPlayerAbilityAvailable(GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)), 'A04Y', false)
        call SetPlayerAbilityAvailable(GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)), 'A04Z', false)
        call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
        call DestroyTimer(GetExpiredTimer())
    else
        call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
        call DestroyTimer(GetExpiredTimer())
    endif
endfunction
function Trig_9C1Func017T takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA, GetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382, GetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x41713DA3, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA) + ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x9A0A741D) * CosBJ(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xB9A583B8)) ) ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382) + ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x9A0A741D) * SinBJ(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xB9A583B8)) ) ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C) - 30.00 ))
    if ( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C) > 0.00 ) ) then
        call SetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), YDWECoordinateX(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x41713DA3)))
        call SetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), YDWECoordinateY(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531)))
        call EXSetEffectXY(LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x8FA135BB), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x41713DA3), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531))
        set ydl_group=CreateGroup()
        call GroupEnumUnitsInRange(ydl_group, LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x41713DA3), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531), 350.00, null)
        loop
            set ydl_unit=FirstOfGroup(ydl_group)
            exitwhen ydl_unit == null
            call GroupRemoveUnit(ydl_group, ydl_unit)
            if ( ( IsUnitEnemy(ydl_unit, GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9))) == true ) and ( IsUnitInGroup(ydl_unit, LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x7B2D08E8)) == false ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) ) then
                // 将选取单位添加至单位组，避免重复对单位造成伤害
                call UnitDamageTarget(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), ydl_unit, ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), ConvertUnitState(0x15)) * 1.50 ), true, true, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_METAL_HEAVY_CHOP)
                call GroupAddUnit(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x7B2D08E8), ydl_unit)
            else
                call DoNothing()
            endif
            if ( ( IsUnitEnemy(ydl_unit, GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9))) == true ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) and ( IsUnitType(ydl_unit, UNIT_TYPE_STRUCTURE) == false ) ) then
                call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xF1DDA59B, ( GetUnitX(ydl_unit) + ( 35.00 * CosBJ(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xB9A583B8)) ) ))
                call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x38D20A1F, ( GetUnitY(ydl_unit) + ( 35.00 * SinBJ(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xB9A583B8)) ) ))
                call SetUnitPosition(ydl_unit, YDWECoordinateX(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xF1DDA59B)), YDWECoordinateY(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x38D20A1F)))
            else
            endif
        endloop
        call DestroyGroup(ydl_group)
    else
        call DestroyEffect(LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x8FA135BB))
        call DestroyGroup(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x7B2D08E8))
        call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
        call DestroyTimer(GetExpiredTimer())
    endif
    set ydl_group=null
    set ydl_unit=null
endfunction
function Trig_9C1Actions takes nothing returns nothing
    local timer ydl_timer
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SetPlayerAbilityAvailable(GetOwningPlayer(GetTriggerUnit()), 'A044', false)
    call SetPlayerAbilityAvailable(GetOwningPlayer(GetTriggerUnit()), 'A04Y', true)
    call SaveInteger(YDHT, GetHandleId(GetTriggerUnit()), 0x99ED79DC, 2)
    set ydl_timer=CreateTimer()
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x458B7DE9, GetTriggerUnit())
    call TimerStart(ydl_timer, 4.00, false, function Trig_9C1Func004T)
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA, GetUnitX(GetTriggerUnit()))
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFDF65382, GetUnitY(GetTriggerUnit()))
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x2392447A, GetSpellTargetX())
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB0897302, GetSpellTargetY())
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB9A583B8, Atan2BJ(( GetSpellTargetY() - LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFDF65382) ), ( GetSpellTargetX() - LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA) )))
    call SaveEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8FA135BB, AddSpecialEffect("TX_klw_1.mdx", LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFDF65382)))
    call EXEffectMatScale(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8FA135BB), 1.00, - 1.00, 1.00)
    call EXEffectMatRotateZ(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8FA135BB), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB9A583B8))
    call EXSetEffectSize(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8FA135BB), 1.20)
    // 分割
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE978590C, 300.00)
    call SaveGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x7B2D08E8, CreateGroup())
    set ydl_timer=CreateTimer()
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x9A0A741D, 30.00)
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x458B7DE9, GetTriggerUnit())
    call SaveGroupHandle(YDLOC, GetHandleId(ydl_timer), 0x7B2D08E8, LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x7B2D08E8))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0xA99320FA, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x41713DA3, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x41713DA3))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0xF1DDA59B, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF1DDA59B))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0xFDF65382, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFDF65382))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x71CA3531, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x71CA3531))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x38D20A1F, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x38D20A1F))
    call SaveEffectHandle(YDLOC, GetHandleId(ydl_timer), 0x8FA135BB, LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8FA135BB))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0xB9A583B8, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB9A583B8))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0xE978590C, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE978590C))
    call TimerStart(ydl_timer, 0.02, true, function Trig_9C1Func017T)
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    set ydl_timer=null
endfunction
//===========================================================================
function InitTrig_9C1 takes nothing returns nothing
    set gg_trg_9C1=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_9C1, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_9C1, Condition(function Trig_9C1Conditions))
    call TriggerAddAction(gg_trg_9C1, function Trig_9C1Actions)
endfunction
