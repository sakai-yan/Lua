//===========================================================================
// Trigger: 复活+平移
//===========================================================================
function Trig______________uConditions takes nothing returns boolean
    return ( ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true ) and ( IsUnitAlly(GetTriggerUnit(), Player(7)) == true ) )
endfunction
function Trig______________uFunc007T takes nothing returns nothing
    call ReviveHero(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), - 500.00, - 7900.00, true)
    call SaveLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA6461A53, GetUnitLoc(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)))
    call PanCameraToTimedLocForPlayer(GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)), LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA6461A53), 0.10)
    call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA6461A53))
    call SetUnitLifePercentBJ(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 100)
    call SetUnitManaPercentBJ(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 100)
    call SelectUnitForPlayerSingle(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)))
    call IssueTargetOrder(gg_unit_H00O_0360, "innerfire", LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9))
    call DestroyTimerDialog(LoadTimerDialogHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x14BDCFE3))
    call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
    call DestroyTimer(GetExpiredTimer())
endfunction
function Trig______________uActions takes nothing returns nothing
    local timer ydl_timer
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveTimerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xC7D77ADA, CreateTimer())
    call SaveTimerDialogHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x14BDCFE3, CreateTimerDialog(LoadTimerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xC7D77ADA)))
    call TimerDialogSetTitle(LoadTimerDialogHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x14BDCFE3), "复活倒计时")
    call TimerDialogDisplayForPlayerBJ(true, LoadTimerDialogHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x14BDCFE3), GetOwningPlayer(GetTriggerUnit()))
    call SaveInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit())), 63, ( ( LoadInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit())), 63) ) + ( 1 ) ))
    if ( ( ( GetUnitTypeId(GetKillingUnitBJ()) == udg_JDCpt[1] ) or ( GetUnitTypeId(GetKillingUnitBJ()) == udg_JDCpt[2] ) or ( GetUnitTypeId(GetKillingUnitBJ()) == udg_JDCpt[3] ) or ( GetUnitTypeId(GetKillingUnitBJ()) == udg_JDCpt[4] ) ) ) then
        call SaveInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit())), 65, ( ( LoadInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit())), 65) ) + ( 1 ) ))
    else
    endif
    set ydl_timer=LoadTimerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xC7D77ADA)
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x458B7DE9, GetTriggerUnit())
    call SaveLocationHandle(YDLOC, GetHandleId(ydl_timer), 0xA6461A53, LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53))
    call SaveTimerDialogHandle(YDLOC, GetHandleId(ydl_timer), 0x14BDCFE3, LoadTimerDialogHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x14BDCFE3))
    call TimerStart(ydl_timer, ( 5.00 + ( I2R(GetUnitLevel(GetTriggerUnit())) * 0.30 ) ), false, function Trig______________uFunc007T)
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    set ydl_timer=null
endfunction
//===========================================================================
function InitTrig______________u takes nothing returns nothing
    set gg_trg______________u=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg______________u, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg______________u, Condition(function Trig______________uConditions))
    call TriggerAddAction(gg_trg______________u, function Trig______________uActions)
endfunction
//===========================================================================
// Trigger: 刷兵01
//
// LV*100*10 + LV/5*1000
//===========================================================================
function Trig_______01Conditions takes nothing returns boolean
    return ( ( GetOwningPlayer(GetEnteringUnit()) == Player(8) ) )
endfunction
function Trig_______01Actions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    if ( ( udg_Lv <= 10 ) ) then
        call SetUnitAbilityLevel(GetEnteringUnit(), 'S000', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A00U', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A00E', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A001', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A00Z', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A00F', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A011', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A014', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A015', ( 1 + ( udg_Lv / 10 ) ))
    else
        call SetUnitAbilityLevel(GetEnteringUnit(), 'S000', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A00U', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A00E', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A001', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A00Z', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A00F', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A011', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A014', ( 1 + ( udg_Lv / 10 ) ))
        call SetUnitAbilityLevel(GetEnteringUnit(), 'A015', ( 1 + ( udg_Lv / 10 ) ))
    endif
    if ( ( GetUnitTypeId(GetEnteringUnit()) == udg_levelL[udg_Lv] ) ) then
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x9890BA1B, ( ( I2R(udg_Lv) ) * ( 500.00 ) * ( udg_ND ) ))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x634C8CDF, ( ( I2R(udg_Lv) ) * ( 250.00 ) * ( udg_ND ) ))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x40536706, ( ( I2R(udg_Lv) ) * ( 2.50 ) * ( udg_ND ) ))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x9375D887, ( ( I2R(udg_Lv) ) * ( 10.00 ) * ( udg_ND ) ))
        call SetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_LIFE, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x9890BA1B))
        call SetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_MANA, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x634C8CDF))
        call SetUnitState(GetEnteringUnit(), ConvertUnitState(0x20), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x40536706))
        call SetUnitState(GetEnteringUnit(), ConvertUnitState(0x12), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x9375D887))
        call SetUnitState(GetEnteringUnit(), UNIT_STATE_LIFE, GetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_LIFE))
        call SetUnitState(GetEnteringUnit(), UNIT_STATE_MANA, GetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_MANA))
    else
        if ( ( GetUnitTypeId(GetEnteringUnit()) == udg_levelR[udg_Lv] ) ) then
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x9890BA1B, ( ( I2R(udg_Lv) ) * ( 250.00 ) * ( udg_ND ) ))
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x634C8CDF, ( ( I2R(udg_Lv) ) * ( 125.00 ) * ( udg_ND ) ))
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x40536706, ( ( I2R(udg_Lv) ) * ( 1.25 ) * ( udg_ND ) ))
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x9375D887, ( ( I2R(udg_Lv) ) * ( 10.00 ) * ( udg_ND ) ))
            call SetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_LIFE, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x9890BA1B))
            call SetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_MANA, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x634C8CDF))
            call SetUnitState(GetEnteringUnit(), ConvertUnitState(0x20), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x40536706))
            call SetUnitState(GetEnteringUnit(), ConvertUnitState(0x12), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x9375D887))
            call SetUnitState(GetEnteringUnit(), UNIT_STATE_LIFE, GetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_LIFE))
            call SetUnitState(GetEnteringUnit(), UNIT_STATE_MANA, GetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_MANA))
        else
        endif
    endif
    if ( ( GetUnitTypeId(GetEnteringUnit()) == udg_Elite[udg_Lv] ) ) then
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x35881FCD, ( ( I2R(udg_Lv) ) * ( 3000.00 ) * ( udg_ND ) ))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x14D76595, ( ( I2R(udg_Lv) ) * ( 1500.00 ) * ( udg_ND ) ))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD12C6208, ( ( I2R(udg_Lv) ) * ( 4.00 ) * ( udg_ND ) ))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xDD4782B9, ( ( I2R(udg_Lv) ) * ( 50.00 ) * ( udg_ND ) ))
        call SetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_LIFE, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x35881FCD))
        call SetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_MANA, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x14D76595))
        call SetUnitState(GetEnteringUnit(), ConvertUnitState(0x20), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD12C6208))
        call SetUnitState(GetEnteringUnit(), ConvertUnitState(0x12), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xDD4782B9))
        call SetUnitState(GetEnteringUnit(), UNIT_STATE_LIFE, GetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_LIFE))
        call SetUnitState(GetEnteringUnit(), UNIT_STATE_MANA, GetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_MANA))
    else
        if ( ( GetUnitTypeId(GetEnteringUnit()) == udg_boss[udg_Lv] ) and ( udg_Lv != 54 ) ) then
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x3950DBED, ( ( I2R(udg_Lv) ) * ( 6000.00 ) * ( udg_ND ) ))
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8F1648E7, ( ( I2R(udg_Lv) ) * ( 4000.00 ) * ( udg_ND ) ))
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xBC6A3596, ( ( I2R(udg_Lv) ) * ( 7.00 ) * ( udg_ND ) ))
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x9883B744, ( ( I2R(udg_Lv) ) * ( 100.00 ) * ( udg_ND ) ))
            call SetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_LIFE, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x3950DBED))
            call SetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_MANA, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8F1648E7))
            call SetUnitState(GetEnteringUnit(), ConvertUnitState(0x20), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xBC6A3596))
            call SetUnitState(GetEnteringUnit(), ConvertUnitState(0x12), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x9883B744))
            call SetUnitState(GetEnteringUnit(), UNIT_STATE_LIFE, GetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_LIFE))
            call SetUnitState(GetEnteringUnit(), UNIT_STATE_MANA, GetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_MANA))
        else
            if ( ( GetUnitTypeId(GetEnteringUnit()) == udg_boss[udg_Lv] ) ) then
                call SetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_LIFE, ( ( I2R(GetUnitPointValue(GetEnteringUnit())) * 15000.00 ) * udg_ND ))
                call SetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_MANA, ( ( I2R(GetUnitPointValue(GetEnteringUnit())) * 12000.00 ) * udg_ND ))
                call SetUnitState(GetEnteringUnit(), ConvertUnitState(0x12), ( ( I2R(GetUnitPointValue(GetEnteringUnit())) * 100.00 ) * udg_ND ))
                call SetUnitState(GetEnteringUnit(), ConvertUnitState(0x20), ( ( I2R(GetUnitPointValue(GetEnteringUnit())) * 12.00 ) * udg_ND ))
                call SetUnitState(GetEnteringUnit(), UNIT_STATE_LIFE, GetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_LIFE))
                call SetUnitState(GetEnteringUnit(), UNIT_STATE_MANA, GetUnitState(GetEnteringUnit(), UNIT_STATE_MAX_MANA))
            else
            endif
        endif
    endif
    call YDWESetUnitAbilityDataReal(GetEnteringUnit() , 'A00T' , 1 , 109 , ( GetUnitStateSwap(ConvertUnitState(0x12), GetEnteringUnit()) * 3.00 ))
    call YDWESetUnitAbilityDataReal(GetEnteringUnit() , 'A013' , 1 , 108 , ( GetUnitStateSwap(ConvertUnitState(0x12), GetEnteringUnit()) * 0.30 ))
    call YDWESetUnitAbilityDataReal(GetEnteringUnit() , 'A019' , 1 , 108 , ( GetUnitStateSwap(ConvertUnitState(0x12), GetEnteringUnit()) * 0.50 ))
    call SaveReal(YDHT, GetHandleId(GetEnteringUnit()), 0xA65B3CF5, GetUnitState(GetEnteringUnit(), ConvertUnitState(0x20)))
    call SaveReal(YDHT, GetHandleId(GetEnteringUnit()), 0x3C007FD8, ( 0.06 * udg_ND ))
    call SaveReal(YDHT, GetHandleId(GetEnteringUnit()), 0x1F5F705A, ( 0.04 * udg_ND ))
    call SaveReal(YDHT, GetHandleId(GetEnteringUnit()), 0x636DFFD3, ( 0.05 * udg_ND ))
    call SaveReal(YDHT, GetHandleId(GetEnteringUnit()), 0xA727C6F6, ( 0.05 * udg_ND ))
    call IssuePointOrder(GetEnteringUnit(), "attack", - 500.00, - 6150.00)
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
