//===========================================================================
// Trigger: 015
//===========================================================================
function Trig_015Conditions takes nothing returns boolean
    return ( ( udg_ND == 0.00 ) )
endfunction
function Trig_015Func016A takes nothing returns nothing
    call CreateUnit(GetEnumPlayer(), 'e000', - 2800.00, - 8100.00, bj_UNIT_FACING)
endfunction
function Trig_015Actions takes nothing returns nothing
    local integer ydul_y
    set udg_ND=0.70
    call DisplayTimedTextToForce(GetPlayersAll(), 30.00, "|cffff0000由于 主机玩家 长时间未选择难度，默认难度设置为 菜鸟模式 （敌人全属性减少30%）|r")
    call TriggerExecute(gg_trg_01______u)
    call EnableTrigger(gg_trg_______03)
    call DisplayTimedTextToForce(GetPlayersAll(), 30.00, "|cffff0000敌人将在120秒后发起进攻，请做好战前准备！|r
|cffffff00温馨提示（新手提示）：出生后前往主城左上角购买相应的物品或装备增强英雄，后通过“传送门”前往各大区域寻找低级小怪（1-10级）练级（前期切勿深入）")
    call DisplayTimedTextToForce(GetPlayersAll(), 30.00, "|cffffff00快捷键：TAB查看/关闭英雄详细属性界面、Z打开/关闭大背包、T回城、鼠标点击左下角“宝物图鉴”可查看游戏中高级装备与材料的来源。
地图QQ群：543258045（内有攻略、以及地图道具掉落资料等）")
    call DisplayTimedTextToForce(GetPlayersAll(), 30.00, ( ( "|cffff9900当前难度敌方属性：" ) + ( ( ( ( ( "物理穿透：" ) + ( I2S(R2I(( ( 0.05 ) * ( udg_ND ) * ( 100.00 ) ))) ) + ( "%  " ) ) ) + ( ( ( "法术穿透：" ) + ( I2S(R2I(( ( 0.05 ) * ( udg_ND ) * ( 100.00 ) ))) ) + ( "%  " ) ) ) + ( ( ( "伤害减免：" ) + ( I2S(R2I(( ( 0.04 ) * ( udg_ND ) * ( 100.00 ) ))) ) + ( "%  " ) ) ) ) ) + ( ( ( "受控韧性：" ) + ( I2S(R2I(( ( 0.06 ) * ( udg_ND ) * ( 100.00 ) ))) ) + ( "%" ) ) ) ))
    call MultiboardSetTitleText(udg_Multitboard, "菜鸟模式")
    call DialogDisplay(ConvertedPlayer(udg_WJDB), udg_dhk, false)
    set udg_BL=CountPlayersInForceBJ(udg_WZJ)
    if ( ( udg_BL < 3 ) ) then
        set udg_BL=0
        call DisplayTimedTextToForce(GetPlayersAll(), 30.00, "|cffffff00当前玩家小于3人，传说级道具爆率：正常")
    else
        if ( ( udg_BL >= 3 ) and ( udg_BL < 5 ) ) then
            set udg_BL=1
            call DisplayTimedTextToForce(GetPlayersAll(), 30.00, "|cffffff00当前玩家（3≤人数≤5人），传说级道具爆率：+10%")
        else
            if ( ( udg_BL >= 5 ) and ( udg_BL < 7 ) ) then
                set udg_BL=2
                call DisplayTimedTextToForce(GetPlayersAll(), 30.00, "|cffffff00当前玩家（5≤人数＜7人），传说级道具爆率：+20%")
            else
                if ( ( udg_BL == 7 ) ) then
                    set udg_BL=3
                    call DisplayTimedTextToForce(GetPlayersAll(), 30.00, "|cffffff00当前玩家（人数=7人），传说级道具爆率：+30%")
                else
                endif
            endif
        endif
    endif
    set ydul_y=1
    loop
        exitwhen ydul_y > 7
        call FlushChildHashtable(YDHT, GetHandleId(udg_dhkan[ydul_y]))
        set ydul_y=ydul_y + 1
    endloop
    call FlushChildHashtable(YDHT, GetHandleId(udg_dhk))
    call DialogClear(udg_dhk)
    call DialogDestroy(udg_dhk)
    call ForForce(udg_WZJ, function Trig_015Func016A)
    call DestroyTrigger(gg_trg_016)
    call EnableTrigger(gg_trg_024)
    call DestroyTrigger(GetTriggeringTrigger())
endfunction
