    // 分割
    set udg_WPLUI[115]=DzCreateFrameByTagName("TEXT", "名字", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[115], 1, udg_WPLUI[100], 1, 0.00, - 0.037)
    call DzFrameShow(udg_WPLUI[100], false)
    set ydul_x=100
