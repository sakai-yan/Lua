        call SaveInteger(udg_HXB, GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xDFB448FB)), LoadInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xDFB448FB)), 0x9B313EF3), 0)
