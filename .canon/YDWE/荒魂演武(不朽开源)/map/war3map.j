    set gg_trg_001=CreateTrigger()
    call YDWESyStemAnyUnitDamagedRegistTrigger(gg_trg_001)
    call TriggerAddCondition(gg_trg_001, Condition(function Trig_001Conditions))
    call TriggerAddAction(gg_trg_001, function Trig_001Actions)
