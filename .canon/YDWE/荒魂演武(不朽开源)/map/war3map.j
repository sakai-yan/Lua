endfunction
function Trig_9W1Func001Func004Conditions takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    if ( ( YDWEIsEventAttackDamage() == true ) and ( GetEventDamageSource() == LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB6C538B7) ) ) then
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA99320FA, GetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB6C538B7)))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xFDF65382, GetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB6C538B7)))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x2392447A, GetUnitX(GetTriggerUnit()))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB0897302, GetUnitY(GetTriggerUnit()))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB9A583B8, Atan2BJ(( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB0897302) - LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xFDF65382) ), ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x2392447A) - LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA99320FA) )))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x41713DA3, ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA99320FA) + ( 350.00 * CosBJ(LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB9A583B8)) ) ))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x71CA3531, ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xFDF65382) + ( 350.00 * SinBJ(LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB9A583B8)) ) ))
        call SaveEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x37BB82D6, AddSpecialEffect("TX_klw_3.mdx", LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x41713DA3), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x71CA3531)))
        call EXEffectMatRotateZ(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x37BB82D6), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB9A583B8))
        call EXSetEffectSize(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x37BB82D6), 1.50)
        call YDWETimerDestroyEffect(0.30 , LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x37BB82D6))
        // 分割
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA3098AE2, 600.00)
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x25F62AE1, 250.00)
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x07C93ED7, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB9A583B8))
        // 摆正坐标
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x5179903A, ( ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x2392447A) ) * ( CosBJ(LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x07C93ED7)) ) ) + ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB0897302) ) * ( SinBJ(LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x07C93ED7)) ) ) ))
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x859C79EB, ( ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB0897302) ) * ( CosBJ(LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x07C93ED7)) ) ) - ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x2392447A) ) * ( SinBJ(LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x07C93ED7)) ) ) ))
        // ----
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x2FC9F415, SquareRoot(( Pow(( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA3098AE2) ) / ( 2.00 ) ), 2.00) + Pow(( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x25F62AE1) ) / ( 2.00 ) ), 2.00) )))
        set ydl_group=CreateGroup()
        call GroupEnumUnitsInRange(ydl_group, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x2392447A), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB0897302), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x2FC9F415), null)
        loop
            set ydl_unit=FirstOfGroup(ydl_group)
            exitwhen ydl_unit == null
            call GroupRemoveUnit(ydl_group, ydl_unit)
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x41713DA3, GetUnitX(ydl_unit))
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x71CA3531, GetUnitY(ydl_unit))
            // 摆正坐标
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xD310CF7A, ( ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x41713DA3) ) * ( CosBJ(LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x07C93ED7)) ) ) + ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x71CA3531) ) * ( SinBJ(LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x07C93ED7)) ) ) ))
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7D73FF94, ( ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x71CA3531) ) * ( CosBJ(LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x07C93ED7)) ) ) - ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x41713DA3) ) * ( SinBJ(LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x07C93ED7)) ) ) ))
            // ----
            if ( ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) and ( IsUnitEnemy(ydl_unit, GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB6C538B7))) == true ) and ( RAbsBJ(( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x5179903A) - LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xD310CF7A) )) <= ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA3098AE2) ) / ( 2.00 ) ) ) and ( RAbsBJ(( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x859C79EB) - LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7D73FF94) )) <= ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x25F62AE1) ) / ( 2.00 ) ) ) ) then
                call UnitDamageTarget(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB6C538B7), ydl_unit, ( ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xB6C538B7), ConvertUnitState(0x15)) * 2.00 ) + ( ( GetUnitState(ydl_unit, UNIT_STATE_MAX_LIFE) - GetUnitState(ydl_unit, UNIT_STATE_LIFE) ) * ( ( 0.02 ) + ( I2R(GetUnitAbilityLevel(GetTriggerUnit(), 'A052')) ) * ( 0.02 ) ) ) ), false, false, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_METAL_HEAVY_CHOP)
            else
            endif
        endloop
        call DestroyGroup(ydl_group)
        // 分割
        call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()))
        call DestroyTrigger(GetTriggeringTrigger())
        set ydl_group=null
        set ydl_unit=null
        return
    else
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()))
    call DestroyTrigger(GetTriggeringTrigger())
    set ydl_group=null
    set ydl_unit=null
endfunction
function Trig_9W1Func001T takes nothing returns nothing
    local trigger ydl_trigger
