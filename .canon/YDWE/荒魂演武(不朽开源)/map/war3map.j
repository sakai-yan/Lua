    call FlushChildHashtable(udg_HXB, GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)))
    call FlushChildHashtable(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetTriggerPlayer())]))
    call FlushChildHashtable(YDHT, GetHandleId(GetTriggerPlayer()))
    call GroupRemoveUnitSimple(udg_Hero[GetConvertedPlayerId(GetTriggerPlayer())], udg_Heros)
    call DzDestroyFrame(udg_Hero_TX_UI[GetConvertedPlayerId(GetTriggerPlayer())])
    call RemoveUnit(udg_Hero[GetConvertedPlayerId(GetTriggerPlayer())])
    call ForceRemovePlayerSimple(GetTriggerPlayer(), udg_WZJ)
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
