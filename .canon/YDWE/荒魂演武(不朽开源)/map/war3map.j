        call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382) + ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x9A0A741D) * SinBJ(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xB9A583B8)) ) ))
        call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C) - 40.00 ))
        call SetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x43DF4AB1), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x41713DA3))
        call SetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x43DF4AB1), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531))
        call SetUnitPosition(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x467F9C21), GetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x43DF4AB1)), GetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x43DF4AB1)))
        call SetUnitFacing(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x467F9C21), GetUnitFacing(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x43DF4AB1)))
    else
        call SetUnitVertexColorBJ(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 100, 100.00, 100.00, 0.00)
        call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Orc\\FeralSpirit\\feralspirittarget.mdl", LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "origin"))
        call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Other\\HowlOfTerror\\HowlCaster.mdl", LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "origin"))
        call SetUnitTimeScale(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 1.00)
        call YDWEUnitRemoveStun(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9))
        call IssueImmediateOrderById(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 851972)
        call SetUnitInvulnerable(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), false)
        if ( ( UnitHasBuffBJ(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 'B000') == true ) ) then
            call QueueUnitAnimation(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "stand Ready Alternate")
        else
            call QueueUnitAnimation(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "stand Ready")
        endif
        // 伤害
        set ydl_group=CreateGroup()
        call GroupEnumUnitsInRange(ydl_group, LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382), 350.00, null)
