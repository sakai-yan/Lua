    if ( ( udg_Hero[GetConvertedPlayerId(GetEnumPlayer())] != null ) ) then
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xD0241DEB, GetUnitStateSwap(ConvertUnitState(0x15), udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]))
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xEEFAE8E0, ( I2R(GetHeroInt(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], true)) * 1.50 ))
        call SaveInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x8FAA51A7, R2I(( I2R(GetHeroInt(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], true)) * 0.003 )))
        call SaveInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x9D31324F, R2I(( I2R(GetHeroStr(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], true)) * 0.003 )))
        call SaveInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xC1C7B969, ( LoadInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x9D31324F) + LoadInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x556E03EA) ))
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x1D89C00E, ( I2R(GetHeroStr(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], true)) * 0.0002 ))
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xBFA256FF, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x1D89C00E) + LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x1B5F3A6A) ))
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x51AABD60, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xEEFAE8E0) + LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x0C65E629) ))
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xFA11BC58, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x51AABD60) * LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x05CDD84B) ))
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xB0C6D98D, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x51AABD60) + LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xFA11BC58) ))
        call SaveInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xC7A2FC1F, ( LoadInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x8FAA51A7) + LoadInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x7027B879) ))
        // 力量
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xEC863048, I2R(GetHeroStr(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], false)))
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x7F701A4A, ( ( ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xEC863048) ) + ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xF791E74B) ) ) * LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x08BAB87E) ))
        // 敏捷
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x0667A2A3, I2R(GetHeroAgi(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], false)))
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xB7D897D1, ( ( ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x0667A2A3) ) + ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x195139DD) ) ) * LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x0098CEEB) ))
        // 智力
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x8FFE89B3, I2R(GetHeroInt(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], false)))
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x3441FD5F, ( ( ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x8FFE89B3) ) + ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xEF6B66A5) ) ) * LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xC08430F1) ))
        call SetUnitAbilityLevel(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], 'A038', 2)
        call YDWESetUnitAbilityDataReal(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())] , 'A038' , 1 , 110 , ( ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xF791E74B) ) + ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x7F701A4A) ) ))
        call YDWESetUnitAbilityDataReal(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())] , 'A038' , 1 , 108 , ( ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x195139DD) ) + ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xB7D897D1) ) ))
        call YDWESetUnitAbilityDataReal(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())] , 'A038' , 1 , 109 , ( ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xEF6B66A5) ) + ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x3441FD5F) ) ))
        call SetUnitAbilityLevel(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], 'A038', 1)
        // 生命
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x2F591435, ( ( 100.00 ) + ( I2R(GetHeroStr(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], true)) ) * ( 25.00 ) ))
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xCB8A0E8E, ( ( ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x2F591435) ) + ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x651DD2FC) ) ) * LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x16C5C392) ))
        call SetUnitState(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], UNIT_STATE_MAX_LIFE, ( ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x2F591435) ) + ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xCB8A0E8E) ) + ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x651DD2FC) ) ))
        // 魔法
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xF8BD5158, ( I2R(GetHeroInt(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], true)) * 15.00 ))
        call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xE4B33AC7, ( ( ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xF8BD5158) ) + ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xCBF95817) ) ) * LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xA006C6C7) ))
        call SetUnitState(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], UNIT_STATE_MAX_MANA, ( ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xF8BD5158) ) + ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xE4B33AC7) ) + ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xCBF95817) ) ))
        // 攻击
        if ( ( ( EXExecuteScript("(require'jass.slk').unit[" + I2S(GetUnitTypeId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())])) + "].Primary") ) == "STR" ) ) then
            call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x3FBE7059, I2R(GetHeroStr(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], true)))
        else
            if ( ( ( EXExecuteScript("(require'jass.slk').unit[" + I2S(GetUnitTypeId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())])) + "].Primary") ) == "AGI" ) ) then
                call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x3FBE7059, I2R(GetHeroAgi(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], true)))
            else
                if ( ( ( EXExecuteScript("(require'jass.slk').unit[" + I2S(GetUnitTypeId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())])) + "].Primary") ) == "INT" ) ) then
                    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x3FBE7059, I2R(GetHeroInt(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], true)))
                else
                endif
            endif
        endif
        call SaveInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x1E4227CE, R2I(( ( ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x3FBE7059) ) + ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xEF12EDB1) ) ) * LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xE2DD07B4) )))
        call YDWEGeneralBounsSystemUnitSetBonus(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())] , 3 , 2 , ( LoadInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x1E4227CE) + R2I(LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xEF12EDB1)) ))
        if ( ( ( HaveSavedReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x7BD67BA5) == true ) or ( HaveSavedReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xF2ED32BC) == true ) ) ) then
            if ( ( HaveSavedReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x7BD67BA5) == true ) ) then
                call SetUnitLifePercentBJ(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x7BD67BA5))
                call RemoveSavedReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0x7BD67BA5)
            else
            endif
            if ( ( HaveSavedReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xF2ED32BC) == true ) ) then
                call SetUnitManaPercentBJ(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xF2ED32BC))
                call RemoveSavedReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())]), 0xF2ED32BC)
            else
            endif
        else
        endif
    else
    endif
endfunction
function Trig_TriggerBFunc003Func010A takes nothing returns nothing
    if ( ( udg_xz[GetConvertedPlayerId(GetEnumPlayer())] != null ) and ( GetEnumPlayer() == GetLocalPlayer() ) ) then
        if ( ( IsUnitType(udg_xz[GetConvertedPlayerId(GetEnumPlayer())], UNIT_TYPE_DEAD) == false ) ) then
            if ( ( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xA65B3CF5) >= 0.00 ) ) then
                call DzFrameSetText(udg_UI[9], ( ( "法伤减少: " ) + ( R2SW(( ( ( 0.01 * LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xA65B3CF5) ) ) / ( ( ( 0.01 ) * ( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xA65B3CF5) ) + ( 1.00 ) ) ) * ( 100.00 ) ), 1, 1) ) + ( " %" ) ))
                call DzFrameSetText(udg_UI[8], I2S(R2I(LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xA65B3CF5))))
            else
                call DzFrameSetText(udg_UI[9], ( ( "|cffff0000法伤加深: " ) + ( R2SW(( ( 1.00 - Pow(0.99, RAbsBJ(LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xA65B3CF5))) ) * 100.00 ), 1, 2) ) + ( " %|r" ) ))
                call DzFrameSetText(udg_UI[8], I2S(R2I(LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xA65B3CF5))))
            endif
        else
            call DzFrameShow(udg_UI[7], false)
        endif
        if ( ( IsUnitType(udg_xz[GetConvertedPlayerId(GetEnumPlayer())], UNIT_TYPE_HERO) == true ) and ( IsUnitAlly(udg_xz[GetConvertedPlayerId(GetEnumPlayer())], Player(7)) == true ) and ( LoadInteger(YDHT, GetHandleId(GetEnumPlayer()), 0xB755BCE8) == 2 ) ) then
            call DzFrameSetText(udg_WPLUI[101], ( "物理攻击：|cff00ff00" + I2S(R2I(LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xD0241DEB))) ))
            call DzFrameSetText(udg_WPLUI[102], ( ( "物理暴击：|cff00ff00" ) + ( I2S(LoadInteger(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xC1C7B969)) ) + ( " %" ) ))
            call DzFrameSetText(udg_WPLUI[103], ( ( "物理暴击效果：|cff00ff00" ) + ( I2S(R2I(( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xBFA256FF) * 100.00 ))) ) + ( " %" ) ))
            call DzFrameSetText(udg_WPLUI[104], ( ( "物理吸血：|cff00ff00" ) + ( I2S(R2I(( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0x59E18EE2) * 100.00 ))) ) + ( " %" ) ))
            call DzFrameSetText(udg_WPLUI[105], ( ( "物理穿透：|cff00ff00" ) + ( I2S(R2I(( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0x636DFFD3) * 100.00 ))) ) + ( " %" ) ))
            call DzFrameSetText(udg_WPLUI[106], ( "法术攻击：|cff00ff00" + I2S(R2I(LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xB0C6D98D))) ))
            call DzFrameSetText(udg_WPLUI[107], ( ( "法术暴击：|cff00ff00" ) + ( I2S(LoadInteger(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xC7A2FC1F)) ) + ( " %" ) ))
            call DzFrameSetText(udg_WPLUI[108], ( ( "法术暴击效果：|cff00ff00" ) + ( I2S(R2I(( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0x9D1E5CF3) * 100.00 ))) ) + ( " %" ) ))
            call DzFrameSetText(udg_WPLUI[109], ( ( "法术吸血：|cff00ff00" ) + ( I2S(R2I(( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0x83C13D14) * 100.00 ))) ) + ( " %" ) ))
            call DzFrameSetText(udg_WPLUI[110], ( ( "法术穿透：|cff00ff00" ) + ( I2S(R2I(( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xA727C6F6) * 100.00 ))) ) + ( " %" ) ))
            call DzFrameSetText(udg_WPLUI[111], ( ( "普攻溅射：|cff00ff00" ) + ( I2S(R2I(( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xAAFAF365) * 100.00 ))) ) + ( " %" ) ))
            call DzFrameSetText(udg_WPLUI[112], ( ( "攻击速度：|cff00ff00" ) + ( R2S(( ( GetUnitState(udg_xz[GetConvertedPlayerId(GetEnumPlayer())], ConvertUnitState(0x51)) ) * ( 100.00 ) - ( 100.00 ) )) ) + ( " %" ) ))
            if ( ( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0x1F5F705A) <= 1.00 ) ) then
                call DzFrameSetText(udg_WPLUI[113], ( ( "伤害减免：|cff00ff00" ) + ( I2S(R2I(( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0x1F5F705A) * 100.00 ))) ) + ( " %" ) ))
            else
                call DzFrameSetText(udg_WPLUI[113], ( ( "伤害减免：|cff00ff00" ) + ( "100" ) + ( " %" ) ))
            endif
            call DzFrameSetText(udg_WPLUI[114], ( "移动速度：|cff00ff00" + I2S(R2I(GetUnitMoveSpeed(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]))) ))
            call DzFrameSetText(udg_WPLUI[115], ( "|cffffff00" + GetUnitName(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]) ))
            if ( ( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xAF04E5E0) <= 0.50 ) ) then
                call DzFrameSetText(udg_WPLUI[116], ( ( "冷却缩减：|cff00ff00" ) + ( I2S(R2I(( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0xAF04E5E0) * 100.00 ))) ) + ( " %" ) ))
            else
                call DzFrameSetText(udg_WPLUI[116], "冷却缩减：|cff00ff0050 %")
            endif
            if ( ( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0x3C007FD8) < 1.00 ) ) then
                call DzFrameSetText(udg_WPLUI[120], ( ( "受控韧性：|cff00ff00" ) + ( I2S(R2I(( LoadReal(YDHT, GetHandleId(udg_xz[GetConvertedPlayerId(GetEnumPlayer())]), 0x3C007FD8) * 100.00 ))) ) + ( " %" ) ))
            else
                call DzFrameSetText(udg_WPLUI[120], "受控韧性：|cff00ff00霸体")
            endif
        else
        endif
    else
    endif
endfunction
function Trig_TriggerBFunc003Func011A takes nothing returns nothing
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x5D47FCCF, GetUnitX(GetEnumUnit()))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x4211070B, GetUnitY(GetEnumUnit()))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xEBEF1CA3, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x5D47FCCF) - GetRectCenterX(GetPlayableMapRect()) ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x34D40D1C, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x4211070B) - GetRectCenterY(GetPlayableMapRect()) ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xEBEF1CA3, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xEBEF1CA3) / 32768.00 ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x34D40D1C, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x34D40D1C) / 40960.00 ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x1E03DFAF, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xEBEF1CA3) * 0.12 ))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA71C642A, ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x34D40D1C) * 0.15 ))
    call DzFrameSetPoint(udg_Hero_TX_UI[GetConvertedPlayerId(GetOwningPlayer(GetEnumUnit()))], 4, DzFrameGetMinimap(), 4, LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x1E03DFAF), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA71C642A))
endfunction
function Trig_TriggerBFunc003T takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x6DEEAE1F, ( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x6DEEAE1F) ) + ( 0.50 ) ))
    if ( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x6DEEAE1F) >= 60.00 ) ) then
        call SaveInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x56BEADF5, ( ( LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x56BEADF5) ) + ( 1 ) ))
        call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x6DEEAE1F, 0.00)
    else
    endif
    if ( ( LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x56BEADF5) >= 60 ) ) then
        call SaveInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x56BEADF5, 0)
        call SaveInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x89E474DB, ( ( LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x89E474DB) ) + ( 1 ) ))
    else
    endif
    call MultiboardReleaseItem(udg_boardproject[2])
    set udg_boardproject[2]=MultiboardGetItem(udg_Multitboard, 0, 1)
    call MultiboardSetItemValue(udg_boardproject[2], ( ( ( I2S(LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x89E474DB)) + " ：" ) ) + ( ( I2S(LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x56BEADF5)) + " ：" ) ) + ( I2S(R2I(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x6DEEAE1F))) ) ))
    call MultiboardReleaseItem(udg_boardproject[3])
    call MultiboardReleaseItem(udg_boardproject[4])
    set udg_boardproject[3]=MultiboardGetItem(udg_Multitboard, 1, 0)
    set udg_boardproject[4]=MultiboardGetItem(udg_Multitboard, 1, 1)
    call MultiboardSetItemValue(udg_boardproject[3], ( ( "|cffffff00第 " ) + ( I2S(udg_Lv) ) + ( " 波进攻|r" ) ))
    call MultiboardSetItemValue(udg_boardproject[4], ( ( "倒计时 |cffff0000" ) + ( I2S(R2I(TimerGetRemaining(udg_jsq))) ) + ( "|r" ) ))
    // 分割
    call ForForce(udg_WZJ, function Trig_TriggerBFunc003Func009A)
    call ForForce(udg_WZJ, function Trig_TriggerBFunc003Func010A)
    call ForGroupBJ(udg_Heros, function Trig_TriggerBFunc003Func011A)
    set ydl_group=null
    set ydl_unit=null
endfunction
function Trig_TriggerBActions takes nothing returns nothing
    local timer ydl_timer
    set udg_boardproject[1]=MultiboardGetItem(udg_Multitboard, 0, 0)
    call MultiboardSetItemValue(udg_boardproject[1], "|cffffff00游戏时间")
    set ydl_timer=CreateTimer()
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0xEBEF1CA3, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0xEBEF1CA3))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x34D40D1C, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x34D40D1C))
    call SaveInteger(YDLOC, GetHandleId(ydl_timer), 0x56BEADF5, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x56BEADF5))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x5D47FCCF, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x5D47FCCF))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x4211070B, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x4211070B))
    call SaveInteger(YDLOC, GetHandleId(ydl_timer), 0x89E474DB, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x89E474DB))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x1E03DFAF, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x1E03DFAF))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0xA71C642A, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0xA71C642A))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x6DEEAE1F, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x6DEEAE1F))
    call TimerStart(ydl_timer, 0.50, true, function Trig_TriggerBFunc003T)
    // 排泄
    call DestroyTrigger(GetTriggeringTrigger())
    set ydl_timer=null
endfunction
//===========================================================================
function InitTrig_TriggerB takes nothing returns nothing
    set gg_trg_TriggerB=CreateTrigger()
    call TriggerRegisterTimerEventSingle(gg_trg_TriggerB, 0.00)
    call TriggerAddAction(gg_trg_TriggerB, function Trig_TriggerBActions)
endfunction
//===========================================================================
// Trigger: 出售选择英雄
//
// maptest2020
//===========================================================================
function Trig___________________uConditions takes nothing returns boolean
    return ( ( IsUnitType(GetSoldUnit(), UNIT_TYPE_HERO) == true ) )
endfunction
function Trig___________________uActions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call UnitAddAbility(GetSoldUnit(), 'A030')
    call UnitAddAbility(GetSoldUnit(), 'A039')
    call SelectUnitForPlayerSingle(GetSoldUnit(), GetOwningPlayer(GetBuyingUnit()))
    call SetPlayerHandicapXPBJ(GetOwningPlayer(GetBuyingUnit()), 0.00)
    call DzSetUnitPosition(GetSoldUnit(), - 2600.00, - 7950.00)
    call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53, GetUnitLoc(GetSoldUnit()))
    call PanCameraToTimedLocForPlayer(GetOwningPlayer(GetBuyingUnit()), LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53), 0)
    call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53))
    set udg_Hero_TX_UI[GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))]=DzCreateFrameByTagName("BACKDROP", "打开按钮", DzGetGameUI(), "template", 0)
    call DzFrameSetSize(udg_Hero_TX_UI[GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))], 0.01, 0.01)
    call DzFrameSetPoint(udg_Hero_TX_UI[GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))], 4, DzFrameGetMinimap(), 4, 0.00, 0.00)
    call DzFrameSetTexture(udg_Hero_TX_UI[GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))], ( EXExecuteScript("(require'jass.slk').unit[" + I2S(GetUnitTypeId(GetSoldUnit())) + "].Art") ), 0)
    if ( ( GetOwningPlayer(GetBuyingUnit()) == GetLocalPlayer() ) ) then
        call DzFrameSetPriority(udg_Hero_TX_UI[GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))], 1)
    else
    endif
    call GroupAddUnit(udg_Heros, GetSoldUnit())
    call KillUnit(GetBuyingUnit())
    call UnitAddItemByIdSwapped('I002', GetSoldUnit())
    call UnitAddItemByIdSwapped('I063', GetSoldUnit())
    call SetItemCharges(GetLastCreatedItem(), 3)
    if ( ( ( DzAPI_Map_HasMallItem(GetOwningPlayer(GetBuyingUnit()), "B3") == true ) or ( DzAPI_Map_IsAuthor(GetOwningPlayer(GetBuyingUnit())) == true ) ) ) then
        call SetUnitMoveSpeed(GetSoldUnit(), ( GetUnitMoveSpeed(GetSoldUnit()) + 30.00 ))
        call SetUnitState(GetSoldUnit(), ConvertUnitState(0x51), ( GetUnitState(GetSoldUnit(), ConvertUnitState(0x51)) + 0.30 ))
        call DisplayTimedTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, 10.00, "|cffff0000 【道具特权】|r|cffff9900：您拥有“疾风祝福”，英雄攻速+40%。移速+35|r")
    else
    endif
    if ( ( ( DzAPI_Map_HasMallItem(GetOwningPlayer(GetBuyingUnit()), "B4") == true ) or ( DzAPI_Map_IsAuthor(GetOwningPlayer(GetBuyingUnit())) == true ) ) ) then
        call SaveReal(YDHT, GetHandleId(GetSoldUnit()), 0x05CDD84B, 0.10)
        call SaveInteger(YDHT, GetHandleId(GetSoldUnit()), 0x556E03EA, 5)
        call SaveInteger(YDHT, GetHandleId(GetSoldUnit()), 0x7027B879, 5)
        call SaveReal(YDHT, GetHandleId(GetSoldUnit()), 0xE2DD07B4, 0.10)
        call SaveReal(YDHT, GetHandleId(GetSoldUnit()), 0x1B5F3A6A, 1.70)
        call SaveReal(YDHT, GetHandleId(GetSoldUnit()), 0x9D1E5CF3, 1.70)
        call DisplayTimedTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, 10.00, "|cffff0000 【统御之冠】|r|cffff9900：英雄物理/法术暴击率+5%、英雄物理/法术暴击上限+20%、英雄总攻击力+10%！、英雄总法术伤害+10%！|r")
    else
        call SaveReal(YDHT, GetHandleId(GetSoldUnit()), 0x1B5F3A6A, 1.50)
        call SaveReal(YDHT, GetHandleId(GetSoldUnit()), 0x9D1E5CF3, 1.50)
    endif
    if ( ( ( ( YDWEGetIntegerByInteger(4 , GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))) ) / ( 100 ) ) >= 10 ) ) then
        call SetUnitMoveSpeed(GetSoldUnit(), ( GetUnitMoveSpeed(GetSoldUnit()) + 10.00 ))
    else
    endif
    if ( ( ( ( YDWEGetIntegerByInteger(4 , GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))) ) / ( 100 ) ) >= 30 ) ) then
        call SetUnitMoveSpeed(GetSoldUnit(), ( GetUnitMoveSpeed(GetSoldUnit()) + 20.00 ))
    else
    endif
    if ( ( ( ( YDWEGetIntegerByInteger(4 , GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))) ) / ( 100 ) ) >= 80 ) ) then
        call ModifyHeroStat(bj_HEROSTAT_STR, GetSoldUnit(), bj_MODIFYMETHOD_ADD, 100)
        call ModifyHeroStat(bj_HEROSTAT_AGI, GetSoldUnit(), bj_MODIFYMETHOD_ADD, 100)
        call ModifyHeroStat(bj_HEROSTAT_INT, GetSoldUnit(), bj_MODIFYMETHOD_ADD, 100)
    else
    endif
    call DzAPI_Map_StoreInteger(Player(0) , "maptest2020" , 10)
    if ( ( DzAPI_Map_GetServerValue(GetOwningPlayer(GetBuyingUnit()) , "maptest2020") == "1" ) ) then
        call DisplayTimedTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, 10.00, "|cffff0000 【内测福利】|r|cffff9900：您是尊贵的内测玩家，开局战魂额外增加100点！|r")
        call AdjustPlayerStateBJ(100, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_LUMBER)
    else
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
//===========================================================================
function InitTrig___________________u takes nothing returns nothing
    set gg_trg___________________u=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg___________________u, EVENT_PLAYER_UNIT_SELL)
    call TriggerAddCondition(gg_trg___________________u, Condition(function Trig___________________uConditions))
    call TriggerAddAction(gg_trg___________________u, function Trig___________________uActions)
endfunction
//===========================================================================
// Trigger: A伤害系统A
//
// 英雄，非攻击，非远程=物理伤害 可以说，英雄=物理伤害
// 英雄，攻击，非远程=可触发发球的物理伤害
// 2-（1-0.06）*护甲
//===========================================================================
function Trig_A____________AConditions takes nothing returns boolean
    return ( ( GetEventDamage() > 0.00 ) )
endfunction
function Trig_A____________AActions takes nothing returns nothing
    local integer ydl_triggerstep
    local trigger ydl_trigger
    local group ydl_group
    local unit ydl_unit
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    if ( ( YDWEIsEventDamageType(DAMAGE_TYPE_UNIVERSAL) == true ) ) then
        set udg_r=100.00
        set udg_g=100.00
        set udg_b=0.00
    else
        if ( ( YDWEIsEventAttackType(ATTACK_TYPE_HERO) == true ) ) then
            // 物理
            if ( ( GetUnitState(GetTriggerUnit(), ConvertUnitState(0x20)) >= 0.00 ) ) then
                if ( ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0x636DFFD3) > 1.00 ) ) then
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xC160BD5E, 0.00)
                else
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xC160BD5E, ( 1.00 - LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0x636DFFD3) ))
                endif
                call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x434DF776, ( ( 0.01 * GetUnitState(GetTriggerUnit(), ConvertUnitState(0x20)) ) / ( ( 0.01 ) * ( GetUnitState(GetTriggerUnit(), ConvertUnitState(0x20)) ) + ( 1.00 ) ) ))
                call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x06ECB893, ( 1.00 - LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x434DF776) ))
                call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE42C4FCD, ( GetEventDamage() / LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x06ECB893) ))
                call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE664F0DA, ( ( ( 0.01 ) * ( GetUnitState(GetTriggerUnit(), ConvertUnitState(0x20)) ) * ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xC160BD5E) ) ) / ( ( 0.01 ) * ( ( GetUnitState(GetTriggerUnit(), ConvertUnitState(0x20)) * LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xC160BD5E) ) ) + ( 1.00 ) ) ))
                call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5B3A060E, ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE42C4FCD) * ( 1.00 - LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE664F0DA) ) ))
                if ( ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xDE68E786) != 0.00 ) ) then
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49, ( 1.00 - LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xDE68E786) ))
                else
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49, 1.00)
                endif
                if ( ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) != 0.00 ) ) then
                    if ( ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) > 1.00 ) ) then
                        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A, 0.00)
                    else
                        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A, ( 1.00 - LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) ))
                    endif
                    call YDWESetEventDamage(( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5B3A060E) ) * ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49) ) * ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A) ) ))
                else
                    call YDWESetEventDamage(( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5B3A060E) * LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49) ))
                endif
            else
                if ( ( GetUnitState(GetTriggerUnit(), ConvertUnitState(0x20)) >= - 20.00 ) ) then
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB29D6446, ( 2.00 - Pow(0.94, RAbsBJ(GetUnitState(GetTriggerUnit(), ConvertUnitState(0x20)))) ))
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE42C4FCD, ( GetEventDamage() / LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB29D6446) ))
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6BC38F96, ( 2.00 - Pow(0.99, RAbsBJ(GetUnitState(GetTriggerUnit(), ConvertUnitState(0x20)))) ))
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5B3A060E, ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE42C4FCD) * LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6BC38F96) ))
                    if ( ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xDE68E786) != 0.00 ) ) then
                        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49, ( 1.00 - LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xDE68E786) ))
                    else
                        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49, 1.00)
                    endif
                    if ( ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) != 0.00 ) ) then
                        if ( ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) > 1.00 ) ) then
                            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A, 0.00)
                        else
                            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A, ( 1.00 - LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) ))
                        endif
                        call YDWESetEventDamage(( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5B3A060E) ) * ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49) ) * ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A) ) ))
                    else
                        call YDWESetEventDamage(( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5B3A060E) * LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49) ))
                    endif
                else
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB29D6446, 1.71)
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE42C4FCD, ( GetEventDamage() / LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB29D6446) ))
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6BC38F96, ( 2.00 - Pow(0.99, RAbsBJ(GetUnitState(GetTriggerUnit(), ConvertUnitState(0x20)))) ))
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5B3A060E, ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE42C4FCD) * LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6BC38F96) ))
                    if ( ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xDE68E786) != 0.00 ) ) then
                        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49, ( 1.00 - LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xDE68E786) ))
                    else
                        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49, 1.00)
                    endif
                    if ( ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) != 0.00 ) ) then
                        if ( ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) > 1.00 ) ) then
                            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A, 0.00)
                        else
                            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A, ( 1.00 - LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) ))
                        endif
                        call YDWESetEventDamage(( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5B3A060E) ) * ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49) ) * ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A) ) ))
                    else
                        call YDWESetEventDamage(( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5B3A060E) * LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49) ))
                    endif
                endif
            endif
        else
            // 法术
            if ( ( YDWEIsEventAttackType(ATTACK_TYPE_NORMAL) == true ) ) then
                if ( ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0xA65B3CF5) >= 0.00 ) ) then
                    if ( ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xA727C6F6) > 1.00 ) ) then
                        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x07D19E86, 0.00)
                    else
                        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x07D19E86, ( 1.00 - LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xA727C6F6) ))
                    endif
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE42C4FCD, GetEventDamage())
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x2D111C77, ( ( ( 0.01 ) * ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0xA65B3CF5) ) * ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x07D19E86) ) ) / ( ( 0.01 ) * ( ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0xA65B3CF5) * LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x07D19E86) ) ) + ( 1.00 ) ) ))
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF72F08DF, ( 1.00 - LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x2D111C77) ))
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x4860B02B, ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE42C4FCD) * LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF72F08DF) ))
                    if ( ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xDE68E786) != 0.00 ) ) then
                        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49, ( 1.00 - LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xDE68E786) ))
                    else
                        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49, 1.00)
                    endif
                    if ( ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) != 0.00 ) ) then
                        if ( ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) > 1.00 ) ) then
                            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A, 0.00)
                        else
                            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A, ( 1.00 - LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) ))
                        endif
                        call YDWESetEventDamage(( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x4860B02B) ) * ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49) ) * ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A) ) ))
                    else
                        call YDWESetEventDamage(( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x4860B02B) * LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49) ))
                    endif
                else
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6BC38F96, ( 2.00 - Pow(0.99, RAbsBJ(LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0xA65B3CF5))) ))
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x4860B02B, ( GetEventDamage() * LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6BC38F96) ))
                    if ( ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xDE68E786) != 0.00 ) ) then
                        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49, ( 1.00 - LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xDE68E786) ))
                    else
                        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49, 1.00)
                    endif
                    if ( ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) != 0.00 ) ) then
                        if ( ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) > 1.00 ) ) then
                            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A, 0.00)
                        else
                            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A, ( 1.00 - LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0x1F5F705A) ))
                        endif
                        call YDWESetEventDamage(( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x4860B02B) ) * ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49) ) * ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1F5F705A) ) ))
                    else
                        call YDWESetEventDamage(( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x4860B02B) * LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xF24F5E49) ))
                    endif
                endif
            else
            endif
        endif
        if ( ( YDWEIsEventAttackType(ATTACK_TYPE_HERO) == true ) and ( YDWEIsEventAttackDamage() == false ) ) then
            // 非攻击类型物理暴击判定
            if ( ( LoadInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))]), 0xC1C7B969) > 0 ) and ( GetRandomInt(1, 100) <= LoadInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))]), 0xC1C7B969) ) ) then
                // 物理暴击效果
                call YDWESetEventDamage(( GetEventDamage() * LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))]), 0xBFA256FF) ))
                // 物理暴击吸血
                if ( ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))]), 0x59E18EE2) > 0.00 ) ) then
                    call SetUnitLifeBJ(GetEventDamageSource(), ( ( GetUnitStateSwap(UNIT_STATE_LIFE, GetEventDamageSource()) ) + ( ( ( GetEventDamage() ) * ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))]), 0x59E18EE2) ) ) ) ))
                    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Undead\\VampiricAura\\VampiricAuraTarget.mdl", GetEventDamageSource(), "origin"))
                    call CreateTextTagUnitBJ(I2S(R2I(( GetEventDamage() * LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))]), 0x59E18EE2) ))), GetEventDamageSource(), 0, 12.00, 0.00, 100.00, 0.00, 0)
                    call SetTextTagPermanent(GetLastCreatedTextTag(), false)
                    call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
                    call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
                    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 85.00, ( GetRandomReal(0.00, 360.00) ))
                else
                endif
                set udg_r=100.00
                set udg_g=0.00
                set udg_b=0.00
            else
                if ( ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))]), 0x59E18EE2) > 0.00 ) ) then
                    call SetUnitLifeBJ(GetEventDamageSource(), ( ( GetUnitStateSwap(UNIT_STATE_LIFE, GetEventDamageSource()) ) + ( ( ( GetEventDamage() ) * ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))]), 0x59E18EE2) ) ) ) ))
                    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Undead\\VampiricAura\\VampiricAuraTarget.mdl", GetEventDamageSource(), "origin"))
                    call CreateTextTagUnitBJ(I2S(R2I(( GetEventDamage() * LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))]), 0x59E18EE2) ))), GetEventDamageSource(), 0, 10.00, 0.00, 85.00, 0.00, 0)
                    call SetTextTagPermanent(GetLastCreatedTextTag(), false)
                    call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
                    call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
                    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 85.00, ( GetRandomReal(0.00, 360.00) ))
                else
                endif
                set udg_r=100.00
                set udg_g=100.00
                set udg_b=100.00
            endif
        else
            if ( ( YDWEIsEventAttackType(ATTACK_TYPE_HERO) == true ) and ( YDWEIsEventAttackDamage() == true ) ) then
                // 重击判定
                if ( ( GetUnitAbilityLevel(GetEventDamageSource(), 'A05I') > 0 ) and ( GetRandomInt(1, 10) <= 3 ) ) then
                    call UnitDamageTarget(GetEventDamageSource(), GetTriggerUnit(), GetUnitState(GetEventDamageSource(), ConvertUnitState(0x15)), false, false, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
                    set ydl_trigger=gg_trg_______1A
                    set ydl_triggerstep=GetHandleId(ydl_trigger) * ( LoadInteger(YDLOC, GetHandleId(ydl_trigger), 0xCFDE6C76) + 3 )
                    call SaveUnitHandle(YDLOC, ydl_triggerstep, 0x911D5DC2, GetTriggerUnit())
                    call SaveReal(YDLOC, ydl_triggerstep, 0x312C4181, 1.00)
                    call TriggerExecute(ydl_trigger)
                else
                endif
                // 能触发法球效果（攻击伤害）
                // 物理暴击伤害判定
                if ( ( LoadInteger(YDHT, GetHandleId(GetEventDamageSource()), 0xC1C7B969) > 0 ) and ( GetRandomInt(1, 100) <= LoadInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))]), 0xC1C7B969) ) ) then
                    // 物理暴击效果
                    call YDWESetEventDamage(( GetEventDamage() * LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xBFA256FF) ))
                    // 暴击溅射
                    set ydl_group=CreateGroup()
                    call GroupEnumUnitsInRange(ydl_group, GetUnitX(GetTriggerUnit()), GetUnitY(GetTriggerUnit()), 300.00, null)
                    loop
                        set ydl_unit=FirstOfGroup(ydl_group)
                        exitwhen ydl_unit == null
                        call GroupRemoveUnit(ydl_group, ydl_unit)
                        if ( ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xAAFAF365) > 0.00 ) and ( IsUnitEnemy(ydl_unit, GetOwningPlayer(GetEventDamageSource())) == true ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) and ( IsUnit(ydl_unit, GetTriggerUnit()) == false ) ) then
                            call UnitDamageTarget(GetEventDamageSource(), ydl_unit, ( GetEventDamage() * LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))]), 0xAAFAF365) ), false, false, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
                        else
                        endif
                    endloop
                    call DestroyGroup(ydl_group)
                    // 物理暴击吸血
                    if ( ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0x59E18EE2) > 0.00 ) ) then
                        call SetUnitLifeBJ(GetEventDamageSource(), ( ( GetUnitStateSwap(UNIT_STATE_LIFE, GetEventDamageSource()) ) + ( ( ( GetEventDamage() ) * ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))]), 0x59E18EE2) ) ) ) ))
                        call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Undead\\VampiricAura\\VampiricAuraTarget.mdl", GetEventDamageSource(), "origin"))
                        call CreateTextTagUnitBJ(I2S(R2I(( GetEventDamage() * LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetEventDamageSource()))]), 0x59E18EE2) ))), GetEventDamageSource(), 0, 12.00, 0.00, 100.00, 0.00, 0)
                        call SetTextTagPermanent(GetLastCreatedTextTag(), false)
                        call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
                        call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
                        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 85.00, ( GetRandomReal(0.00, 360.00) ))
                    else
                    endif
                    set udg_r=100.00
                    set udg_g=0.00
                    set udg_b=0.00
                else
                    // 普通溅射
                    set ydl_group=CreateGroup()
                    call GroupEnumUnitsInRange(ydl_group, GetUnitX(GetTriggerUnit()), GetUnitY(GetTriggerUnit()), 200.00, null)
                    loop
                        set ydl_unit=FirstOfGroup(ydl_group)
                        exitwhen ydl_unit == null
                        call GroupRemoveUnit(ydl_group, ydl_unit)
                        if ( ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xAAFAF365) > 0.00 ) and ( IsUnitEnemy(ydl_unit, GetOwningPlayer(GetEventDamageSource())) == true ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) and ( IsUnit(ydl_unit, GetTriggerUnit()) == false ) ) then
                            call UnitDamageTarget(GetEventDamageSource(), ydl_unit, ( GetEventDamage() * LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xAAFAF365) ), false, false, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
                        else
                        endif
                    endloop
                    call DestroyGroup(ydl_group)
                    // 物理吸血
                    if ( ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0x59E18EE2) > 0.00 ) ) then
                        call SetUnitLifeBJ(GetEventDamageSource(), ( ( GetUnitStateSwap(UNIT_STATE_LIFE, GetEventDamageSource()) ) + ( ( ( GetEventDamage() ) * ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0x59E18EE2) ) ) ) ))
                        call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Undead\\VampiricAura\\VampiricAuraTarget.mdl", GetEventDamageSource(), "origin"))
                        call CreateTextTagUnitBJ(I2S(R2I(( GetEventDamage() * LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0x59E18EE2) ))), GetEventDamageSource(), 0, 10.00, 0.00, 85.00, 0.00, 0)
                        call SetTextTagPermanent(GetLastCreatedTextTag(), false)
                        call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
                        call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
                        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 85.00, ( GetRandomReal(0.00, 360.00) ))
                    else
                    endif
                    set udg_r=100.00
                    set udg_g=100.00
                    set udg_b=100.00
                endif
            else
                if ( ( YDWEIsEventAttackType(ATTACK_TYPE_NORMAL) == true ) ) then
                    // 法术暴击伤害
                    if ( ( LoadInteger(YDHT, GetHandleId(GetEventDamageSource()), 0xC7A2FC1F) > 0 ) and ( GetRandomInt(1, 100) <= LoadInteger(YDHT, GetHandleId(GetEventDamageSource()), 0xC7A2FC1F) ) ) then
                        call YDWESetEventDamage(( GetEventDamage() * LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0x9D1E5CF3) ))
                        // 法术暴击吸血
                        if ( ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0x83C13D14) > 0.00 ) ) then
                            call SetUnitLifeBJ(GetEventDamageSource(), ( ( GetUnitStateSwap(UNIT_STATE_LIFE, GetEventDamageSource()) ) + ( ( ( GetEventDamage() ) * ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0x83C13D14) ) ) ) ))
                            call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Undead\\VampiricAura\\VampiricAuraTarget.mdl", GetEventDamageSource(), "origin"))
                            call CreateTextTagUnitBJ(I2S(R2I(( GetEventDamage() * LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0x83C13D14) ))), GetEventDamageSource(), 0, 12.00, 0.00, 100.00, 0.00, 0)
                            call SetTextTagPermanent(GetLastCreatedTextTag(), false)
                            call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
                            call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
                            call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 85.00, ( GetRandomReal(0.00, 360.00) ))
                        else
                        endif
                        set udg_r=225.00
                        set udg_g=0.00
                        set udg_b=0.00
                    else
                        // 法术普通吸血
                        if ( ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0x83C13D14) > 0.00 ) ) then
                            call SetUnitLifeBJ(GetEventDamageSource(), ( ( GetUnitStateSwap(UNIT_STATE_LIFE, GetEventDamageSource()) ) + ( ( ( GetEventDamage() ) * ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0x83C13D14) ) ) ) ))
                            call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Undead\\VampiricAura\\VampiricAuraTarget.mdl", GetEventDamageSource(), "origin"))
                            call CreateTextTagUnitBJ(I2S(R2I(( GetEventDamage() * LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0x83C13D14) ))), GetEventDamageSource(), 0, 10.00, 0.00, 85.00, 0.00, 0)
                            call SetTextTagPermanent(GetLastCreatedTextTag(), false)
                            call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
                            call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
                            call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 85.00, ( GetRandomReal(0.00, 360.00) ))
                        else
                        endif
                        set udg_r=100.00
                        set udg_g=50.00
                        set udg_b=50.00
                    endif
                else
                endif
            endif
        endif
    endif
    // 白色伤害
    call CreateTextTagUnitBJ(I2S(R2I(GetEventDamage())), GetTriggerUnit(), 0, 12.00, udg_r, udg_g, udg_b, 0)
    call SetTextTagPermanent(GetLastCreatedTextTag(), false)
    call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
    call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
    call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 80.00, ( GetRandomReal(85.00, 105.00) ))
    set udg_r=100.00
    set udg_g=100.00
    set udg_b=100.00
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    set ydl_trigger=null
    set ydl_group=null
    set ydl_unit=null
endfunction
//===========================================================================
function InitTrig_A____________A takes nothing returns nothing
    set gg_trg_A____________A=CreateTrigger()
    call YDWESyStemAnyUnitDamagedRegistTrigger(gg_trg_A____________A)
    call TriggerAddCondition(gg_trg_A____________A, Condition(function Trig_A____________AConditions))
    call TriggerAddAction(gg_trg_A____________A, function Trig_A____________AActions)
endfunction
