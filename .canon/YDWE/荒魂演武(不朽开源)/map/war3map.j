function Trig_mainFunc091FT takes nothing returns nothing
    call DzSyncData("点击回城", "1")
endfunction
function Trig_mainFunc092KT takes nothing returns nothing
    call DzSyncData("TAB同步", "1")
endfunction
function Trig_mainActions takes nothing returns nothing
    local integer ydul_i
    local integer ydul_x
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call DzLoadToc("war3mapImported\\custom2.toc")
    set udg_WPLUI[0]=DzCreateFrameByTagName("BACKDROP", "提示背景", DzGetGameUI(), "a", 0)
    set udg_WPLUI[1]=DzCreateFrameByTagName("TEXT", "物品描述", udg_WPLUI[0], "template", 0)
    set udg_WPLUI[2]=DzCreateFrameByTagName("TEXT", "物品属性", udg_WPLUI[0], "template", 0)
    set udg_WPLUI[3]=DzCreateFrameByTagName("TEXT", "物品名字", udg_WPLUI[0], "template", 0)
    set udg_WPLUI[4]=DzCreateFrameByTagName("BACKDROP", "物品贴图", udg_WPLUI[0], "template", 0)
    set udg_WPLUI[5]=DzCreateFrameByTagName("BACKDROP", "黄金贴图", udg_WPLUI[0], "template", 0)
    set udg_WPLUI[6]=DzCreateFrameByTagName("TEXT", "物品价钱", udg_WPLUI[0], "template", 0)
    set udg_WPLUI[7]=DzCreateFrameByTagName("TEXT", "物品出卖提示", udg_WPLUI[0], "template", 0)
    call DzFrameSetSize(udg_WPLUI[1], 0.21, 0.00)
    call DzFrameSetSize(udg_WPLUI[2], 0.21, 0.00)
    call DzFrameSetSize(udg_WPLUI[4], 0.032, 0.032)
    call DzFrameSetSize(udg_WPLUI[5], 0.01, 0.01)
    call DzFrameSetTexture(udg_WPLUI[4], "UI\\Widgets\\ToolTips\\Human\\human-tooltip-background.blp", 0)
    call DzFrameSetTexture(udg_WPLUI[5], "UI\\Feedback\\Resources\\ResourceGold.blp", 0)
    call DzFrameSetText(udg_WPLUI[1], "这里显示物品的说明")
    call DzFrameSetFont(udg_WPLUI[1], "Fonts\\fonts.ttf", 0.011, 0)
    call DzFrameSetText(udg_WPLUI[2], "物品属性这里显示物品的属性")
    call DzFrameSetFont(udg_WPLUI[2], "Fonts\\fonts.ttf", 0.011, 0)
    call DzFrameSetText(udg_WPLUI[3], "物品名字")
    call DzFrameSetFont(udg_WPLUI[3], "Fonts\\fonts.ttf", 0.013, 0)
    call DzFrameSetPoint(udg_WPLUI[1], 7, DzFrameGetCommandBarButton(0, 1), 1, 0.01, 0.04)
    call DzFrameSetPoint(udg_WPLUI[2], 6, udg_WPLUI[1], 0, 0, 0.01)
    call DzFrameSetPoint(udg_WPLUI[3], 0, udg_WPLUI[2], 0, 0.037, 0.042)
    call DzFrameSetPoint(udg_WPLUI[4], 6, udg_WPLUI[2], 0, 0, 0.01)
    call DzFrameSetPoint(udg_WPLUI[5], 6, udg_WPLUI[4], 8, 0.005, 0.008)
    call DzFrameSetPoint(udg_WPLUI[6], 6, udg_WPLUI[5], 8, 0.01, 0.00)
    call DzFrameSetPoint(udg_WPLUI[7], 6, udg_WPLUI[6], 8, 0.01, 0.00)
    call DzFrameSetPoint(udg_WPLUI[0], 1, udg_WPLUI[3], 1, 0, 0.005)
    call DzFrameSetPoint(udg_WPLUI[0], 3, udg_WPLUI[2], 3, - 0.005, 0)
    call DzFrameSetPoint(udg_WPLUI[0], 5, udg_WPLUI[2], 5, 0.005, 0)
    call DzFrameSetPoint(udg_WPLUI[0], 7, udg_WPLUI[1], 7, 0, - 0.005)
    call DzFrameShow(udg_WPLUI[0], false)
    set ydul_i=0
    loop
        exitwhen ydul_i > 5
        call DzFrameSetScript(DzFrameGetItemBarButton(ydul_i), 2, "Trig_call_FrameOvActions", false)
        call DzFrameSetScript(DzFrameGetItemBarButton(ydul_i), 3, "Trig_call_FrameOutActions", false)
        call SaveInteger(YDHT, DzF2I(DzFrameGetItemBarButton(ydul_i)), 0x6F96F2D2, ydul_i)
        set ydul_i=ydul_i + 1
    endloop
    // 分割
    set udg_WPLUI[100]=DzCreateFrameByTagName("BACKDROP", "属性背景", DzGetGameUI(), "template", 0)
    call DzFrameSetSize(udg_WPLUI[100], 0.22, 0.3)
    call DzFrameSetTexture(udg_WPLUI[100], "SXMB.blp", 0)
    call DzFrameSetPoint(udg_WPLUI[100], 4, DzGetGameUI(), 4, - 0.25, 0.07)
    set udg_WPLUI[101]=DzCreateFrameByTagName("TEXT", "物理攻击", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[101], 0, udg_WPLUI[100], 0, 0.03, - 0.06)
    set udg_WPLUI[102]=DzCreateFrameByTagName("TEXT", "物理暴击", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[102], 0, udg_WPLUI[101], 6, 0.00, - 0.01)
    set udg_WPLUI[103]=DzCreateFrameByTagName("TEXT", "物理暴击效果", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[103], 0, udg_WPLUI[102], 6, 0.00, - 0.01)
    set udg_WPLUI[104]=DzCreateFrameByTagName("TEXT", "物理吸血", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[104], 0, udg_WPLUI[103], 6, 0.00, - 0.01)
    set udg_WPLUI[105]=DzCreateFrameByTagName("TEXT", "物理穿透", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[105], 0, udg_WPLUI[104], 6, 0.00, - 0.01)
    set udg_WPLUI[111]=DzCreateFrameByTagName("TEXT", "普攻溅射", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[111], 0, udg_WPLUI[105], 6, 0.00, - 0.01)
    set udg_WPLUI[112]=DzCreateFrameByTagName("TEXT", "攻击速度", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[112], 0, udg_WPLUI[111], 6, 0.00, - 0.01)
    set udg_WPLUI[116]=DzCreateFrameByTagName("TEXT", "冷却缩减", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[116], 0, udg_WPLUI[112], 6, 0.00, - 0.01)
    // 分割
    set udg_WPLUI[106]=DzCreateFrameByTagName("TEXT", "法术攻击", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[106], 0, udg_WPLUI[100], 2, - 0.10, - 0.06)
    set udg_WPLUI[107]=DzCreateFrameByTagName("TEXT", "法术暴击", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[107], 0, udg_WPLUI[106], 6, 0.00, - 0.01)
    set udg_WPLUI[108]=DzCreateFrameByTagName("TEXT", "法术暴击效果", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[108], 0, udg_WPLUI[107], 6, 0.00, - 0.01)
    set udg_WPLUI[109]=DzCreateFrameByTagName("TEXT", "法术吸血", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[109], 0, udg_WPLUI[108], 6, 0.00, - 0.01)
    set udg_WPLUI[110]=DzCreateFrameByTagName("TEXT", "法术穿透", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[110], 0, udg_WPLUI[109], 6, 0.00, - 0.01)
    set udg_WPLUI[113]=DzCreateFrameByTagName("TEXT", "伤害减免", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[113], 0, udg_WPLUI[110], 6, 0.00, - 0.01)
    set udg_WPLUI[114]=DzCreateFrameByTagName("TEXT", "移动速度", udg_WPLUI[100], "template", 0)
    call DzFrameSetPoint(udg_WPLUI[114], 0, udg_WPLUI[113], 6, 0.00, - 0.01)
