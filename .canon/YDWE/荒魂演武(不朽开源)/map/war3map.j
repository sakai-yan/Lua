                            call DzSyncData("物品栏右键", I2S(LoadInteger(YDLOC, 0xBFD19E14, 0xC13DC62F)))
                        else
                        endif
                    else
                        if ( ( LoadReal(YDLOC, 0xBFD19E14, 0xE9538A45) >= 0.556 ) and ( LoadReal(YDLOC, 0xBFD19E14, 0xE9538A45) <= 0.587 ) and ( LoadReal(YDLOC, 0xBFD19E14, 0xB9A5F07B) >= 0.075 ) ) then
                            call SaveInteger(YDLOC, 0xBFD19E14, 0xC13DC62F, 2)
