function InitTrig_TF_1______u takes nothing returns nothing
    set gg_trg_TF_1______u=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_TF_1______u, EVENT_PLAYER_UNIT_SELL_ITEM)
    call TriggerAddCondition(gg_trg_TF_1______u, Condition(function Trig_TF_1______uConditions))
    call TriggerAddAction(gg_trg_TF_1______u, function Trig_TF_1______uActions)
endfunction
