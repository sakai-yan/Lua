        call SetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), 'A001', ( 1 + ( GetUnitLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)) / 10 ) ))
        call SetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), 'A00F', ( 1 + ( GetUnitLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)) / 10 ) ))
        call YDWESetUnitAbilityDataReal(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F) , 'A01W' , 1 , 108 , ( GetUnitStateSwap(ConvertUnitState(0x12), LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)) * 0.30 ))
        call SaveReal(YDHT, GetHandleId(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)), 0xA65B3CF5, GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), ConvertUnitState(0x20)))
    else
        if ( ( GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)) >= 50 ) ) then
            call SetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), UNIT_STATE_MAX_LIFE, ( ( ( - 200000.00 ) + ( I2R(GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F))) ) * ( 9000.00 ) ) * udg_ND ))
            call SetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), UNIT_STATE_MAX_MANA, ( ( I2R(GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F))) * 5000.00 ) * udg_ND ))
            call SetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), ConvertUnitState(0x12), ( ( I2R(GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F))) * 80.00 ) * udg_ND ))
            call SetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), ConvertUnitState(0x20), ( ( I2R(GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F))) * 10.00 ) * udg_ND ))
            call SetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), UNIT_STATE_LIFE, GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), UNIT_STATE_MAX_LIFE))
            call SetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), UNIT_STATE_MANA, GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), UNIT_STATE_MAX_MANA))
            call PingMinimapEx(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382), 6.00, 255, 0, 0, true)
            call DisplayTimedTextToForce(GetPlayersAll(), 10.00, ( ( "|cffff0000" ) + ( ( "传说级BOSS  " + ( ( EXExecuteScript("(require'jass.slk').unit[" + I2S(GetUnitTypeId(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F))) + "].Name") ) + ( ( "  " ) + ( GetHeroProperName(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)) ) + ( "  |r" ) ) ) ) ) + ( "降临！" ) ))
            call PlaySoundBJ(gg_snd_Hint)
        else
            call SetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), UNIT_STATE_MAX_LIFE, ( ( ( - 85000.00 ) + ( I2R(GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F))) ) * ( 4000.00 ) ) * udg_ND ))
            call SetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), UNIT_STATE_MAX_MANA, ( ( I2R(GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F))) * 1100.00 ) * udg_ND ))
            call SetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), ConvertUnitState(0x12), ( ( I2R(GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F))) * 40.00 ) * udg_ND ))
            call SetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), ConvertUnitState(0x20), ( ( I2R(GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F))) * 7.00 ) * udg_ND ))
            call SetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), UNIT_STATE_LIFE, GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), UNIT_STATE_MAX_LIFE))
            call SetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), UNIT_STATE_MANA, GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), UNIT_STATE_MAX_MANA))
            call PingMinimapEx(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382), 6.00, 255, 0, 0, true)
            call DisplayTimedTextToForce(GetPlayersAll(), 10.00, ( ( "|cffffff00" ) + ( ( "英雄级BOSS  " + ( ( EXExecuteScript("(require'jass.slk').unit[" + I2S(GetUnitTypeId(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F))) + "].Name") ) + ( ( "  " ) + ( GetHeroProperName(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)) ) + ( "  |r" ) ) ) ) ) + ( "降临！" ) ))
            call PlaySoundBJ(gg_snd_Hint)
        endif
        call SetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), 'A00U', ( 1 + ( GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)) / 10 ) ))
        call SetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), 'A00E', ( 1 + ( GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)) / 10 ) ))
        call SetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), 'A011', ( 1 + ( GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)) / 10 ) ))
        call SetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), 'A014', ( 1 + ( GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)) / 10 ) ))
        call SetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), 'A001', ( 1 + ( GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)) / 10 ) ))
        call SetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), 'A00F', ( 1 + ( GetUnitPointValue(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)) / 10 ) ))
        call SaveReal(YDHT, GetHandleId(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)), 0xA65B3CF5, GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F), ConvertUnitState(0x20)))
        call SaveReal(YDHT, GetHandleId(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)), 0x3C007FD8, ( 0.06 * udg_ND ))
        call SaveReal(YDHT, GetHandleId(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)), 0x1F5F705A, ( 0.04 * udg_ND ))
        call SaveReal(YDHT, GetHandleId(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)), 0x636DFFD3, ( 0.05 * udg_ND ))
        call SaveReal(YDHT, GetHandleId(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x41EDBF2F)), 0xA727C6F6, ( 0.05 * udg_ND ))
        call RemoveUnit(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x31FCE5AE))
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
    call DestroyTimer(GetExpiredTimer())
endfunction
function Trig_02____________uActions takes nothing returns nothing
    local timer ydl_timer
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    if ( ( IsUnitType(GetDyingUnit(), UNIT_TYPE_HERO) == false ) ) then
        if ( ( GetUnitLevel(GetDyingUnit()) <= 19 ) ) then
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x269EB3F5, 60.00)
        else
            if ( ( GetUnitLevel(GetDyingUnit()) > 19 ) and ( GetUnitLevel(GetDyingUnit()) < 30 ) ) then
                call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x269EB3F5, 70.00)
            else
                if ( ( GetUnitLevel(GetDyingUnit()) > 29 ) and ( GetUnitLevel(GetDyingUnit()) < 35 ) ) then
                    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x269EB3F5, 80.00)
                else
                    if ( ( GetUnitLevel(GetDyingUnit()) > 34 ) and ( GetUnitLevel(GetDyingUnit()) < 45 ) ) then
                        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x269EB3F5, 120.00)
                    else
                        if ( ( GetUnitLevel(GetDyingUnit()) > 44 ) and ( GetUnitLevel(GetDyingUnit()) < 50 ) ) then
                            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x269EB3F5, 180.00)
                        else
                            if ( ( GetUnitLevel(GetDyingUnit()) >= 50 ) ) then
                                call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x269EB3F5, 240.00)
                            else
                            endif
                        endif
                    endif
                endif
            endif
        endif
    else
        if ( ( GetUnitPointValue(GetDyingUnit()) >= 50 ) ) then
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x269EB3F5, 240.00)
        else
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x269EB3F5, 180.00)
        endif
    endif
    set ydl_timer=CreateTimer()
    call SaveInteger(YDLOC, GetHandleId(ydl_timer), 0x75F50D63, LoadInteger(YDHT, GetHandleId(GetDyingUnit()), 0x7602A218))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0xA99320FA, LoadReal(YDHT, GetHandleId(GetDyingUnit()), 0xFF431EB1))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0xFDF65382, LoadReal(YDHT, GetHandleId(GetDyingUnit()), 0x797E43AA))
    call FlushChildHashtable(YDHT, GetHandleId(GetDyingUnit()))
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x31FCE5AE, GetDyingUnit())
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x41EDBF2F, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x41EDBF2F))
    call TimerStart(ydl_timer, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x269EB3F5), false, function Trig_02____________uFunc002T)
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    set ydl_timer=null
endfunction
//===========================================================================
function InitTrig_02____________u takes nothing returns nothing
    set gg_trg_02____________u=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_02____________u, EVENT_PLAYER_UNIT_DEATH)
    call TriggerAddCondition(gg_trg_02____________u, Condition(function Trig_02____________uConditions))
    call TriggerAddAction(gg_trg_02____________u, function Trig_02____________uActions)
endfunction
//===========================================================================
// Trigger: 03召唤赋值
//===========================================================================
function Trig_03____________uConditions takes nothing returns boolean
    return ( ( IsUnitEnemy(GetSummonedUnit(), Player(7)) == true ) )
endfunction
function Trig_03____________uActions takes nothing returns nothing
    call SetUnitState(GetSummonedUnit(), UNIT_STATE_MAX_LIFE, ( GetUnitState(GetSummoningUnit(), UNIT_STATE_MAX_LIFE) * 0.60 ))
    call SetUnitState(GetSummonedUnit(), UNIT_STATE_MAX_MANA, ( GetUnitState(GetSummoningUnit(), UNIT_STATE_MAX_MANA) * 0.60 ))
    call SetUnitState(GetSummonedUnit(), ConvertUnitState(0x12), ( GetUnitState(GetSummoningUnit(), ConvertUnitState(0x12)) * 0.50 ))
    call SetUnitState(GetSummonedUnit(), ConvertUnitState(0x20), ( GetUnitState(GetSummoningUnit(), ConvertUnitState(0x20)) * 0.50 ))
    call SetUnitState(GetSummonedUnit(), UNIT_STATE_LIFE, GetUnitState(GetSummonedUnit(), UNIT_STATE_MAX_LIFE))
    call SetUnitState(GetSummonedUnit(), UNIT_STATE_MANA, GetUnitState(GetSummonedUnit(), UNIT_STATE_MAX_MANA))
endfunction
//===========================================================================
function InitTrig_03____________u takes nothing returns nothing
    set gg_trg_03____________u=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_03____________u, EVENT_PLAYER_UNIT_SUMMON)
    call TriggerAddCondition(gg_trg_03____________u, Condition(function Trig_03____________uConditions))
    call TriggerAddAction(gg_trg_03____________u, function Trig_03____________uActions)
endfunction
