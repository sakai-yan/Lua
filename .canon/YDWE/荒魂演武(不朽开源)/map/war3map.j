            else
                if ( ( ( LoadInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, 0xBFD19E14, 0x48656946)), 0xD559A298) == 1 ) or ( LoadInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, 0xBFD19E14, 0x48656946)), 0xAC8C0C19) == 1 ) or ( LoadInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, 0xBFD19E14, 0x48656946)), 0x559F7668) == 1 ) ) ) then
                    call DzSyncData("右键世界", "1")
