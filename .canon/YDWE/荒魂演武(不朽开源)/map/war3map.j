        loop
            set ydl_unit=FirstOfGroup(ydl_group)
            exitwhen ydl_unit == null
            call GroupRemoveUnit(ydl_group, ydl_unit)
            if ( ( IsUnitEnemy(ydl_unit, GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9))) == true ) and ( UnitHasBuffBJ(ydl_unit, 'B00F') == true ) and ( IsUnitInGroup(ydl_unit, LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xB69688B0)) == false ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) ) then
                call GroupAddUnit(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xB69688B0), ydl_unit)
                call SaveReal(YDHT, GetHandleId(ydl_unit), 0xDE68E786, ( LoadReal(YDHT, GetHandleId(ydl_unit), 0xDE68E786) + 0.15 ))
            else
            endif
        endloop
        call DestroyGroup(ydl_group)
        call ForGroupBJ(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xB69688B0), function Trig_0005Func001Func001Func001Func005A)
    else
        if ( ( CountUnitsInGroup(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xB69688B0)) == 0 ) ) then
            call DestroyGroup(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xB69688B0))
            call RemoveSavedInteger(YDHT, GetHandleId(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)), 0x8215E9CF)
            call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
            call DestroyTimer(GetExpiredTimer())
        else
            call ForGroupBJ(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xB69688B0), function Trig_0005Func001Func001Func001Func001Func001A)
        endif
    endif
    set ydl_group=null
    set ydl_unit=null
