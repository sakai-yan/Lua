//===========================================================================
// Trigger: 001
//===========================================================================
function Trig_001Conditions takes nothing returns boolean
    return ( ( IsUnitEnemy(GetTriggerUnit(), Player(7)) == true ) )
endfunction
function Trig_001Func001T takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    if ( ( ( GetUnitCurrentOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)) == ( 851983 ) ) or ( GetUnitCurrentOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)) == ( 851986 ) ) ) ) then
        // 无目标
        if ( ( YDWEDistanceBetweenUnits(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9) , LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF047C7C9)) <= 400.00 ) ) then
            call IssueImmediateOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "stomp")
            call IssueImmediateOrderById(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 852588)
        else
        endif
        call IssueImmediateOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "roar")
        call IssueImmediateOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "mirrorimage")
        call IssueImmediateOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "berserk")
        if ( ( GetUnitLifePercent(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)) <= 70.00 ) and ( ( GetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 'AEme') > 0 ) or ( GetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 'Abrf') > 0 ) or ( GetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 'AHav') > 0 ) ) ) then
            call IssueImmediateOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "bearform")
            call IssueImmediateOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "metamorphosis")
            call IssueImmediateOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "avatar")
        else
        endif
        // 单位目标
        if ( ( GetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 'A016') > 0 ) ) then
            set ydl_group=CreateGroup()
            call GroupEnumUnitsInRange(ydl_group, GetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)), GetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)), 720.00, null)
            loop
                set ydl_unit=FirstOfGroup(ydl_group)
                exitwhen ydl_unit == null
                call GroupRemoveUnit(ydl_group, ydl_unit)
                if ( ( IsUnitAlly(ydl_unit, Player(8)) == true ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) ) then
                    call IssueTargetOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "healingwave", ydl_unit)
                else
                endif
            endloop
            call DestroyGroup(ydl_group)
        else
        endif
        if ( ( GetUnitAbilityLevel(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 'A017') > 0 ) ) then
            set ydl_group=CreateGroup()
            call GroupEnumUnitsInRange(ydl_group, GetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)), GetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)), 720.00, null)
            loop
                set ydl_unit=FirstOfGroup(ydl_group)
                exitwhen ydl_unit == null
                call GroupRemoveUnit(ydl_group, ydl_unit)
                if ( ( IsUnitAlly(ydl_unit, Player(8)) == false ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) ) then
                    call IssueTargetOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "chainlightning", ydl_unit)
                else
                endif
            endloop
            call DestroyGroup(ydl_group)
        else
        endif
        call IssueTargetOrderById(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 852211, LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF047C7C9))
        call IssueTargetOrderById(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 852095, LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF047C7C9))
        call IssueTargetOrderById(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 852527, LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF047C7C9))
        call IssueTargetOrderById(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 852179, LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF047C7C9))
        call IssueTargetOrderById(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 852075, LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF047C7C9))
        // 点目标
        call IssuePointOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), "shockwave", GetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF047C7C9)), GetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF047C7C9)))
        call IssuePointOrderById(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 852105, GetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF047C7C9)), GetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF047C7C9)))
        call IssuePointOrderById(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 852488, GetUnitX(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF047C7C9)), GetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xF047C7C9)))
    else
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
    call DestroyTimer(GetExpiredTimer())
    set ydl_group=null
    set ydl_unit=null
endfunction
function Trig_001Actions takes nothing returns nothing
    local timer ydl_timer
    set ydl_timer=CreateTimer()
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0xF047C7C9, GetEventDamageSource())
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x458B7DE9, GetTriggerUnit())
    call TimerStart(ydl_timer, 0.00, false, function Trig_001Func001T)
    set ydl_timer=null
endfunction
