                call SaveReal(YDLOC, 0x73EF02D4, 0x9758C297, ( ( 1.00 ) - ( ( ( I2R(LoadInteger(YDLOC, 0x73EF02D4, 0x92656BCF)) ) / ( I2R(LoadInteger(YDLOC, 0x73EF02D4, 0x7E363F5C)) ) ) ) ))
                call SaveReal(YDLOC, 0x73EF02D4, 0xB9A5F07B, ( ( LoadReal(YDLOC, 0x73EF02D4, 0x9758C297) ) * ( 0.60 ) ))
                if ( ( LoadReal(YDLOC, 0x73EF02D4, 0xB9A5F07B) >= 0.11 ) ) then
                    if ( ( LoadInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, 0x73EF02D4, 0x192409FE)), 0xAC8C0C19) == 0 ) ) then
