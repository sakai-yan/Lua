function Trig_CJUI_1Func017A takes nothing returns nothing
    if ( ( DzAPI_Map_IsAuthor(GetEnumPlayer()) == true ) ) then
        call YDWESaveIntegerByInteger(4 , GetConvertedPlayerId(GetEnumPlayer()) , 12000)
    else
    endif
    call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x52DB984E, "")
    if ( ( ( ( YDWEGetIntegerByInteger(4 , GetConvertedPlayerId(GetEnumPlayer())) ) / ( 100 ) ) >= 10 ) ) then
        call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x52DB984E, ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x52DB984E) + "成就等级10：英雄移速+10|cff00ff00 【已解锁】|r" ))
