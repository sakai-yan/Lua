function Trig_02____________uConditions takes nothing returns boolean
    return ( ( IsUnitAlly(GetDyingUnit(), Player(PLAYER_NEUTRAL_AGGRESSIVE)) == true ) and ( IsUnitType(GetDyingUnit(), UNIT_TYPE_SUMMONED) == false ) and ( IsUnitType(GetDyingUnit(), UNIT_TYPE_STRUCTURE) == false ) )
endfunction
