                call DzFrameShow(udg_ZBTB[LoadInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), 0x9B313EF3)], false)
                call DzFrameShow(udg_YDTB, false)
            else
            endif
            if ( ( GetItemType(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD14F34A9)) == ITEM_TYPE_CHARGED ) ) then
                call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8D62EFEB, ( GetItemCharges(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD14F34A9)) * ( S2I(EXExecuteScript("(require'jass.slk').item[" + I2S(GetItemTypeId(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD14F34A9))) + "].goldcost")) / 2 ) ))
                call AdjustPlayerStateBJ(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8D62EFEB), LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946), PLAYER_STATE_RESOURCE_GOLD)
                call CreateTextTagUnitBJ(( "+" + I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8D62EFEB)) ), udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946))], - 3.00, 11.00, 100, 86.27, 0.00, 0)
                call SetTextTagPermanent(GetLastCreatedTextTag(), false)
                call SetTextTagFadepoint(GetLastCreatedTextTag(), 2.00)
                call SetTextTagLifespan(GetLastCreatedTextTag(), 3.00)
                call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 54.00, 90)
            else
                call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8D62EFEB, ( S2I(EXExecuteScript("(require'jass.slk').item[" + I2S(GetItemTypeId(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD14F34A9))) + "].goldcost")) / 2 ))
                call AdjustPlayerStateBJ(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8D62EFEB), LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946), PLAYER_STATE_RESOURCE_GOLD)
                call CreateTextTagUnitBJ(( "+" + I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x8D62EFEB)) ), udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946))], - 3.00, 11.00, 100, 86.27, 0.00, 0)
                call SetTextTagPermanent(GetLastCreatedTextTag(), false)
                call SetTextTagFadepoint(GetLastCreatedTextTag(), 2.00)
                call SetTextTagLifespan(GetLastCreatedTextTag(), 3.00)
                call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 54.00, 90)
            endif
            call SaveInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), 0xD559A298, 0)
            call SaveInteger(udg_HXB, GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), LoadInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), 0x9B313EF3), 0)
            call SaveInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), 0x559F7668, 2)
            call SaveInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), 0xD559A298, 0)
            call FlushChildHashtable(YDHT, GetHandleId(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD14F34A9)))
            call RemoveItem(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD14F34A9))
        else
            call DisplayTextToPlayer(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946), 0, 0, "|cffff0000该物品不可贩卖|r")
