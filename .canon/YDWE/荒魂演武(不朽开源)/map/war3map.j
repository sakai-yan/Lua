    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xF2ED32BC, GetUnitManaPercent(GetTriggerUnit()))
    // 生命值
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x651DD2FC, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x651DD2FC) + LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x9890BA1B) ))
    // 魔法值
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xCBF95817, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xCBF95817) + LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x634C8CDF) ))
    // 物理攻击
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xEF12EDB1, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xEF12EDB1) + LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xD0241DEB) ))
    // 三维
    if ( ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x30FA192C) == true ) or ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x678A421B) == true ) or ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x6F97DD18) == true ) ) ) then
        if ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x30FA192C) == true ) ) then
