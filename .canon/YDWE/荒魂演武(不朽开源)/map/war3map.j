// Trigger: 6E0
//===========================================================================
function Trig_6E0Conditions takes nothing returns boolean
    return ( ( GetLearnedSkill() == 'A04L' ) )
endfunction
function Trig_6E0Actions takes nothing returns nothing
    call TriggerRegisterUnitEvent(gg_trg_6E, GetTriggerUnit(), EVENT_UNIT_TARGET_IN_RANGE)
    // 分割
    call TriggerRegisterUnitEvent(gg_trg_6E1, GetTriggerUnit(), EVENT_UNIT_DEATH)
    call TriggerRegisterUnitEvent(gg_trg_6E1, GetTriggerUnit(), EVENT_UNIT_SPELL_CHANNEL)
    call TriggerRegisterUnitEvent(gg_trg_6E1, GetTriggerUnit(), EVENT_UNIT_ISSUED_TARGET_ORDER)
    call TriggerRegisterUnitEvent(gg_trg_6E1, GetTriggerUnit(), EVENT_UNIT_ISSUED_POINT_ORDER)
    call TriggerRegisterUnitEvent(gg_trg_6E1, GetTriggerUnit(), EVENT_UNIT_ISSUED_ORDER)
    // 分割
    call TriggerRegisterUnitEvent(gg_trg_6E2, GetTriggerUnit(), EVENT_UNIT_ISSUED_ORDER)
    call DestroyTrigger(GetTriggeringTrigger())
endfunction
