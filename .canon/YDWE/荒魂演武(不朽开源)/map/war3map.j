function Trig_______07Func001Func001A takes nothing returns nothing
    if ( ( GetUnitCurrentOrder(GetEnumUnit()) != String2OrderIdBJ("attack") ) ) then
        call IssuePointOrder(GetEnumUnit(), "attack", - 500.00, - 6150.00)
    else
    endif
endfunction
function Trig_______07Func001T takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    call ForGroupBJ(udg_attack, function Trig_______07Func001Func001A)
    set ydl_group=null
    set ydl_unit=null
endfunction
