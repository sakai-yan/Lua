function Trig_020Actions takes nothing returns nothing
    local integer ydul_x
    local timer ydl_timer
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call DisplayTimedTextToForce(GetPlayersAll(), 10.00, "|cffffff00恭喜你们！战胜了堕落泰坦！")
    set udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]=( ( udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] ) + ( 200.00 ) )
    call ForForce(udg_WZJ, function Trig_020Func003A)
    set ydul_x=1
    loop
        exitwhen ydul_x > 7
        if ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE7EF03D0) == udg_MVP[ydul_x] ) ) then
            call SavePlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946, ConvertedPlayer(ydul_x))
            call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xC3E47FB0, DzAPI_Map_GetStoredInteger(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946) , "MVP"))
            call DzAPI_Map_StoreInteger(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946) , "MVP" , ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xC3E47FB0) ) + ( 1 ) ))
            call DzAPI_Map_Stat_SetStat(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946) , "MVP" , I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xC3E47FB0)))
            if ( ( udg_ND >= 7.00 ) ) then
                call DialogSetMessage(udg_WJdhk, "无尽模式")
                // 分割
                call DialogAddButtonWithHotkeyBJ(udg_WJdhk, "无尽第 1 波开始(快捷键：1）", '0')
                set udg_WJdhkan[1]=bj_lastCreatedButton
                call SaveInteger(YDHT, GetHandleId(udg_WJdhkan[1]), 0x67F63465, 1)
                // 分割
                call DialogAddButtonWithHotkeyBJ(udg_WJdhk, "无尽第 50 波开始(快捷键：1）", '1')
                set udg_WJdhkan[2]=bj_lastCreatedButton
                call SaveInteger(YDHT, GetHandleId(udg_WJdhkan[2]), 0x67F63465, 50)
                // 分割
                call DialogAddButtonWithHotkeyBJ(udg_WJdhk, "无尽第 100 波开始(快捷键：2）", '2')
                set udg_WJdhkan[3]=GetLastCreatedButtonBJ()
                call SaveInteger(YDHT, GetHandleId(udg_WJdhkan[3]), 0x67F63465, 100)
                // 取消
                call DialogAddButtonWithHotkeyBJ(udg_WJdhk, "退出游戏", 512)
                set udg_WJdhkan[9]=GetLastCreatedButtonBJ()
                call DialogDisplay(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946), udg_WJdhk, true)
                call DisplayTimedTextToForce(GetPlayersAll(), 30, "请等待本局MVP选择无尽开始波数！")
            else
                set ydl_timer=CreateTimer()
                call TimerStart(ydl_timer, 5.00, false, function Trig_020Func004Func001Func005Func002T)
            endif
        else
        endif
        set ydul_x=ydul_x + 1
    endloop
    call DestroyTrigger(GetTriggeringTrigger())
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    set ydl_timer=null
endfunction
