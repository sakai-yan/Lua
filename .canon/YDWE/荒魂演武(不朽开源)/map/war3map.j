                    call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E) ) + ( "|n提升物理攻击: " ) + ( ( I2S(R2I(( ( LoadReal(YDHT, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), 0xE2DD07B4) ) * ( I2R(ydul_LV) ) * ( 100.00 ) ))) + " %" ) ) ))
