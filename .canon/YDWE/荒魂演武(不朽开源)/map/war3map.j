                        if ( ( UnitInventoryCount(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, 0x73EF02D4, 0x192409FE))]) < 6 ) ) then
                            call SaveInteger(YDLOC, 0x73EF02D4, 0x19EAB52A, DzGetMouseX())
