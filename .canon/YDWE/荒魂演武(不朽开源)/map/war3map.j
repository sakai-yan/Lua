function Trig_19DConditions takes nothing returns boolean
    return ( ( GetSpellAbilityId() == 'A06Q' ) )
endfunction
function Trig_19DFunc004T takes nothing returns nothing
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)))]), 0xE2DD07B4, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)))]), 0xE2DD07B4) - LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xC12A04F7) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)))]), 0x1F5F705A, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9)))]), 0x1F5F705A) - 1.00 ))
    call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
    call DestroyTimer(GetExpiredTimer())
endfunction
function Trig_19DActions takes nothing returns nothing
    local timer ydl_timer
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xC12A04F7, ( ( 0.00 ) + ( I2R(GetUnitAbilityLevel(GetTriggerUnit(), 'A06Q')) ) * ( 1.00 ) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x1F5F705A, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x1F5F705A) + 1.00 ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xE2DD07B4, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xE2DD07B4) + LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xC12A04F7) ))
    set ydl_timer=CreateTimer()
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x458B7DE9, GetTriggerUnit())
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0xC12A04F7, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xC12A04F7))
    call TimerStart(ydl_timer, 30.00, false, function Trig_19DFunc004T)
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    set ydl_timer=null
endfunction
