//===========================================================================
function InitTrig_TF_2______u takes nothing returns nothing
    set gg_trg_TF_2______u=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_TF_2______u, EVENT_PLAYER_UNIT_SELL_ITEM)
    call TriggerAddCondition(gg_trg_TF_2______u, Condition(function Trig_TF_2______uConditions))
    call TriggerAddAction(gg_trg_TF_2______u, function Trig_TF_2______uActions)
endfunction
//===========================================================================
// Trigger: wjgw无尽怪物
//===========================================================================
function Trig_wjgw____________uActions takes nothing returns nothing
    // 小怪
    set udg_WJXB[0]='h00W'
    set udg_WJXB[1]='h00Y'
    set udg_WJXB[2]='h010'
    // BOSS
    set udg_WJBOSS[0]='h00V'
    set udg_WJBOSS[1]='h00X'
    set udg_WJBOSS[2]='h00Z'
    // 排泄
    call DestroyTrigger(GetTriggeringTrigger())
endfunction
//===========================================================================
function InitTrig_wjgw____________u takes nothing returns nothing
    set gg_trg_wjgw____________u=CreateTrigger()
    call TriggerAddAction(gg_trg_wjgw____________u, function Trig_wjgw____________uActions)
endfunction
//===========================================================================
// Trigger: wj1_无尽开启
//===========================================================================
function Trig_wj1_____________uFunc001Func015A takes nothing returns nothing
    call CreateFogModifierRectBJ(true, GetEnumPlayer(), FOG_OF_WAR_VISIBLE, LoadRectHandle(YDHT, GetHandleId(GetEnumPlayer()), 0x99CFE654))
    call SaveLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x5B0D7524, PolarProjectionBJ(udg_WJ_GWD[GetConvertedPlayerId(GetEnumPlayer())], 800.00, 270.00))
    call PanCameraToTimedLocForPlayer(GetEnumPlayer(), LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x5B0D7524), 0.10)
    call SetUnitPositionLoc(udg_Hero[GetConvertedPlayerId(GetEnumPlayer())], LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x5B0D7524))
