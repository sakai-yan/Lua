        call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x8B1FFFFC, ( ( 200.00 ) + ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFBBFF844) ) * ( SinBJ(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xB9A583B8)) ) ))
