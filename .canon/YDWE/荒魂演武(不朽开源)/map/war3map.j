//===========================================================================
// Trigger: TAB_同步
//===========================================================================
function Trig_TAB_______uActions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SavePlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946, DzGetTriggerSyncPlayer())
    if ( ( LoadInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), 0xB755BCE8) == 1 ) ) then
        call SaveInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), 0xB755BCE8, 2)
        if ( ( LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946) == GetLocalPlayer() ) ) then
            call DzFrameShow(udg_WPLUI[100], true)
        else
        endif
    else
        call SaveInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), 0xB755BCE8, 1)
        if ( ( LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946) == GetLocalPlayer() ) ) then
            call DzFrameShow(udg_WPLUI[100], false)
        else
        endif
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
//===========================================================================
function InitTrig_TAB_______u takes nothing returns nothing
    set gg_trg_TAB_______u=CreateTrigger()
    call DzTriggerRegisterSyncData(gg_trg_TAB_______u, "TAB同步", false)
    call TriggerAddAction(gg_trg_TAB_______u, function Trig_TAB_______uActions)
endfunction
//===========================================================================
// Trigger: call_FrameOv
//===========================================================================
function Trig_call_FrameOvActions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x2F128C38, DzGetTriggerUIEventFrame())
    call SavePlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x32A9E4C8, DzGetTriggerUIEventPlayer())
    call SaveItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCDB28B13, UnitItemInSlot(udg_xz[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x32A9E4C8))], LoadInteger(YDHT, DzF2I(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x2F128C38)), 0x6F96F2D2)))
    if ( ( LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCDB28B13) != null ) ) then
        call DzFrameShow(udg_WPLUI[0], true)
        if ( ( HaveSavedString(YDHT, GetItemTypeId(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCDB28B13)), 0xC3C655B7) == true ) ) then
            call DzFrameSetText(udg_WPLUI[1], LoadStr(YDHT, GetItemTypeId(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCDB28B13)), 0xC3C655B7))
        else
            if ( ( HaveSavedString(YDHT, GetItemTypeId(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCDB28B13)), 0x6945FB09) == true ) ) then
                call DzFrameSetText(udg_WPLUI[1], "")
            else
                call DzFrameSetText(udg_WPLUI[1], YDWEGetItemDataString(GetItemTypeId(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCDB28B13)) , 3))
            endif
        endif
        call DzFrameSetText(udg_WPLUI[2], LoadStr(YDHT, GetItemTypeId(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCDB28B13)), 0x6945FB09))
        call DzFrameSetText(udg_WPLUI[3], GetItemName(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCDB28B13)))
        if ( ( IsItemPawnable(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCDB28B13)) == true ) ) then
            call DzFrameSetText(udg_WPLUI[6], ( "|CFFFED312" + I2S(( S2I(( EXExecuteScript("(require'jass.slk').item[" + I2S(GetItemTypeId(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCDB28B13))) + "].goldcost") )) / 2 )) ))
            call DzFrameSetText(udg_WPLUI[7], "|cff808080将物品扔在商店上以卖出|R")
        else
            call DzFrameSetText(udg_WPLUI[6], "|CFFFED312不可出售")
            call DzFrameSetText(udg_WPLUI[7], " ")
        endif
        call DzFrameSetTexture(udg_WPLUI[4], YDWEGetItemDataString(GetItemTypeId(LoadItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCDB28B13)) , 1), 0)
        call DzFrameClearAllPoints(DzFrameGetTooltip())
        call DzFrameSetPoint(DzFrameGetTooltip(), 7, DzGetGameUI(), 7, 0, - 0.60)
    else
    endif
    call SaveItemHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xCDB28B13, null)
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
