        call IssueImmediateOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x8B1FFFFC), "stop")
        call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
        call DestroyTimer(GetExpiredTimer())
    else
        call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA))
        if ( ( GetUnitCurrentOrder(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x8B1FFFFC)) != String2OrderIdBJ("move") ) ) then
            call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
            call DestroyTimer(GetExpiredTimer())
        else
        endif
    endif
endfunction
