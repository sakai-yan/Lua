//===========================================================================
// Trigger: 022
//
// 6+lv*lv/10
//===========================================================================
function Trig_022Conditions takes nothing returns boolean
    return ( ( IsUnitEnemy(GetDyingUnit(), Player(7)) == true ) and ( IsUnitAlly(GetDyingUnit(), Player(8)) == false ) )
endfunction
function Trig_022Actions takes nothing returns nothing
    if ( ( IsUnitType(GetDyingUnit(), UNIT_TYPE_HERO) == false ) ) then
        if ( ( GetUnitLevel(GetDyingUnit()) >= 45 ) and ( GetUnitLevel(GetDyingUnit()) < 50 ) ) then
            set udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]=( ( udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] ) + ( 30.00 ) )
            call DisplayTimedTextToForce(GetPlayersAll(), 6.00, ( ( ( ( GetPlayerName(GetOwningPlayer(GetKillingUnitBJ())) ) + ( " 的 " ) + ( GetUnitName(GetKillingUnitBJ()) ) ) ) + ( " |cffff0000击杀|r 英雄级怪物 " ) + ( GetUnitName(GetDyingUnit()) ) ))
        else
            if ( ( GetUnitLevel(GetDyingUnit()) > 50 ) ) then
                set udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]=( ( udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] ) + ( 70.00 ) )
                call DisplayTimedTextToForce(GetPlayersAll(), 6.00, ( ( ( ( GetPlayerName(GetOwningPlayer(GetKillingUnitBJ())) ) + ( " 的 " ) + ( GetUnitName(GetKillingUnitBJ()) ) ) ) + ( " |cffff0000击杀|r 传说级怪物！ " ) + ( GetUnitName(GetDyingUnit()) ) ))
            else
                set udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]=( ( udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] ) + ( ( I2R(GetUnitLevel(GetDyingUnit())) / 50.00 ) ) )
            endif
        endif
    else
        if ( ( GetUnitPointValue(GetDyingUnit()) >= 50 ) ) then
            set udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]=( ( udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] ) + ( 70.00 ) )
            call DisplayTimedTextToForce(GetPlayersAll(), 6.00, ( ( ( ( GetPlayerName(GetOwningPlayer(GetKillingUnitBJ())) ) + ( " 的 " ) + ( GetUnitName(GetKillingUnitBJ()) ) ) ) + ( " |cffff0000击杀|r 传说级怪物！ " ) + ( GetUnitName(GetDyingUnit()) ) ))
        else
            set udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))]=( ( udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ()))] ) + ( 30.00 ) )
            call DisplayTimedTextToForce(GetPlayersAll(), 6.00, ( ( ( ( GetPlayerName(GetOwningPlayer(GetKillingUnitBJ())) ) + ( " 的 " ) + ( GetUnitName(GetKillingUnitBJ()) ) ) ) + ( " |cffff0000击杀|r 英雄级怪物 " ) + ( GetUnitName(GetDyingUnit()) ) ))
        endif
    endif
endfunction
