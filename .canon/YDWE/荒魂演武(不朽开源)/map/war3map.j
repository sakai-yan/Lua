function Trig_______UI_______uActions takes nothing returns nothing
    local integer ydul_EbfFG6yY
    local integer ydul_X
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    set udg_HXB=InitHashtable()
    // 创建图标
    set udg_UI[0]=DzCreateFrameByTagName("BACKDROP", "name", DzGetGameUI(), "template", 0)
    call DzFrameSetTexture(udg_UI[0], "ReplaceableTextures\\CommandButtons\\BTNbb.blp", 0)
    call DzFrameSetSize(udg_UI[0], 0.03, 0.04)
    call DzFrameSetPoint(udg_UI[0], 4, DzGetGameUI(), 4, - 0.34, - 0.11)
    // 创建按钮
    set udg_UI[1]=DzCreateFrameByTagName("GLUETEXTBUTTON", "name", DzGetGameUI(), "template", 0)
    call DzFrameSetSize(udg_UI[1], 0.03, 0.04)
    call DzFrameSetPoint(udg_UI[1], 4, udg_UI[0], 4, 0.00, 0.00)
    if GetLocalPlayer() == GetLocalPlayer() then
    	call DzFrameSetScriptByCode(udg_UI[1], 1, function Trig_______UI_______uFunc011FT, false)
    endif
    // 创建背景
    set udg_UI[2]=DzCreateFrameByTagName("BACKDROP", "name", DzGetGameUI(), "template", 0)
    call DzFrameSetTexture(udg_UI[2], "bb.blp", 0)
    call DzFrameSetSize(udg_UI[2], 0.33, 0.30)
    call DzFrameSetPoint(udg_UI[2], 4, DzGetGameUI(), 4, 0.30, 0.05)
    call DzFrameShow(udg_UI[2], false)
    // 创建背景阻挡
    set udg_UI[99]=DzCreateFrameByTagName("GLUETEXTBUTTON", "name", udg_UI[2], "template", 0)
    call DzFrameSetSize(udg_UI[99], 0.33, 0.30)
    call DzFrameSetPoint(udg_UI[99], 4, DzGetGameUI(), 4, 0.30, 0.05)
    call SaveBoolean(YDHT, DzF2I(udg_UI[99]), 0x142CC13F, true)
    // 关闭按钮
    set udg_UI[3]=DzCreateFrameByTagName("GLUETEXTBUTTON", "name", udg_UI[2], "template", 0)
    call DzFrameSetSize(udg_UI[3], 0.03, 0.03)
    call DzFrameSetPoint(udg_UI[3], 4, DzGetGameUI(), 4, 0.18, - 0.053)
    if GetLocalPlayer() == GetLocalPlayer() then
    	call DzFrameSetScriptByCode(udg_UI[3], 1, function Trig_______UI_______uFunc027FT, false)
    endif
    // 关闭按钮图标
    set udg_UI[4]=DzCreateFrameByTagName("BACKDROP", "name", udg_UI[2], "template", 0)
    call DzFrameSetTexture(udg_UI[4], "gb.blp", 0)
    call DzFrameSetSize(udg_UI[4], 0.03, 0.03)
    call DzFrameSetPoint(udg_UI[4], 4, udg_UI[3], 4, 0.00, 0.00)
    set udg_UI[10]=DzCreateFrameByTagName("BACKDROP", "name", udg_UI[2], "template", 0)
    call DzFrameSetTexture(udg_UI[10], "UI_bb_fmck.blp", 0)
    call DzFrameSetSize(udg_UI[10], 0.13, 0.08)
    call DzFrameSetPoint(udg_UI[10], 4, udg_UI[3], 4, 0.145, 0.01)
    set udg_UI[11]=DzCreateFrameByTagName("GLUETEXTBUTTON", "name", udg_UI[2], "template", 0)
    call DzFrameSetSize(udg_UI[11], 0.13, 0.08)
    call DzFrameSetPoint(udg_UI[11], 4, udg_UI[10], 4, 0.00, 0.00)
    if GetLocalPlayer() == GetLocalPlayer() then
    	call DzFrameSetScriptByCode(udg_UI[11], 1, function Trig_______UI_______uFunc033Func008FT, false)
    endif
    call SaveBoolean(YDHT, DzF2I(udg_UI[11]), 0x142CC13F, true)
    // 坐标参照
    set udg_UI[6]=DzCreateFrameByTagName("GLUETEXTBUTTON", "name", udg_UI[2], "template", 0)
    call DzFrameSetSize(udg_UI[6], 0.03, 0.03)
    call DzFrameSetPoint(udg_UI[6], 4, DzGetGameUI(), 4, 0.134, 0.166)
    call DzFrameShow(udg_UI[6], false)
    // 文本框
    set udg_UIWBK=DzCreateFrameByTagName("BACKDROP", "name", udg_UI[2], "c", 0)
    call DzFrameSetAlpha(udg_UIWBK, 200)
    call DzFrameSetSize(udg_UIWBK, 0.10, 0.30)
    call DzFrameSetPoint(udg_UIWBK, 4, udg_UI[6], 4, - 0.05, - 0.12)
    // 文本
    set udg_UIWB=DzCreateFrameByTagName("TEXT", "name", udg_UIWBK, "template", 0)
    call DzFrameSetSize(udg_UIWB, 0.09, 0.29)
    call DzFrameSetPoint(udg_UIWB, 4, udg_UIWBK, 4, 0.00, 0.00)
    call DzFrameSetText(udg_UIWB, " ")
    call DzFrameSetFont(udg_UIWB, "Fonts\\fonts.ttf", 0.009, 0)
    // 分割
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD3065916, 0.00)
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5F0E88EF, 0)
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x300B6E6B, 0)
    set ydul_EbfFG6yY=1
    loop
        exitwhen ydul_EbfFG6yY > 40
        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5F0E88EF, ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5F0E88EF) + 1 ))
        if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x300B6E6B) <= 7 ) ) then
            call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x300B6E6B, ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x300B6E6B) ) + ( 1 ) ))
            // 图标
            set udg_ZBTB[ydul_EbfFG6yY]=DzCreateFrameByTagName("BACKDROP", "name", udg_UI[2], "template", 0)
            call DzFrameSetSize(udg_ZBTB[ydul_EbfFG6yY], 0.025, 0.033)
            call DzFrameSetTexture(udg_ZBTB[ydul_EbfFG6yY], "ReplaceableTextures\\CommandButtons\\BTNPackBeast.blp", 0)
            call DzFrameSetPoint(udg_ZBTB[ydul_EbfFG6yY], 4, udg_UI[6], 4, ( I2R(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x300B6E6B)) * 0.0297 ), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD3065916))
            call DzFrameShow(udg_ZBTB[ydul_EbfFG6yY], false)
            // 使用次数
            set udg_ZBCS[ydul_EbfFG6yY]=DzCreateFrameByTagName("TEXT", "物品使用次数", udg_ZBTB[ydul_EbfFG6yY], "template", 0)
            call DzFrameSetPoint(udg_ZBCS[ydul_EbfFG6yY], 0, udg_ZBTB[ydul_EbfFG6yY], 8, - 0.005, 0.01)
            call DzFrameSetText(udg_ZBCS[ydul_EbfFG6yY], "1")
            call DzFrameShow(udg_ZBCS[ydul_EbfFG6yY], false)
            // 分割
            // 哈希表注册
            set ydul_X=1
            loop
                exitwhen ydul_X > 7
                call SaveInteger(udg_HXB, ydul_X, ydul_EbfFG6yY, 0)
                set ydul_X=ydul_X + 1
            endloop
            // 按钮
            set udg_UIAN[ydul_EbfFG6yY]=DzCreateFrameByTagName("GLUETEXTBUTTON", "name", udg_UI[2], "template", 0)
            call DzFrameSetSize(udg_UIAN[ydul_EbfFG6yY], 0.025, 0.033)
            call DzFrameSetPoint(udg_UIAN[ydul_EbfFG6yY], 4, udg_UI[6], 4, ( I2R(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x300B6E6B)) * 0.0297 ), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD3065916))
            call SaveInteger(YDHT, DzF2I(udg_UIAN[ydul_EbfFG6yY]), 0x5F0E88EF, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5F0E88EF))
            call SaveStr(YDLOC, 0xC30EE100, 0x90F4A78E, LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E))
            call SaveInteger(YDLOC, 0xC30EE100, 0xA99320FA, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA))
            call SaveInteger(YDLOC, 0xC30EE100, 0x1ADEDE7B, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1ADEDE7B))
            if GetLocalPlayer() == GetLocalPlayer() then
            	call DzFrameSetScriptByCode(udg_UIAN[ydul_EbfFG6yY], 2, function Trig_______UI_______uFunc054Func002Func043FT, false)
            endif
        else
            call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x300B6E6B, 1)
            call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD3065916, ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD3065916) - 0.036 ))
            // 图标
            set udg_ZBTB[ydul_EbfFG6yY]=DzCreateFrameByTagName("BACKDROP", "name", udg_UI[2], "template", 0)
            call DzFrameSetSize(udg_ZBTB[ydul_EbfFG6yY], 0.025, 0.033)
            call DzFrameSetTexture(udg_ZBTB[ydul_EbfFG6yY], "ReplaceableTextures\\CommandButtons\\BTNPackBeast.blp", 0)
            call DzFrameSetPoint(udg_ZBTB[ydul_EbfFG6yY], 4, udg_UI[6], 4, ( I2R(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x300B6E6B)) * 0.0297 ), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD3065916))
            call DzFrameShow(udg_ZBTB[ydul_EbfFG6yY], false)
            // 使用次数
            set udg_ZBCS[ydul_EbfFG6yY]=DzCreateFrameByTagName("TEXT", "物品使用次数", udg_ZBTB[ydul_EbfFG6yY], "template", 0)
            call DzFrameSetPoint(udg_ZBCS[ydul_EbfFG6yY], 0, udg_ZBTB[ydul_EbfFG6yY], 8, - 0.005, 0.01)
            call DzFrameSetText(udg_ZBCS[ydul_EbfFG6yY], "1")
            call DzFrameShow(udg_ZBCS[ydul_EbfFG6yY], false)
            // 分割
            // 哈希表注册
            set ydul_X=1
            loop
                exitwhen ydul_X > 7
                call SaveInteger(udg_HXB, ydul_X, ydul_EbfFG6yY, 0)
                set ydul_X=ydul_X + 1
            endloop
            // 按钮
            set udg_UIAN[ydul_EbfFG6yY]=DzCreateFrameByTagName("GLUETEXTBUTTON", "name", udg_UI[2], "template", 0)
            call DzFrameSetSize(udg_UIAN[ydul_EbfFG6yY], 0.025, 0.033)
            call DzFrameSetPoint(udg_UIAN[ydul_EbfFG6yY], 4, udg_UI[6], 4, ( I2R(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x300B6E6B)) * 0.0297 ), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xD3065916))
            call SaveInteger(YDHT, DzF2I(udg_UIAN[ydul_EbfFG6yY]), 0x5F0E88EF, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x5F0E88EF))
            call SaveStr(YDLOC, 0x3E338A2A, 0x90F4A78E, LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E))
            call SaveInteger(YDLOC, 0x3E338A2A, 0xA99320FA, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA))
            call SaveInteger(YDLOC, 0x3E338A2A, 0x1ADEDE7B, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x1ADEDE7B))
            if GetLocalPlayer() == GetLocalPlayer() then
            	call DzFrameSetScriptByCode(udg_UIAN[ydul_EbfFG6yY], 2, function Trig_______UI_______uFunc054Func002Func022FT, false)
            endif
        endif
        set ydul_EbfFG6yY=ydul_EbfFG6yY + 1
    endloop
    // 分割
    if GetLocalPlayer() == GetLocalPlayer() then
    	call DzTriggerRegisterKeyEventByCode(null, 'Z', 1, false, function Trig_______UI_______uFunc056KT)
    endif
    // 排泄
    set udg_YDTB=DzCreateFrameByTagName("BACKDROP", "name", DzGetGameUI(), "template", 0)
    call DzFrameSetTexture(udg_YDTB, "ReplaceableTextures\\CommandButtons\\BTNDranaiAkama.blp", 0)
    call DzFrameSetSize(udg_YDTB, 0.03, 0.03)
    call DzFrameSetPoint(udg_YDTB, 4, DzGetGameUI(), 4, 0.00, 0.00)
    call DzFrameShow(udg_YDTB, false)
    call DestroyTrigger(GetTriggeringTrigger())
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
