        if ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x08BAB87E) == true ) ) then
            call SaveReal(YDHT, GetHandleId(GetManipulatingUnit()), 0x08BAB87E, ( LoadReal(YDHT, GetHandleId(GetManipulatingUnit()), 0x08BAB87E) + LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x08BAB87E) ))
