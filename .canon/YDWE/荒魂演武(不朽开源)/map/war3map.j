function main takes nothing returns nothing
    call SetCameraBounds(- 16128.0 + GetCameraMargin(CAMERA_MARGIN_LEFT), - 8704.0 + GetCameraMargin(CAMERA_MARGIN_BOTTOM), 15104.0 - GetCameraMargin(CAMERA_MARGIN_RIGHT), 30720.0 - GetCameraMargin(CAMERA_MARGIN_TOP), - 16128.0 + GetCameraMargin(CAMERA_MARGIN_LEFT), 30720.0 - GetCameraMargin(CAMERA_MARGIN_TOP), 15104.0 - GetCameraMargin(CAMERA_MARGIN_RIGHT), - 8704.0 + GetCameraMargin(CAMERA_MARGIN_BOTTOM))
    call SetDayNightModels("Environment\\DNC\\DNCLordaeron\\DNCLordaeronTerrain\\DNCLordaeronTerrain.mdl", "Environment\\DNC\\DNCLordaeron\\DNCLordaeronUnit\\DNCLordaeronUnit.mdl")
    call NewSoundEnvironment("Default")
    call SetAmbientDaySound("LordaeronSummerDay")
    call SetAmbientNightSound("LordaeronSummerNight")
    call SetMapMusic("Music", true, 0)
    call InitSounds()
    call CreateRegions()
    call CreateAllUnits()
    call InitBlizzard()

call ExecuteFunc("jasshelper__initstructs881000")
call ExecuteFunc("YDTriggerSaveLoadSystem___Init")
call ExecuteFunc("InitializeYD")
call ExecuteFunc("YDWEGeneralBounsSystem__Initialize")
call ExecuteFunc("YDWETimerPattern__Init")
call ExecuteFunc("YDWETimerSystem__Init")

    call InitGlobals()
    call InitCustomTriggers()
    call RunInitializationTriggers()
endfunction
//***************************************************************************
//*
//*  Map Configuration
//*
//***************************************************************************
function config takes nothing returns nothing
    call SetMapName("荒魂演武")
    call SetMapDescription("守住54波敌人
击败最终BOSS萨格拉斯赢得游戏。")
    call SetPlayers(10)
    call SetTeams(10)
    call SetGamePlacement(MAP_PLACEMENT_TEAMS_TOGETHER)
    call DefineStartLocation(0, - 2880.0, - 8320.0)
    call DefineStartLocation(1, - 2880.0, - 8320.0)
    call DefineStartLocation(2, - 2880.0, - 8320.0)
    call DefineStartLocation(3, - 2880.0, - 8320.0)
    call DefineStartLocation(4, - 2880.0, - 8320.0)
    call DefineStartLocation(5, - 2880.0, - 8320.0)
    call DefineStartLocation(6, - 2880.0, - 8320.0)
    call DefineStartLocation(7, - 512.0, - 6144.0)
    call DefineStartLocation(8, 0.0, 2624.0)
    call DefineStartLocation(9, 13568.0, 13632.0)
    // Player setup
    call InitCustomPlayerSlots()
    call InitCustomTeams()
    call InitAllyPriorities()
endfunction
