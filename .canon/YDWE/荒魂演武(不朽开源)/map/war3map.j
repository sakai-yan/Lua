//===========================================================================
// Trigger: 角斗场1
//===========================================================================
function Trig__________1Actions takes nothing returns nothing
    // 角斗场难度
    set udg_JDCND=0
    // 普通20-29
    set udg_JDCpt[1]='o00F'
