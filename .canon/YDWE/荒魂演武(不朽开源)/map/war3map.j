        exitwhen ydul_x > 116
        call DzFrameSetFont(udg_WPLUI[ydul_x], "Fonts\\fonts.ttf", 0.013, 0)
        set ydul_x=ydul_x + 1
    endloop
    // 分割
    set udg_WPLUI[117]=DzCreateFrameByTagName("BACKDROP", "属性图标", DzGetGameUI(), "template", 0)
    call DzFrameSetSize(udg_WPLUI[117], 0.03, 0.04)
