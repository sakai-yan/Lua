//===========================================================================
// Trigger: CJUI_2
//===========================================================================
function Trig_CJUI_2Actions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SavePlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946, DzGetTriggerSyncPlayer())
    if ( ( LoadInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), 0x840FE6D3) == 0 ) ) then
        call SaveInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), 0x840FE6D3, 1)
        call SaveInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), 0x4DBE9797, 0)
        if ( ( LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946) == GetLocalPlayer() ) ) then
            call DzFrameShow(udg_WPZSUI[10], false)
            call DzFrameShow(udg_WPZSUI[11], false)
            call DzFrameShow(udg_WPZSUIAN[12], false)
            call DzFrameShow(udg_WPZSUIAN[13], false)
            call DzFrameShow(udg_WPZSUI[5], false)
            call DzFrameShow(udg_WPZSUI[6], false)
            call DzFrameShow(udg_CJUI[1], true)
            call DzFrameShow(udg_CJUI[2], true)
            call DzFrameShow(udg_CJUI[3], true)
            call DzFrameShow(udg_CJUI[200], true)
            call DzFrameShow(udg_CJUIAN[4], true)
            call DzFrameShow(udg_CJUI[204], true)
        else
        endif
    else
        call SaveInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946)), 0x840FE6D3, 0)
        if ( ( LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946) == GetLocalPlayer() ) ) then
            call DzFrameShow(udg_CJUI[1], false)
            call DzFrameShow(udg_CJUI[2], false)
            call DzFrameShow(udg_CJUI[3], false)
            call DzFrameShow(udg_CJUI[200], false)
            call DzFrameShow(udg_CJUIAN[4], false)
            call DzFrameShow(udg_CJUIAN[5], false)
            call DzFrameShow(udg_CJUI[6], false)
        else
        endif
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
//===========================================================================
function InitTrig_CJUI_2 takes nothing returns nothing
    set gg_trg_CJUI_2=CreateTrigger()
    call DzTriggerRegisterSyncData(gg_trg_CJUI_2, "打开成就", false)
    call TriggerAddAction(gg_trg_CJUI_2, function Trig_CJUI_2Actions)
endfunction
