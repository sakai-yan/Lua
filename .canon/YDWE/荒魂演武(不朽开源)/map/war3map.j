//===========================================================================
function Trig_______0Conditions takes nothing returns boolean
    return ( ( GetItemType(GetManipulatedItem()) == ITEM_TYPE_CHARGED ) )
endfunction
function Trig_______0Actions takes nothing returns nothing
    local integer ydul_x
    set ydul_x=0
    loop
        exitwhen ydul_x > 5
        if ( ( GetItemTypeId(GetManipulatedItem()) == GetItemTypeId(UnitItemInSlot(GetTriggerUnit(), ydul_x)) ) and ( GetManipulatedItem() != UnitItemInSlot(GetTriggerUnit(), ydul_x) ) ) then
            call SetItemCharges(UnitItemInSlot(GetTriggerUnit(), ydul_x), ( GetItemCharges(GetManipulatedItem()) + GetItemCharges(UnitItemInSlot(GetTriggerUnit(), ydul_x)) ))
            call RemoveItem(GetManipulatedItem())
        else
        endif
        set ydul_x=ydul_x + 1
    endloop
endfunction
//===========================================================================
function InitTrig_______0 takes nothing returns nothing
    set gg_trg_______0=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_______0, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_______0, Condition(function Trig_______0Conditions))
    call TriggerAddAction(gg_trg_______0, function Trig_______0Actions)
endfunction
//===========================================================================
// Trigger: 人造1
//===========================================================================
function Trig_______1Conditions takes nothing returns boolean
    return ( ( ( GetItemTypeId(GetSoldItem()) == 'I062' ) or ( GetItemTypeId(GetSoldItem()) == 'I06C' ) ) )
endfunction
function Trig_______1Actions takes nothing returns nothing
    if ( ( GetItemTypeId(GetSoldItem()) == 'I062' ) ) then
        if ( ( YDWEUnitHasItemOfTypeBJNull(GetBuyingUnit() , 'I05T') == true ) and ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) >= 1000 ) ) then
            call RemoveItem(YDWEGetItemOfTypeFromUnitBJNull(GetBuyingUnit() , 'I05T'))
            call AdjustPlayerStateBJ(- 1000, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
            call UnitAddItemByIdSwapped('I061', GetBuyingUnit())
            call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cffffff00升级成功！|r")
            call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Invisibility\\InvisibilityTarget.mdl", GetBuyingUnit(), "chest"))
        else
            if ( ( YDWEUnitHasItemOfTypeBJNull(GetBuyingUnit() , 'I061') == true ) and ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) >= 3000 ) ) then
                call RemoveItem(YDWEGetItemOfTypeFromUnitBJNull(GetBuyingUnit() , 'I061'))
