function Trig_A______uActions takes nothing returns nothing
    local integer ydl_triggerstep
    local trigger ydl_trigger
    set ydl_trigger=gg_trg_______1A
    set ydl_triggerstep=GetHandleId(ydl_trigger) * ( LoadInteger(YDLOC, GetHandleId(ydl_trigger), 0xCFDE6C76) + 3 )
    call SaveUnitHandle(YDLOC, ydl_triggerstep, 0x911D5DC2, GetEnumUnit())
    call SaveReal(YDLOC, ydl_triggerstep, 0x312C4181, 3.00)
    call TriggerExecute(ydl_trigger)
    // 减速
    set ydl_trigger=gg_trg_______3C
    set ydl_triggerstep=GetHandleId(ydl_trigger) * ( LoadInteger(YDLOC, GetHandleId(ydl_trigger), 0xCFDE6C76) + 3 )
    call SaveUnitHandle(YDLOC, ydl_triggerstep, 0x911D5DC2, GetEnumUnit())
    call SaveReal(YDLOC, ydl_triggerstep, 0x312C4181, 2.00)
    call TriggerExecute(ydl_trigger)
    set ydl_trigger=gg_trg_______________________________3C2
    set ydl_triggerstep=GetHandleId(ydl_trigger) * ( LoadInteger(YDLOC, GetHandleId(ydl_trigger), 0xCFDE6C76) + 3 )
    call SaveUnitHandle(YDLOC, ydl_triggerstep, 0x911D5DC2, GetEnumUnit())
    call SaveReal(YDLOC, ydl_triggerstep, 0x312C4181, 3.00)
    call SaveReal(YDLOC, ydl_triggerstep, 0x506BAE05, 0.20)
    call TriggerExecute(ydl_trigger)
    // 霜冻减速
    set ydl_trigger=gg_trg_____________4D
    set ydl_triggerstep=GetHandleId(ydl_trigger) * ( LoadInteger(YDLOC, GetHandleId(ydl_trigger), 0xCFDE6C76) + 3 )
    call SaveUnitHandle(YDLOC, ydl_triggerstep, 0x911D5DC2, GetEnumUnit())
    call SaveReal(YDLOC, ydl_triggerstep, 0x312C4181, 2.00)
    call TriggerExecute(ydl_trigger)
    // 缠绕
    set ydl_trigger=gg_trg_______2B
    set ydl_triggerstep=GetHandleId(ydl_trigger) * ( LoadInteger(YDLOC, GetHandleId(ydl_trigger), 0xCFDE6C76) + 3 )
    call SaveUnitHandle(YDLOC, ydl_triggerstep, 0x911D5DC2, GetSpellTargetUnit())
    call SaveReal(YDLOC, ydl_triggerstep, 0x312C4181, 3.00)
    call SaveReal(YDLOC, ydl_triggerstep, 0x301CC1D8, GetUnitState(GetTriggerUnit(), ConvertUnitState(0x15)))
    call TriggerExecute(ydl_trigger)
    set ydl_trigger=null
endfunction
