endfunction
function Trig_____________00Func003MT takes nothing returns nothing
    call SaveInteger(YDLOC, 0x73EF02D4, 0x07C93ED7, DzF2I(DzGetMouseFocus()))
    call SaveInteger(YDLOC, 0x73EF02D4, 0xA534D943, LoadInteger(YDHT, LoadInteger(YDLOC, 0x73EF02D4, 0x07C93ED7), 0x5F0E88EF))
