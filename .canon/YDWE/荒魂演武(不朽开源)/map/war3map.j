//===========================================================================
// Trigger: TF_初始化
//===========================================================================
function Trig_TF__________uActions takes nothing returns nothing
    local integer ydul_XH
    local integer ydul_LV
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call YDWESaveAbilityIDByInteger(1 , 1 , 'A05R')
    call YDWESaveAbilityIDByInteger(1 , 2 , 'A05S')
    call YDWESaveAbilityIDByInteger(1 , 3 , 'A05T')
    call YDWESaveAbilityIDByInteger(1 , 4 , 'A05U')
    call YDWESaveAbilityIDByInteger(1 , 5 , 'A05V')
    call YDWESaveAbilityIDByInteger(1 , 6 , 'A05O')
    call YDWESaveAbilityIDByInteger(1 , 7 , 'A05W')
    call YDWESaveAbilityIDByInteger(1 , 8 , 'A05X')
    call YDWESaveAbilityIDByInteger(1 , 9 , 'A05Y')
    call YDWESaveAbilityIDByInteger(1 , 10 , 'A05Z')
    call YDWESaveAbilityIDByInteger(1 , 11 , 'A060')
    call SaveReal(YDHT, 'A05O', 0x08BAB87E, 0.05)
    call SaveReal(YDHT, 'A060', 0x0098CEEB, 0.05)
    call SaveReal(YDHT, 'A05S', 0xC08430F1, 0.05)
    call SaveReal(YDHT, 'A05T', 0x16C5C392, 0.08)
    call SaveReal(YDHT, 'A05U', 0xA006C6C7, 0.08)
    call SaveReal(YDHT, 'A05W', 0xE2DD07B4, 0.09)
    call SaveReal(YDHT, 'A05W', 0xAAFEB883, 0.09)
    call SaveReal(YDHT, 'A05X', 0x636DFFD3, 0.025)
    call SaveReal(YDHT, 'A05R', 0xA727C6F6, 0.025)
    call SaveReal(YDHT, 'A05Z', 0x59E18EE2, 0.04)
    call SaveReal(YDHT, 'A05Z', 0x83C13D14, 0.04)
    call SaveInteger(YDHT, 'A05Y', 0x556E03EA, 3)
    call SaveReal(YDHT, 'A05Y', 0x1B5F3A6A, 0.16)
    call SaveInteger(YDHT, 'A05V', 0x7027B879, 3)
    call SaveReal(YDHT, 'A05V', 0x9D1E5CF3, 0.16)
    // 物编数据
    set ydul_XH=1
    loop
        exitwhen ydul_XH > 11
        call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E, "")
        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA, YDWEGetAbilityIDByInteger(1 , ydul_XH))
        set ydul_LV=1
        loop
            exitwhen ydul_LV > 10
            if ( ( ydul_LV <= 7 ) ) then
                call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E, "")
                if ( ( HaveSavedReal(YDHT, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), 0x08BAB87E) == true ) ) then
                    call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E) ) + ( "提升力量: " ) + ( ( I2S(R2I(( ( LoadReal(YDHT, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), 0x08BAB87E) ) * ( I2R(ydul_LV) ) * ( 100.00 ) ))) + " %" ) ) ))
                else
                endif
                if ( ( HaveSavedReal(YDHT, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), 0x0098CEEB) == true ) ) then
                    call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E) ) + ( "|n提升敏捷: " ) + ( ( I2S(R2I(( ( LoadReal(YDHT, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), 0x0098CEEB) ) * ( I2R(ydul_LV) ) * ( 100.00 ) ))) + " %" ) ) ))
                else
                endif
                if ( ( HaveSavedReal(YDHT, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), 0xC08430F1) == true ) ) then
                    call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E) ) + ( "|n提升智力: " ) + ( ( I2S(R2I(( ( LoadReal(YDHT, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), 0xC08430F1) ) * ( I2R(ydul_LV) ) * ( 100.00 ) ))) + " %" ) ) ))
                else
                endif
                if ( ( HaveSavedReal(YDHT, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), 0x16C5C392) == true ) ) then
                    call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E) ) + ( "|n提升最大生命值: " ) + ( ( I2S(R2I(( ( LoadReal(YDHT, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), 0x16C5C392) ) * ( I2R(ydul_LV) ) * ( 100.00 ) ))) + " %" ) ) ))
                else
