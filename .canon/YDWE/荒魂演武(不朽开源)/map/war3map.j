                                                                                                    call AdjustPlayerStateBJ(- 3000, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
                                                                                                    call UnitAddItemByIdSwapped('I06V', GetBuyingUnit())
                                                                                                    call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cffffff00升级成功！|r")
                                                                                                    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Invisibility\\InvisibilityTarget.mdl", GetBuyingUnit(), "chest"))
                                                                                                else
                                                                                                    if ( ( YDWEUnitHasItemOfTypeBJNull(GetBuyingUnit() , 'I06V') == true ) and ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) >= 3000 ) ) then
                                                                                                        call RemoveItem(YDWEGetItemOfTypeFromUnitBJNull(GetBuyingUnit() , 'I06V'))
                                                                                                        call AdjustPlayerStateBJ(- 3000, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
                                                                                                        call UnitAddItemByIdSwapped('I06W', GetBuyingUnit())
                                                                                                        call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cffffff00升级成功！|r")
                                                                                                        call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Invisibility\\InvisibilityTarget.mdl", GetBuyingUnit(), "chest"))
                                                                                                    else
                                                                                                        call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cff00ffff升级条件不足！|r")
                                                                                                    endif
                                                                                                endif
                                                                                            endif
                                                                                        endif
                                                                                    endif
                                                                                endif
                                                                            endif
                                                                        endif
                                                                    endif
                                                                endif
                                                            endif
                                                        endif
                                                    endif
                                                endif
                                            endif
                                        endif
                                    endif
                                endif
                            endif
                        endif
                    endif
                endif
            endif
        endif
    else
        if ( ( YDWEUnitHasItemOfTypeBJNull(GetBuyingUnit() , 'I00E') == true ) and ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) >= 500 ) ) then
            call RemoveItem(YDWEGetItemOfTypeFromUnitBJNull(GetBuyingUnit() , 'I00E'))
            call AdjustPlayerStateBJ(- 500, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
            call UnitAddItemByIdSwapped('I00F', GetBuyingUnit())
            call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cffffff00升级成功！|r")
            call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Invisibility\\InvisibilityTarget.mdl", GetBuyingUnit(), "chest"))
        else
            if ( ( YDWEUnitHasItemOfTypeBJNull(GetBuyingUnit() , 'I00F') == true ) and ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) >= 500 ) ) then
                call RemoveItem(YDWEGetItemOfTypeFromUnitBJNull(GetBuyingUnit() , 'I00F'))
                call AdjustPlayerStateBJ(- 500, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
                call UnitAddItemByIdSwapped('I00G', GetBuyingUnit())
                call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cffffff00升级成功！|r")
                call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Invisibility\\InvisibilityTarget.mdl", GetBuyingUnit(), "chest"))
            else
                if ( ( YDWEUnitHasItemOfTypeBJNull(GetBuyingUnit() , 'I00G') == true ) and ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) >= 1000 ) ) then
                    call RemoveItem(YDWEGetItemOfTypeFromUnitBJNull(GetBuyingUnit() , 'I00G'))
                    call AdjustPlayerStateBJ(- 1000, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
                    call UnitAddItemByIdSwapped('I00H', GetBuyingUnit())
                    call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cffffff00升级成功！|r")
                    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Invisibility\\InvisibilityTarget.mdl", GetBuyingUnit(), "chest"))
                else
                    if ( ( YDWEUnitHasItemOfTypeBJNull(GetBuyingUnit() , 'I00H') == true ) and ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) >= 1000 ) ) then
                        call RemoveItem(YDWEGetItemOfTypeFromUnitBJNull(GetBuyingUnit() , 'I00H'))
                        call AdjustPlayerStateBJ(- 1000, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
                        call UnitAddItemByIdSwapped('I00I', GetBuyingUnit())
                        call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cffffff00升级成功！|r")
                        call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Invisibility\\InvisibilityTarget.mdl", GetBuyingUnit(), "chest"))
                    else
                        if ( ( YDWEUnitHasItemOfTypeBJNull(GetBuyingUnit() , 'I00I') == true ) and ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) >= 1000 ) ) then
                            call RemoveItem(YDWEGetItemOfTypeFromUnitBJNull(GetBuyingUnit() , 'I00I'))
                            call AdjustPlayerStateBJ(- 1000, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
                            call UnitAddItemByIdSwapped('I00J', GetBuyingUnit())
                            call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cffffff00升级成功！|r")
                            call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Invisibility\\InvisibilityTarget.mdl", GetBuyingUnit(), "chest"))
                        else
                            if ( ( YDWEUnitHasItemOfTypeBJNull(GetBuyingUnit() , 'I00J') == true ) and ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) >= 3000 ) ) then
                                call RemoveItem(YDWEGetItemOfTypeFromUnitBJNull(GetBuyingUnit() , 'I00J'))
                                call AdjustPlayerStateBJ(- 3000, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
                                call UnitAddItemByIdSwapped('I00K', GetBuyingUnit())
                                call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cffffff00升级成功！|r")
                                call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Invisibility\\InvisibilityTarget.mdl", GetBuyingUnit(), "chest"))
                            else
                                if ( ( YDWEUnitHasItemOfTypeBJNull(GetBuyingUnit() , 'I00K') == true ) and ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) >= 3000 ) ) then
                                    call RemoveItem(YDWEGetItemOfTypeFromUnitBJNull(GetBuyingUnit() , 'I00K'))
                                    call AdjustPlayerStateBJ(- 3000, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
                                    call UnitAddItemByIdSwapped('I00L', GetBuyingUnit())
                                    call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cffffff00升级成功！|r")
                                    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Invisibility\\InvisibilityTarget.mdl", GetBuyingUnit(), "chest"))
                                else
                                    if ( ( YDWEUnitHasItemOfTypeBJNull(GetBuyingUnit() , 'I00L') == true ) and ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) >= 3000 ) ) then
                                        call RemoveItem(YDWEGetItemOfTypeFromUnitBJNull(GetBuyingUnit() , 'I00L'))
                                        call AdjustPlayerStateBJ(- 3000, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
                                        call UnitAddItemByIdSwapped('I00M', GetBuyingUnit())
                                        call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cffffff00升级成功！|r")
                                        call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Invisibility\\InvisibilityTarget.mdl", GetBuyingUnit(), "chest"))
                                    else
                                        call DisplayTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, "|cff00ffff升级条件不足！|r")
                                    endif
                                endif
                            endif
                        endif
                    endif
                endif
            endif
        endif
    endif
endfunction
