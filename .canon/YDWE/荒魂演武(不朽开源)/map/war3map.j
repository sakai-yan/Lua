function Trig_016DFunc005Func002Func001T takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    local integer ydl_triggerstep
    local trigger ydl_trigger
    if ( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B) < 5.00 ) ) then
        call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B, ( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B) ) + ( 1.00 ) ))
        call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\NightElf\\BattleRoar\\RoarCaster.mdl", LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x04FC4D6D), "origin"))
        set ydl_group=CreateGroup()
        call GroupEnumUnitsInRange(ydl_group, LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382), 600.00, null)
        loop
            set ydl_unit=FirstOfGroup(ydl_group)
            exitwhen ydl_unit == null
            call GroupRemoveUnit(ydl_group, ydl_unit)
            if ( ( IsUnitEnemy(ydl_unit, GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9))) == true ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) ) then
                call UnitDamageTarget(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x04FC4D6D), ydl_unit, ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), ConvertUnitState(0x15)) * 1.00 ), false, false, ATTACK_TYPE_CHAOS, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
                set ydl_trigger=gg_trg_______1A
                set ydl_triggerstep=GetHandleId(ydl_trigger) * ( LoadInteger(YDLOC, GetHandleId(ydl_trigger), 0xCFDE6C76) + 3 )
                call SaveUnitHandle(YDLOC, ydl_triggerstep, 0x911D5DC2, ydl_unit)
                call SaveReal(YDLOC, ydl_triggerstep, 0x312C4181, 1.00)
                call TriggerExecute(ydl_trigger)
            else
            endif
        endloop
        call DestroyGroup(ydl_group)
    else
        call YDWEUnitRemoveStun(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9))
        call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
        call DestroyTimer(GetExpiredTimer())
    endif
    set ydl_group=null
    set ydl_unit=null
    set ydl_trigger=null
endfunction
