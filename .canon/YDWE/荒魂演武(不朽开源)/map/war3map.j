        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xFDF65382, EXGetEffectY(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x65BCB4D1)))
