// Trigger: 017
//===========================================================================
function Trig_017Conditions takes nothing returns boolean
    return ( ( ( GetItemTypeId(GetSoldItem()) == 'I06X' ) or ( GetItemTypeId(GetSoldItem()) == 'I075' ) or ( GetItemTypeId(GetSoldItem()) == 'I074' ) or ( GetItemTypeId(GetSoldItem()) == 'I07G' ) ) )
endfunction
function Trig_017Func001Func001Func001Func004Func005T takes nothing returns nothing
    call ResumeTimer(udg_jsq)
    call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
    call DestroyTimer(GetExpiredTimer())
endfunction
function Trig_017Actions takes nothing returns nothing
    local timer ydl_timer
    if ( ( GetItemTypeId(GetSoldItem()) == 'I06X' ) ) then
        call AdjustPlayerStateBJ(100, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_LUMBER)
        call AddPlayerTechResearched(Player(7), 'R002', 1)
        call SaveReal(YDHT, GetHandleId(gg_unit_halt_0017), 0xA65B3CF5, ( LoadReal(YDHT, GetHandleId(gg_unit_halt_0017), 0xA65B3CF5) + 5.00 ))
        call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Items\\TomeOfRetraining\\TomeOfRetrainingCaster.mdl", GetSellingUnit(), "origin"))
        call DisplayTimedTextToForce(GetPlayersAll(), 10.00, ( ( "|cffffff00" ) + ( "玩家 " ) + ( ( ( GetPlayerName(GetOwningPlayer(GetBuyingUnit())) ) + ( " 花费重金强化光明祭坛！" ) + ( "获得 100 战魂奖励！" ) ) ) ))
        set udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))]=( ( udg_MVP[GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit()))] ) + ( 2.00 ) )
        call SaveInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit())), 48, ( ( LoadInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit())), 48) ) + ( 1 ) ))
    else
        if ( ( GetItemTypeId(GetSoldItem()) == 'I074' ) ) then
            call SetUnitLifePercentBJ(GetSellingUnit(), 100)
            call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Demon\\DarkPortal\\DarkPortalTarget.mdl", GetSellingUnit(), "origin"))
            call SaveInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit())), 67, ( ( LoadInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit())), 67) ) + ( 1 ) ))
        else
            if ( ( GetItemTypeId(GetSoldItem()) == 'I075' ) ) then
                call SaveInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit())), 68, ( ( LoadInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetBuyingUnit())), 68) ) + ( 10 ) ))
                if ( ( TimerGetRemaining(udg_jsq) > 0.00 ) ) then
                    call DisplayTimedTextToForce(GetPlayersAll(), 10.00, ( ( "|cffff00ff" ) + ( "玩家 " ) + ( ( ( GetPlayerName(GetOwningPlayer(GetBuyingUnit())) ) + ( "购买了“虚空禁锢”，下一波敌人将暂缓进攻" ) + ( " 120 秒！" ) ) ) ))
                    call PauseTimer(udg_jsq)
                    set ydl_timer=CreateTimer()
                    call TimerStart(ydl_timer, 120.00, false, function Trig_017Func001Func001Func001Func004Func005T)
                else
                    call DisplayTimedTextToForce(GetPlayersAll(), 10.00, ( ( "|cffff00ff" ) + ( "玩家 " ) + ( ( ( GetPlayerName(GetOwningPlayer(GetBuyingUnit())) ) + ( "购买了“虚空禁锢”，下一波敌人将暂缓进攻" ) + ( " 120 秒！" ) ) ) ))
                    call SaveInteger(YDHT, GetHandleId(Player(7)), 0xDC8FC027, 1)
                endif
            else
                if ( ( GetItemTypeId(GetSoldItem()) == 'I07G' ) and ( udg_Lv < 54 ) ) then
                    set udg_Lv=( ( udg_Lv ) + ( 1 ) )
                    call DisplayTimedTextToForce(GetPlayersAll(), 10.00, ( ( "|cffff0000" ) + ( "玩家 " ) + ( ( GetUnitName(GetBuyingUnit()) + "购买了“虚空解禁”,使敌人进攻波次进入下1波。" ) ) ))
                else
                    call DisplayTimedTextToForce(GetPlayersAll(), 10.00, "|cffff0000禁止购买！")
                endif
            endif
        endif
    endif
    set ydl_timer=null
endfunction
