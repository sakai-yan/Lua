        call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x8B1FFFFC, ( ( ( 100.00 + GetLocationZ(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x1F451449)) ) ) + ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFBBFF844) ) * ( SinBJ(LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xB9A583B8)) ) ))
        call EXSetEffectXY(LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x329FF8E6), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x324AE96A), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x058682B9))
