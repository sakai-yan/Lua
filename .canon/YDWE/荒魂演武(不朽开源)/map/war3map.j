            endif
            call SaveStr(YDHT, udg_WP[ydul_WP], 0x6945FB09, LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09))
            call YDWESetItemDataString(udg_WP[ydul_WP] , 3 , " ")
        else
        endif
        set ydul_WP=ydul_WP + 1
    endloop
    // 排泄
    call DestroyTrigger(GetTriggeringTrigger())
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
