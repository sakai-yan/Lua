    call SaveStr(YDHT, 'I00S', 0x1FD16D41, ( ( ( ( "|n" + ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00S') + "].Name") ) ) + " + " ) ) + ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00O') + "].Name") ) + " + " ) ) + ( ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00P') + "].Name") ) ) + ( " = " ) + ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00T') + "].Name") ) ) ) ) ))
