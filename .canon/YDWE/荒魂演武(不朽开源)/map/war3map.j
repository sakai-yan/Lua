    call SaveStr(YDHT, 'I00U', 0x1FD16D41, ( ( ( ( "|n" + ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00T') + "].Name") ) ) + " + " ) ) + ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00U') + "].Name") ) + " = " ) ) + ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00V') + "].Name") ) ) ))
    // 波纹法杖
    call SaveStr(YDHT, 'I00S', 0x8EBDF2CD, ( ( ( ( "|n" + ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00S') + "].Name") ) ) + " + " ) ) + ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I013') + "].Name") ) + " + " ) ) + ( ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00P') + "].Name") ) ) + ( " = " ) + ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I016') + "].Name") ) ) ) ) ))
    call SaveStr(YDHT, 'I013', 0x1FD16D41, ( ( ( ( "|n" + ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00S') + "].Name") ) ) + " + " ) ) + ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I013') + "].Name") ) + " + " ) ) + ( ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00P') + "].Name") ) ) + ( " = " ) + ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I016') + "].Name") ) ) ) ) ))
    call SaveStr(YDHT, 'I00P', 0x8EBDF2CD, ( ( ( ( "|n" + ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00S') + "].Name") ) ) + " + " ) ) + ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I013') + "].Name") ) + " + " ) ) + ( ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00P') + "].Name") ) ) + ( " = " ) + ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I016') + "].Name") ) ) ) ) ))
    // 涛声回响
    call SaveStr(YDHT, 'I00Q', 0x8EBDF2CD, ( ( ( ( "|n" + ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00Q') + "].Name") ) ) + " + " ) ) + ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I014') + "].Name") ) + " + " ) ) + ( ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00N') + "].Name") ) ) + ( " = " ) + ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I015') + "].Name") ) ) ) ) ))
    call SaveStr(YDHT, 'I014', 0x1FD16D41, ( ( ( ( "|n" + ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00Q') + "].Name") ) ) + " + " ) ) + ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I014') + "].Name") ) + " + " ) ) + ( ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00N') + "].Name") ) ) + ( " = " ) + ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I015') + "].Name") ) ) ) ) ))
    call SaveStr(YDHT, 'I00N', 0x8EBDF2CD, ( ( ( ( "|n" + ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00Q') + "].Name") ) ) + " + " ) ) + ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I014') + "].Name") ) + " + " ) ) + ( ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00N') + "].Name") ) ) + ( " = " ) + ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I015') + "].Name") ) ) ) ) ))
    // 沧浪权杖
    call SaveStr(YDHT, 'I016', 0x1FD16D41, ( ( ( ( "|n" + ( EXExecuteScript("(require'jass.slk').item[" + I2S('I016') + "].Name") ) ) + " + " ) ) + ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I015') + "].Name") ) + " = " ) ) + ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I017') + "].Name") ) ) ))
