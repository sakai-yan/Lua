            if ( ( HaveSavedString(YDHT, udg_WP[ydul_WP], 0x502565CE) == true ) ) then
                call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09, ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09) + LoadStr(YDHT, udg_WP[ydul_WP], 0x502565CE) ))
            else
