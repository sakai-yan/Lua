function Trig_013Conditions takes nothing returns boolean
    return ( ( udg_Hero[GetConvertedPlayerId(DzGetTriggerKeyPlayer())] != null ) )
endfunction
function Trig_013Func003Func011T takes nothing returns nothing
    call SaveLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA6461A53, Location(- 500.00, - 6500.00))
    call PanCameraToTimedLocForPlayer(LoadPlayerHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x48656946), LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA6461A53), 0.10)
    call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\MassTeleport\\MassTeleportCaster.mdl", udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x48656946))], "origin"))
    call SetUnitPosition(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x48656946))], - 500.00, - 6500.00)
    call PauseUnit(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x48656946))], false)
    call SetUnitInvulnerable(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x48656946))], false)
    call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA6461A53))
    call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
    call DestroyTimer(GetExpiredTimer())
endfunction
function Trig_013Actions takes nothing returns nothing
    local timer ydl_timer
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SavePlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946, DzGetTriggerKeyPlayer())
    if ( ( ( IsUnitPausedBJ(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946))]) != true ) and ( IsUnitType(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946))], UNIT_TYPE_ATTACKS_GROUND) == true ) ) and ( UnitHasBuffBJ(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946))], 'BSTN') != true ) and ( UnitHasBuffBJ(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946))], 'BPSE') != true ) and ( UnitHasBuffBJ(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946))], 'BHtb') != true ) and ( IsUnitType(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946))], UNIT_TYPE_DEAD) == false ) ) then
        call SetUnitInvulnerable(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946))], true)
        call PauseUnit(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946))], true)
        call YDWETimerDestroyEffect(3.00 , AddSpecialEffect("Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTo.mdl", GetUnitX(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946))]), GetUnitY(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946))])))
        call YDWETimerDestroyEffect(3.00 , AddSpecialEffect("Abilities\\Spells\\Human\\MassTeleport\\MassTeleportTo.mdl", - 500.00, - 6500.00))
        set ydl_timer=CreateTimer()
        call SavePlayerHandle(YDLOC, GetHandleId(ydl_timer), 0x48656946, LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946))
        call SaveLocationHandle(YDLOC, GetHandleId(ydl_timer), 0xA6461A53, LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53))
        call TimerStart(ydl_timer, 3.00, false, function Trig_013Func003Func011T)
    else
        call DisplayTextToPlayer(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x48656946), 0, 0, "|cffff6600当前状态无法进行传送！|r")
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    set ydl_timer=null
endfunction
