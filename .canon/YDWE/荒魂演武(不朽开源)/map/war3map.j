    call SaveStr(YDHT, 'I00N', 0x1FD16D41, ( ( ( ( "|n" + ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00Q') + "].Name") ) ) + " + " ) ) + ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00R') + "].Name") ) + " + " ) ) + ( ( ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00N') + "].Name") ) ) + ( " = " ) + ( ( EXExecuteScript("(require'jass.slk').item[" + I2S('I00U') + "].Name") ) ) ) ) ))
