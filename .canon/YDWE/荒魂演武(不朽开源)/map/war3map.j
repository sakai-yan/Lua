// Trigger: 017C
//
// 变的一瞬间 是已远程单位变的
// 落地的一瞬间 也是以远程单位落地的
//===========================================================================
function Trig_017CConditions takes nothing returns boolean
    return ( ( ( GetSpellAbilityId() == 'A01Z' ) or ( GetSpellAbilityId() == 'A020' ) or ( GetSpellAbilityId() == 'A022' ) or ( GetSpellAbilityId() == 'A01Y' ) ) )
endfunction
function Trig_017CFunc003Func002Func002Func004003003 takes nothing returns boolean
    return ( ( IsUnitEnemy(GetFilterUnit(), Player(PLAYER_NEUTRAL_AGGRESSIVE)) == true ) )
endfunction
function Trig_017CFunc003Func002Func002T takes nothing returns nothing
    if ( ( IsUnitType(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x04FC4D6D), UNIT_TYPE_DEAD) == true ) ) then
        call YDWESetUnitAbilityDataInteger(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x04FC4D6D) , LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0xA9CA38BB) , 1 , 104 , 0)
        call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
        call DestroyTimer(GetExpiredTimer())
    else
    endif
    call SaveLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA6461A53, GetUnitLoc(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x04FC4D6D)))
    call SaveGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x657DACBA, YDWEGetUnitsInRangeOfLocMatchingNull(1000.00 , LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA6461A53) , Condition(function Trig_017CFunc003Func002Func002Func004003003)))
    call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA6461A53))
    if ( ( CountUnitsInGroup(LoadGroupHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x657DACBA)) == 0 ) ) then
