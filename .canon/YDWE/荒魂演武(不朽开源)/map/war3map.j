function Trig_021Func002A takes nothing returns nothing
    local integer ydul_X
    call SaveInteger(udg_CJ_HXB, GetConvertedPlayerId(GetEnumPlayer()), 64, ( ( LoadInteger(udg_CJ_HXB, GetConvertedPlayerId(GetEnumPlayer()), 64) ) + ( 1 ) ))
    set ydul_X=61
    loop
        exitwhen ydul_X > 68
        call SavePlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x48656946, GetEnumPlayer())
        call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7169EBED, "")
        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7D8E3CF9, LoadInteger(udg_CJ_HXB, GetConvertedPlayerId(GetEnumPlayer()), ydul_X))
        call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7169EBED, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7169EBED) ) + ( I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7D8E3CF9)) ) + ( "/" ) ))
        call DzAPI_Map_StoreString(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x48656946) , "隐藏成就" , LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7169EBED))
        set ydul_X=ydul_X + 1
    endloop
    // 主城爆炸存档
    // 局数存档
    call DzAPI_Map_StoreInteger(GetEnumPlayer() , "KEY3" , ( ( LoadInteger(udg_CJ_HXB, GetConvertedPlayerId(GetEnumPlayer()), 45) ) + ( 1 ) ))
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0xF9B0F26D, LoadInteger(udg_CJ_HXB, GetConvertedPlayerId(GetEnumPlayer()), 46))
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x779AC9E9, LoadInteger(udg_CJ_HXB, GetConvertedPlayerId(GetEnumPlayer()), 47))
    call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7B682025, ( ( I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0xF9B0F26D)) ) + ( "/" ) + ( I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x779AC9E9)) ) ))
    call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7B682025, ( ( I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0xF9B0F26D)) ) + ( "/" ) + ( ( ( I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x779AC9E9)) ) + ( "/" ) + ( I2S(LoadInteger(udg_CJ_HXB, GetConvertedPlayerId(GetEnumPlayer()), 48)) ) ) ) ))
    call DzAPI_Map_StoreString(GetEnumPlayer() , "单通成就" , LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7B682025))
