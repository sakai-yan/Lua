    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
//===========================================================================
function InitTrig_____________B takes nothing returns nothing
    set gg_trg_____________B=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_____________B, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_____________B, Condition(function Trig_____________BConditions))
    call TriggerAddAction(gg_trg_____________B, function Trig_____________BActions)
endfunction
//===========================================================================
// Trigger: 丢弃物品C
//===========================================================================
function Trig_____________CConditions takes nothing returns boolean
    return ( ( IsItemPowerup(GetManipulatedItem()) == false ) )
endfunction
function Trig_____________CActions takes nothing returns nothing
    call SaveInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x556E03EA, ( LoadInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x556E03EA) - LoadInteger(YDHT, GetItemTypeId(GetManipulatedItem()), 0xC1C7B969) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x59E18EE2, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x59E18EE2) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x59E18EE2) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xA65B3CF5, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xA65B3CF5) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xA65B3CF5) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x1B5F3A6A, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x1B5F3A6A) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xBFA256FF) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x636DFFD3, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x636DFFD3) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x636DFFD3) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x0C65E629, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x0C65E629) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xB0C6D98D) ))
    call SaveInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x7027B879, ( LoadInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x7027B879) - LoadInteger(YDHT, GetItemTypeId(GetManipulatedItem()), 0xC7A2FC1F) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x83C13D14, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x83C13D14) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x83C13D14) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x9D1E5CF3, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x9D1E5CF3) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x9D1E5CF3) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xA727C6F6, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xA727C6F6) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xA727C6F6) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xAAFAF365, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xAAFAF365) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xAAFAF365) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x05CDD84B, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x05CDD84B) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x05CDD84B) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x1F5F705A, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x1F5F705A) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x5AF44D77) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xAF04E5E0, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xAF04E5E0) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xAF04E5E0) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x3C007FD8, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x3C007FD8) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x3C007FD8) ))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x7BD67BA5, GetUnitLifePercent(GetTriggerUnit()))
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xF2ED32BC, GetUnitManaPercent(GetTriggerUnit()))
    // 生命值
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x651DD2FC, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x651DD2FC) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x9890BA1B) ))
    // 魔法值
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xCBF95817, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xCBF95817) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x634C8CDF) ))
    // 物理攻击
    call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xEF12EDB1, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xEF12EDB1) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xD0241DEB) ))
    // 三维
    if ( ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x30FA192C) == true ) or ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x678A421B) == true ) or ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x6F97DD18) == true ) ) ) then
        if ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x30FA192C) == true ) ) then
            call SaveReal(YDHT, GetHandleId(GetManipulatingUnit()), 0xF791E74B, ( LoadReal(YDHT, GetHandleId(GetManipulatingUnit()), 0xF791E74B) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x30FA192C) ))
        else
        endif
        if ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x678A421B) == true ) ) then
            call SaveReal(YDHT, GetHandleId(GetManipulatingUnit()), 0x195139DD, ( LoadReal(YDHT, GetHandleId(GetManipulatingUnit()), 0x195139DD) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x678A421B) ))
        else
        endif
        if ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x6F97DD18) == true ) ) then
            call SaveReal(YDHT, GetHandleId(GetManipulatingUnit()), 0xEF6B66A5, ( LoadReal(YDHT, GetHandleId(GetManipulatingUnit()), 0xEF6B66A5) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x6F97DD18) ))
        else
        endif
    else
    endif
    if ( ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x08BAB87E) == true ) or ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x0098CEEB) == true ) or ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xC08430F1) == true ) or ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x16C5C392) == true ) or ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xA006C6C7) == true ) or ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xE2DD07B4) == true ) ) ) then
        if ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x08BAB87E) == true ) ) then
            call SaveReal(YDHT, GetHandleId(GetManipulatingUnit()), 0x08BAB87E, ( LoadReal(YDHT, GetHandleId(GetManipulatingUnit()), 0x08BAB87E) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x08BAB87E) ))
        else
        endif
        if ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x0098CEEB) == true ) ) then
            call SaveReal(YDHT, GetHandleId(GetManipulatingUnit()), 0x0098CEEB, ( LoadReal(YDHT, GetHandleId(GetManipulatingUnit()), 0x0098CEEB) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x0098CEEB) ))
        else
        endif
        if ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xC08430F1) == true ) ) then
            call SaveReal(YDHT, GetHandleId(GetManipulatingUnit()), 0xC08430F1, ( LoadReal(YDHT, GetHandleId(GetManipulatingUnit()), 0xC08430F1) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xC08430F1) ))
        else
        endif
        if ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x16C5C392) == true ) ) then
            call SaveReal(YDHT, GetHandleId(GetManipulatingUnit()), 0x16C5C392, ( LoadReal(YDHT, GetHandleId(GetManipulatingUnit()), 0x16C5C392) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x16C5C392) ))
        else
        endif
        if ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xA006C6C7) == true ) ) then
            call SaveReal(YDHT, GetHandleId(GetManipulatingUnit()), 0xA006C6C7, ( LoadReal(YDHT, GetHandleId(GetManipulatingUnit()), 0xA006C6C7) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xA006C6C7) ))
        else
        endif
        if ( ( HaveSavedReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xE2DD07B4) == true ) ) then
            call SaveReal(YDHT, GetHandleId(GetManipulatingUnit()), 0xE2DD07B4, ( LoadReal(YDHT, GetHandleId(GetManipulatingUnit()), 0xE2DD07B4) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0xE2DD07B4) ))
        else
        endif
    else
    endif
    // 攻速
    if ( ( LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x86A02DAE) != 0.00 ) ) then
        call SetUnitState(GetTriggerUnit(), ConvertUnitState(0x51), ( GetUnitState(GetTriggerUnit(), ConvertUnitState(0x51)) - LoadReal(YDHT, GetItemTypeId(GetManipulatedItem()), 0x86A02DAE) ))
    else
    endif
    // 物理防御
    call YDWEGeneralBounsSystemUnitSetBonus(GetTriggerUnit() , 2 , 1 , LoadInteger(YDHT, GetItemTypeId(GetManipulatedItem()), 0x40536706))
endfunction
//===========================================================================
function InitTrig_____________C takes nothing returns nothing
    set gg_trg_____________C=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_____________C, EVENT_PLAYER_UNIT_DROP_ITEM)
    call TriggerAddCondition(gg_trg_____________C, Condition(function Trig_____________CConditions))
    call TriggerAddAction(gg_trg_____________C, function Trig_____________CActions)
endfunction
