function InitTrig_13D takes nothing returns nothing
    set gg_trg_13D=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_13D, EVENT_PLAYER_UNIT_SPELL_EFFECT)
    call TriggerAddCondition(gg_trg_13D, Condition(function Trig_13DConditions))
    call TriggerAddAction(gg_trg_13D, function Trig_13DActions)
endfunction
