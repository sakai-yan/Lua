//===========================================================================
// Trigger: 角斗场01
//===========================================================================
function Trig__________01Conditions takes nothing returns boolean
    return ( ( IsUnitType(GetTriggerUnit(), UNIT_TYPE_HERO) == true ) )
endfunction
function Trig__________01Func002003002 takes nothing returns boolean
    return ( ( ( IsUnitEnemy(GetFilterUnit(), Player(11)) == true ) and ( IsUnitType(GetFilterUnit(), UNIT_TYPE_DEAD) == false ) ) )
endfunction
function Trig__________01Actions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x12FBF5EE, YDWEGetUnitsInRectMatchingNull(gg_rct________________E , Condition(function Trig__________01Func002003002)))
    if ( ( CountUnitsInGroup(LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x12FBF5EE)) <= 0 ) ) then
        call TriggerExecute(gg_trg__________2)
    else
        call DisplayTextToPlayer(GetOwningPlayer(GetTriggerUnit()), 0, 0, "正在与其他玩家一同挑战！")
    endif
    call DestroyGroup(LoadGroupHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x12FBF5EE))
    call SetUnitPosition(GetTriggerUnit(), 11512.00, - 2651.00)
    call SetCameraBoundsToRectForPlayerBJ(GetOwningPlayer(GetTriggerUnit()), gg_rct______________002)
    call SaveLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53, GetUnitLoc(GetTriggerUnit()))
    call PanCameraToTimedLocForPlayer(GetOwningPlayer(GetTriggerUnit()), LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53), 0)
    call RemoveLocation(LoadLocationHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA6461A53))
    call DisplayTimedTextToPlayer(GetOwningPlayer(GetTriggerUnit()), 0, 0, 10.00, "|cffff0000您已进入决斗场请尽情战斗！|r")
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
