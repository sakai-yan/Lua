                                call DzSyncData("物品栏右键", I2S(LoadInteger(YDLOC, 0xBFD19E14, 0xC13DC62F)))
                            else
                            endif
                        else
                            if ( ( LoadReal(YDLOC, 0xBFD19E14, 0xE9538A45) >= 0.517 ) and ( LoadReal(YDLOC, 0xBFD19E14, 0xE9538A45) < 0.547 ) and ( LoadReal(YDLOC, 0xBFD19E14, 0xB9A5F07B) < 0.075 ) and ( LoadReal(YDLOC, 0xBFD19E14, 0xB9A5F07B) >= 0.043 ) ) then
                                call SaveInteger(YDLOC, 0xBFD19E14, 0xC13DC62F, 3)
                                if ( ( UnitItemInSlotBJ(udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, 0xBFD19E14, 0x48656946))], LoadInteger(YDLOC, 0xBFD19E14, 0xC13DC62F)) != null ) ) then
                                    call DzSyncData("物品栏右键", I2S(LoadInteger(YDLOC, 0xBFD19E14, 0xC13DC62F)))
                                else
                                endif
                            else
                                if ( ( LoadReal(YDLOC, 0xBFD19E14, 0xE9538A45) >= 0.556 ) and ( LoadReal(YDLOC, 0xBFD19E14, 0xE9538A45) <= 0.587 ) and ( LoadReal(YDLOC, 0xBFD19E14, 0xB9A5F07B) < 0.075 ) and ( LoadReal(YDLOC, 0xBFD19E14, 0xB9A5F07B) >= 0.043 ) ) then
