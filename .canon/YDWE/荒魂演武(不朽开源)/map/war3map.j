    call DzFrameSetPoint(udg_WPZSUI[3], 1, udg_WPZSUI[2], 7, 0.00, - 0.02)
    set udg_WPZSUI[4]=DzCreateFrameByTagName("TEXT", "物品描述", udg_WPZSUI[1], "template", 0)
