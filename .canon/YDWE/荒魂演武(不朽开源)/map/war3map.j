                            call SaveInteger(YDLOC, 0x73EF02D4, 0x92656BCF, ( ( LoadInteger(YDLOC, 0x73EF02D4, 0x12F94FDA) ) - ( LoadInteger(YDLOC, 0x73EF02D4, 0x1D197851) ) ))
