    call SaveInteger(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetTriggerPlayer())]), 0x8FAA51A7, R2I(( I2R(GetHeroInt(udg_Hero[GetConvertedPlayerId(GetTriggerPlayer())], true)) * 0.01 )))
