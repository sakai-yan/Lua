//===========================================================================
function Trig_1____________uFunc002A takes nothing returns nothing
    local integer ydul_X
    if ( true ) then
        call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0xBAFDCC9A, "")
        call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x2ED7E670, "")
        call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7169EBED, "")
        call SavePlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x48656946, GetEnumPlayer())
        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x6F96F2D2, GetConvertedPlayerId(GetEnumPlayer()))
        set ydul_X=1
        loop
            exitwhen ydul_X > 8
            call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x692728ED, LoadInteger(udg_CJ_HXB, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x6F96F2D2), ydul_X))
            call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0xBAFDCC9A, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0xBAFDCC9A) ) + ( I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x692728ED)) ) + ( "/" ) ))
            if ( ( LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x48656946) == GetLocalPlayer() ) ) then
                if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x692728ED) >= udg_CJ_JX[ydul_X] ) ) then
                    call DzFrameSetText(udg_CJUIWB[( ( 20 ) + ( ydul_X ) )], "|cff00ff00已达成")
                else
                    call DzFrameSetText(udg_CJUIWB[( ( 20 ) + ( ydul_X ) )], ( ( I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x692728ED)) ) + ( "/" ) + ( I2S(udg_CJ_JX[ydul_X]) ) ))
                endif
            else
            endif
            set ydul_X=ydul_X + 1
        endloop
        set ydul_X=21
        loop
            exitwhen ydul_X > 32
            call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x692728ED, LoadInteger(udg_CJ_HXB, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x6F96F2D2), ydul_X))
            call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x2ED7E670, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x2ED7E670) ) + ( I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x692728ED)) ) + ( "/" ) ))
            if ( ( LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x48656946) == GetLocalPlayer() ) ) then
                if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x692728ED) >= udg_CJ_JX[ydul_X] ) ) then
                    call DzFrameSetText(udg_CJUIWB[( ( 20 ) + ( ydul_X ) )], "|cff00ff00已达成")
                else
                    call DzFrameSetText(udg_CJUIWB[( ( 20 ) + ( ydul_X ) )], ( ( I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x692728ED)) ) + ( "/" ) + ( I2S(udg_CJ_JX[ydul_X]) ) ))
                endif
            else
            endif
            set ydul_X=ydul_X + 1
        endloop
        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0xFF5B33D3, LoadInteger(udg_CJ_HXB, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x6F96F2D2), 48))
        if ( ( LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x48656946) == GetLocalPlayer() ) ) then
            if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0xFF5B33D3) >= udg_CJ_JX[48] ) ) then
                call DzFrameSetText(udg_CJUIWB[68], "|cff00ff00已达成")
            else
                call DzFrameSetText(udg_CJUIWB[68], ( ( I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0xFF5B33D3)) ) + ( "/" ) + ( I2S(udg_CJ_JX[48]) ) ))
            endif
        else
        endif
        set ydul_X=61
        loop
            exitwhen ydul_X > 68
            call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7D8E3CF9, LoadInteger(udg_CJ_HXB, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x6F96F2D2), ydul_X))
            call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7169EBED, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7169EBED) ) + ( I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7D8E3CF9)) ) + ( "/" ) ))
            if ( ( LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x48656946) == GetLocalPlayer() ) ) then
                if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7D8E3CF9) >= udg_CJ_JX[ydul_X] ) ) then
                    call DzFrameSetText(udg_CJUIWB[( ( 20 ) + ( ydul_X ) )], "|cff00ff00已达成")
                else
                    call DzFrameSetText(udg_CJUIWB[( ( 20 ) + ( ydul_X ) )], ( ( I2S(LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7D8E3CF9)) ) + ( "/" ) + ( I2S(udg_CJ_JX[ydul_X]) ) ))
                endif
            else
            endif
            set ydul_X=ydul_X + 1
        endloop
        call DzAPI_Map_StoreString(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x48656946) , "KILL1" , LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0xBAFDCC9A))
        call DzAPI_Map_StoreString(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x48656946) , "KILL2" , LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x2ED7E670))
        call DzAPI_Map_StoreString(LoadPlayerHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x48656946) , "隐藏成就" , LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0x7169EBED))
    else
    endif
endfunction
