//===========================================================================
// Trigger: 028
//===========================================================================
function Trig_028Actions takes nothing returns nothing
    if ( ( GetEventDamage() < 20000.00 ) and ( GetRandomInt(1, 3) <= 1 ) ) then
        call CreateTextTagUnitBJ("行不行啊？细狗", GetTriggerUnit(), 0, 10.00, 100.00, 100.00, 100.00, 0)
        call SetTextTagPermanent(GetLastCreatedTextTag(), false)
        call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
        call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 85.00, ( GetRandomReal(0.00, 360.00) ))
    else
        if ( ( GetEventDamage() >= 20000.00 ) and ( GetEventDamage() < 50000.00 ) and ( GetRandomInt(1, 3) <= 2 ) ) then
            call CreateTextTagUnitBJ("诶哟！有点痛！", GetTriggerUnit(), 0, 10.00, 100.00, 100.00, 100.00, 0)
            call SetTextTagPermanent(GetLastCreatedTextTag(), false)
            call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
            call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
            call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 85.00, ( GetRandomReal(0.00, 360.00) ))
        else
            if ( ( GetEventDamage() >= 50000.00 ) and ( GetEventDamage() < 100000.00 ) ) then
                call CreateTextTagUnitBJ("我草？！", GetTriggerUnit(), 0, 10.00, 100.00, 100.00, 100.00, 0)
                call SetTextTagPermanent(GetLastCreatedTextTag(), false)
                call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
                call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
                call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 85.00, ( GetRandomReal(0.00, 360.00) ))
            else
                call CreateTextTagUnitBJ("饶命啊！大人！", GetTriggerUnit(), 0, 10.00, 100.00, 100.00, 100.00, 0)
                call SetTextTagPermanent(GetLastCreatedTextTag(), false)
                call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
                call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
                call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 85.00, ( GetRandomReal(0.00, 360.00) ))
            endif
        endif
    endif
endfunction
