function Trig_5W1Func001Func004Conditions takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    if ( ( YDWEIsEventAttackDamage() == true ) and ( GetEventDamageSource() == LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7642F3D7) ) ) then
        call SaveEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7075B667, AddSpecialEffect("TXnrtbj.mdx", GetUnitX(GetTriggerUnit()), GetUnitY(GetTriggerUnit())))
        call EXSetEffectSpeed(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7075B667), 2.00)
        call EXSetEffectSize(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7075B667), 2.00)
        call EXSetEffectZ(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7075B667), - 80.00)
        call DestroyEffect(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7075B667))
        set ydl_group=CreateGroup()
        call GroupEnumUnitsInRange(ydl_group, GetUnitX(GetTriggerUnit()), GetUnitY(GetTriggerUnit()), 300.00, null)
        loop
            set ydl_unit=FirstOfGroup(ydl_group)
            exitwhen ydl_unit == null
            call GroupRemoveUnit(ydl_group, ydl_unit)
            if ( ( IsUnitEnemy(ydl_unit, GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7642F3D7))) == true ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) ) then
                call UnitDamageTarget(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7642F3D7), ydl_unit, ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7642F3D7), ConvertUnitState(0x15)) + ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7642F3D7), UNIT_STATE_MAX_LIFE) * 0.15 ) ), false, false, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
            else
            endif
        endloop
        call DestroyGroup(ydl_group)
        call YDWESetUnitAbilityState(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7642F3D7) , 'A04G' , 1 , ( YDWEGetUnitAbilityState(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7642F3D7) , 'A04G' , 1) - 3.00 ))
        call YDWESetUnitAbilityState(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7642F3D7) , 'A04E' , 1 , ( YDWEGetUnitAbilityState(LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x7642F3D7) , 'A04E' , 1) - 3.00 ))
        call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()))
        call DestroyTrigger(GetTriggeringTrigger())
        set ydl_group=null
        set ydl_unit=null
        return
    else
    endif
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()))
    call DestroyTrigger(GetTriggeringTrigger())
    set ydl_group=null
    set ydl_unit=null
endfunction
