function Trig_4Conditions takes nothing returns boolean
    return ( ( GetSpellAbilityId() == 'A033' ) and ( GetUnitTypeId(GetTriggerUnit()) == 'h00X' ) )
endfunction
function Trig_4Func005T takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    set ydl_group=CreateGroup()
    call GroupEnumUnitsInRange(ydl_group, LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xA99320FA), LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382), 180.00, null)
    loop
        set ydl_unit=FirstOfGroup(ydl_group)
        exitwhen ydl_unit == null
        call GroupRemoveUnit(ydl_group, ydl_unit)
        if ( ( IsUnitEnemy(ydl_unit, GetOwningPlayer(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9))) == true ) and ( IsUnitType(ydl_unit, UNIT_TYPE_DEAD) == false ) ) then
            call UnitDamageTarget(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), ydl_unit, ( GetUnitState(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), ConvertUnitState(0x15)) * 1.50 ), true, false, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_METAL_HEAVY_SLICE)
        else
        endif
    endloop
    call DestroyGroup(ydl_group)
    if ( ( LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0xBA0F14A8) < 6 ) ) then
        call SaveInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0xBA0F14A8, ( ( LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0xBA0F14A8) ) + ( 1 ) ))
    else
        call SetUnitTimeScale(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 1.00)
        call PauseUnit(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), false)
        call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
        call DestroyTimer(GetExpiredTimer())
    endif
    if ( ( LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B) == 0 ) ) then
        call SaveInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B, 6)
    else
        call SaveInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B, 0)
    endif
    call SetUnitAnimationByIndex(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B))
    set ydl_group=null
    set ydl_unit=null
endfunction
