function Trig_____________00Func002MT takes nothing returns nothing
    call SaveInteger(YDLOC, 0xBFD19E14, 0x07C93ED7, DzF2I(DzGetMouseFocus()))
    call SaveInteger(YDLOC, 0xBFD19E14, 0xA534D943, LoadInteger(YDHT, LoadInteger(YDLOC, 0xBFD19E14, 0x07C93ED7), 0x5F0E88EF))
    call SavePlayerHandle(YDLOC, 0xBFD19E14, 0x48656946, DzGetTriggerKeyPlayer())
    if ( ( HaveSavedInteger(YDHT, LoadInteger(YDLOC, 0xBFD19E14, 0x07C93ED7), 0x5F0E88EF) == true ) and ( LoadInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, 0xBFD19E14, 0x48656946)), 0xD559A298) == 0 ) and ( udg_xz[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, 0xBFD19E14, 0x48656946))] == udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, 0xBFD19E14, 0x48656946))] ) ) then
        if ( ( LoadInteger(udg_HXB, GetConvertedPlayerId(LoadPlayerHandle(YDLOC, 0xBFD19E14, 0x48656946)), LoadInteger(YDLOC, 0xBFD19E14, 0xA534D943)) == 1 ) ) then
            call DzSyncData("物品拖动", I2S(LoadInteger(YDLOC, 0xBFD19E14, 0xA534D943)))
        else
        endif
    else
        if ( ( udg_xz[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, 0xBFD19E14, 0x48656946))] == udg_Hero[GetConvertedPlayerId(LoadPlayerHandle(YDLOC, 0xBFD19E14, 0x48656946))] ) ) then
            call SaveInteger(YDLOC, 0xBFD19E14, 0x19EAB52A, DzGetMouseX())
            call SaveInteger(YDLOC, 0xBFD19E14, 0x12F94FDA, DzGetMouseY())
            call SaveInteger(YDLOC, 0xBFD19E14, 0xD8F185E3, DzGetWindowX())
            call SaveInteger(YDLOC, 0xBFD19E14, 0x1D197851, DzGetWindowY())
            call SaveInteger(YDLOC, 0xBFD19E14, 0xF0C49CB8, DzGetWindowWidth())
            call SaveInteger(YDLOC, 0xBFD19E14, 0x7E363F5C, DzGetWindowHeight())
            call SaveInteger(YDLOC, 0xBFD19E14, 0x58AA238F, ( ( LoadInteger(YDLOC, 0xBFD19E14, 0x19EAB52A) ) - ( LoadInteger(YDLOC, 0xBFD19E14, 0xD8F185E3) ) ))
            call SaveInteger(YDLOC, 0xBFD19E14, 0x92656BCF, ( ( LoadInteger(YDLOC, 0xBFD19E14, 0x12F94FDA) ) - ( LoadInteger(YDLOC, 0xBFD19E14, 0x1D197851) ) ))
            call SaveReal(YDLOC, 0xBFD19E14, 0x53E91E59, ( ( I2R(LoadInteger(YDLOC, 0xBFD19E14, 0x58AA238F)) ) / ( I2R(LoadInteger(YDLOC, 0xBFD19E14, 0xF0C49CB8)) ) ))
            call SaveReal(YDLOC, 0xBFD19E14, 0x9758C297, ( ( 1.00 ) - ( ( ( I2R(LoadInteger(YDLOC, 0xBFD19E14, 0x92656BCF)) ) / ( I2R(LoadInteger(YDLOC, 0xBFD19E14, 0x7E363F5C)) ) ) ) ))
            call SaveReal(YDLOC, 0xBFD19E14, 0xE9538A45, ( ( LoadReal(YDLOC, 0xBFD19E14, 0x53E91E59) ) * ( 0.80 ) ))
            call SaveReal(YDLOC, 0xBFD19E14, 0xB9A5F07B, ( ( LoadReal(YDLOC, 0xBFD19E14, 0x9758C297) ) * ( 0.60 ) ))
            if ( ( LoadReal(YDLOC, 0xBFD19E14, 0xB9A5F07B) < 0.12 ) and ( LoadInteger(YDHT, GetHandleId(LoadPlayerHandle(YDLOC, 0xBFD19E14, 0x48656946)), 0xD559A298) == 0 ) ) then
                if ( ( LoadReal(YDLOC, 0xBFD19E14, 0xB9A5F07B) < 0.11 ) ) then
                    if ( ( LoadReal(YDLOC, 0xBFD19E14, 0xE9538A45) >= 0.517 ) and ( LoadReal(YDLOC, 0xBFD19E14, 0xE9538A45) <= 0.547 ) and ( LoadReal(YDLOC, 0xBFD19E14, 0xB9A5F07B) >= 0.075 ) ) then
                        call SaveInteger(YDLOC, 0xBFD19E14, 0xC13DC62F, 1)
