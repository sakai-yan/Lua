function Trig_008Func001Func002A takes nothing returns nothing
    if ( ( RectContainsItem(GetEnumItem(), gg_rct______________001) == false ) and ( IsItemVisible(GetEnumItem()) == true ) ) then
        if ( ( GetItemLifeBJ(GetEnumItem()) == 0.00 ) ) then
            call SetWidgetLife(GetEnumItem(), 1.00)
            call FlushChildHashtable(YDHT, GetHandleId(GetEnumItem()))
            call RemoveItem(GetEnumItem())
