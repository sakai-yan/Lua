//===========================================================================
function InitTrig_10C1 takes nothing returns nothing
    set gg_trg_10C1=CreateTrigger()
    call DisableTrigger(gg_trg_10C1)
    call TriggerRegisterAnyUnitEventBJ(gg_trg_10C1, EVENT_PLAYER_UNIT_ISSUED_POINT_ORDER)
    call TriggerAddCondition(gg_trg_10C1, Condition(function Trig_10C1Conditions))
    call TriggerAddAction(gg_trg_10C1, function Trig_10C1Actions)
endfunction
//===========================================================================
// Trigger: 10E
//===========================================================================
function Trig_10EConditions takes nothing returns boolean
    return ( ( GetLearnedSkill() == 'A056' ) )
endfunction
function Trig_10EActions takes nothing returns nothing
    call TriggerRegisterUnitEvent(gg_trg_10E1, GetTriggerUnit(), EVENT_UNIT_TARGET_IN_RANGE)
    // 分割
    call TriggerRegisterUnitEvent(gg_trg_10E2, GetTriggerUnit(), EVENT_UNIT_DEATH)
    call TriggerRegisterUnitEvent(gg_trg_10E2, GetTriggerUnit(), EVENT_UNIT_SPELL_CHANNEL)
    call TriggerRegisterUnitEvent(gg_trg_10E2, GetTriggerUnit(), EVENT_UNIT_ISSUED_TARGET_ORDER)
    call TriggerRegisterUnitEvent(gg_trg_10E2, GetTriggerUnit(), EVENT_UNIT_ISSUED_POINT_ORDER)
    call TriggerRegisterUnitEvent(gg_trg_10E2, GetTriggerUnit(), EVENT_UNIT_ISSUED_ORDER)
    // 分割
    call TriggerRegisterUnitEvent(gg_trg_10E3, GetTriggerUnit(), EVENT_UNIT_ISSUED_ORDER)
    call DestroyTrigger(GetTriggeringTrigger())
endfunction
//===========================================================================
function InitTrig_10E takes nothing returns nothing
    set gg_trg_10E=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_10E, EVENT_PLAYER_HERO_SKILL)
    call TriggerAddCondition(gg_trg_10E, Condition(function Trig_10EConditions))
    call TriggerAddAction(gg_trg_10E, function Trig_10EActions)
endfunction
