function InitTrig____A takes nothing returns nothing
    set gg_trg____A=CreateTrigger()
    call YDWESyStemAnyUnitDamagedRegistTrigger(gg_trg____A)
    call TriggerAddCondition(gg_trg____A, Condition(function Trig____AConditions))
    call TriggerAddAction(gg_trg____A, function Trig____AActions)
endfunction
//===========================================================================
// Trigger: 防B
//
// 英雄，非攻击，非远程=物理伤害 可以说，英雄=物理伤害
// 英雄，攻击，非远程=可触发发球的物理伤害
// 2-（1-0.06）*护甲
//===========================================================================
function Trig____BConditions takes nothing returns boolean
    return ( ( GetEventDamage() > 0.00 ) and ( IsUnitAlly(GetTriggerUnit(), Player(7)) == true ) )
endfunction
function Trig____BFunc002Func001Func016003003 takes nothing returns boolean
    return ( ( IsUnitEnemy(GetFilterUnit(), GetOwningPlayer(GetTriggerUnit())) == true ) )
endfunction
function Trig____BFunc002Func001Func017A takes nothing returns nothing
    local integer ydl_triggerstep
    local trigger ydl_trigger
    if ( ( CosBJ(( ( YDWEAngleBetweenUnits(GetTriggerUnit() , GetEnumUnit()) ) - ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7), 0xB9A583B8) ) )) > CosBJ(18.00) ) ) then
        call UnitDamageTarget(GetTriggerUnit(), GetEnumUnit(), ( GetUnitState(GetTriggerUnit(), ConvertUnitState(0x15)) * 2.50 ), false, false, ATTACK_TYPE_HERO, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
        call UnitDamageTarget(GetTriggerUnit(), GetEnumUnit(), ( LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0xB0C6D98D) * 2.50 ), false, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_ENHANCED, WEAPON_TYPE_WHOKNOWS)
