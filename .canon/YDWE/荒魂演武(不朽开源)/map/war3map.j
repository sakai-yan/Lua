    set udg_WPLUI[119]=DzCreateFrameByTagName("GLUETEXTBUTTON", "name", DzGetGameUI(), "template", 0)
    call DzFrameSetSize(udg_WPLUI[119], 0.03, 0.04)
    call DzFrameSetPoint(udg_WPLUI[119], 4, udg_WPLUI[118], 4, 0.00, 0.00)
    if GetLocalPlayer() == GetLocalPlayer() then
    	call DzFrameSetScriptByCode(udg_WPLUI[119], 1, function Trig_mainFunc091FT, false)
    endif
    if GetLocalPlayer() == GetLocalPlayer() then
    	call DzTriggerRegisterKeyEventByCode(null, 9, 1, false, function Trig_mainFunc092KT)
    endif
    call DestroyTrigger(GetTriggeringTrigger())
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
