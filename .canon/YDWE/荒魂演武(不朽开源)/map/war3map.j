function Trig_____________DActions takes nothing returns nothing
    local integer ydul_WP
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    set ydul_WP=0
    loop
        exitwhen ydul_WP > 450
        if ( ( udg_WP[ydul_WP] != GetItemTypeId(null) ) ) then
            call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09, "")
            if ( ( LoadReal(YDHT, udg_WP[ydul_WP], 0xD0241DEB) != 0.00 ) ) then
                call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09, ( "|n|n物理攻击: + " + I2S(R2I(LoadReal(YDHT, udg_WP[ydul_WP], 0xD0241DEB))) ))
            else
            endif
            if ( ( LoadReal(YDHT, udg_WP[ydul_WP], 0xB0C6D98D) != 0.00 ) ) then
                call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09) ) + ( "|n法术攻击: + " ) + ( I2S(R2I(LoadReal(YDHT, udg_WP[ydul_WP], 0xB0C6D98D))) ) ))
