    return ( ( GetEventDamage() > 0.00 ) and ( IsUnitAlly(GetEventDamageSource(), Player(7)) == true ) and ( YDWEIsEventAttackType(ATTACK_TYPE_NORMAL) == true ) and ( YDWEIsEventDamageType(DAMAGE_TYPE_MAGIC) == false ) )
