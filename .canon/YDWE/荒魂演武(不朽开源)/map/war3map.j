                call SaveReal(YDLOC, ydl_triggerstep, 0x312C4181, ( ( 1.00 ) + ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x25B4E1BE) ) ))
                call SaveReal(YDLOC, GetHandleId(ydl_trigger), 0x25B4E1BE, LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x25B4E1BE))
                call TriggerExecute(ydl_trigger)
            else
            endif
        endloop
        call DestroyGroup(ydl_group)
    else
