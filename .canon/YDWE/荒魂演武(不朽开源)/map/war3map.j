    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xB0897302, GetUnitY(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x8B1FFFFC)))
    call SaveReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xE978590C, SquareRoot(( Pow(( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x2392447A) ) - ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x41713DA3) ) ), 2.00) + Pow(( ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xB0897302) ) - ( LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x71CA3531) ) ), 2.00) )))
