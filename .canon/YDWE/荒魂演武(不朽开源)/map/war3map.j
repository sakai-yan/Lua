function InitTrig_3____________u takes nothing returns nothing
    set gg_trg_3____________u=CreateTrigger()
    call TriggerRegisterUnitEvent(gg_trg_3____________u, gg_unit_nech_0424, EVENT_UNIT_DEATH)
    call TriggerRegisterUnitEvent(gg_trg_3____________u, gg_unit_nech_0425, EVENT_UNIT_DEATH)
    call TriggerRegisterUnitEvent(gg_trg_3____________u, gg_unit_nech_0097, EVENT_UNIT_DEATH)
    call TriggerRegisterUnitEvent(gg_trg_3____________u, gg_unit_N03L_0413, EVENT_UNIT_DEATH)
    call TriggerAddAction(gg_trg_3____________u, function Trig_3____________uActions)
endfunction
