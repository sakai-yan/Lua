function Trig_CJUI_1Actions takes nothing returns nothing
    local integer ydul_x
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    set udg_CJUI[0]=DzCreateFrameByTagName("BACKDROP", "打开按钮", DzGetGameUI(), "template", 0)
    call DzFrameSetSize(udg_CJUI[0], 0.03, 0.04)
    call DzFrameSetPoint(udg_CJUI[0], 4, DzGetGameUI(), 4, - 0.22, - 0.11)
    call DzFrameSetTexture(udg_CJUI[0], "UITB_yxcj.tga", 0)
    set udg_CJUIAN[0]=DzCreateFrameByTagName("GLUETEXTBUTTON", "按钮", DzGetGameUI(), "template", 0)
    call DzFrameSetSize(udg_CJUIAN[0], 0.03, 0.04)
    call DzFrameSetPoint(udg_CJUIAN[0], 4, udg_CJUI[0], 4, 0.00, 0.00)
    if GetLocalPlayer() == GetLocalPlayer() then
    	call DzFrameSetScriptByCode(udg_CJUIAN[0], 1, function Trig_CJUI_1Func001Func008FT, false)
    endif
    // 边框
    set udg_CJUI[1]=DzCreateFrameByTagName("BACKDROP", "成就背景", udg_CJUI[0], "template", 0)
    call DzFrameSetSize(udg_CJUI[1], 0.51, 0.39)
    call DzFrameSetPoint(udg_CJUI[1], 4, DzGetGameUI(), 4, 0.00, 0.09)
    call DzFrameSetTexture(udg_CJUI[1], "UI_cjbj.tga", 0)
    call DzFrameShow(udg_CJUI[1], false)
    set udg_CJUI[6]=DzCreateFrameByTagName("BACKDROP", "隐藏成就背景", udg_CJUI[0], "template", 0)
    call DzFrameSetSize(udg_CJUI[6], 0.51, 0.39)
    call DzFrameSetPoint(udg_CJUI[6], 4, DzGetGameUI(), 4, 0.00, 0.09)
    call DzFrameSetTexture(udg_CJUI[6], "UI_yccj.tga", 0)
    call DzFrameShow(udg_CJUI[6], false)
    // 2级按钮
    set udg_CJUI[2]=DzCreateFrameByTagName("BACKDROP", "打开按钮", udg_CJUI[0], "template", 0)
    call DzFrameSetSize(udg_CJUI[2], 0.03, 0.03)
    call DzFrameSetPoint(udg_CJUI[2], 2, udg_CJUI[1], 7, - 0.01, 0.02)
    call DzFrameSetTexture(udg_CJUI[2], "UITB_yxcj1.tga", 0)
    set udg_CJUIAN[2]=DzCreateFrameByTagName("GLUETEXTBUTTON", "1111", udg_CJUI[2], "template", 0)
    call DzFrameSetSize(udg_CJUIAN[2], 0.03, 0.03)
    call DzFrameSetPoint(udg_CJUIAN[2], 4, udg_CJUI[2], 4, 0.00, 0.00)
    call DzFrameShow(udg_CJUI[2], false)
    if GetLocalPlayer() == GetLocalPlayer() then
    	call DzFrameSetScriptByCode(udg_CJUIAN[2], 1, function Trig_CJUI_1Func001Func029FT, false)
    endif
    set udg_CJUI[3]=DzCreateFrameByTagName("BACKDROP", "打开按钮", udg_CJUI[0], "template", 0)
