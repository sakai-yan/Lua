            if ( ( HaveSavedString(YDHT, udg_WP[ydul_WP], 0x1FD16D41) == true ) ) then
                call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09, ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09) + LoadStr(YDHT, udg_WP[ydul_WP], 0x1FD16D41) ))
