        if ( ( LoadStr(YDHT, GetItemTypeId(GetManipulatedItem()), 0x7602A218) == "近战武器" ) ) then
            if ( ( IsUnitType(GetManipulatingUnit(), UNIT_TYPE_MELEE_ATTACKER) == true ) ) then
                set ydul_x=1
                loop
                    exitwhen ydul_x > 6
                    if ( ( LoadStr(YDHT, GetItemTypeId(UnitItemInSlotBJ(GetManipulatingUnit(), ydul_x)), 0x7602A218) == "近战武器" ) ) then
                        call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x73B99F65, ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x73B99F65) ) + ( 1 ) ))
                        if ( ( LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x73B99F65) > 1 ) ) then
