                call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09) ) + ( "|n法术穿透: + " ) + ( ( I2S(R2I(( LoadReal(YDHT, udg_WP[ydul_WP], 0xA727C6F6) * 100.00 ))) + " %" ) ) ))
