function Trig_______04Func001Func002Func002T takes nothing returns nothing
    call TriggerExecute(gg_trg_______05)
    call DestroyTimer(udg_jsq)
    call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
    call DestroyTimer(GetExpiredTimer())
endfunction
function Trig_______04Func001Func002T takes nothing returns nothing
    local timer ydl_timer
    set udg_jsq=CreateTimer()
    set ydl_timer=udg_jsq
    call TimerStart(ydl_timer, 70.00, false, function Trig_______04Func001Func002Func002T)
    call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
    call DestroyTimer(GetExpiredTimer())
    set ydl_timer=null
endfunction
function Trig_______04Func001Func005T takes nothing returns nothing
    call TriggerExecute(gg_trg_______05)
    call DestroyTimer(udg_jsq)
    call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
    call DestroyTimer(GetExpiredTimer())
endfunction
function Trig_______04Actions takes nothing returns nothing
    local timer ydl_timer
    if ( ( LoadInteger(YDHT, GetHandleId(Player(7)), 0xDC8FC027) == 0 ) ) then
        set udg_jsq=CreateTimer()
        set ydl_timer=udg_jsq
        call TimerStart(ydl_timer, 70.00, false, function Trig_______04Func001Func005T)
    else
        call SaveInteger(YDHT, GetHandleId(Player(7)), 0xDC8FC027, 0)
        set ydl_timer=CreateTimer()
        call TimerStart(ydl_timer, 120.00, false, function Trig_______04Func001Func002T)
    endif
    set ydl_timer=null
endfunction
