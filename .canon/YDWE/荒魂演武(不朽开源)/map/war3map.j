    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFDF65382, GetUnitY(GetTriggerUnit()))
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x2392447A, GetOrderPointX())
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB0897302, GetOrderPointY())
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB9A583B8, Atan2BJ(( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB0897302) - LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFDF65382) ), ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x2392447A) - LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA) )))
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE978590C, SquareRoot(( Pow(( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA) ) - ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x2392447A) ) ), 2.00) + Pow(( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFDF65382) ) - ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB0897302) ) ), 2.00) )))
    if ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE978590C) > 1000.00 ) ) then
        call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE978590C, 800.00)
    else
    endif
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x91D9239B, ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE978590C) / 7.00 ))
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x3D4834E1, ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x91D9239B) / ( ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE978590C) ) / ( 2.00 ) ) ))
    call SaveReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x3D4834E1, ( LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x3D4834E1) * 33.00 ))
    call IssueImmediateOrder(GetTriggerUnit(), "stop")
    call YDWEUnitAddStun(GetTriggerUnit())
    call YDWEFlyEnable(GetTriggerUnit())
    call YDWESetUnitAbilityState(GetTriggerUnit() , 'A054' , 1 , ( YDWEGetUnitAbilityDataReal(GetTriggerUnit() , 'A054' , GetUnitAbilityLevel(GetTriggerUnit(), 'A054') , 105) * ( 1.00 - LoadReal(YDHT, GetHandleId(GetTriggerUnit()), 0xAF04E5E0) ) ))
    call SetUnitState(GetTriggerUnit(), UNIT_STATE_MANA, ( ( GetUnitState(GetTriggerUnit(), UNIT_STATE_MANA) ) - ( I2R(GetUnitAbilityLevel(GetTriggerUnit(), 'A054')) ) * ( 50.00 ) ))
    call SetUnitFacing(GetTriggerUnit(), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xB9A583B8))
    set ydl_timer=CreateTimer()
    call SetUnitTimeScale(GetTriggerUnit(), ( 600.00 / LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xE978590C) ))
    call SetUnitAnimationByIndex(GetTriggerUnit(), 6)
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x458B7DE9, GetTriggerUnit())
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0xA99320FA, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA))
    call SaveReal(YDLOC, GetHandleId(ydl_timer), 0x41713DA3, LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x41713DA3))
