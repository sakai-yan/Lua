//===========================================================================
// Trigger: 刷兵05
//===========================================================================
function Trig_______05Func004T takes nothing returns nothing
    local integer ydul_X
    if ( ( LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B) < 27 ) ) then
        call SaveInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B, ( ( LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B) ) + ( 1 ) ))
        if ( ( ModuloInteger(LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x300B6E6B), 3) == 1 ) ) then
            call GroupAddUnit(udg_attack, CreateUnit(Player(8), udg_levelR[udg_Lv], 300.00, 7666.00, 0))
        else
        endif
        call GroupAddUnit(udg_attack, CreateUnit(Player(8), udg_levelL[udg_Lv], - 1320.00, 7666.00, 0))
    else
        if ( ( udg_Lv == 54 ) ) then
            call PlaySoundBJ(gg_snd_GameFound)
            call PingMinimapEx(- 500.00, 7777.00, 3.00, 255, 0, 0, true)
            call SaveUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x58CBD5C1, CreateUnit(Player(8), 'O00D', - 500.00, 7777.00, 270.00))
            call GroupAddUnit(udg_attack, LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x58CBD5C1))
            call TriggerRegisterUnitEvent(gg_trg_000, LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x58CBD5C1), EVENT_UNIT_TARGET_IN_RANGE)
            call EnableTrigger(gg_trg_000A)
            call EnableTrigger(gg_trg_000B)
            call EnableTrigger(gg_trg_000________________u)
            call DisplayTimedTextToForce(udg_WZJ, 10.00, ( ( "|cffff0000" ) + ( ( "最终BOSS！！！  " + ( "堕落泰坦 萨格拉斯！  |r" ) ) ) + ( "率领燃烧军团精锐前来毁灭！" ) ))
            call EnableTrigger(gg_trg_020)
            set ydul_X=1
            loop
                exitwhen ydul_X > 7
                call CreateFogModifierRectBJ(true, ConvertedPlayer(ydul_X), FOG_OF_WAR_VISIBLE, gg_rct_____________004)
                set ydul_X=ydul_X + 1
            endloop
        else
            set udg_Lv=( udg_Lv + 1 )
            call TriggerExecute(gg_trg_______04)
        endif
        call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
        call DestroyTimer(GetExpiredTimer())
    endif
endfunction
function Trig_______05Actions takes nothing returns nothing
    local timer ydl_timer
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    if ( ( ModuloInteger(udg_Lv, 3) == 0 ) and ( udg_Lv != 54 ) ) then
        call PlaySoundBJ(gg_snd_Hint)
        call PingMinimapEx(- 500.00, 7777.00, 3.00, 255, 0, 0, false)
        call GroupAddUnit(udg_attack, CreateUnit(Player(8), udg_Elite[udg_Lv], - 500.00, 7777.00, 0))
        call DisplayTimedTextToForce(udg_WZJ, 10.00, ( ( "|cffff6800" ) + ( ( "小头目  " + ( ( EXExecuteScript("(require'jass.slk').unit[" + I2S(udg_Elite[udg_Lv]) + "].Name") ) + "  |r" ) ) ) + ( "协同大军前来进攻！" ) ))
    else
    endif
    if ( ( ModuloInteger(udg_Lv, 5) == 0 ) ) then
        call PingMinimapEx(- 500.00, 7777.00, 3.00, 255, 0, 0, true)
        call DisplayTimedTextToForce(udg_WZJ, 10.00, ( ( "|cffff0000" ) + ( ( "BOSS  " + ( ( EXExecuteScript("(require'jass.slk').unit[" + I2S(udg_boss[udg_Lv]) + "].Name") ) + "  |r" ) ) ) + ( "率领大军杀来！" ) ))
        call GroupAddUnit(udg_attack, CreateUnit(Player(8), udg_boss[udg_Lv], - 500.00, 7777.00, 0))
        call PlaySoundBJ(gg_snd_ArrangedTeamInvitation)
    else
    endif
    call DisplayTimedTextToForce(udg_WZJ, 10.00, ( ( ( ( ( "第" ) + ( I2S(udg_Lv) ) + ( "波敌军  " ) ) + ( EXExecuteScript("(require'jass.slk').unit[" + I2S(udg_levelL[udg_Lv]) + "].Name") ) ) ) + ( ( " 与 " + ( EXExecuteScript("(require'jass.slk').unit[" + I2S(udg_levelR[udg_Lv]) + "].Name") ) ) ) + ( " 前来进攻！" ) ))
    set ydl_timer=CreateTimer()
    call SaveInteger(YDLOC, GetHandleId(ydl_timer), 0x300B6E6B, 0)
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x58CBD5C1, LoadUnitHandle(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x58CBD5C1))
    call TimerStart(ydl_timer, 0.50, true, function Trig_______05Func004T)
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
    set ydl_timer=null
endfunction
