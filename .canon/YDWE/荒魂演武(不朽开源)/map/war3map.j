function Trig_025Actions takes nothing returns nothing
    if ( ( GetItemTypeId(GetSoldItem()) == 'I005' ) and ( IsUnitType(GetBuyingUnit(), UNIT_TYPE_MELEE_ATTACKER) == false ) ) then
        call DisplayTimedTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, 7.00, "|cffff0000您不可购买此武器，现已退还您的金币|r")
        call AdjustPlayerStateBJ(500, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
        call RemoveItem(GetSoldItem())
    else
    endif
    if ( ( GetItemTypeId(GetSoldItem()) == 'I06D' ) and ( IsUnitType(GetBuyingUnit(), UNIT_TYPE_MELEE_ATTACKER) == true ) ) then
        call DisplayTimedTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, 7.00, "|cffff0000您不可购买此武器，现已退还您的金币|r")
        call AdjustPlayerStateBJ(500, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
        call RemoveItem(GetSoldItem())
    else
    endif
    if ( ( GetItemTypeId(GetSoldItem()) == 'I06O' ) and ( IsUnitType(GetBuyingUnit(), UNIT_TYPE_MELEE_ATTACKER) == true ) ) then
        call DisplayTimedTextToPlayer(GetOwningPlayer(GetBuyingUnit()), 0, 0, 7.00, "|cffff0000您不可购买此武器，现已退还您的金币|r")
        call AdjustPlayerStateBJ(500, GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD)
        call RemoveItem(GetSoldItem())
    else
    endif
endfunction
