            endif
        endif
    else
        if ( ( YDWEUnitHasItemOfTypeBJNull(GetBuyingUnit() , 'I05S') == true ) and ( GetPlayerState(GetOwningPlayer(GetBuyingUnit()), PLAYER_STATE_RESOURCE_GOLD) >= 1000 ) ) then
