//===========================================================================
function InitTrig_UBZBZS1 takes nothing returns nothing
    set gg_trg_UBZBZS1=CreateTrigger()
    call TriggerRegisterTimerEventSingle(gg_trg_UBZBZS1, 0.70)
    call TriggerAddAction(gg_trg_UBZBZS1, function Trig_UBZBZS1Actions)
endfunction
//===========================================================================
// Trigger: UIZBZS2
//===========================================================================
function Trig_UIZBZS2Actions takes nothing returns nothing
    local integer ydl_localvar_step= LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76)
 set ydl_localvar_step=ydl_localvar_step + 3
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xCFDE6C76, ydl_localvar_step)
 call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xECE825E7, ydl_localvar_step)
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA, DzF2I(DzGetTriggerUIEventFrame()))
    call SaveInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFDF65382, LoadInteger(YDHT, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), 0xA6461A53))
    call DzFrameSetPoint(udg_WPZSUI[2], 1, DzGetTriggerUIEventFrame(), 7, 0.00, - 0.01)
    call DzFrameSetText(udg_WPZSUI[2], ( EXExecuteScript("(require'jass.slk').item[" + I2S(udg_WP[LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFDF65382)]) + "].Name") ))
    call DzFrameSetText(udg_WPZSUI[3], LoadStr(YDHT, udg_WP[LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFDF65382)], 0x6945FB09))
    call DzFrameSetText(udg_WPZSUI[4], LoadStr(YDHT, udg_WP[LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFDF65382)], 0xC3C655B7))
    if ( ( HaveSavedString(YDHT, udg_WP[LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFDF65382)], 0x5A5B4CBF) == true ) ) then
        call DzFrameSetText(udg_WPZSUI[12], ( "来源：" + LoadStr(YDHT, udg_WP[LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xFDF65382)], 0x5A5B4CBF) ))
    else
        call DzFrameSetText(udg_WPZSUI[12], "")
    endif
    call DzFrameShow(udg_WPZSUI[1], true)
    call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step)
endfunction
//===========================================================================
function InitTrig_UIZBZS2 takes nothing returns nothing
    set gg_trg_UIZBZS2=CreateTrigger()
    call TriggerAddAction(gg_trg_UIZBZS2, function Trig_UIZBZS2Actions)
endfunction
