            if ( ( LoadReal(YDHT, udg_WP[ydul_WP], 0x83C13D14) != 0.00 ) ) then
                call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09) ) + ( "|n法术吸血: + " ) + ( ( I2S(R2I(( LoadReal(YDHT, udg_WP[ydul_WP], 0x83C13D14) * 100.00 ))) + " %" ) ) ))
