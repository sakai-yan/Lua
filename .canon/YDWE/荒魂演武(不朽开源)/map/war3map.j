function Trig_0009Conditions takes nothing returns boolean
    return ( ( GetItemTypeId(GetManipulatedItem()) == 'I04F' ) )
endfunction
function Trig_0009Func003Func002Func001Func004Func007T takes nothing returns nothing
    call UnitRemoveAbility(LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x458B7DE9), 'A03L')
    call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
    call DestroyTimer(GetExpiredTimer())
endfunction
function Trig_0009Func003Func002Conditions takes nothing returns nothing
    local timer ydl_timer
    if ( ( YDWEUnitHasItemOfTypeBJNull(GetTriggerUnit() , 'I04F') == true ) ) then
        if ( ( GetRandomInt(1, 5) <= 1 ) ) then
            call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Defend\\DefendCaster.mdl", GetTriggerUnit(), "origin"))
            call CreateTextTagUnitBJ("吞噬！", GetTriggerUnit(), - 50.00, 10.00, 0.00, 100.00, 0.00, 0)
            call SetTextTagPermanent(GetLastCreatedTextTag(), false)
            call SetTextTagFadepoint(GetLastCreatedTextTag(), 0.10)
            call SetTextTagLifespan(GetLastCreatedTextTag(), 1.30)
            call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 80.00, ( GetRandomReal(85.00, 105.00) ))
            set ydl_timer=CreateTimer()
            call UnitAddAbility(GetTriggerUnit(), 'A03L')
            call SaveUnitHandle(YDLOC, GetHandleId(ydl_timer), 0x458B7DE9, GetTriggerUnit())
            call TimerStart(ydl_timer, 0.00, false, function Trig_0009Func003Func002Func001Func004Func007T)
        else
        endif
    else
        call RemoveSavedInteger(YDHT, GetHandleId(GetTriggerUnit()), 0x49AEC882)
        call FlushChildHashtable(YDLOC, GetHandleId(GetTriggeringTrigger()))
        call DestroyTrigger(GetTriggeringTrigger())
    endif
    set ydl_timer=null
endfunction
function Trig_0009Actions takes nothing returns nothing
    local trigger ydl_trigger
    call YDWEPolledWaitNull(0.10)
    if ( ( LoadInteger(YDHT, GetHandleId(GetTriggerUnit()), 0x49AEC882) == 0 ) ) then
        call SaveInteger(YDHT, GetHandleId(GetTriggerUnit()), 0x49AEC882, 1)
        set ydl_trigger=CreateTrigger()
        call TriggerRegisterUnitEvent(ydl_trigger, GetTriggerUnit(), EVENT_UNIT_DAMAGED)
        call TriggerAddCondition(ydl_trigger, Condition(function Trig_0009Func003Func002Conditions))
    else
    endif
    set ydl_trigger=null
endfunction
