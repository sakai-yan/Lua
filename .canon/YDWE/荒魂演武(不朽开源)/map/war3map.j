//===========================================================================
// Trigger: 3特定死亡
//===========================================================================
function Trig_3____________uActions takes nothing returns nothing
    if ( ( GetUnitTypeId(GetTriggerUnit()) == 'nech' ) ) then
        if ( ( GetRandomInt(1, 4) == 1 ) ) then
            call SaveInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ())), 62, ( ( LoadInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ())), 62) ) + ( 1 ) ))
        else
        endif
    else
        call SaveInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ())), 61, ( ( LoadInteger(udg_CJ_HXB, GetConvertedPlayerId(GetOwningPlayer(GetKillingUnitBJ())), 61) ) + ( 1 ) ))
        call CreateTextTagUnitBJ("你干嘛？！哎哟！....", GetTriggerUnit(), 0, 13.00, 100.00, 100.00, 100.00, 0)
        call SetTextTagPermanent(GetLastCreatedTextTag(), false)
        call SetTextTagFadepoint(GetLastCreatedTextTag(), 2.00)
        call SetTextTagLifespan(GetLastCreatedTextTag(), 3.00)
        call SetTextTagVelocityBJ(GetLastCreatedTextTag(), 85.00, ( GetRandomReal(0.00, 360.00) ))
    endif
endfunction
