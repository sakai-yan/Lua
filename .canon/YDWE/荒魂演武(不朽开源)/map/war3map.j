            endif
            if ( ( LoadReal(YDHT, udg_WP[ydul_WP], 0x59E18EE2) != 0.00 ) ) then
                call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x6945FB09) ) + ( "|n物理吸血: + " ) + ( ( I2S(R2I(( LoadReal(YDHT, udg_WP[ydul_WP], 0x59E18EE2) * 100.00 ))) + " %" ) ) ))
            else
