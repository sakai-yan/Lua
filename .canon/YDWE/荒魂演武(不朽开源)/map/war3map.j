        call SaveEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x65BCB4D1, AddSpecialEffect("Abilities\\Weapons\\SearingArrow\\SearingArrowMissile.mdl", LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xA99320FA), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0xFDF65382)))
        call EXEffectMatRotateZ(LoadEffectHandle(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x65BCB4D1), LoadReal(YDLOC, GetHandleId(GetTriggeringTrigger()), 0x795160B8))
