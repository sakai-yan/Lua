            call UnitDamageTarget(GetEventDamageSource(), GetTriggerUnit(), ( LoadReal(YDHT, GetHandleId(GetEventDamageSource()), 0xB0C6D98D) * 2.00 ), false, false, ATTACK_TYPE_NORMAL, DAMAGE_TYPE_NORMAL, WEAPON_TYPE_WHOKNOWS)
