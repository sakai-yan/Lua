    else
        if ( ( GetUnitAbilityLevel(GetTriggerUnit(), 'A04M') == 3 ) ) then
            call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xEF12EDB1, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xEF12EDB1) + 400.00 ))
            call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x59E18EE2, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x59E18EE2) + 0.05 ))
            call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x636DFFD3, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x636DFFD3) + 0.05 ))
            call DestroyTrigger(GetTriggeringTrigger())
        else
            call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xEF12EDB1, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0xEF12EDB1) + 400.00 ))
            call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x59E18EE2, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x59E18EE2) + 0.05 ))
            call SaveReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x636DFFD3, ( LoadReal(YDHT, GetHandleId(udg_Hero[GetConvertedPlayerId(GetOwningPlayer(GetTriggerUnit()))]), 0x636DFFD3) + 0.05 ))
        endif
    endif
