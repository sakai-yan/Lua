                            call SaveReal(YDLOC, 0x73EF02D4, 0xB9A5F07B, ( ( LoadReal(YDLOC, 0x73EF02D4, 0x9758C297) ) * ( 0.60 ) ))
                            if ( ( LoadReal(YDLOC, 0x73EF02D4, 0xB9A5F07B) < 0.11 ) ) then
                                if ( ( LoadReal(YDLOC, 0x73EF02D4, 0xE9538A45) >= 0.517 ) and ( LoadReal(YDLOC, 0x73EF02D4, 0xE9538A45) <= 0.547 ) and ( LoadReal(YDLOC, 0x73EF02D4, 0xB9A5F07B) >= 0.075 ) ) then
                                    call DzSyncData("左键放置2", "1")
                                else
