//===========================================================================
function InitTrig_____________B_______u takes nothing returns nothing
    set gg_trg_____________B_______u=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_____________B_______u, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddAction(gg_trg_____________B_______u, function Trig_____________B_______uActions)
endfunction
//===========================================================================
// Trigger: HCTX
//
// |cffffff00金
// |cffff6800橙装|r
// |cffff0000红装|r
//===========================================================================
function Trig_HCTXConditions takes nothing returns boolean
    return ( ( HaveSavedString(YDHT, GetItemTypeId(GetManipulatedItem()), 0x2DA5DF67) == false ) and ( GetItemUserData(GetManipulatedItem()) == 0 ) and ( ( SubStringBJ(GetItemName(GetManipulatedItem()), 1, 10) == "|cffffff00" ) or ( SubStringBJ(GetItemName(GetManipulatedItem()), 1, 10) == "|cffff6800" ) or ( SubStringBJ(GetItemName(GetManipulatedItem()), 1, 10) == "|cffff0000" ) ) )
endfunction
function Trig_HCTXActions takes nothing returns nothing
    call SetItemUserData(GetManipulatedItem(), 1)
    if ( ( SubStringBJ(GetItemName(GetManipulatedItem()), 1, 10) == "|cffffff00" ) ) then
        call DisplayTimedTextToForce(GetPlayersAll(), 10.00, ( ( GetPlayerName(GetOwningPlayer(GetTriggerUnit())) ) + ( ( "  的  " + GetUnitName(GetTriggerUnit()) ) ) + ( ( "  获得 英雄级装备！  " + GetItemName(GetManipulatedItem()) ) ) ))
        call DestroyEffect(AddSpecialEffectTarget("TXwphuang.mdx", GetTriggerUnit(), "origin"))
        call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Items\\AIlm\\AIlmTarget.mdl", GetTriggerUnit(), "origin"))
    else
        if ( ( SubStringBJ(GetItemName(GetManipulatedItem()), 1, 10) == "|cffff6800" ) ) then
            call DisplayTimedTextToForce(GetPlayersAll(), 10.00, ( ( GetPlayerName(GetOwningPlayer(GetTriggerUnit())) ) + ( ( "  的  " + GetUnitName(GetTriggerUnit()) ) ) + ( ( "  获得 传说级装备！  " + GetItemName(GetManipulatedItem()) ) ) ))
            call DestroyEffect(AddSpecialEffectTarget("TXwpcheng.mdx", GetTriggerUnit(), "origin"))
            call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Orc\\FeralSpirit\\feralspiritdone.mdl", GetTriggerUnit(), "origin"))
        else
            if ( ( SubStringBJ(GetItemName(GetManipulatedItem()), 1, 10) == "|cffff0000" ) ) then
                call DisplayTimedTextToForce(GetPlayersAll(), 10.00, ( ( GetPlayerName(GetOwningPlayer(GetTriggerUnit())) ) + ( ( "  的  " + GetUnitName(GetTriggerUnit()) ) ) + ( ( "  获得 顶级！不朽装备！  " + GetItemName(GetManipulatedItem()) ) ) ))
                call DestroyEffect(AddSpecialEffectTarget("TXwphong.mdx", GetTriggerUnit(), "origin"))
                call DestroyEffect(AddSpecialEffectTarget("Abilities\\Spells\\Human\\Thunderclap\\ThunderClapCaster.mdl", GetTriggerUnit(), "origin"))
            else
            endif
        endif
    endif
endfunction
//===========================================================================
function InitTrig_HCTX takes nothing returns nothing
    set gg_trg_HCTX=CreateTrigger()
    call TriggerRegisterAnyUnitEventBJ(gg_trg_HCTX, EVENT_PLAYER_UNIT_PICKUP_ITEM)
    call TriggerAddCondition(gg_trg_HCTX, Condition(function Trig_HCTXConditions))
    call TriggerAddAction(gg_trg_HCTX, function Trig_HCTXActions)
endfunction
