    call SaveReal(YDLOC, GetHandleId(ydl_trigger), 0xFDF65382, LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0xFDF65382))
    call SaveEffectHandle(YDLOC, GetHandleId(ydl_trigger), 0xA4FCAD46, LoadEffectHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xA4FCAD46))
    call SaveUnitHandle(YDLOC, GetHandleId(ydl_trigger), 0xBB85B401, LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0xBB85B401))
    call SaveInteger(YDLOC, GetHandleId(ydl_trigger), 0x3864ED47, LoadInteger(YDLOC, GetHandleId(GetExpiredTimer()), 0x3864ED47))
    call TriggerRegisterUnitEvent(ydl_trigger, LoadUnitHandle(YDLOC, GetHandleId(GetExpiredTimer()), 0x7D1E37AD), EVENT_UNIT_DAMAGED)
    call TriggerRegisterTimerEventSingle(ydl_trigger, ( 0.40 / LoadReal(YDLOC, GetHandleId(GetExpiredTimer()), 0x86A02DAE) ))
    call TriggerAddCondition(ydl_trigger, Condition(function Trig_15W2Func001Func005Conditions))
    call FlushChildHashtable(YDLOC, GetHandleId(GetExpiredTimer()))
    call DestroyTimer(GetExpiredTimer())
    set ydl_trigger=null
endfunction
