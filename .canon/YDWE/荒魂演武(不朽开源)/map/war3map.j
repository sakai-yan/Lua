//===========================================================================
function Trig_01______uFunc001A takes nothing returns nothing
    if ( ( IsUnitType(GetEnumUnit(), UNIT_TYPE_HERO) == false ) ) then
        if ( ( GetUnitLevel(GetEnumUnit()) <= 19 ) ) then
            call SetUnitState(GetEnumUnit(), UNIT_STATE_MAX_LIFE, ( ( I2R(GetUnitLevel(GetEnumUnit())) * 100.00 ) * udg_ND ))
            call SetUnitState(GetEnumUnit(), UNIT_STATE_MAX_MANA, ( ( I2R(GetUnitLevel(GetEnumUnit())) * 50.00 ) * udg_ND ))
            call SetUnitState(GetEnumUnit(), ConvertUnitState(0x12), ( ( 3.00 ) + ( ( I2R(GetUnitLevel(GetEnumUnit())) * 8.00 ) ) * ( udg_ND ) ))
            call SetUnitState(GetEnumUnit(), ConvertUnitState(0x20), ( ( I2R(GetUnitLevel(GetEnumUnit())) * 1.00 ) * udg_ND ))
            call SetUnitState(GetEnumUnit(), UNIT_STATE_LIFE, GetUnitState(GetEnumUnit(), UNIT_STATE_MAX_LIFE))
            call SetUnitState(GetEnumUnit(), UNIT_STATE_MANA, GetUnitState(GetEnumUnit(), UNIT_STATE_MAX_MANA))
        else
            if ( ( GetUnitLevel(GetEnumUnit()) > 19 ) and ( GetUnitLevel(GetEnumUnit()) < 30 ) ) then
                call SetUnitState(GetEnumUnit(), UNIT_STATE_MAX_LIFE, ( ( I2R(GetUnitLevel(GetEnumUnit())) * 300.00 ) * udg_ND ))
                call SetUnitState(GetEnumUnit(), UNIT_STATE_MAX_MANA, ( ( I2R(GetUnitLevel(GetEnumUnit())) * 200.00 ) * udg_ND ))
                call SetUnitState(GetEnumUnit(), ConvertUnitState(0x12), ( ( I2R(GetUnitLevel(GetEnumUnit())) * 10.00 ) * udg_ND ))
