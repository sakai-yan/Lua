function Trig_01______uActions takes nothing returns nothing
    local group ydl_group
    local unit ydl_unit
    call ForGroupBJ(YDWEGetUnitsOfPlayerAllNull(Player(PLAYER_NEUTRAL_AGGRESSIVE)), function Trig_01______uFunc001A)
    // 排泄
    call DestroyTrigger(GetTriggeringTrigger())
    set ydl_group=null
    set ydl_unit=null
endfunction
//===========================================================================
function InitTrig_01______u takes nothing returns nothing
    set gg_trg_01______u=CreateTrigger()
    call TriggerAddAction(gg_trg_01______u, function Trig_01______uActions)
endfunction
