                if ( ( HaveSavedReal(YDHT, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), 0xA727C6F6) == true ) ) then
                    call SaveStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E, ( ( LoadStr(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0x90F4A78E) ) + ( "|n提升法术穿透: " ) + ( ( I2S(R2I(( ( LoadReal(YDHT, LoadInteger(YDLOC, GetHandleId(GetTriggeringTrigger()) * ydl_localvar_step, 0xA99320FA), 0xA727C6F6) ) * ( I2R(ydul_LV) ) * ( 100.00 ) ))) + " %" ) ) ))
