// 单位种类: 古树
constant integer UNIT_FLAG_TYPE_ANCIENT = 0x80
// 单位种类: 守卫
constant integer UNIT_FLAG_TYPE_WARD = 0x200
// 单位种类: 可通行
constant integer UNIT_FLAG_TYPE_STANDON = 0x400
// 单位种类: 牛头人
constant integer UNIT_FLAG_TYPE_TAUREN = 0x800

