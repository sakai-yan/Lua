constant integer UNIT_WEAPON_TYPE_MELEE = 0x1
// 单位武器类型: 箭矢
constant integer UNIT_WEAPON_TYPE_MISSILE = 0x2
// 单位武器类型: 炮火
constant integer UNIT_WEAPON_TYPE_ARTILLERY = 0x3
// 单位武器类型: 立即
constant integer UNIT_WEAPON_TYPE_INSTANT = 0x4
// 单位武器类型: 箭矢 (溅射)
constant integer UNIT_WEAPON_TYPE_MISSILE_SPLASH = 0x5
// 单位武器类型: 箭矢 (弹射)
constant integer UNIT_WEAPON_TYPE_MISSILE_BOUNCE = 0x6
// 单位武器类型: 箭矢 (穿透)
